{"id":"A4mrpgaJaT2ySvhR","meta":{"instanceId":"b81912ca572d0a4c58ee509388cf31962871c0c8953df088c33e6dbbd58d1d27","builderVariant":"mcp","aiBuilderAssisted":true,"templateCredsSetupCompleted":true},"name":"Create restorable n8n Docker backups in Google Drive via SSH","tags":[],"nodes":[{"id":"98e557ed-269a-42ed-8b26-e5ee70774388","name":"Loop Over Workflows","type":"n8n-nodes-base.splitInBatches","position":[1552,832],"parameters":{"options":{},"batchSize":20},"typeVersion":3},{"id":"835ec9bb-9117-47da-9faf-400ad60521cf","name":"Loop Over Credentials","type":"n8n-nodes-base.splitInBatches","position":[1552,1376],"parameters":{"options":{},"batchSize":20},"typeVersion":3},{"id":"9dc991c6-6e48-43bd-9245-b39479b9ba54","name":"Run Scheduled Backup","type":"n8n-nodes-base.scheduleTrigger","position":[-240,960],"parameters":{"rule":{"interval":[{"field":"cronExpression","expression":"0 10,22 * * *"}]}},"typeVersion":1.3},{"id":"55249e7d-e5bf-4924-8fee-e6e390757a1f","name":"Export Workflows via SSH","type":"n8n-nodes-base.ssh","maxTries":2,"position":[656,768],"parameters":{"command":"=docker exec {{ $(\"Backup Configuration\").first().json.dockerContainer }} sh -c \"n8n export:workflow --all --output=/tmp/workflows.json >/dev/null && cat /tmp/workflows.json\""},"credentials":{"sshPassword":{"id":"credential-id","name":"SSH Password account"}},"retryOnFail":true,"typeVersion":1,"waitBetweenTries":1500},{"id":"ef6c8c8f-4435-419e-b30f-d00238be665f","name":"Export Credentials via SSH","type":"n8n-nodes-base.ssh","maxTries":2,"position":[656,1248],"parameters":{"command":"=docker exec {{ $(\"Backup Configuration\").first().json.dockerContainer }} sh -c \"n8n export:credentials --all --output=/tmp/credentials.json >/dev/null && cat /tmp/credentials.json\""},"credentials":{"sshPassword":{"id":"credential-id","name":"SSH Password account"}},"retryOnFail":true,"typeVersion":1,"waitBetweenTries":1500},{"id":"5705fd83-3dd3-43d8-a7a9-fd89493f3b63","name":"Parse Workflow Export JSON","type":"n8n-nodes-base.code","position":[880,768],"parameters":{"jsCode":"const workflows = JSON.parse($input.first().json.stdout);\n\nreturn [{ json: { workflows } }];"},"typeVersion":2},{"id":"cf707e10-5231-4c30-8ef1-d709f70845e7","name":"Parse Credential Export JSON","type":"n8n-nodes-base.code","position":[880,1248],"parameters":{"jsCode":"const credentials = JSON.parse($input.first().json.stdout);\n\nreturn [{ json: { credentials } }];"},"typeVersion":2},{"id":"9022bd89-0b38-460a-9728-017ec8afd5ef","name":"Split Workflow Export","type":"n8n-nodes-base.splitOut","position":[1104,768],"parameters":{"options":{},"fieldToSplitOut":"workflows"},"typeVersion":1},{"id":"b03de40b-b214-4abb-8a30-83a1ca419bff","name":"Split Credential Export","type":"n8n-nodes-base.splitOut","position":[1104,1248],"parameters":{"options":{},"fieldToSplitOut":"credentials"},"typeVersion":1},{"id":"d113486a-dfc5-4668-8cf1-0c2b2c828a4d","name":"Convert Workflow Archive to JSON","type":"n8n-nodes-base.convertToFile","position":[1568,400],"parameters":{"options":{"fileName":"workflows-all.json"},"operation":"toJson"},"typeVersion":1.1},{"id":"f908bfd3-f1b9-4992-b5de-cad1e144b60f","name":"Convert Workflow to JSON","type":"n8n-nodes-base.convertToFile","position":[1776,800],"parameters":{"mode":"each","options":{"fileName":"={{ $json.name }}.json"},"operation":"toJson"},"typeVersion":1.1},{"id":"29cbc175-5b13-47c0-be0f-15b43ae1ce9a","name":"Prepare Workflow Archive Upload","type":"n8n-nodes-base.code","position":[1792,400],"parameters":{"jsCode":"const path = $(\"Init Backup Folder\").first().json.id;\n\nreturn $input.all().map(item => ({\n  json: {\n    ...item.json,\n    path\n  },\n  binary: item.binary\n}));"},"typeVersion":2},{"id":"e2cabf67-fb12-45eb-bf84-d6e055efd3ec","name":"Prepare Workflow File Upload","type":"n8n-nodes-base.code","position":[2000,800],"parameters":{"jsCode":"const path = $(\"Init Workflows Folder\").first().json.id;\n\nreturn $input.all().map(item => ({\n  json: {\n    path\n  },\n  binary: item.binary,\n}));"},"typeVersion":2},{"id":"354a16e9-4fd6-4009-99bf-af4702619623","name":"Prepare Credential File Upload","type":"n8n-nodes-base.code","position":[2000,1344],"parameters":{"jsCode":"const path = $(\"Init Credentials Folder\").first().json.id;\n\nreturn $input.all().map(item => ({\n  json: {\n    path\n  },\n  binary: item.binary,\n}));"},"typeVersion":2},{"id":"b9a54556-bae7-40c8-b006-3610e87d25a4","name":"Convert Credential to JSON","type":"n8n-nodes-base.convertToFile","position":[1776,1344],"parameters":{"mode":"each","options":{"fileName":"={{ $json.name }}_{{ $json.type }}.json"},"operation":"toJson"},"typeVersion":1.1},{"id":"c123bfa9-4e27-4888-b5dd-483b4144f337","name":"Prepare Credential Archive Upload","type":"n8n-nodes-base.code","position":[1776,1776],"parameters":{"jsCode":"const path = $(\"Init Backup Folder\").first().json.id;\n\nreturn $input.all().map(item => ({\n  json: {\n    ...item.json,\n    path\n  },\n  binary: item.binary\n}));"},"typeVersion":2},{"id":"ee61092e-bd48-4abe-b7e4-637d791b2c5d","name":"Convert Credential Archive to JSON","type":"n8n-nodes-base.convertToFile","position":[1552,1776],"parameters":{"options":{"fileName":"credentials-all.json"},"operation":"toJson"},"typeVersion":1.1},{"id":"4d036508-8857-4019-909b-9898dcb24ff1","name":"Merge Workflow and Credential Exports","type":"n8n-nodes-base.merge","position":[2624,976],"parameters":{"mode":"combine","options":{},"combineBy":"combineByPosition"},"typeVersion":3.2},{"id":"0d490135-41eb-4aaf-8167-829bb0a16e35","name":"Convert Combined Backup to JSON","type":"n8n-nodes-base.convertToFile","position":[3072,976],"parameters":{"mode":"each","options":{"fileName":"=workflows-credentials.json"},"operation":"toJson"},"typeVersion":1.1},{"id":"bf9dbcd7-5644-4a70-b90e-aa8b26eadbac","name":"Prepare Combined Backup Upload","type":"n8n-nodes-base.code","position":[3296,976],"parameters":{"jsCode":"const path = $(\"Init Backup Folder\").first().json.id;\n\nreturn $input.all().map(item => ({\n  json: {\n    ...item.json,\n    path\n  },\n  binary: item.binary\n}));"},"typeVersion":2},{"id":"3a93489d-d554-4804-9fd9-56eaeecddd6c","name":"Split Uploaded Backup Files","type":"n8n-nodes-base.code","position":[304,2816],"parameters":{"jsCode":"const item = $input.first();\n\nconst output = [];\n\nfor (const [key, binary] of Object.entries(item.binary || {})) {\n  output.push({\n    json: {\n      field: key\n    },\n    binary: {\n      data: binary\n    }\n  });\n}\n\nreturn output;"},"typeVersion":2},{"id":"2c69dc73-30c3-4298-8cba-9b4bb7493ad3","name":"Parse Uploaded JSON Files","type":"n8n-nodes-base.extractFromFile","position":[528,2816],"parameters":{"options":{},"operation":"fromJson"},"typeVersion":1.1},{"id":"b81a5ae2-f5bd-4138-8292-b2db13f32e5d","name":"Detect Backup Record Types","type":"n8n-nodes-base.code","position":[752,2816],"parameters":{"jsCode":"const output = [];\n\nfor (const item of $input.all()) {\n\n  const data = item.json.data;\n\n  // Single workflow\n  if (data?.nodes) {\n    output.push({\n      json: {\n        type: 'workflows',\n        data: [data]\n      }\n    });\n    continue;\n  }\n\n  // Single credential\n  if (data?.type && data?.id) {\n    output.push({\n      json: {\n        type: 'credentials',\n        data: [data]\n      }\n    });\n    continue;\n  }\n\n  // workflows export all\n  if (Array.isArray(data) && data.length && data[0]?.nodes) {\n    output.push({\n      json: {\n        type: 'workflows',\n        data\n      }\n    });\n    continue;\n  }\n\n  // credentials export all\n  if (Array.isArray(data) && data.length && data[0]?.type) {\n    output.push({\n      json: {\n        type: 'credentials',\n        data\n      }\n    });\n    continue;\n  }\n\n  // backup all\n  if (data?.workflows || data?.credentials) {\n\n    if (data.workflows) {\n      output.push({\n        json: {\n          type: 'workflows',\n          data: data.workflows\n        }\n      });\n    }\n\n    if (data.credentials) {\n      output.push({\n        json: {\n          type: 'credentials',\n          data: data.credentials\n        }\n      });\n    }\n  }\n}\n\nreturn output;"},"typeVersion":2},{"id":"14e412ec-1d94-47a2-9134-ed57f34fb876","name":"Route Workflows and Credentials","type":"n8n-nodes-base.switch","position":[976,2816],"parameters":{"rules":{"values":[{"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"4c4ed0eb-1f95-4257-a1cc-316f4a98400f","operator":{"type":"string","operation":"equals"},"leftValue":"={{ $json.type }}","rightValue":"workflows"}]}},{"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"e3d5456c-68e8-471b-b4ae-7a594b18c73f","operator":{"name":"filter.operator.equals","type":"string","operation":"equals"},"leftValue":"={{ $json.type }}","rightValue":"credentials"}]}}]},"options":{}},"typeVersion":3.4},{"id":"564bf9e7-0593-4d74-b143-eac1c8e2987d","name":"Split Workflow Records","type":"n8n-nodes-base.splitOut","position":[1200,2624],"parameters":{"options":{},"fieldToSplitOut":"data"},"typeVersion":1},{"id":"b76b8204-8dae-456a-b61d-ef31d55be6d7","name":"Split Credential Records","type":"n8n-nodes-base.splitOut","position":[1216,3120],"parameters":{"options":{},"fieldToSplitOut":"data"},"typeVersion":1},{"id":"b9b7d12b-5fa9-4740-8b25-025424b84ca4","name":"Convert Workflows for Import","type":"n8n-nodes-base.convertToFile","position":[1424,2624],"parameters":{"options":{"fileName":"workflows.json"},"operation":"toJson"},"typeVersion":1.1},{"id":"ff03f7ed-8158-48c8-abd0-79094fc5baa3","name":"Convert Credentials for Import","type":"n8n-nodes-base.convertToFile","position":[1440,3120],"parameters":{"options":{"fileName":"credentials.json"},"operation":"toJson"},"typeVersion":1.1},{"id":"1e945dd2-eef7-4f3d-8874-fe0644a380b4","name":"Upload Workflows to Remote Host","type":"n8n-nodes-base.ssh","maxTries":2,"position":[1648,2624],"parameters":{"path":"=/tmp/workflows-{{ $now.format('dd-MM-yyyy') }}","options":{},"resource":"file"},"credentials":{"sshPassword":{"id":"credential-id","name":"SSH Password account"}},"retryOnFail":true,"typeVersion":1,"waitBetweenTries":1500},{"id":"84435205-c28f-442f-bc9d-a076e77d9e5a","name":"Import Workflows into n8n","type":"n8n-nodes-base.ssh","maxTries":2,"position":[1872,2624],"parameters":{"command":"=docker cp \"/tmp/workflows-{{ $now.format('dd-MM-yyyy') }}/{{ $binary.data.fileName }}\" {{ $(\"Restore Configuration\").first().json.dockerContainer }}:/tmp/ && docker exec {{ $(\"Restore Configuration\").first().json.dockerContainer }} sh -c \"n8n import:workflow --input=/tmp/workflows.json\""},"credentials":{"sshPassword":{"id":"credential-id","name":"SSH Password account"}},"retryOnFail":true,"typeVersion":1,"waitBetweenTries":1500},{"id":"29c810e2-f212-40d0-8d61-2f18e23b6461","name":"Import Credentials into n8n","type":"n8n-nodes-base.ssh","maxTries":2,"position":[1888,3120],"parameters":{"command":"=docker cp \"/tmp/credentials-{{ $now.format('dd-MM-yyyy') }}/{{ $binary.data.fileName }}\" {{ $(\"Restore Configuration\").first().json.dockerContainer }}:/tmp/ && docker exec {{ $(\"Restore Configuration\").first().json.dockerContainer }} sh -c \"n8n import:credentials --input=/tmp/credentials.json\""},"credentials":{"sshPassword":{"id":"credential-id","name":"SSH Password account"}},"retryOnFail":true,"typeVersion":1,"waitBetweenTries":1500},{"id":"ce7ba65a-35e8-436b-8265-9449b2585318","name":"Upload Credentials to Remote Host","type":"n8n-nodes-base.ssh","maxTries":2,"position":[1664,3120],"parameters":{"path":"=/tmp/credentials-{{ $now.format('dd-MM-yyyy') }}","options":{},"resource":"file"},"credentials":{"sshPassword":{"id":"credential-id","name":"SSH Password account"}},"retryOnFail":true,"typeVersion":1,"waitBetweenTries":1500},{"id":"edba6772-1dda-4619-b131-c230f6ec93ba","name":"Set Backup Configuration","type":"n8n-nodes-base.set","position":[-16,960],"parameters":{"options":{},"assignments":{"assignments":[{"id":"66ef4+1234567890-b5c1-575fa44c4d39","name":"dockerContainer","type":"string","value":"YOUR_N8N_DOCKER_CONTAINER_NAME"},{"id":"ea4e4e60-1124-4ec6-8bf1-44a06ab1884f","name":"date","type":"string","value":"={{ $now.format('dd-MM-yyyy HH-mm-ss') }}"}]}},"typeVersion":3.4},{"id":"7c760708-0fde-4b7a-a036-8bbe0eb09d2e","name":"Set Restore Configuration","type":"n8n-nodes-base.set","position":[80,2816],"parameters":{"options":{},"assignments":{"assignments":[{"id":"07149403-9ed6-4747-a060-8974a6e60f6a","name":"dockerContainer","type":"string","value":"YOUR_N8N_DOCKER_CONTAINER_NAME"}]},"includeOtherFields":true},"typeVersion":3.4},{"id":"a5af3206-91a3-4342-b84b-ad6b897b2f1f","name":"Receive Restore Files","type":"n8n-nodes-base.formTrigger","position":[-144,2816],"webhookId":"e0a5eba8-2db7-495b-9beb-12b20b5b706f","parameters":{"options":{"customCss":":root {\n\t--font-family: 'Open Sans', sans-serif;\n\t--font-weight-normal: 400;\n\t--font-weight-bold: 600;\n\t--font-size-body: 12px;\n\t--font-size-label: 14px;\n\t--font-size-test-notice: 12px;\n\t--font-size-input: 14px;\n\t--font-size-header: 20px;\n\t--font-size-paragraph: 14px;\n\t--font-size-link: 12px;\n\t--font-size-error: 12px;\n\t--font-size-html-h1: 28px;\n\t--font-size-html-h2: 20px;\n\t--font-size-html-h3: 16px;\n\t--font-size-html-h4: 14px;\n\t--font-size-html-h5: 12px;\n\t--font-size-html-h6: 10px;\n\t--font-size-subheader: 14px;\n\n\t/* Colors */\n\t--color-background: #fbfcfe;\n\t--color-test-notice-text: #e6a23d;\n\t--color-test-notice-bg: #fefaf6;\n\t--color-test-notice-border: #f6dcb7;\n\t--color-card-bg: #ffffff;\n\t--color-card-border: #dbdfe7;\n\t--color-card-shadow: rgba(99, 77, 255, 0.06);\n\t--color-link: #7e8186;\n\t--color-header: #525356;\n\t--color-label: #555555;\n\t--color-input-border: #dbdfe7;\n\t--color-input-text: #71747A;\n\t--color-focus-border: rgb(90, 76, 194);\n\t--color-submit-btn-bg: #ff6d5a;\n\t--color-submit-btn-text: #ffffff;\n\t--color-error: #ea1f30;\n\t--color-required: #ff6d5a;\n\t--color-clear-button-bg: #7e8186;\n\t--color-html-text: #555;\n\t--color-html-link: #ff6d5a;\n\t--color-header-subtext: #7e8186;\n\n\t/* Border Radii */\n\t--border-radius-card: 8px;\n\t--border-radius-input: 6px;\n\t--border-radius-clear-btn: 50%;\n\t--card-border-radius: 8px;\n\n\t/* Spacing */\n\t--padding-container-top: 24px;\n\t--padding-card: 24px;\n\t--padding-test-notice-vertical: 12px;\n\t--padding-test-notice-horizontal: 24px;\n\t--margin-bottom-card: 16px;\n\t--padding-form-input: 12px;\n\t--card-padding: 24px;\n\t--card-margin-bottom: 16px;\n\n\t/* Dimensions */\n\t--container-width: 448px;\n\t--submit-btn-height: 48px;\n\t--checkbox-size: 18px;\n\n\t/* Others */\n\t--box-shadow-card: 0px 4px 16px 0px var(--color-card-shadow);\n\t--opacity-placeholder: 0.5;\n}\n\n.form-header p {\n  text-align: left;\n}","appendAttribution":false},"formTitle":"Restore n8n workflows and credentials","formFields":{"values":[{"fieldType":"file","fieldLabel":"data","requiredField":true,"acceptFileTypes":".json"}]},"responseMode":"lastNode","authentication":"basicAuth","formDescription":"Upload JSON files created by this template. Matching workflow or credential\nIDs can be overwritten. Use only on a trusted self-hosted n8n instance.\nBasic Auth must be configured before activation."},"credentials":{"httpBasicAuth":{"id":"credential-id","name":"Unnamed credential"}},"typeVersion":2.5},{"id":"cdf6e428-2aed-4c71-a2eb-32a426c1f45e","name":"Build Combined Backup","type":"n8n-nodes-base.code","position":[2848,976],"parameters":{"jsCode":"// Read the complete workflow and credential exports.\nconst workflowsData = $(\"Parse Workflow Export\").first()?.json?.workflows || [];\nconst credentialsData = $(\"Parse Creds Export\").first()?.json?.credentials || [];\n\n// Return one object for the combined backup file.\nreturn [{\n  json: {\n    workflows: workflowsData,\n    credentials: credentialsData,\n  },\n}];"},"typeVersion":2},{"id":"bd79f36f-16ec-4b23-b47d-fd79a625684c","name":"Upload Combined Backup to Drive","type":"n8n-nodes-base.googleDrive","position":[3504,976],"parameters":{"name":"={{ $binary.data.fileName }}","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"options":{},"folderId":{"__rl":true,"mode":"id","value":"={{ $json.path }}"}},"credentials":{"googleDriveOAuth2Api":{"id":"credential-id","name":"Google Drive account 2"}},"typeVersion":3},{"id":"13825f60-5e1d-4c09-9550-bfa3967c5819","name":"Upload Workflow Archive to Drive","type":"n8n-nodes-base.googleDrive","position":[2016,400],"parameters":{"name":"={{ $binary.data.fileName }}","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"options":{},"folderId":{"__rl":true,"mode":"id","value":"={{ $json.path }}"}},"credentials":{"googleDriveOAuth2Api":{"id":"credential-id","name":"Google Drive account 2"}},"typeVersion":3},{"id":"a3c17f7a-2ad7-41b1-b663-da6df464d8f6","name":"Upload Workflow File to Drive","type":"n8n-nodes-base.googleDrive","position":[2224,880],"parameters":{"name":"={{ $binary.data.fileName }}","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"options":{},"folderId":{"__rl":true,"mode":"id","value":"={{ $json.path }}"}},"credentials":{"googleDriveOAuth2Api":{"id":"credential-id","name":"Google Drive account 2"}},"typeVersion":3},{"id":"30c4b619-0a78-47b9-9ccd-128904d1b8b0","name":"Create Credentials Folder","type":"n8n-nodes-base.googleDrive","position":[432,1248],"parameters":{"name":"credentials","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"options":{},"folderId":{"__rl":true,"mode":"id","value":"={{ $json.id }}"},"resource":"folder"},"credentials":{"googleDriveOAuth2Api":{"id":"credential-id","name":"Google Drive account 2"}},"typeVersion":3},{"id":"238dec8f-d8eb-470f-987f-a3e6d7e116e8","name":"Create Workflows Folder","type":"n8n-nodes-base.googleDrive","position":[432,768],"parameters":{"name":"workflows","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"options":{},"folderId":{"__rl":true,"mode":"id","value":"={{ $json.id }}"},"resource":"folder"},"credentials":{"googleDriveOAuth2Api":{"id":"credential-id","name":"Google Drive account 2"}},"typeVersion":3},{"id":"aa71d10e-b3b3-45f0-92fd-284cd8322f60","name":"Create Backup Folder","type":"n8n-nodes-base.googleDrive","position":[208,960],"parameters":{"name":"=Backup {{ $json.date }}","driveId":{"__rl":true,"mode":"list","value":"My Drive","cachedResultUrl":"https://drive.google.com/drive/my-drive","cachedResultName":"My Drive"},"options":{},"folderId":{"__rl":true,"mode":"id","value":"YOUR_GOOGLE_DRIVE_BACKUP_FOLDER_ID"},"resource":"folder"},"credentials":{"googleDriveOAuth2Api":{"id":"credential-id","name":"Google Drive account 2"}},"typeVersion":3},{"id":"e845aad2-698e-42e2-91a0-f90d009400e3","name":"Upload Credential File to Drive","type":"n8n-nodes-base.googleDrive","position":[2224,1424],"parameters":{"name":"={{ $binary.data.fileName }}","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"options":{},"folderId":{"__rl":true,"mode":"id","value":"={{ $json.path }}"}},"credentials":{"googleDriveOAuth2Api":{"id":"credential-id","name":"Google Drive account 2"}},"typeVersion":3},{"id":"0bb818b0-cce5-4d3c-aec5-aebbae6601e7","name":"Upload Credential Archive to Drive","type":"n8n-nodes-base.googleDrive","position":[2000,1776],"parameters":{"name":"={{ $binary.data.fileName }}","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"options":{},"folderId":{"__rl":true,"mode":"id","value":"={{ $json.path }}"}},"credentials":{"googleDriveOAuth2Api":{"id":"credential-id","name":"Google Drive account 2"}},"typeVersion":3},{"id":"a1769e31-9910-41fc-b4b3-9ecb18ff55da","name":"00 - Template overview","type":"n8n-nodes-base.stickyNote","position":[-320,-64],"parameters":{"color":2,"width":1760,"height":608,"content":"## Who's it for\n\nThis template is for administrators and technical teams running self-hosted n8n in Docker who need repeatable backups and a practical recovery path.\n\n## How it works\n\nA schedule starts the backup process. The workflow connects to the Docker host through SSH, runs the n8n CLI, and exports all workflows and encrypted credentials. It creates timestamped folders in Google Drive and stores complete archives, individual files, and a combined backup package. For recovery, an authenticated form accepts JSON backup files, detects their format, and imports workflows or credentials into the target n8n container.\n\n## How to set up\n\n- [ ] Connect Google Drive credentials with access to the backup destination.\n- [ ] Select the parent folder in **Create Backup Folder**.\n- [ ] Connect SSH credentials that can run Docker commands on the n8n host.\n- [ ] Replace `YOUR_N8N_DOCKER_CONTAINER_NAME` in both configuration nodes.\n- [ ] Enable Basic Auth and HTTPS for the restore form.\n\n## Requirements\n\n- A self-hosted n8n instance running in Docker on Linux\n- SSH access to the Docker host\n- Google Drive credentials\n- The same `N8N_ENCRYPTION_KEY` on source and destination when restoring credentials\n\n## How to customize the workflow\n\nChange the schedule, folder structure, retention process, or disable archive formats you do not need. Test backup and restore operations on staging before production use."},"typeVersion":1},{"id":"2fb37d19-33da-4326-a09c-da7823318acd","name":"01 - Schedule and configuration","type":"n8n-nodes-base.stickyNote","position":[-320,656],"parameters":{"color":5,"width":704,"height":592,"content":"## Schedule and configure backups\n\nRuns the workflow on the configured schedule, records a timestamp, and identifies the source n8n Docker container.\n\nSet the schedule, Docker container name, Google Drive destination, and credentials before activation."},"typeVersion":1},{"id":"05a9e26a-1b70-4ced-a355-7ed37cfc16e7","name":"02 - Initialize Drive folders","type":"n8n-nodes-base.stickyNote","position":[384,576],"parameters":{"color":5,"width":448,"height":880,"content":"## Create Google Drive folders\n\nCreates a timestamped backup folder with separate `workflows` and `credentials` subfolders.\n\nThe upload steps reuse these folder IDs."},"typeVersion":1},{"id":"6958fe26-68ec-49ca-9c04-cd21c93927e2","name":"03 - Export workflows","type":"n8n-nodes-base.stickyNote","position":[832,576],"parameters":{"color":5,"width":608,"height":416,"content":"## Export workflows through SSH\n\nRuns `n8n export:workflow --all` inside the Docker container, parses the CLI output, and separates the workflows for archive and individual-file backups."},"typeVersion":1},{"id":"28c1df7d-a560-41fe-816a-9235482f5d48","name":"04 - Export credentials","type":"n8n-nodes-base.stickyNote","position":[832,1040],"parameters":{"color":5,"width":608,"height":416,"content":"## Export credentials through SSH\n\nRuns `n8n export:credentials --all` inside the Docker container, parses the CLI output, and separates encrypted credentials for backup.\n\nRestoration requires the same `N8N_ENCRYPTION_KEY`."},"typeVersion":1},{"id":"3ef8204b-02ee-4a33-9268-454ce04cb67f","name":"05 - Back up all workflows","type":"n8n-nodes-base.stickyNote","position":[1504,208],"parameters":{"color":5,"width":880,"height":352,"content":"## Save the workflow archive\n\nCreates `workflows-all.json` from the complete workflow export and uploads it to Google Drive for bulk recovery."},"typeVersion":1},{"id":"5f478c63-9f0f-4f2c-8171-f1e2745f016b","name":"06 - Loop through each workflow","type":"n8n-nodes-base.stickyNote","position":[1504,592],"parameters":{"color":5,"width":880,"height":480,"content":"## Save individual workflow files\n\nProcesses every workflow, creates a separate `<workflow name>.json` file, and uploads each file to Google Drive."},"typeVersion":1},{"id":"0d22f028-dd19-4052-9c39-740c5931d120","name":"07 - Loop through each credential","type":"n8n-nodes-base.stickyNote","position":[1504,1136],"parameters":{"color":5,"width":880,"height":480,"content":"## Save individual credential files\n\nProcesses every encrypted credential, creates a separate `<name>_<type>.json` file, and uploads each file to Google Drive."},"typeVersion":1},{"id":"381c9494-64ac-403c-9b78-36a034cbc430","name":"08 - Back up all credentials","type":"n8n-nodes-base.stickyNote","position":[1504,1648],"parameters":{"color":5,"width":880,"height":320,"content":"## Save the credential archive\n\nCreates `credentials-all.json` from the complete encrypted credential export and uploads it to Google Drive for bulk recovery."},"typeVersion":1},{"id":"985d375c-7129-4386-a2c9-85b13244ce98","name":"09 - Create combined backup","type":"n8n-nodes-base.stickyNote","position":[2544,736],"parameters":{"color":5,"width":1152,"height":544,"content":"## Create the combined backup\n\nMerges workflow and encrypted credential exports into `workflows-credentials.json`, then uploads the portable package to the timestamped Google Drive folder."},"typeVersion":1},{"id":"57e423cf-9114-4720-86bb-272f5f6d14b0","name":"10 - Upload restore files","type":"n8n-nodes-base.stickyNote","position":[-352,2640],"parameters":{"color":6,"width":576,"height":480,"content":"## Receive authenticated restore files\n\nAccepts one or more `.json` backup files through a form and identifies the target Docker container.\n\nProtect the form with Basic Auth and HTTPS before publishing it."},"typeVersion":1},{"id":"f53f2a78-5033-42ce-8aca-34e4193c3adf","name":"11 - Detect backup file type","type":"n8n-nodes-base.stickyNote","position":[224,2640],"parameters":{"color":6,"width":928,"height":480,"content":"## Detect and route backup data\n\nReads each uploaded JSON file, recognizes individual, archive, or combined backup formats, and routes workflow and credential records to separate recovery paths."},"typeVersion":1},{"id":"c8e013d3-2f60-41b4-9e5c-671331ca0b07","name":"12 - Import workflows","type":"n8n-nodes-base.stickyNote","position":[1152,2400],"parameters":{"color":6,"width":896,"height":432,"content":"## Restore workflows through SSH\n\nCreates `workflows.json`, uploads it to the Docker host, copies it into the target container, and runs `n8n import:workflow`.\n\nReview imported workflows before activation."},"typeVersion":1},{"id":"32dca244-b47b-444a-9386-a78d1ea6c85d","name":"13 - Import credentials","type":"n8n-nodes-base.stickyNote","position":[1152,2896],"parameters":{"color":6,"width":896,"height":432,"content":"## Restore credentials through SSH\n\nCreates `credentials.json`, uploads it to the Docker host, copies it into the target container, and runs `n8n import:credentials`.\n\nThe destination must use the source `N8N_ENCRYPTION_KEY`."},"typeVersion":1},{"id":"bc7a8343-56fe-413f-b7b3-d58dc8197235","name":"14 - Security checklist","type":"n8n-nodes-base.stickyNote","position":[2048,2608],"parameters":{"color":6,"width":896,"height":608,"content":"## Review security before production\n\n- [ ] Restrict Google Drive folder access to trusted administrators.\n- [ ] Use SSH private-key authentication.\n- [ ] Limit the SSH account to required Docker operations.\n- [ ] Store `N8N_ENCRYPTION_KEY` in a secret manager.\n- [ ] Protect the restore form with Basic Auth and HTTPS.\n- [ ] Test backup and recovery on staging.\n- [ ] Review imported workflows before activation.\n- [ ] Keep an additional backup outside Google Drive."},"typeVersion":1}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","callerPolicy":"workflowsFromSameOwner","timeSavedMode":"fixed","availableInMCP":true,"executionOrder":"v1"},"versionId":"6e670cb8-0a23-4727-a5fe-895577996703","nodeGroups":[],"connections":{"Loop Over Workflows":{"main":[[],[{"node":"Convert Workflow to JSON","type":"main","index":0}]]},"Create Backup Folder":{"main":[[{"node":"Create Credentials Folder","type":"main","index":0},{"node":"Create Workflows Folder","type":"main","index":0}]]},"Run Scheduled Backup":{"main":[[{"node":"Set Backup Configuration","type":"main","index":0}]]},"Build Combined Backup":{"main":[[{"node":"Convert Combined Backup to JSON","type":"main","index":0}]]},"Loop Over Credentials":{"main":[[],[{"node":"Convert Credential to JSON","type":"main","index":0}]]},"Receive Restore Files":{"main":[[{"node":"Set Restore Configuration","type":"main","index":0}]]},"Split Workflow Export":{"main":[[{"node":"Convert Workflow Archive to JSON","type":"main","index":0},{"node":"Loop Over Workflows","type":"main","index":0}]]},"Split Workflow Records":{"main":[[{"node":"Convert Workflows for Import","type":"main","index":0}]]},"Create Workflows Folder":{"main":[[{"node":"Export Workflows via SSH","type":"main","index":0}]]},"Split Credential Export":{"main":[[{"node":"Loop Over Credentials","type":"main","index":0},{"node":"Convert Credential Archive to JSON","type":"main","index":0}]]},"Convert Workflow to JSON":{"main":[[{"node":"Prepare Workflow File Upload","type":"main","index":0}]]},"Export Workflows via SSH":{"main":[[{"node":"Parse Workflow Export JSON","type":"main","index":0}]]},"Set Backup Configuration":{"main":[[{"node":"Create Backup Folder","type":"main","index":0}]]},"Split Credential Records":{"main":[[{"node":"Convert Credentials for Import","type":"main","index":0}]]},"Create Credentials Folder":{"main":[[{"node":"Export Credentials via SSH","type":"main","index":0}]]},"Parse Uploaded JSON Files":{"main":[[{"node":"Detect Backup Record Types","type":"main","index":0}]]},"Set Restore Configuration":{"main":[[{"node":"Split Uploaded Backup Files","type":"main","index":0}]]},"Convert Credential to JSON":{"main":[[{"node":"Prepare Credential File Upload","type":"main","index":0}]]},"Detect Backup Record Types":{"main":[[{"node":"Route Workflows and Credentials","type":"main","index":0}]]},"Export Credentials via SSH":{"main":[[{"node":"Parse Credential Export JSON","type":"main","index":0}]]},"Parse Workflow Export JSON":{"main":[[{"node":"Split Workflow Export","type":"main","index":0}]]},"Split Uploaded Backup Files":{"main":[[{"node":"Parse Uploaded JSON Files","type":"main","index":0}]]},"Convert Workflows for Import":{"main":[[{"node":"Upload Workflows to Remote Host","type":"main","index":0}]]},"Parse Credential Export JSON":{"main":[[{"node":"Split Credential Export","type":"main","index":0}]]},"Prepare Workflow File Upload":{"main":[[{"node":"Upload Workflow File to Drive","type":"main","index":0}]]},"Upload Workflow File to Drive":{"main":[[{"node":"Loop Over Workflows","type":"main","index":0}]]},"Convert Credentials for Import":{"main":[[{"node":"Upload Credentials to Remote Host","type":"main","index":0}]]},"Prepare Combined Backup Upload":{"main":[[{"node":"Upload Combined Backup to Drive","type":"main","index":0}]]},"Prepare Credential File Upload":{"main":[[{"node":"Upload Credential File to Drive","type":"main","index":0}]]},"Convert Combined Backup to JSON":{"main":[[{"node":"Prepare Combined Backup Upload","type":"main","index":0}]]},"Prepare Workflow Archive Upload":{"main":[[{"node":"Upload Workflow Archive to Drive","type":"main","index":0}]]},"Route Workflows and Credentials":{"main":[[{"node":"Split Workflow Records","type":"main","index":0}],[{"node":"Split Credential Records","type":"main","index":0}]]},"Upload Credential File to Drive":{"main":[[{"node":"Loop Over Credentials","type":"main","index":0}]]},"Upload Workflows to Remote Host":{"main":[[{"node":"Import Workflows into n8n","type":"main","index":0}]]},"Convert Workflow Archive to JSON":{"main":[[{"node":"Prepare Workflow Archive Upload","type":"main","index":0}]]},"Upload Workflow Archive to Drive":{"main":[[{"node":"Merge Workflow and Credential Exports","type":"main","index":0}]]},"Prepare Credential Archive Upload":{"main":[[{"node":"Upload Credential Archive to Drive","type":"main","index":0}]]},"Upload Credentials to Remote Host":{"main":[[{"node":"Import Credentials into n8n","type":"main","index":0}]]},"Convert Credential Archive to JSON":{"main":[[{"node":"Prepare Credential Archive Upload","type":"main","index":0}]]},"Upload Credential Archive to Drive":{"main":[[{"node":"Merge Workflow and Credential Exports","type":"main","index":1}]]},"Merge Workflow and Credential Exports":{"main":[[{"node":"Build Combined Backup","type":"main","index":0}]]}}}