omelife.ca', 'rankmyagent.com',\n  'rate-my-agent.com', 'royallepage.ca', 'century21.ca',\n  'zoocasa.com', 'kijiji.ca', 'flowercityrealty.com',\n  'executivehomesrealty.ca', 'openroom.ca', 'rentals.ca',\n  'researchgate.net', 'studylib.net', 'datanyze.com',\n  'rocketreach.co', 'nature.com', 'worldbank.org',\n  'pubs.acs.org', 'acpjournals.org', 'hfg.org', 'imdb.com',\n  'osgoode.yorku.ca', 'digitalcommons', 'ubc.ca', 'umanitoba.ca',\n  'gov.uk', 'gloucester-ma.gov', 'transitchicago.com',\n  'cloudfront.net', 'codalab.org', 'pestend.ca',\n  'find-and-update.company-information',\n  'westburyrentals.com', 'myrentalunit.ca',\n  'forumproperties.com', 'thaparteam.ca',\n  'ontario.ca/document', 'digital.ontarioreports.ca'\n];\n\nconst cleanResults = results\n  .filter(r => {\n    if (!r.link) return false;\n    if (!r.link.startsWith('http')) return false;\n    if (r.link.match(/\\.(pdf|csv|txt|doc|xls|xlsx|png|jpg|jpeg)(\\?|$)/i)) return false;\n    if (BLOCKED_DOMAINS.some(b => r.link.toLowerCase().includes(b))) return false;\n    return true;\n  })\n  .slice(0, 3) // ← changed from 5 to 3\n  .map(r => ({\n    url:     r.link,\n    title:   r.title || '',\n    snippet: (r.snippet || '').substring(0, 150) // ← also reduced from 200 to 150\n  }));\n\nreturn {\n  clean_results: cleanResults,\n  has_results:   cleanResults.length > 0\n};"},"typeVersion":2},{"id":"5082b1b7-f46e-4ed5-9d1a-7581235758a4","name":"Batch Size Limit","type":"n8n-nodes-base.limit","position":[48,4608],"parameters":{"maxItems":700},"typeVersion":1},{"id":"bfd7f498-3f59-4d2d-9735-082e588db33a","name":"Has Search Results?","type":"n8n-nodes-base.if","position":[720,4608],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"4f5a2e35-5370-4c03-a53c-21d8be982144","operator":{"type":"boolean","operation":"equals"},"leftValue":"={{ $json.has_results }}","rightValue":true}]}},"typeVersion":2.3},{"id":"3d2208a0-3f18-41d5-b926-ae73dbd0956f","name":"Prepare AI Input","type":"n8n-nodes-base.set","position":[944,4608],"parameters":{"options":{},"assignments":{"assignments":[{"id":"6471eb39-1688-4763-80cf-eb26fed02154","name":"clean_results","type":"array","value":"={{ $json.clean_results }}"},{"id":"3bdbea53-7a64-4e31-8825-d1e3d06b1032","name":"person_name","type":"string","value":"={{ $('Limit').item.json['First Name'] }} {{ $('Limit').item.json['Last Name'] }}"},{"id":"07151515-b5fa-4e59-a16a-0bcfbc9583a9","name":"Licensed as","type":"string","value":"={{ $('Limit').item.json['Licensed as'] }}"},{"id":"c60b67da-cb6c-43b9-97c2-47e14e2c77ba","name":"First Name","type":"string","value":"={{ $('Limit').item.json['First Name'] }}"},{"id":"0bac7c50-8172-4613-8874-7ac49fad718f","name":"Last Name","type":"string","value":"={{ $('Limit').item.json['Last Name'] }}"}]},"includeOtherFields":true},"typeVersion":3.4},{"id":"379e329f-8967-4cb4-ac6b-a7823f2e3107","name":"Google Sheets - Read Leads (Pipeline 2)","type":"n8n-nodes-base.googleSheets","position":[2384,4656],"parameters":{"options":{},"filtersUI":{"values":[{"lookupValue":"true","lookupColumn":"is_linkedin"},{"lookupValue":"false","lookupColumn":"proceed_to_prospeo"}]},"sheetName":{"__rl":true,"mode":"list","value":1100974956,"cachedResultUrl":"","cachedResultName":"Your Sheet Tab"},"documentId":{"__rl":true,"mode":"list","value":"YOUR_GOOGLE_SHEET_ID","cachedResultUrl":"","cachedResultName":"Your Lead Sheet"}},"credentials":{"googleSheetsOAuth2Api":{"id":"credential-id","name":"Google Sheets account"}},"typeVersion":4.7},{"id":"881a4dc9-7e39-4843-89a0-05cbd408166d","name":"Rate Limit Wait","type":"n8n-nodes-base.wait","position":[2736,4720],"webhookId":"dbe15229-6693-4401-be4e-0471dc0baef7","parameters":{},"typeVersion":1.1},{"id":"91ae756e-ee10-40fe-9794-f5a05f4dd8d0","name":"Process Each Lead","type":"n8n-nodes-base.splitInBatches","position":[2896,4976],"parameters":{"options":{}},"typeVersion":3},{"id":"5a6d747a-ceda-4d7c-a366-5686f78ca23f","name":"Google Sheets - Save LinkedIn URL","type":"n8n-nodes-base.googleSheets","position":[1984,4608],"parameters":{"columns":{"value":{"serp_url":"={{ $json.serp_url }}","ai_reason":"={{ $json.ai_reason }}","confidence":"={{ $json.ai_confidence }}","row_number":0,"is_linkedin":"={{ $json.is_linkedin }}","enrichment_status":"={{ $json.enrichment_status }}","Complete legal name":"={{ $json['Complete legal name'] }}"},"schema":[{"id":"Complete legal name","type":"string","display":true,"removed":false,"required":false,"displayName":"Complete legal name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"First Name","type":"string","display":true,"required":false,"displayName":"First Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Last Name","type":"string","display":true,"required":false,"displayName":"Last Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Licensed as","type":"string","display":true,"required":false,"displayName":"Licensed as","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Employer Name","type":"string","display":true,"required":false,"displayName":"Employer Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Principal Condominium Manager","type":"string","display":true,"required":false,"displayName":"Principal Condominium Manager","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Business Address","type":"string","display":true,"required":false,"displayName":"Business Address","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Business Email Address","type":"string","display":true,"required":false,"displayName":"Business Email Address","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Business Phone Number","type":"string","display":true,"required":false,"displayName":"Business Phone Number","defaultMatch":false,"canBeUsedToMatch":true},{"id":"serp_url","type":"string","display":true,"required":false,"displayName":"serp_url","defaultMatch":false,"canBeUsedToMatch":true},{"id":"is_linkedin","type":"string","display":true,"required":false,"displayName":"is_linkedin","defaultMatch":false,"canBeUsedToMatch":true},{"id":"confidence","type":"string","display":true,"required":false,"displayName":"confidence","defaultMatch":false,"canBeUsedToMatch":true},{"id":"enrichment_status","type":"string","display":true,"required":false,"displayName":"enrichment_status","defaultMatch":false,"canBeUsedToMatch":true},{"id":"ai_reason","type":"string","display":true,"required":false,"displayName":"ai_reason","defaultMatch":false,"canBeUsedToMatch":true},{"id":"row_number","type":"number","display":true,"removed":false,"readOnly":true,"required":false,"displayName":"row_number","defaultMatch":false,"canBeUsedToMatch":true}],"mappingMode":"defineBelow","matchingColumns":["Complete legal name"],"attemptToConvertTypes":false,"convertFieldsToString":false},"options":{},"operation":"update","sheetName":{"__rl":true,"mode":"list","value":1100974956,"cachedResultUrl":"","cachedResultName":"Your Sheet Tab"},"documentId":{"__rl":true,"mode":"list","value":"YOUR_GOOGLE_SHEET_ID","cachedResultUrl":"","cachedResultName":"Your Lead Sheet"}},"credentials":{"googleSheetsOAuth2Api":{"id":"credential-id","name":"Google Sheets account"}},"typeVersion":4.7},{"id":"941c3ea2-77e4-4a67-a7a6-526d10bb340e","name":"AI - Validate LinkedIn Match","type":"@n8n/n8n-nodes-langchain.anthropic","position":[1408,4608],"parameters":{"modelId":{"__rl":true,"mode":"list","value":"claude-haiku-4-5-20251001","cachedResultName":"claude-haiku-4-5-20251001"},"options":{"system":"You are a data enrichment assistant for a licensed property manager database in Texas, US. Your job is to analyze Google search results and identify the single best matching URL for a given person.\n\nCRITICAL: Your response must start with { and end with }. Nothing before or after. No explanation. No markdown. No code blocks. Just raw JSON. Keep reason under 10 words.\n\nCONFIDENCE RULE: Only return a URL when you are medium or high confidence. If confidence is low or you are unsure, return null for url and none for type. A wrong result is worse than no result.\n\nPRIORITY ORDER:\n1. LinkedIn personal profile (linkedin.com/in/) where person matches\n2. Any legitimate business website connected to this person\n\nIMPORTANT CONTEXT CHANGE: The search query used was name + Texas only — no job title was included. This means search results may include people from ANY industry in Texas. You MUST verify the person's role from the LinkedIn headline. Do NOT accept a profile based on name match alone. Role verification is now mandatory.\n\nLINKEDIN HEADLINE RULE (most important):\nBase your decision PRIMARILY on the LinkedIn headline. If the headline clearly shows a wrong role, REJECT immediately. Only use snippet as supporting evidence, never as primary reason to accept.\n\nACCEPT a LinkedIn profile only if ALL of these are true:\n- Person's first name appears in the title or URL\n- LinkedIn HEADLINE shows current or past role in: property management, condominium management, building management, facilities management, strata management, real estate leasing, OLCM, CMRAO, property administrator, building superintendent, or closely related field\n- Confidence is medium or high\n- Do NOT reject based on LinkedIn URL country code alone\n\nREJECT a LinkedIn profile if ANY of these are true:\n- HEADLINE shows NO connection to property/condominium/building management\n- HEADLINE shows wrong industry: petroleum, oil, gas, automotive, pharma, food, retail, computing, software, banking, insurance, airline, hospital, military, mining, academic research, startup\n- HEADLINE shows: REALTOR, Real Estate Agent, Real Estate Broker, mortgage broker\n- HEADLINE shows: entrepreneur, co-founder, founder (unless combined with property management company)\n- HEADLINE shows: Accountant, Financial Analyst, CPA, Controller, Bookkeeper\n- HEADLINE shows: student, intern, PhD researcher, academic\n- First name does not match at all\n- Location explicitly outside Canada AND no Canadian company in result\n- Confidence is low\n\nACCEPT a website only if ALL of these are true:\n- Legitimate business website\n- Person's name OR property management company in title, URL, or snippet\n- Business is in property management or closely related field\n- Confidence is medium or high\n\nREJECT a website if ANY of these are true:\n- Real estate agent listing: remax, royallepage, homelife, century21, zoocasa, zolo, realtor\n- News article, research paper, government document, obituary, legal document\n- Generic directory with no specific connection to this person\n- Social media: facebook, instagram, twitter, tiktok\n- Wrong industry: healthcare, hospital, educational institution, government, religious organization\n- No mention of person's name or employer\n- Confidence is low\n\nRespond with ONLY this JSON, max 50 tokens, no text before or after:\n{\"url\":\"matched url or null\",\"type\":\"linkedin or website or none\",\"confidence\":\"high or medium or low\",\"reason\":\"max 10 words\"}","maxTokens":500,"temperature":0},"messages":{"values":[{"content":"=Person name: {{ $json['First Name'] }} {{ $json['Last Name'] }}\n\nSearch results:\n{{ JSON.stringify($json.clean_results) }}\n\nRespond with ONLY this JSON starting with { :\n{\"url\":\"matched url or null\",\"type\":\"linkedin or website or none\",\"confidence\":\"high or medium or low\",\"reason\":\"one line\"}"}]}},"credentials":{"anthropicApi":{"id":"credential-id","name":"Anthropic account"}},"retryOnFail":true,"typeVersion":1},{"id":"11987a6e-1c3d-42df-9e83-16035e0ac401","name":"Rate Limit Wait (AI)","type":"n8n-nodes-base.wait","position":[1168,4608],"webhookId":"bad2812e-fbcb-4ca6-81b9-5f5d52e67399","parameters":{"amount":3},"typeVersion":1.1},{"id":"ea55b3cd-7cc8-4111-a6b7-49128f4635b2","name":"Parse AI Response","type":"n8n-nodes-base.code","position":[1760,4608],"parameters":{"mode":"runOnceForEachItem","jsCode":" const item = $input.item;\n\n// ── Extract text — Haiku first, then Gemini fallback ─────\nlet aiText = '';\n\n// Haiku response path (content[0].text)\nif (item.json.content?.[0]?.text) {\n  aiText = item.json.content[0].text;\n}\n// Gemini Simplify ON path\nelse if (item.json.text) {\n  aiText = item.json.text;\n}\n// Gemini Simplify OFF path\nelse if (item.json.candidates?.[0]?.content?.parts?.[0]?.text) {\n  aiText = item.json.candidates[0].content.parts[0].text;\n}\nelse if (item.json.content?.parts?.[0]?.text) {\n  aiText = item.json.content.parts[0].text;\n}\n\n// Remove markdown backticks if present\naiText = aiText.replace(/```json\\n?|```/g, '').trim();\n\n// ── Extract JSON using regex ──────────────────────────────\nlet cleaned = '';\nconst jsonMatch = aiText.match(/\\{[\\s\\S]*\\}/);\nif (jsonMatch) {\n  cleaned = jsonMatch[0];\n}\n\n// ── Parse JSON ────────────────────────────────────────────\nlet aiResult = { url: null, type: 'none', confidence: 'low', reason: 'parse error' };\ntry {\n  aiResult = JSON.parse(cleaned);\n} catch(e) {\n  const urlMatch    = aiText.match(/\"url\"\\s*:\\s*\"([^\"]+)\"/);\n  const typeMatch   = aiText.match(/\"type\"\\s*:\\s*\"([^\"]+)\"/);\n  const confMatch   = aiText.match(/\"confidence\"\\s*:\\s*\"([^\"]+)\"/);\n  const reasonMatch = aiText.match(/\"reason\"\\s*:\\s*\"([^\"]+)\"/);\n\n  aiResult = {\n    url:        urlMatch    ? urlMatch[1]    : null,\n    type:       typeMatch   ? typeMatch[1]   : 'none',\n    confidence: confMatch   ? confMatch[1]   : 'low',\n    reason:     reasonMatch ? reasonMatch[1] : 'no match found'\n  };\n}\n\n// ── Sanitize ──────────────────────────────────────────────\nconst validTypes = ['linkedin', 'website', 'none'];\nconst type       = validTypes.includes(aiResult.type) ? aiResult.type : 'none';\nlet url          = (type !== 'none' && aiResult.url && aiResult.url !== 'null')\n  ? aiResult.url : null;\nconst confidence = aiResult.confidence || 'low';\nconst reason     = aiResult.reason || '';\n\n// ── Enrichment status ─────────────────────────────────────\nlet enrichmentStatus = 'no_results';\nif (url && type === 'linkedin') enrichmentStatus = 'linkedin_found';\nif (url && type === 'website')  enrichmentStatus = 'website_found_direct';\n\n// ── Force no_results if low confidence + no match ────────\nif (\n  confidence === 'low' &&\n  reason.toLowerCase().includes('no match')\n) {\n  enrichmentStatus = 'no_results';\n  url = null;\n}\n\n// ── Get clean_results from Edit Fields node ───────────────\nconst cleanResults = $('Edit Fields').item.json.clean_results || [];\n\n// ── Extract serp_title and serp_company ───────────────────\nlet serpTitle   = null;\nlet serpCompany = null;\n\nif (url) {\n  const matchedResult = cleanResults.find(r => r.url === url);\n  if (matchedResult) {\n    serpTitle = matchedResult.title || null;\n\n    if (type === 'linkedin' && serpTitle) {\n      const atIndex = serpTitle.indexOf(' at ');\n      if (atIndex !== -1) {\n        const raw = serpTitle\n          .substring(atIndex + 4)\n          .replace(/\\.{2,}$/, '')\n          .trim();\n        const INVALID = [\n          'university', 'college', 'student', 'school',\n          'hospital', 'pharma', 'bank', 'petroleum', 'automotive'\n        ];\n        if (\n          !INVALID.some(k => raw.toLowerCase().includes(k)) &&\n          raw.length >= 3 &&\n          raw.length <= 80\n        ) {\n          serpCompany = raw;\n        }\n      }\n    }\n  }\n}\n\n// ── Get sheet fields ──────────────────────────────────────\nconst sheetData = $('Limit').item.json;\n\n// ── Build full person name ────────────────────────────────\nconst personName = `${sheetData['First Name'] || ''} ${sheetData['Last Name'] || ''}`.trim();\n\nreturn {\n  'Complete legal name': sheetData['Complete legal name'] || null,\n  'First Name':          sheetData['First Name'] || null,\n  'Last Name':           sheetData['Last Name'] || null,\n  'Licensed as':         sheetData['Licensed as'] || null,\n  person_name:           personName,\n  serp_title:            serpTitle,\n  serp_url:              url,\n  serp_company:          serpCompany,\n  serp_location:         sheetData.serp_location || null,\n  is_linkedin:           type === 'linkedin',\n  company_name:          null,\n  website:               type === 'website' ? url : null,\n  email:                 null,\n  email_valid:           null,\n  confidence:            sheetData.confidence || null,\n  ai_confidence:         confidence,\n  ai_reason:             reason,\n  enrichment_status:     enrichmentStatus\n};"},"typeVersion":2},{"id":"b50db274-7c57-4195-85ba-05e6d434f760","name":"SerpAPI - Find LinkedIn URL (Pass 2)","type":"n8n-nodes-base.httpRequest","position":[272,5312],"parameters":{"url":"https://serpapi.com/search.json","options":{},"sendQuery":true,"queryParameters":{"parameters":[{"name":"api_key","value":"YOUR_SERPAPI_KEY"},{"name":"q","value":"={{ $json['First Name'] }} {{ $json['Last Name'] }} {{ $json['Employer Name'] }} Ontario site:linkedin.com"},{"name":"engine","value":"google"},{"name":"num","value":"5"},{"name":"gl","value":"ca"},{"name":"hl","value":"en"}]}},"retryOnFail":true,"typeVersion":4.4},{"id":"52519a4e-d11a-488f-a0b3-5742fd0779e5","name":"Google Sheets - Read No-Result Leads","type":"n8n-nodes-base.googleSheets","position":[-240,5328],"parameters":{"options":{},"filtersUI":{"values":[{"lookupValue":"true","lookupColumn":"is_linkedin"},{"lookupValue":"false","lookupColumn":"proceed_to_prospeo"}]},"sheetName":{"__rl":true,"mode":"list","value":1100974956,"cachedResultUrl":"","cachedResultName":"Your Sheet Tab"},"documentId":{"__rl":true,"mode":"list","value":"YOUR_GOOGLE_SHEET_ID","cachedResultUrl":"","cachedResultName":"Your Lead Sheet"}},"credentials":{"googleSheetsOAuth2Api":{"id":"credential-id","name":"Google Sheets account"}},"typeVersion":4.7},{"id":"634adebe-2160-4681-8a1b-1d40043517b1","name":"Filter & Clean Results (Pass 2)","type":"n8n-nodes-base.code","position":[496,5312],"parameters":{"mode":"runOnceForEachItem","jsCode":"const item = $input.item;\nconst results = item.json.organic_results || [];\nconst BLOCKED_DOMAINS = [\n  'facebook.com', 'instagram.com', 'twitter.com', 'tiktok.com',\n  'youtube.com', 'reddit.com', 'wikipedia.org',\n  'yellowpages', 'canada411', 'yelp.com', 'yelp.ca',\n  'whitepages', 'zoominfo.com', 'crunchbase.com', 'bloomberg.com',\n  'remax.ca', 'remax-quebec.com', 'rew.ca', 'realtor.ca',\n  'zolo.ca', 'housesigma.com', 'homelife.ca', 'rankmyagent.com',\n  'rate-my-agent.com', 'royallepage.ca', 'century21.ca',\n  'zoocasa.com', 'kijiji.ca', 'flowercityrealty.com',\n  'executivehomesrealty.ca', 'openroom.ca', 'rentals.ca',\n  'researchgate.net', 'studylib.net', 'datanyze.com',\n  'rocketreach.co', 'nature.com', 'worldbank.org',\n  'pubs.acs.org', 'acpjournals.org', 'hfg.org', 'imdb.com',\n  'osgoode.yorku.ca', 'digitalcommons', 'ubc.ca', 'umanitoba.ca',\n  'gov.uk', 'gloucester-ma.gov', 'transitchicago.com',\n  'cloudfront.net', 'codalab.org', 'pestend.ca',\n  'find-and-update.company-information',\n  'westburyrentals.com', 'myrentalunit.ca',\n  'forumproperties.com', 'thaparteam.ca',\n  'ontario.ca/document', 'digital.ontarioreports.ca'\n];\n\nconst cleanResults = results\n  .filter(r => {\n    if (!r.link) return false;\n    if (!r.link.startsWith('http')) return false;\n    if (r.link.match(/\\.(pdf|csv|txt|doc|xls|xlsx|png|jpg|jpeg)(\\?|$)/i)) return false;\n    if (BLOCKED_DOMAINS.some(b => r.link.toLowerCase().includes(b))) return false;\n    return true;\n  })\n  .slice(0, 3) // ← changed from 5 to 3\n  .map(r => ({\n    url:     r.link,\n    title:   r.title || '',\n    snippet: (r.snippet || '').substring(0, 150) // ← also reduced from 200 to 150\n  }));\n\nreturn {\n  clean_results: cleanResults,\n  has_results:   cleanResults.length > 0\n};"},"typeVersion":2},{"id":"f9f21901-aef5-40e7-bc88-8a259588ac2f","name":"Batch Size Limit (Pass 2)","type":"n8n-nodes-base.limit","position":[80,5312],"parameters":{"maxItems":31},"typeVersion":1},{"id":"1942f7c2-2a72-402c-9edd-7d6038ac5f88","name":"Has Search Results? (Pass 2)","type":"n8n-nodes-base.if","position":[688,5328],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"4f5a2e35-5370-4c03-a53c-21d8be982144","operator":{"type":"boolean","operation":"equals"},"leftValue":"={{ $json.has_results }}","rightValue":true}]}},"typeVersion":2.3},{"id":"bb571b1e-017c-4f6d-8e78-6a6e7a92a8d2","name":"Prepare AI Input (Pass 2)","type":"n8n-nodes-base.set","position":[912,5312],"parameters":{"options":{},"assignments":{"assignments":[{"id":"6471eb39-1688-4763-80cf-eb26fed02154","name":"clean_results","type":"array","value":"={{ $json.clean_results }}"},{"id":"3bdbea53-7a64-4e31-8825-d1e3d06b1032","name":"person_name","type":"string","value":"={{ $('Limit1').item.json['First Name'] }} {{ $('Limit1').item.json['Last Name'] }}"},{"id":"07151515-b5fa-4e59-a16a-0bcfbc9583a9","name":"Licensed as","type":"string","value":"={{ $('Limit1').item.json['Licensed as'] }}"},{"id":"c60b67da-cb6c-43b9-97c2-47e14e2c77ba","name":"First Name","type":"string","value":"={{ $('Limit1').item.json['First Name'] }}"},{"id":"0bac7c50-8172-4613-8874-7ac49fad718f","name":"Last Name","type":"string","value":"={{ $('Limit1').item.json['Last Name'] }}"},{"id":"bc9ba76d-e6cb-4c62-b6c9-d0f6d74d055f","name":"Employer Name","type":"string","value":"={{ $('Limit1').item.json['Employer Name'] }}"},{"id":"ef205822-ea3a-49e5-b819-8480de3821fa","name":"row_number","type":"number","value":"={{ $('Limit1').item.json.row_number }}"}]},"includeOtherFields":true},"typeVersion":3.4},{"id":"32fb0df2-5251-43b1-9a0f-6168510edbf6","name":"Google Sheets - Save Results (Pass 2)","type":"n8n-nodes-base.googleSheets","position":[1840,5312],"parameters":{"columns":{"value":{"serp_url":"={{ $json.serp_url }}","ai_reason":"={{ $json.ai_reason }}","confidence":"={{ $json.ai_confidence }}","row_number":0,"is_linkedin":"={{ $json.is_linkedin }}","enrichment_status":"={{ $json.enrichment_status }}","Complete legal name":"={{ $json['Complete legal name'] }}"},"schema":[{"id":"Complete legal name","type":"string","display":true,"removed":false,"required":false,"displayName":"Complete legal name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"First Name","type":"string","display":true,"required":false,"displayName":"First Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Last Name","type":"string","display":true,"required":false,"displayName":"Last Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Licensed as","type":"string","display":true,"required":false,"displayName":"Licensed as","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Employer Name","type":"string","display":true,"required":false,"displayName":"Employer Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Principal Condominium Manager","type":"string","display":true,"required":false,"displayName":"Principal Condominium Manager","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Business Address","type":"string","display":true,"required":false,"displayName":"Business Address","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Business Email Address","type":"string","display":true,"required":false,"displayName":"Business Email Address","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Business Phone Number","type":"string","display":true,"required":false,"displayName":"Business Phone Number","defaultMatch":false,"canBeUsedToMatch":true},{"id":"serp_url","type":"string","display":true,"required":false,"displayName":"serp_url","defaultMatch":false,"canBeUsedToMatch":true},{"id":"is_linkedin","type":"string","display":true,"required":false,"displayName":"is_linkedin","defaultMatch":false,"canBeUsedToMatch":true},{"id":"confidence","type":"string","display":true,"required":false,"displayName":"confidence","defaultMatch":false,"canBeUsedToMatch":true},{"id":"enrichment_status","type":"string","display":true,"required":false,"displayName":"enrichment_status","defaultMatch":false,"canBeUsedToMatch":true},{"id":"ai_reason","type":"string","display":true,"required":false,"displayName":"ai_reason","defaultMatch":false,"canBeUsedToMatch":true},{"id":"row_number","type":"number","display":true,"removed":false,"readOnly":true,"required":false,"displayName":"row_number","defaultMatch":false,"canBeUsedToMatch":true}],"mappingMode":"defineBelow","matchingColumns":["Complete legal name"],"attemptToConvertTypes":false,"convertFieldsToString":false},"options":{},"operation":"update","sheetName":{"__rl":true,"mode":"list","value":1100974956,"cachedResultUrl":"","cachedResultName":"Your Sheet Tab"},"documentId":{"__rl":true,"mode":"list","value":"YOUR_GOOGLE_SHEET_ID","cachedResultUrl":"","cachedResultName":"Your Lead Sheet"}},"credentials":{"googleSheetsOAuth2Api":{"id":"credential-id","name":"Google Sheets account"}},"typeVersion":4.7},{"id":"1f55fe0a-c349-4424-8c7e-ab827d81ba6a","name":"AI - Validate LinkedIn Match (Pass 2)","type":"@n8n/n8n-nodes-langchain.anthropic","position":[1328,5312],"parameters":{"modelId":{"__rl":true,"mode":"list","value":"claude-haiku-4-5-20251001","cachedResultName":"claude-haiku-4-5-20251001"},"options":{"system":"You are a data enrichment assistant for a licensed property manager database in Texas, US. Your job is to analyze Google search results and identify the single best matching URL for a given person.\n\nCRITICAL: Your response must start with { and end with }. Nothing before or after. No explanation. No markdown. No code blocks. Just raw JSON. Keep reason under 10 words.\n\nCONFIDENCE RULE: Only return a URL when you are medium or high confidence. If confidence is low or you are unsure, return null for url and none for type. A wrong result is worse than no result.\n\nPRIORITY ORDER:\n1. LinkedIn personal profile (linkedin.com/in/) where person matches\n2. Any legitimate business website connected to this person\n\nIMPORTANT CONTEXT CHANGE: The search query used was name + Texas only — no job title was included. This means search results may include people from ANY industry in Texas. You MUST verify the person's role from the LinkedIn headline. Do NOT accept a profile based on name match alone. Role verification is now mandatory.\n\nLINKEDIN HEADLINE RULE (most important):\nBase your decision PRIMARILY on the LinkedIn headline. If the headline clearly shows a wrong role, REJECT immediately. Only use snippet as supporting evidence, never as primary reason to accept.\n\nACCEPT a LinkedIn profile only if ALL of these are true:\n- Person's first name appears in the title or URL\n- LinkedIn HEADLINE shows current or past role in: property management, condominium management, building management, facilities management, strata management, real estate leasing, OLCM, CMRAO, property administrator, building superintendent, or closely related field\n- Confidence is medium or high\n- Do NOT reject based on LinkedIn URL country code alone\n\nREJECT a LinkedIn profile if ANY of these are true:\n- HEADLINE shows NO connection to property/condominium/building management\n- HEADLINE shows wrong industry: petroleum, oil, gas, automotive, pharma, food, retail, computing, software, banking, insurance, airline, hospital, military, mining, academic research, startup\n- HEADLINE shows: REALTOR, Real Estate Agent, Real Estate Broker, mortgage broker\n- HEADLINE shows: entrepreneur, co-founder, founder (unless combined with property management company)\n- HEADLINE shows: Accountant, Financial Analyst, CPA, Controller, Bookkeeper\n- HEADLINE shows: student, intern, PhD researcher, academic\n- First name does not match at all\n- Location explicitly outside Canada AND no Canadian company in result\n- Confidence is low\n\nACCEPT a website only if ALL of these are true:\n- Legitimate business website\n- Person's name OR property management company in title, URL, or snippet\n- Business is in property management or closely related field\n- Confidence is medium or high\n\nREJECT a website if ANY of these are true:\n- Real estate agent listing: remax, royallepage, homelife, century21, zoocasa, zolo, realtor\n- News article, research paper, government document, obituary, legal document\n- Generic directory with no specific connection to this person\n- Social media: facebook, instagram, twitter, tiktok\n- Wrong industry: healthcare, hospital, educational institution, government, religious organization\n- No mention of person's name or employer\n- Confidence is low\n\nRespond with ONLY this JSON, max 50 tokens, no text before or after:\n{\"url\":\"matched url or null\",\"type\":\"linkedin or website or none\",\"confidence\":\"high or medium or low\",\"reason\":\"max 10 words\"}","maxTokens":300,"temperature":0},"messages":{"values":[{"content":"=Person name: {{ $json['First Name'] }} {{ $json['Last Name'] }}\n\nEmployer: {{ $json['Employer Name'] }}\n\nSearch results:\n{{ JSON.stringify($json.clean_results) }}\n\nRespond with ONLY this JSON:\n{\"url\":\"matched url or null\",\"type\":\"linkedin or website or none\",\"confidence\":\"high or medium or low\",\"reason\":\"max 10 words\"}"}]}},"credentials":{"anthropicApi":{"id":"credential-id","name":"Anthropic account"}},"retryOnFail":true,"typeVersion":1},{"id":"8b52c99e-0427-44b2-bf23-7ff354f3e469","name":"Parse AI Response (Pass 2)","type":"n8n-nodes-base.code","position":[1632,5312],"parameters":{"mode":"runOnceForEachItem","jsCode":"const item = $input.item;\n\n// ── Extract text — Haiku first, then Gemini fallback ─────\nlet aiText = '';\n\n// Haiku response path (content[0].text)\nif (item.json.content?.[0]?.text) {\n  aiText = item.json.content[0].text;\n}\n// Gemini Simplify ON path\nelse if (item.json.text) {\n  aiText = item.json.text;\n}\n// Gemini Simplify OFF path\nelse if (item.json.candidates?.[0]?.content?.parts?.[0]?.text) {\n  aiText = item.json.candidates[0].content.parts[0].text;\n}\nelse if (item.json.content?.parts?.[0]?.text) {\n  aiText = item.json.content.parts[0].text;\n}\n\n// Remove markdown backticks if present\naiText = aiText.replace(/```json\\n?|```/g, '').trim();\n\n// ── Extract JSON using regex ──────────────────────────────\nlet cleaned = '';\nconst jsonMatch = aiText.match(/\\{[\\s\\S]*\\}/);\nif (jsonMatch) {\n  cleaned = jsonMatch[0];\n}\n\n// ── Parse JSON ────────────────────────────────────────────\nlet aiResult = { url: null, type: 'none', confidence: 'low', reason: 'parse error' };\ntry {\n  aiResult = JSON.parse(cleaned);\n} catch(e) {\n  const urlMatch    = aiText.match(/\"url\"\\s*:\\s*\"([^\"]+)\"/);\n  const typeMatch   = aiText.match(/\"type\"\\s*:\\s*\"([^\"]+)\"/);\n  const confMatch   = aiText.match(/\"confidence\"\\s*:\\s*\"([^\"]+)\"/);\n  const reasonMatch = aiText.match(/\"reason\"\\s*:\\s*\"([^\"]+)\"/);\n\n  aiResult = {\n    url:        urlMatch    ? urlMatch[1]    : null,\n    type:       typeMatch   ? typeMatch[1]   : 'none',\n    confidence: confMatch   ? confMatch[1]   : 'low',\n    reason:     reasonMatch ? reasonMatch[1] : 'no match found'\n  };\n}\n\n// ── Sanitize ──────────────────────────────────────────────\nconst validTypes = ['linkedin', 'website', 'none'];\nconst type       = validTypes.includes(aiResult.type) ? aiResult.type : 'none';\nlet url          = (type !== 'none' && aiResult.url && aiResult.url !== 'null')\n  ? aiResult.url : null;\nconst confidence = aiResult.confidence || 'low';\nconst reason     = aiResult.reason || '';\n\n// ── Enrichment status ─────────────────────────────────────\nlet enrichmentStatus = 'no_results';\nif (url && type === 'linkedin') enrichmentStatus = 'linkedin_found';\nif (url && type === 'website')  enrichmentStatus = 'website_found_direct';\n\n// ── Force no_results if low confidence + no match ────────\nif (\n  confidence === 'low' &&\n  reason.toLowerCase().includes('no match')\n) {\n  enrichmentStatus = 'no_results';\n  url = null;\n}\n\n// ── Get clean_results from Edit Fields node ───────────────\nconst cleanResults = $('Edit Fields1').item.json.clean_results || [];\n\n// ── Extract serp_title and serp_company ───────────────────\nlet serpTitle   = null;\nlet serpCompany = null;\n\nif (url) {\n  const matchedResult = cleanResults.find(r => r.url === url);\n  if (matchedResult) {\n    serpTitle = matchedResult.title || null;\n\n    if (type === 'linkedin' && serpTitle) {\n      const atIndex = serpTitle.indexOf(' at ');\n      if (atIndex !== -1) {\n        const raw = serpTitle\n          .substring(atIndex + 4)\n          .replace(/\\.{2,}$/, '')\n          .trim();\n        const INVALID = [\n          'university', 'college', 'student', 'school',\n          'hospital', 'pharma', 'bank', 'petroleum', 'automotive'\n        ];\n        if (\n          !INVALID.some(k => raw.toLowerCase().includes(k)) &&\n          raw.length >= 3 &&\n          raw.length <= 80\n        ) {\n          serpCompany = raw;\n        }\n      }\n    }\n  }\n}\n\n// ── Get sheet fields ──────────────────────────────────────\nconst sheetData = $('Limit1').item.json;\n\n// ── Build full person name ────────────────────────────────\nconst personName = `${sheetData['First Name'] || ''} ${sheetData['Last Name'] || ''}`.trim();\n\nreturn {\n  'Complete legal name': sheetData['Complete legal name'] || null,\n  'First Name':          sheetData['First Name'] || null,\n  'Last Name':           sheetData['Last Name'] || null,\n  'Licensed as':         sheetData['Licensed as'] || null,\n  'Employer Name':       sheetData['Employer Name'] || null,  // ← added\n  person_name:           personName,\n  serp_title:            serpTitle,\n  serp_url:              url,\n  serp_company:          serpCompany,\n  serp_location:         sheetData.serp_location || null,\n  is_linkedin:           type === 'linkedin',\n  company_name:          null,\n  website:               type === 'website' ? url : null,\n  email:                 null,\n  email_valid:           null,\n  confidence:            sheetData.confidence || null,\n  ai_confidence:         confidence,\n  ai_reason:             reason,\n  enrichment_status:     enrichmentStatus\n};"},"typeVersion":2},{"id":"d45c8b5a-7f89-4704-9943-4c8a7d6b9dbc","name":"Filter Unprocessed Records","type":"n8n-nodes-base.filter","position":[-80,5488],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"22ce8fb2-0888-4b4b-92f1-71acf8ee6508","operator":{"type":"number","operation":"gt"},"leftValue":"={{ $json.row_number }}","rightValue":3333}]}},"typeVersion":2.3},{"id":"3ddfbad2-e969-4a85-ab95-8ec4df2885e8","name":"Rate Limit Wait (Pass 3)","type":"n8n-nodes-base.wait","position":[1376,5472],"webhookId":"bad2812e-fbcb-4ca6-81b9-5f5d52e67399","parameters":{"amount":3},"typeVersion":1.1},{"id":"14054169-9250-4852-96c3-05407e86713d","name":"Batch Size Limit (Pipeline 2)","type":"n8n-nodes-base.limit","position":[2576,4928],"parameters":{"maxItems":51},"typeVersion":1},{"id":"67a3c9c9-a294-48a2-9252-e3ec9f5cb3db","name":"Filter LinkedIn Found","type":"n8n-nodes-base.filter","position":[1840,5504],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"22ce8fb2-0888-4b4b-92f1-71acf8ee6508","operator":{"type":"boolean","operation":"true","singleValue":true},"leftValue":"={{ $json.is_linkedin }}","rightValue":51}]}},"typeVersion":2.3},{"id":"82dc2a93-2a81-444c-885f-1601a20c470f","name":"Filter Ready for Apify","type":"n8n-nodes-base.filter","position":[2400,4928],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"loose"},"combinator":"and","conditions":[{"id":"22ce8fb2-0888-4b4b-92f1-71acf8ee6508","operator":{"type":"number","operation":"gt"},"leftValue":"={{ $json.row_number }}","rightValue":2317}]},"looseTypeValidation":true},"typeVersion":2.3},{"id":"ca72366e-f933-4b18-abc3-d180abda241d","name":"Apify - Scrape LinkedIn Profile","type":"n8n-nodes-base.httpRequest","onError":"continueRegularOutput","position":[2912,4720],"parameters":{"url":"https://api.apify.com/v2/actors/harvestapi~linkedin-profile-scraper/run-sync-get-dataset-items?token=YOUR_TOKEN_HERE","method":"POST","options":{"response":{"response":{"responseFormat":"text"}}},"jsonBody":"={\n  \"urls\": [\"{{ $json.serp_url }}\"],\n  \"scrapeMode\": \"email\"\n}","sendBody":true,"specifyBody":"json"},"notesInFlow":false,"retryOnFail":true,"typeVersion":4.4},{"id":"74e8c077-43cd-44fd-ad2b-b7d75b72ed8d","name":"SerpAPI - Find Company Domain","type":"n8n-nodes-base.httpRequest","position":[3312,4720],"parameters":{"url":"https://serpapi.com/search.json","options":{},"sendQuery":true,"queryParameters":{"parameters":[{"name":"api_key","value":"YOUR_SERPAPI_KEY"},{"name":"q","value":"={{ $json['First Name'] }} {{ $json['Last Name'] }} YOUR_LOCATION site:linkedin.com"},{"name":"engine","value":"google"},{"name":"num","value":"5"},{"name":"gl","value":"ca"}]}},"retryOnFail":true,"typeVersion":4.4},{"id":"8d03dcdb-a9be-4810-ab27-8559287dbaa3","name":"Prepare Domain Search","type":"n8n-nodes-base.set","position":[3536,4720],"parameters":{"options":{},"assignments":{"assignments":[{"id":"5a412912-0d59-4e40-8499-c7bf4c1bff6c","name":"company_name_clean","type":"string","value":"={{ $('Parse Linkedin data').item.json.company_name_clean }}"},{"id":"ca265875-a221-4aed-8bd9-f8e147fe12fc","name":"company_name","type":"string","value":"={{ $('Parse Linkedin data').item.json.company_name }}"}]},"includeOtherFields":true},"typeVersion":3.4},{"id":"fedb5601-aa1d-4e22-89f0-1750da466476","name":"Extract Company Domain","type":"n8n-nodes-base.code","position":[3696,4720],"parameters":{"mode":"runOnceForEachItem","jsCode":"const item = $input.item.json;\n\n// ── Company name ──────────────────────────────────────────\nconst companyName = item.company_name_clean || \n                    item.company_name || \n                    (item.search_parameters?.q || '').replace(/\\s+Ontario\\s*$/i, '').trim() ||\n                    'unknown';\n\n// ── Skip domains ──────────────────────────────────────────\nconst SKIP_DOMAINS = [\n  'linkedin.com', 'facebook.com', 'instagram.com',\n  'twitter.com', 'youtube.com', 'wikipedia.org',\n  'yellowpages', 'canada411', 'yelp.com', 'yelp.ca',\n  'zoominfo.com', 'crunchbase.com', 'bloomberg.com',\n  'remax.ca', 'realtor.ca', 'zoocasa.com',\n  'bbb.org', 'glassdoor.com', 'indeed.com',\n  'kijiji.ca', 'rentals.ca', 'padmapper.com',\n  'cmrao.ca', 'ontario.ca', 'canada.ca',\n  'google.com', 'serpapi.com',\n  'tripadvisor.com', 'lnkd.in', 'tinyurl.com',\n  'nationalpost.com', 'bit.ly', 'nextdoor.com',\n  'mapquest.com', 'apple.com', 'bing.com'\n];\n\n// ── Helpers ───────────────────────────────────────────────\nfunction extractDomain(url) {\n  if (!url) return null;\n  let s = url.trim();\n  s = s.replace(/^https?:\\/\\//i, '');\n  s = s.replace(/^www\\./i, '');\n  s = s.split('/')[0];\n  s = s.split('?')[0];\n  s = s.split('#')[0];\n  s = s.toLowerCase().trim();\n  if (s.includes('.') && s.length > 4 && !s.includes(' ')) {\n    return s;\n  }\n  return null;\n}\n\nfunction isSkipped(url) {\n  if (!url) return true;\n  const lower = url.toLowerCase();\n  return SKIP_DOMAINS.some(s => lower.includes(s));\n}\n\n// Extract domain from snippet text\nfunction extractFromSnippet(snippet) {\n  if (!snippet) return null;\n  // Look for explicit URL in snippet\n  const urlMatch = snippet.match(/https?:\\/\\/[^\\s,;\\\"\\'<>]+/);\n  if (urlMatch) {\n    const url = urlMatch[0].replace(/[.,;)>]$/, '');\n    if (!isSkipped(url)) {\n      return extractDomain(url);\n    }\n  }\n  // Look for domain pattern like \"www.something.com\" or \"something.ca\"\n  const domainMatch = snippet.match(/(?:www\\.)?([a-zA-Z0-9-]+\\.(?:com|ca|org|net|co))/);\n  if (domainMatch) {\n    const d = domainMatch[0].replace(/^www\\./, '').toLowerCase();\n    if (!isSkipped(d) && d.length > 4) {\n      return d;\n    }\n  }\n  return null;\n}\n\nlet domain = null;\nlet domainSource = null;\nlet domainMethod = null;\n\n// ── Method 1: Knowledge Graph website ────────────────────\nconst kgWebsite = item.knowledge_graph?.website;\nif (kgWebsite && !isSkipped(kgWebsite)) {\n  const d = extractDomain(kgWebsite);\n  if (d) {\n    domain = d;\n    domainSource = kgWebsite;\n    domainMethod = 'knowledge_graph_website';\n  }\n}\n\n// ── Method 2: Knowledge Graph appointment providers ──────\nif (!domain) {\n  const providers = item.knowledge_graph?.appointment_providers || [];\n  for (const p of providers) {\n    const url = p.link || p.url || '';\n    if (url && !isSkipped(url)) {\n      const d = extractDomain(url);\n      if (d) {\n        domain = d;\n        domainSource = url;\n        domainMethod = 'knowledge_graph_appointment';\n        break;\n      }\n    }\n  }\n}\n\n// ── Method 3: Knowledge Graph posts ──────────────────────\nif (!domain) {\n  const posts = item.knowledge_graph?.posts || [];\n  for (const post of posts) {\n    const url = post.link || '';\n    if (url && !isSkipped(url)) {\n      const d = extractDomain(url);\n      if (d) {\n        domain = d;\n        domainSource = url;\n        domainMethod = 'knowledge_graph_post';\n        break;\n      }\n    }\n  }\n}\n\n// ── Method 4: Organic result snippets ────────────────────\nif (!domain) {\n  const results = item.organic_results || [];\n  for (const result of results) {\n    const d = extractFromSnippet(result.snippet || '');\n    if (d) {\n      domain = d;\n      domainSource = result.link || '';\n      domainMethod = 'snippet_extraction';\n      break;\n    }\n  }\n}\n\n// ── Method 5: Organic result direct links ────────────────\nif (!domain) {\n  const results = item.organic_results || [];\n  for (const result of results) {\n    const url = result.link || '';\n    if (url && !isSkipped(url)) {\n      const d = extractDomain(url);\n      if (d) {\n        domain = d;\n        domainSource = url;\n        domainMethod = 'organic_result';\n        break;\n      }\n    }\n  }\n}\n\n// ── Return only essential fields ──────────────────────────\n// Don't spread ...item — keeps output lean for 26K scale\nreturn {\n  // Pass through only what downstream nodes need\n  'Complete legal name': item['Complete legal name'] || null,\n  'First Name': item['First Name'] || null,\n  'Last Name': item['Last Name'] || null,\n  'Licensed as': item['Licensed as'] || null,\n  'Employer Name': item['Employer Name'] || null,\n  person_name: item.person_name || null,\n  serp_url: item.serp_url || null,\n  serp_title: item.serp_title || null,\n  serp_company: item.serp_company || null,\n  apify_email: item.apify_email || null,\n  apify_personal_email: item.apify_personal_email || null,\n  company_name: companyName,\n  company_name_clean: companyName,\n  job_title: item.job_title || null,\n  company_linkedin_url: item.company_linkedin_url || null,\n  company_is_current: item.company_is_current || false,\n  company_is_pm_related: item.company_is_pm_related || false,\n  linkedin_headline: item.linkedin_headline || null,\n  linkedin_location: item.linkedin_location || null,\n\n  // Domain results\n  domain: domain,\n  domain_source_url: domainSource,\n  domain_method: domainMethod,\n\n  // Pipeline control\n  proceed_to_prospeo: !!domain,\n  selection_reason: item.selection_reason || null,\n  enrichment_status: domain\n    ? 'domain_found_proceed_to_prospeo'\n    : 'domain_not_found',\n  enrichment_note: domain\n    ? `Domain: ${domain} (via ${domainMethod})`\n    : `Could not find domain for: ${companyName}`\n};"},"typeVersion":2},{"id":"8daa34a5-c680-44be-bbc5-c1414214ef0c","name":"Parse LinkedIn & Select Company","type":"n8n-nodes-base.code","position":[3088,4720],"parameters":{"mode":"runOnceForEachItem","jsCode":"const item = $input.item.json;\n\n// ── HELPER FUNCTIONS ──────────────────────────────────────\n\nfunction isPersonalEmail(email) {\n  if (!email) return false;\n  const personalDomains = [\n    'gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com',\n    'icloud.com', 'live.com', 'msn.com', 'aol.com',\n    'mail.com', 'protonmail.com', 'zoho.com'\n  ];\n  const domain = email.split('@')[1]?.toLowerCase() || '';\n  return personalDomains.includes(domain);\n}\n\nfunction isValidCompanyName(name) {\n  if (!name) return false;\n  const cleaned = name.trim();\n  if (cleaned.length < 3) return false;\n  const genericOnly = /^(inc\\.?|ltd\\.?|llc\\.?|corp\\.?|co\\.?|plc\\.?)$/i;\n  if (genericOnly.test(cleaned)) return false;\n  const selfEmployed = /self.?employ|freelance|independent contractor/i;\n  if (selfEmployed.test(cleaned)) return false;\n  return true;\n}\n\nfunction cleanCompanyName(name) {\n  if (!name) return null;\n  return name\n    .replace(/[&+@#$%^*]/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction isCurrentJob(exp) {\n  if (!exp.endDate) return true;\n  if (Object.keys(exp.endDate).length === 0) return true;\n  const text = (exp.endDate.text || '').toLowerCase();\n  return text === 'present' || text === '' || text === 'now';\n}\n\nfunction hasPMKeyword(text) {\n  const PM_KEYWORDS = [\n    'property management', 'property manager',\n    'condominium management', 'condo management', 'condo manager',\n    'building management', 'building manager', 'building superintendent',\n    'facilities management', 'facility management',\n    'strata management', 'property administrator',\n    'residential management', 'community management',\n    'site manager', 'rental management', 'leasing manager',\n    'property operations', 'olcm', 'cmrao',\n    'licensed condominium', 'property supervisor',\n    'condo corporation', 'condominium corporation'\n  ];\n  const lower = text.toLowerCase();\n  return PM_KEYWORDS.some(k => lower.includes(k));\n}\n\nfunction hasRejectKeyword(text) {\n  const REJECT_KEYWORDS = [\n    'software', 'technology', 'tech company', 'saas', 'app developer',\n    'bank', 'banking', 'credit union', 'financial services',\n    'insurance', 'pharma', 'pharmaceutical', 'biotech',\n    'hospital', 'healthcare', 'medical center', 'clinic',\n    'university', 'college', 'school', 'academy', 'institute',\n    'retail', 'grocery', 'restaurant', 'food service',\n    'automotive', 'car dealer', 'airline', 'aviation',\n    'military', 'defence', 'defense', 'armed forces',\n    'realtor', 'real estate agent', 'real estate broker',\n    'mortgage broker', 'mining', 'petroleum', 'oil and gas',\n    'security guard', 'security services',\n    'staffing agency', 'recruitment agency', 'temp agency',\n    'robotics', 'manufacturing', 'warehouse',\n    'property management software', 'property management system',\n    'yardi', 'buildium', 'appfolio', 'propertyware'\n  ];\n  const lower = text.toLowerCase();\n  return REJECT_KEYWORDS.some(k => lower.includes(k));\n}\n\nconst FALSE_POSITIVE_COMPANIES = [\n  'brookfield asset management',\n  'starlight capital',\n  'td bank', 'td canada trust',\n  'royal bank', 'rbc',\n  'scotiabank', 'bmo', 'cibc',\n  'condor security',\n  'rogers', 'bell canada', 'telus'\n];\n\nfunction isFalsePositive(companyName) {\n  const lower = (companyName || '').toLowerCase();\n  return FALSE_POSITIVE_COMPANIES.some(fp => lower.includes(fp));\n}\n\n// ── PARSE APIFY RESPONSE ──────────────────────────────────\nlet profile = null;\n\ntry {\n  if (Array.isArray(item) && item[0]?.data) {\n    const parsed = JSON.parse(item[0].data);\n    profile = Array.isArray(parsed) ? parsed[0] : parsed;\n  }\n  else if (item.data && typeof item.data === 'string') {\n    const parsed = JSON.parse(item.data);\n    profile = Array.isArray(parsed) ? parsed[0] : parsed;\n  }\n  else if (Array.isArray(item) && item[0]?.experience) {\n    profile = item[0];\n  }\n  else if (item.experience) {\n    profile = item;\n  }\n  else if (Array.isArray(item) && item.length === 0) {\n    profile = null;\n  }\n} catch(e) {\n  profile = null;\n}\n\n// ── Apify timeout/error ───────────────────────────────────\nif (!profile) {\n  return {\n    ...item,\n    apify_email: null,\n    company_name: null,\n    job_title: null,\n    company_linkedin_url: null,\n    company_is_pm_related: false,\n    company_is_current: false,\n    proceed_to_zerobounce: false,\n    proceed_to_prospeo: false,\n    proceed_to_serp: false,\n    proceed_to_prospeo_directly: false,\n    existing_email_domain: null,\n    enrichment_status: 'apify_parse_failed',\n    enrichment_note: 'Apify returned empty or unparseable response'\n  };\n}\n\n// ── CHECK APIFY EMAIL ─────────────────────────────────────\nconst apifyEmails = profile.emails || [];\nconst apifyEmail = apifyEmails.find(e => !isPersonalEmail(e)) || null;\nconst apifyPersonalEmail = apifyEmails.find(e => isPersonalEmail(e)) || null;\n\n// ── GET EXPERIENCE ────────────────────────────────────────\nlet experience = profile.experience || [];\n\nif (experience.length === 0 && profile.currentPosition?.length > 0) {\n  experience = profile.currentPosition.map(p => ({\n    ...p,\n    endDate: { text: 'Present' }\n  }));\n}\n\n// ── No work history ───────────────────────────────────────\nif (experience.length === 0) {\n  return {\n    ...item,\n    apify_email: apifyEmail,\n    apify_personal_email: apifyPersonalEmail,\n    company_name: null,\n    job_title: null,\n    company_linkedin_url: null,\n    company_is_pm_related: false,\n    company_is_current: false,\n    proceed_to_zerobounce: !!apifyEmail,\n    proceed_to_prospeo: false,\n    proceed_to_serp: false,\n    proceed_to_prospeo_directly: false,\n    existing_email_domain: null,\n    enrichment_status: apifyEmail ? 'email_found_by_apify' : 'no_experience_found',\n    enrichment_note: 'No work history on LinkedIn profile'\n  };\n}\n\n// ── SCORE EACH POSITION ───────────────────────────────────\nconst seenCompanies = new Set();\n\nconst scoredPositions = experience.map(exp => {\n  const companyName = (exp.companyName || '').trim();\n  const jobTitle = (exp.position || '').trim();\n  const combined = `${companyName} ${jobTitle}`;\n  const isCurrent = isCurrentJob(exp);\n\n  let score = 0;\n  if (hasPMKeyword(jobTitle)) score += 12;\n  if (hasPMKeyword(companyName)) score += 8;\n  if (isCurrent) score += 5;\n  if (hasRejectKeyword(combined)) score -= 20;\n  if (isFalsePositive(companyName)) score -= 20;\n  if (!isValidCompanyName(companyName)) score -= 10;\n\n  return {\n    company_name: companyName || null,\n    company_name_clean: cleanCompanyName(companyName),\n    job_title: jobTitle || null,\n    is_current: isCurrent,\n    start_date: exp.startDate?.text || null,\n    end_date: exp.endDate?.text || null,\n    company_linkedin_url: exp.companyLinkedinUrl || null,\n    score\n  };\n});\n\nscoredPositions.sort((a, b) => b.score - a.score);\n\n// ── Deduplicate ───────────────────────────────────────────\nconst dedupedPositions = [];\nfor (const pos of scoredPositions) {\n  const key = (pos.company_name || '').toLowerCase().trim();\n  if (!seenCompanies.has(key)) {\n    seenCompanies.add(key);\n    dedupedPositions.push(pos);\n  }\n}\n\n// ── FIND BEST COMPANY ─────────────────────────────────────\nconst currentPMPositions = dedupedPositions.filter(\n  p => p.score > 0 && p.is_current\n);\n\nconst previousPMPositions = dedupedPositions.filter(\n  p => p.score > 0 && !p.is_current\n);\n\nconst hasAnyCurrent = dedupedPositions.some(p => p.is_current);\n\nlet selectedCompany = null;\nlet selectionReason = null;\n\nif (currentPMPositions.length > 0) {\n  selectedCompany = currentPMPositions[0];\n  selectionReason = 'current_pm_company_found';\n\n// ── CHANGE 1 — Recent previous PM company ─────────────────\n} else if (!hasAnyCurrent && previousPMPositions.length > 0) {\n  const recentPM = previousPMPositions[0];\n  const endDateText = recentPM.end_date || '';\n  const isRecent = endDateText.includes('2026') || endDateText.includes('2025');\n\n  if (isRecent) {\n    selectedCompany = recentPM;\n    selectionReason = 'recent_pm_company_found';\n  } else {\n    selectionReason = 'no_current_job_found';\n  }\n// ── END CHANGE 1 ──────────────────────────────────────────\n\n} else if (previousPMPositions.length > 0) {\n  selectionReason = 'only_previous_pm_company';\n} else {\n  selectionReason = 'no_pm_company_in_history';\n}\n\n// ── EXTRACT DOMAIN FROM EXISTING EMAIL ────────────────────\nconst PERSONAL_DOMAINS = [\n  'gmail.com', 'yahoo.com', 'hotmail.com', 'outlook.com',\n  'icloud.com', 'live.com', 'msn.com', 'aol.com',\n  'mail.com', 'protonmail.com', 'zoho.com'\n];\n\nconst existingEmail = item['Business Email Address'] || '';\nlet existingEmailDomain = null;\n\nif (existingEmail && existingEmail.includes('@')) {\n  const emailDomain = existingEmail.split('@')[1]?.toLowerCase().trim();\n  if (emailDomain &&\n      !PERSONAL_DOMAINS.includes(emailDomain) &&\n      emailDomain.includes('.') &&\n      emailDomain.length > 4) {\n    existingEmailDomain = emailDomain;\n  }\n}\n\n// ── PIPELINE FLAGS ────────────────────────────────────────\nconst proceedToZeroBounce = !!apifyEmail;\n\n// ── CHANGE 2 — Include recent PM company ──────────────────\nconst proceedToProspeo = !apifyEmail && (\n  selectionReason === 'current_pm_company_found' ||\n  selectionReason === 'recent_pm_company_found'\n);\n// ── END CHANGE 2 ──────────────────────────────────────────\n\n// Skip SerpAPI if domain already known from existing email\nconst proceedToSerp = proceedToProspeo && !existingEmailDomain;\nconst proceedToProspeoDirectly = proceedToProspeo && !!existingEmailDomain;\n\n// ── ENRICHMENT STATUS ─────────────────────────────────────\nlet enrichmentStatus = 'linkedin_only';\nlet enrichmentNote = '';\n\nif (apifyEmail) {\n  enrichmentStatus = 'email_found_by_apify';\n  enrichmentNote = `Apify found business email: ${apifyEmail}`;\n} else if (apifyPersonalEmail) {\n  enrichmentNote = `Apify found personal email only: ${apifyPersonalEmail}`;\n}\n\nif (!apifyEmail) {\n  if (selectionReason === 'current_pm_company_found') {\n    enrichmentStatus = 'company_found_proceed_to_prospeo';\n    enrichmentNote += ` | Company: ${selectedCompany.company_name} | Role: ${selectedCompany.job_title}`;\n  } else if (selectionReason === 'recent_pm_company_found') {\n    enrichmentStatus = 'company_found_proceed_to_prospeo';\n    enrichmentNote += ` | Recent PM company: ${selectedCompany.company_name} | Left: ${selectedCompany.end_date}`;\n  } else if (selectionReason === 'only_previous_pm_company') {\n    enrichmentStatus = 'linkedin_only';\n    enrichmentNote += ` | Previous PM only: ${previousPMPositions[0]?.company_name} — email dead`;\n  } else if (selectionReason === 'no_current_job_found') {\n    enrichmentStatus = 'linkedin_only';\n    enrichmentNote += ' | No current job and no recent PM company';\n  } else {\n    enrichmentStatus = 'linkedin_only';\n    enrichmentNote += ' | No PM company in work history';\n  }\n}\n\nreturn {\n  ...item,\n\n  // Email\n  apify_email: apifyEmail,\n  apify_personal_email: apifyPersonalEmail,\n\n  // Company\n  company_name: selectedCompany?.company_name || null,\n  company_name_clean: selectedCompany?.company_name_clean || null,\n  job_title: selectedCompany?.job_title || null,\n  company_linkedin_url: selectedCompany?.company_linkedin_url || null,\n  company_is_current: selectedCompany?.is_current || false,\n  company_is_pm_related: !!(selectedCompany && selectedCompany.score > 0),\n  has_linkedin_company_page: !!(selectedCompany?.company_linkedin_url),\n\n  // Existing email domain\n  existing_email_domain: existingEmailDomain,\n\n  // Pipeline flags\n  proceed_to_zerobounce: proceedToZeroBounce,\n  proceed_to_prospeo: proceedToProspeo,\n  proceed_to_serp: proceedToSerp,\n  proceed_to_prospeo_directly: proceedToProspeoDirectly,\n  selection_reason: selectionReason,\n  enrichment_status: enrichmentStatus,\n  enrichment_note: enrichmentNote.trim(),\n\n  // Profile info\n  linkedin_headline: profile.headline || null,\n  linkedin_location: profile.location?.linkedinText || null,\n\n  // Debug\n  total_positions: experience.length,\n  current_pm_count: currentPMPositions.length,\n  previous_pm_count: previousPMPositions.length,\n  all_positions_debug: dedupedPositions.map(p => ({\n    company: p.company_name,\n    title: p.job_title,\n    current: p.is_current,\n    score: p.score\n  }))\n};"},"typeVersion":2},{"id":"b4768178-0952-439b-9c5d-29481bfd55fa","name":"Google Sheets - Save Domain & Company","type":"n8n-nodes-base.googleSheets","position":[3904,4720],"parameters":{"columns":{"value":{"domain":"={{ $json.domain }}","job_title":"={{ $('Parse Linkedin data').item.json.job_title }}","row_number":"={{ $('Limit3').item.json.row_number }}","apify_email":"={{ $('Parse Linkedin data').item.json.apify_email }}","apify_status":"={{ $('Parse Linkedin data').item.json.enrichment_status }}","company_name":"={{ $('Parse Linkedin data').item.json.company_name }}","domain_method":"={{ $json.domain_method }}","domain_status":"={{ $json.enrichment_status }}","domain_source_url":"={{ $json.domain_source_url }}","linkedin_headline":"={{ $('Parse Linkedin data').item.json.linkedin_headline }}","linkedin_location":"={{ $('Parse Linkedin data').item.json.linkedin_location }}","proceed_to_prospeo":"={{ $('Parse Linkedin data').item.json.proceed_to_prospeo }}","company_linkedin_url":"={{ $('Parse Linkedin data').item.json.company_linkedin_url }}","proceed_to_zerobounce":"={{ $('Parse Linkedin data').item.json.proceed_to_zerobounce }}"},"schema":[{"id":"Complete legal name","type":"string","display":true,"required":false,"displayName":"Complete legal name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"First Name","type":"string","display":true,"required":false,"displayName":"First Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Last Name","type":"string","display":true,"required":false,"displayName":"Last Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Licensed as","type":"string","display":true,"required":false,"displayName":"Licensed as","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Employer Name","type":"string","display":true,"required":false,"displayName":"Employer Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Principal Condominium Manager","type":"string","display":true,"required":false,"displayName":"Principal Condominium Manager","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Business Address","type":"string","display":true,"required":false,"displayName":"Business Address","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Business Email Address","type":"string","display":true,"required":false,"displayName":"Business Email Address","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Business Phone Number","type":"string","display":true,"required":false,"displayName":"Business Phone Number","defaultMatch":false,"canBeUsedToMatch":true},{"id":"serp_url","type":"string","display":true,"required":false,"displayName":"serp_url","defaultMatch":false,"canBeUsedToMatch":true},{"id":"is_linkedin","type":"string","display":true,"required":false,"displayName":"is_linkedin","defaultMatch":false,"canBeUsedToMatch":true},{"id":"confidence","type":"string","display":true,"required":false,"displayName":"confidence","defaultMatch":false,"canBeUsedToMatch":true},{"id":"enrichment_status","type":"string","display":true,"required":false,"displayName":"enrichment_status","defaultMatch":false,"canBeUsedToMatch":true},{"id":"ai_reason","type":"string","display":true,"required":false,"displayName":"ai_reason","defaultMatch":false,"canBeUsedToMatch":true},{"id":"job_title","type":"string","display":true,"required":false,"displayName":"job_title","defaultMatch":false,"canBeUsedToMatch":true},{"id":"company_name","type":"string","display":true,"required":false,"displayName":"company_name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"company_linkedin_url","type":"string","display":true,"required":false,"displayName":"company_linkedin_url","defaultMatch":false,"canBeUsedToMatch":true},{"id":"linkedin_headline","type":"string","display":true,"required":false,"displayName":"linkedin_headline","defaultMatch":false,"canBeUsedToMatch":true},{"id":"linkedin_location","type":"string","display":true,"required":false,"displayName":"linkedin_location","defaultMatch":false,"canBeUsedToMatch":true},{"id":"apify_email","type":"string","display":true,"required":false,"displayName":"apify_email","defaultMatch":false,"canBeUsedToMatch":true},{"id":"domain","type":"string","display":true,"required":false,"displayName":"domain","defaultMatch":false,"canBeUsedToMatch":true},{"id":"domain_source_url","type":"string","display":true,"required":false,"displayName":"domain_source_url","defaultMatch":false,"canBeUsedToMatch":true},{"id":"domain_method","type":"string","display":true,"required":false,"displayName":"domain_method","defaultMatch":false,"canBeUsedToMatch":true},{"id":"apify_status","type":"string","display":true,"required":false,"displayName":"apify_status","defaultMatch":false,"canBeUsedToMatch":true},{"id":"domain_status","type":"string","display":true,"required":false,"displayName":"domain_status","defaultMatch":false,"canBeUsedToMatch":true},{"id":"proceed_to_zerobounce","type":"string","display":true,"required":false,"displayName":"proceed_to_zerobounce","defaultMatch":false,"canBeUsedToMatch":true},{"id":"proceed_to_prospeo","type":"string","display":true,"required":false,"displayName":"proceed_to_prospeo","defaultMatch":false,"canBeUsedToMatch":true},{"id":"prospeo_email","type":"string","display":true,"required":false,"displayName":"prospeo_email","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Zero bounce email_status","type":"string","display":true,"required":false,"displayName":"Zero bounce email_status","defaultMatch":false,"canBeUsedToMatch":true},{"id":"final_email","type":"string","display":true,"required":false,"displayName":"final_email","defaultMatch":false,"canBeUsedToMatch":true},{"id":"outreach_channel","type":"string","display":true,"required":false,"displayName":"outreach_channel","defaultMatch":false,"canBeUsedToMatch":true},{"id":"row_number","type":"number","display":true,"removed":false,"readOnly":true,"required":false,"displayName":"row_number","defaultMatch":false,"canBeUsedToMatch":true}],"mappingMode":"defineBelow","matchingColumns":["row_number"],"attemptToConvertTypes":false,"convertFieldsToString":false},"options":{},"operation":"update","sheetName":{"__rl":true,"mode":"list","value":1100974956,"cachedResultUrl":"","cachedResultName":"Your Sheet Tab"},"documentId":{"__rl":true,"mode":"list","value":"YOUR_GOOGLE_SHEET_ID","cachedResultUrl":"","cachedResultName":"Your Lead Sheet"}},"credentials":{"googleSheetsOAuth2Api":{"id":"credential-id","name":"Google Sheets account"}},"retryOnFail":true,"typeVersion":4.7},{"id":"1999168e-2abf-418a-867c-646eb9c9412c","name":"When clicking ‘Execute workflow’","type":"n8n-nodes-base.manualTrigger","position":[-368,4608],"parameters":{},"typeVersion":1},{"id":"4579cae0-2669-4d60-a902-572642ee8cff","name":"📖 Setup Guide","type":"n8n-nodes-base.stickyNote","position":[-1072,4368],"parameters":{"width":560,"height":1212,"content":"##  🔍 LinkedIn Lead Enrichment Pipeline\n\nAutomatically enriches a Google Sheets lead list with LinkedIn profile URLs, job titles, company names, and company domains — using SerpAPI for search, Claude for AI validation, and Apify for profile scraping.\n\n---\n\n### 🧰 Required Credentials\n| Service | Purpose |\n|---|---|\n| **Google Sheets OAuth2** | Read & write lead data |\n| **SerpAPI key** | Google search via HTTP Request nodes |\n| **Anthropic API** | AI-powered LinkedIn match validation |\n| **Apify token** | Scrape LinkedIn profile data |\n\n---\n\n### ⚙️ One-Time Setup\n1. **Google Sheets** — connect credential in all Sheet nodes\n2. **SerpAPI** — paste your API key in the 4 SerpAPI nodes (`YOUR_SERPAPI_KEY`)\n3. **Anthropic** — connect your Anthropic credential in the 2 AI nodes\n4. **Apify** — add your Apify token in the Apify node\n5. **Sheet ID** — replace `YOUR_GOOGLE_SHEET_ID` in all Sheet nodes\n6. **Search location** — update the `q` param in SerpAPI nodes to your target region\n7. **AI prompt** — update the system prompt in both AI nodes to match your industry\n\n---\n\n### 📊 Required Sheet Columns\n`First Name` · `Last Name` · `Employer Name` · `enrichment_status` · `serp_url` · `is_linkedin` · `confidence` · `ai_reason` · `job_title` · `company_name` · `domain` \n\n---\n\n### ▶️ Execution Order\nRun **Pipeline 1 → Pipeline 2** in sequence by clicking Execute Workflow.\nAdjust the **Limit** node values to control batch size per run.\n"},"typeVersion":1},{"id":"4ba8b55c-ea3d-4bf7-9478-fbc3aabf0bc1","name":"🔎 Phase 1 — LinkedIn URL Discovery","type":"n8n-nodes-base.stickyNote","position":[-416,4128],"parameters":{"color":4,"width":2596,"height":684,"content":"## 🔎 Phase 1 — LinkedIn URL Discovery\n\n**Trigger:** Manual (click Execute Workflow)\n\n**How it works:**\n1. Reads unenriched leads from Google Sheets (`enrichment_status` is blank)\n2. Limits batch size to avoid API overload\n3. Searches Google via SerpAPI: `First Name + Last Name + Location + site:linkedin.com`\n4. Filters and cleans results — removes social media, real estate directories, and unrelated domains\n5. Claude AI validates each result against the target industry profile\n6. Saves the matched LinkedIn URL, confidence score, and AI reason back to the sheet\n\n**Output fields written:** `serp_url` · `is_linkedin` · `confidence` · `ai_reason` · `enrichment_status`\n\n\n"},"typeVersion":1},{"id":"b4dabaec-b1cd-4253-9192-f1e72b864a6f","name":"🔁 Phase 2 — Second Pass (Employer Search)","type":"n8n-nodes-base.stickyNote","position":[-416,4896],"parameters":{"color":2,"width":2592,"height":784,"content":"## 🔁 Phase 2 — Second Pass (Employer Search)\n\n**Trigger:** Runs automatically after Phase 1\n\n**When:** Only processes leads where Phase 1 returned no results\n\n**How it works:**\n1. Reads leads where `enrichment_status` is not yet `linkedin_found`\n2. Filters to records beyond a row threshold (avoids reprocessing)\n3. Uses a more targeted SerpAPI query: `First Name + Last Name + Employer Name + site:linkedin.com`\n4. Same clean/filter/AI-validate pipeline as Phase 1\n5. Confirmed LinkedIn matches flow to Phase 3; all results written back to sheet\n\n\n"},"typeVersion":1},{"id":"85340c1e-3dde-4866-ae74-5f1fb30f8ae3","name":"🤖 AI Validation — Customise for Your Industry","type":"n8n-nodes-base.stickyNote","position":[1184,4160],"parameters":{"color":3,"width":640,"height":440,"content":"## 🤖 AI Validation\n\nUses **Claude Haiku** to validate each search result.\n\n**The model checks:**\n- Does the LinkedIn headline match the target industry?\n- Is the name a plausible match?\n- Is confidence high or medium enough to accept?\n\n**To adapt for your use case**, update the `system` prompt in both AI nodes:\n- Replace job titles (e.g. `property manager` → `software engineer`)\n- Replace industry keywords and reject conditions\n- Adjust location references to match your region\n\nLow-confidence matches are automatically discarded — a blank result is better than a wrong one.\n"},"typeVersion":1},{"id":"1328212f-1f55-47cc-84bb-8e88a90300d3","name":"🚀 Phase 3 — Profile Scrape & Domain Extraction","type":"n8n-nodes-base.stickyNote","position":[2304,4128],"parameters":{"color":7,"width":1808,"height":1060,"content":"## 🚀 Phase 3 — Profile Scrape & Domain Extraction\n\n**Trigger:** Reads leads where `is_linkedin = true` \n\n**How it works:**\n1. Filters confirmed LinkedIn leads ready for scraping\n2. Processes in batches using Split In Batches with a rate-limit Wait (avoids Apify throttling)\n3. **Apify** scrapes the LinkedIn profile — extracts job title, company name, company LinkedIn URL, headline, location, and any visible email\n4. Selects the most relevant current employer from work history\n5. **SerpAPI** searches for the company's official website domain\n6. Extracts and validates the domain via a Code node\n7. Writes all enriched fields back to the sheet\n\n**Output fields written:** `job_title` · `company_name` · `company_linkedin_url` · `linkedin_headline` · `linkedin_location` · `apify_email` · `domain` · `domain_source_url` · `domain_method` · `apify_status` · `domain_status`\n\n> ⚠️ Apify scraping consumes Apify credits. Keep batch sizes small (≤50) to control costs.\n"},"typeVersion":1}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","executionOrder":"v1"},"versionId":"d7becea2-c238-4335-8e52-4dfc33e14a94","nodeGroups":[],"connections":{"Rate Limit Wait":{"main":[[{"node":"Apify - Scrape LinkedIn Profile","type":"main","index":0}]]},"Batch Size Limit":{"main":[[{"node":"SerpAPI - Find LinkedIn URL","type":"main","index":0}]]},"Prepare AI Input":{"main":[[{"node":"Rate Limit Wait (AI)","type":"main","index":0}]]},"Parse AI Response":{"main":[[{"node":"Google Sheets - Save LinkedIn URL","type":"main","index":0}]]},"Process Each Lead":{"main":[[],[{"node":"Rate Limit Wait","type":"main","index":0}]]},"Has Search Results?":{"main":[[{"node":"Prepare AI Input","type":"main","index":0}]]},"Rate Limit Wait (AI)":{"main":[[{"node":"AI - Validate LinkedIn Match","type":"main","index":0}]]},"Prepare Domain Search":{"main":[[{"node":"Extract Company Domain","type":"main","index":0}]]},"Extract Company Domain":{"main":[[{"node":"Google Sheets - Save Domain & Company","type":"main","index":0},{"node":"Process Each Lead","type":"main","index":0}]]},"Filter Ready for Apify":{"main":[[{"node":"Batch Size Limit (Pipeline 2)","type":"main","index":0}]]},"Rate Limit Wait (Pass 3)":{"main":[[{"node":"AI - Validate LinkedIn Match (Pass 2)","type":"main","index":0}]]},"Batch Size Limit (Pass 2)":{"main":[[{"node":"SerpAPI - Find LinkedIn URL (Pass 2)","type":"main","index":0}]]},"Prepare AI Input (Pass 2)":{"main":[[{"node":"Rate Limit Wait (Pass 3)","type":"main","index":0}]]},"Filter Unprocessed Records":{"main":[[{"node":"Batch Size Limit (Pass 2)","type":"main","index":0}]]},"Parse AI Response (Pass 2)":{"main":[[{"node":"Filter LinkedIn Found","type":"main","index":0},{"node":"Google Sheets - Save Results (Pass 2)","type":"main","index":0}]]},"SerpAPI - Find LinkedIn URL":{"main":[[{"node":"Filter & Clean Search Results","type":"main","index":0}]]},"AI - Validate LinkedIn Match":{"main":[[{"node":"Parse AI Response","type":"main","index":0}]]},"Has Search Results? (Pass 2)":{"main":[[{"node":"Prepare AI Input (Pass 2)","type":"main","index":0}]]},"Batch Size Limit (Pipeline 2)":{"main":[[{"node":"Process Each Lead","type":"main","index":0}]]},"Filter & Clean Search Results":{"main":[[{"node":"Has Search Results?","type":"main","index":0}]]},"SerpAPI - Find Company Domain":{"main":[[{"node":"Prepare Domain Search","type":"main","index":0}]]},"Apify - Scrape LinkedIn Profile":{"main":[[{"node":"Parse LinkedIn & Select Company","type":"main","index":0}]]},"Filter & Clean Results (Pass 2)":{"main":[[{"node":"Has Search Results? (Pass 2)","type":"main","index":0}]]},"Parse LinkedIn & Select Company":{"main":[[{"node":"SerpAPI - Find Company Domain","type":"main","index":0}]]},"Google Sheets - Read No-Result Leads":{"main":[[{"node":"Filter Unprocessed Records","type":"main","index":0}]]},"SerpAPI - Find LinkedIn URL (Pass 2)":{"main":[[{"node":"Filter & Clean Results (Pass 2)","type":"main","index":0}]]},"When clicking ‘Execute workflow’":{"main":[[{"node":"Google Sheets - Read Leads (Pipeline 1)","type":"main","index":0}]]},"AI - Validate LinkedIn Match (Pass 2)":{"main":[[{"node":"Parse AI Response (Pass 2)","type":"main","index":0}]]},"Google Sheets - Read Leads (Pipeline 1)":{"main":[[{"node":"Batch Size Limit","type":"main","index":0}]]},"Google Sheets - Read Leads (Pipeline 2)":{"main":[[{"node":"Filter Ready for Apify","type":"main","index":0}]]}}}