ing","display":true,"required":false,"displayName":"approved_by","defaultMatch":false,"canBeUsedToMatch":true},{"id":"approved_at","type":"string","display":true,"required":false,"displayName":"approved_at","defaultMatch":false,"canBeUsedToMatch":true},{"id":"sent_at","type":"string","display":true,"required":false,"displayName":"sent_at","defaultMatch":false,"canBeUsedToMatch":true},{"id":"row_number","type":"number","display":true,"removed":false,"readOnly":true,"required":false,"displayName":"row_number","defaultMatch":false,"canBeUsedToMatch":true}],"mappingMode":"defineBelow","matchingColumns":["ticket_id"],"attemptToConvertTypes":false,"convertFieldsToString":false},"options":{},"operation":"update","sheetName":{"__rl":true,"mode":"list","value":"YOUR_SHEET_TAB_ID","cachedResultUrl":"https://docs.google.com/spreadsheets/d/YOUR_GOOGLE_SHEET_ID/edit#gid=YOUR_SHEET_TAB_ID","cachedResultName":"YOUR_SHEET_TAB_NAME"},"documentId":{"__rl":true,"mode":"list","value":"YOUR_GOOGLE_SHEET_ID","cachedResultUrl":"https://docs.google.com/spreadsheets/d/YOUR_GOOGLE_SHEET_ID/edit","cachedResultName":"YOUR_GOOGLE_SHEET_NAME"}},"credentials":{"googleSheetsOAuth2Api":{"id":"GOOGLE_SHEETS_OAUTH2_CREDENTIAL_ID_PLACEHOLDER","name":"GOOGLE_SHEETS_OAUTH2_CREDENTIAL_NAME_PLACEHOLDER"}},"typeVersion":4.7},{"id":"24f6097b-03c0-4847-b7b8-dc1d00312ac7","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[-368,-496],"parameters":{"color":5,"width":320,"height":352,"content":"## Slack Button Webhook\n\nReceives Slack button clicks.\n\nSlack Interactivity Request URL should point to this workflow’s production webhook.\n\nUse production URL when active:\n.../webhook/support-approval"},"typeVersion":1},{"id":"bcf50853-aa21-44a9-a05c-9d7fbe904fb4","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[-16,-496],"parameters":{"color":5,"width":320,"height":352,"content":"## Parse Slack Action\n\nExtracts the reviewer decision from Slack.\n\nOutputs:\n- ticket_id\n- decision\n- clicked_by_name\n- slack_channel\n- slack_message_ts\n\nButton value format:\nticket_id|decision"},"typeVersion":1},{"id":"fdae237d-f4d7-400c-b598-e438ae080f78","name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[336,-432],"parameters":{"color":5,"width":320,"height":288,"content":"## Parse Slack Action\n\nFinds the matching ticket in Google Sheets using ticket_id & relevant column"},"typeVersion":1},{"id":"a38ce5e2-93f5-4951-899b-60fdfe32897c","name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[688,-496],"parameters":{"color":5,"width":336,"height":368,"content":"## Prepare Ticket Context\n\nCombines Google Sheets ticket data with Slack reviewer data.\n\nCreates shared fields used by all decision paths:\n- reply_to_send\n- reviewed_by\n- reviewed_at\n- slack_channel\n- slack_message_ts"},"typeVersion":1},{"id":"b06f3e4c-d699-4657-896e-3ccfe532b31f","name":"Sticky Note4","type":"n8n-nodes-base.stickyNote","position":[1040,-496],"parameters":{"width":336,"height":368,"content":"## Route Decision\n\nRoutes based on the Slack button clicked.\n\napprove → send reply\nneeds_edit → mark for editing\nreject → reject AI draft\n\nOnly approve sends an email."},"typeVersion":1},{"id":"a6b3b0a5-d76c-4ed4-a355-83bfd1c1b078","name":"Sticky Note5","type":"n8n-nodes-base.stickyNote","position":[1632,-1360],"parameters":{"color":6,"width":496,"height":208,"content":"## Approve Path\n\nReviewer approved the AI draft.\n\nActions:\n1. Send Gmail reply\n2. Mark ticket as Sent\n3. Update original Slack message\n\nCustomer receives the email only in this path."},"typeVersion":1},{"id":"f9c518e0-fae8-4acd-8093-1c27246ebcc3","name":"Sticky Note6","type":"n8n-nodes-base.stickyNote","position":[1616,-1088],"parameters":{"width":256,"height":384,"content":"## Send Gmail Reply\n\nSends the approved final_reply to the customer.\n\nUses:\n- customer_email\n- subject\n- reply_to_send\n\nThis node runs only after Slack approval."},"typeVersion":1},{"id":"73e09271-e622-4060-9cd9-592fab452b97","name":"Sticky Note7","type":"n8n-nodes-base.stickyNote","position":[1888,-1088],"parameters":{"width":256,"height":384,"content":"## Update Ticket as Sent\n\nUpdates the Google Sheet after the Gmail reply is sent.\n\nSets:\n- status = Sent\n- approved_by\n- approved_at\n- sent_at"},"typeVersion":1},{"id":"df059b2f-8d62-4ee3-b3bf-bb58d86db3cf","name":"Sticky Note8","type":"n8n-nodes-base.stickyNote","position":[2160,-1088],"parameters":{"width":400,"height":384,"content":"## Update Slack: Approved\n\nUpdates the original Slack message using chat.update.\n\nShows:\n- Approved and sent\n- ticket_id\n- approver\n- sent reply summary\n\nThis removes the approval buttons."},"typeVersion":1},{"id":"66a32a47-2224-4792-b18e-e969e5d31c50","name":"Sticky Note9","type":"n8n-nodes-base.stickyNote","position":[1616,-672],"parameters":{"color":2,"width":496,"height":208,"content":"## Needs Edit Path\n\nReviewer wants to revise the AI draft.\n\nNo email is sent.\n\nThe ticket is marked Needs Edit so a human can update final_reply in Google Sheets."},"typeVersion":1},{"id":"d6bde331-1124-4a07-9c54-db4177290e29","name":"Sticky Note10","type":"n8n-nodes-base.stickyNote","position":[1616,-432],"parameters":{"width":256,"height":432,"content":"## Update Ticket as Needs Edit\n\nUpdates Google Sheets when the reviewer requests edits.\n\nSets:\n- status = Needs Edit\n- reviewer_notes\n- approved_by / reviewed_by\n- approved_at / reviewed_at"},"typeVersion":1},{"id":"8322d0dc-7c20-4026-9957-3af489415a16","name":"Sticky Note11","type":"n8n-nodes-base.stickyNote","position":[1904,-336],"parameters":{"width":400,"height":336,"content":"## Update Slack: Needs Edit\n\nUpdates the original Slack message.\n\nShows that the ticket needs editing and reminds the reviewer to update final_reply in Google Sheets.\n\nButtons are removed."},"typeVersion":1},{"id":"05378b21-bcf4-44f7-9000-4694213fadda","name":"Sticky Note12","type":"n8n-nodes-base.stickyNote","position":[1616,32],"parameters":{"color":3,"width":496,"height":208,"content":"## Reject Path\n\nReviewer rejects the AI draft.\n\nNo email is sent.\n\nUse this when the AI response is wrong, risky, irrelevant, or should be handled manually."},"typeVersion":1},{"id":"de7dbe0f-4883-4fc7-be2b-5da210ab712a","name":"Sticky Note13","type":"n8n-nodes-base.stickyNote","position":[1616,272],"parameters":{"width":256,"height":432,"content":"## Update Ticket as Rejected\n\nUpdates Google Sheets when the AI draft is rejected.\n\nSets:\n- status = Rejected\n- reviewer_notes\n- approved_by / reviewed_by\n- approved_at / reviewed_at"},"typeVersion":1},{"id":"d1928fe9-4e1d-49bb-a9ab-23cc0ae51927","name":"Sticky Note14","type":"n8n-nodes-base.stickyNote","position":[1904,400],"parameters":{"width":400,"height":304,"content":"## Update Slack: Rejected\n\nUpdates the original Slack message to show rejection.\n\nConfirms no email was sent and removes the buttons."},"typeVersion":1},{"id":"af58775e-f84b-4916-93f7-cfe5f94fa40d","name":"Sticky Note15","type":"n8n-nodes-base.stickyNote","position":[-368,-944],"parameters":{"color":5,"width":592,"content":"## Safety\n\nOnly the Approve path sends a customer email.\n\nNeeds Edit and Reject never send Gmail replies.\n\nThis keeps the AI human-in-the-loop and prevents unsafe automatic responses."},"typeVersion":1},{"id":"3b679914-9037-4efc-a58f-dea834b1b8b3","name":"Sticky Note16","type":"n8n-nodes-base.stickyNote","position":[-368,-1488],"parameters":{"color":5,"width":592,"height":224,"content":"## Support Approval Button Handler\n\nThis workflow handles the human decision after the AI triage workflow posts a Slack approval message.\n\nWhen a reviewer clicks Approve, Needs Edit, or Reject in Slack, this workflow receives the button event, finds the matching ticket in Google Sheets, and updates the ticket based on the reviewer’s decision.\n\nOnly the Approve path sends a Gmail reply to the customer.\nNeeds Edit and Reject never send emails."},"typeVersion":1},{"id":"09cbe7d9-b06f-48b2-9942-181d481ccc7e","name":"Sticky Note17","type":"n8n-nodes-base.stickyNote","position":[-368,-1248],"parameters":{"color":5,"width":592,"height":288,"content":"## Workflow Steps\n\n1. Receive Slack button click through Webhook.\n2. Parse the Slack action to get ticket_id and decision.\n3. Look up the matching ticket in Google Sheets.\n4. Prepare shared ticket and reviewer context.\n5. Route the decision:\n   - Approve → send Gmail reply, mark Sent, update Slack.\n   - Needs Edit → mark Needs Edit, update Slack.\n   - Reject → mark Rejected, update Slack.\n6. Update the original Slack message and remove the buttons."},"typeVersion":1}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","executionOrder":"v1"},"versionId":"WORKFLOW_VERSION_ID_PLACEHOLDER","connections":{"Slack Trigger":{"main":[[{"node":"Parse Slack Approval Action","type":"main","index":0}]]},"Lookup Tickets":{"main":[[{"node":"Prepare Ticket Decision Context","type":"main","index":0}]]},"Reply to a message":{"main":[[{"node":"Update Sheet: Approved","type":"main","index":0}]]},"Update Sheet: Approved":{"main":[[{"node":"Slack: Update Approved","type":"main","index":0}]]},"Update Sheet: Rejected":{"main":[[{"node":"Slack: Update Rejected Message","type":"main","index":0}]]},"Route Approval Decision":{"main":[[{"node":"Reply to a message","type":"main","index":0}],[{"node":"Update Sheet: Needs Edit","type":"main","index":0}],[{"node":"Update Sheet: Rejected","type":"main","index":0}]]},"Update Sheet: Needs Edit":{"main":[[{"node":"Slack: Update Needs Edit Message","type":"main","index":0}]]},"Parse Slack Approval Action":{"main":[[{"node":"Lookup Tickets","type":"main","index":0}]]},"Prepare Ticket Decision Context":{"main":[[{"node":"Route Approval Decision","type":"main","index":0}]]}}}