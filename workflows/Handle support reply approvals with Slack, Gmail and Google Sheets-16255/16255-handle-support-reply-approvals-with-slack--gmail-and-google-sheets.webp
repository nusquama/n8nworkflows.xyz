{"id":"WORKFLOW_ID_PLACEHOLDER","meta":{"instanceId":"N8N_INSTANCE_ID_PLACEHOLDER","templateCredsSetupCompleted":true},"name":"Support Approval Button Handler","tags":[],"nodes":[{"id":"c804ca8e-7514-4dff-8e50-46e50f6730e1","name":"Parse Slack Approval Action","type":"n8n-nodes-base.code","position":[160,-304],"parameters":{"jsCode":"const input = $input.first().json;\n\n// Slack usually sends interactive payload as form field: payload\nlet payloadRaw =\n  input.body?.payload ||\n  input.payload ||\n  input.body;\n\nlet payload;\n\ntry {\n  payload = typeof payloadRaw === 'string'\n    ? JSON.parse(payloadRaw)\n    : payloadRaw;\n} catch (error) {\n  throw new Error(`Could not parse Slack payload: ${error.message}`);\n}\n\nconst clickedAction = payload.actions?.[0];\n\nif (!clickedAction?.value) {\n  throw new Error('No Slack action value found.');\n}\n\nconst [ticket_id, decision] = clickedAction.value.split('|');\n\nreturn [\n  {\n    json: {\n      ticket_id,\n      decision,\n      action_id: clickedAction.action_id,\n      clicked_by_id: payload.user?.id || '',\n      clicked_by_name: payload.user?.username || payload.user?.name || '',\n      slack_channel: payload.channel?.id || '',\n      slack_message_ts: payload.message?.ts || '',\n      response_url: payload.response_url || '',\n      original_message_text: payload.message?.text || ''\n    }\n  }\n];"},"typeVersion":2},{"id":"4d158faf-433d-46ba-bf9b-23869b9a92a4","name":"Route Approval Decision","type":"n8n-nodes-base.switch","position":[1168,-320],"parameters":{"rules":{"values":[{"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"2965871a-5ddc-4f47-b69a-e90ec958f6dd","operator":{"type":"string","operation":"equals"},"leftValue":"={{ $json.decision }}","rightValue":"approve"}]}},{"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"