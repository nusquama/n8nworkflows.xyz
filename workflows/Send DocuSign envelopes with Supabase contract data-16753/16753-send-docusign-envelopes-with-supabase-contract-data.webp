{"name":"DocuSign Send Envelope (Part 1 of 2)","nodes":[{"name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[-1584,-688],"parameters":{"width":480,"height":624,"content":"## DocuSign Send Envelope (PROD)\n\n### How it works\n\n1. Triggered when executed by another workflow.\n2. Fetches assessment data from Supabase.\n3. Builds and encodes contract HTML.\n4. Decides on environment and builds JWT.\n5. Obtains DocuSign access token and creates an envelope.\n6. Updates status back in Supabase.\n\n### Setup steps\n\n- [ ] Ensure Supabase credentials are configured.\n- [ ] Configure DocuSign API keys for both production and sandbox environments.\n- [ ] Set up triggers to call this workflow from others.\n\n### Customization\n\nModify the code nodes to adjust the format of the contract HTML if needed."},"typeVersion":1},{"name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[-1024,-656],"parameters":{"color":7,"width":384,"height":336,"content":"## Trigger and fetch assessment\n\nStarts the workflow on execution by another workflow and fetches assessment data from Supabase."},"typeVersion":1},{"name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[-576,-624],"parameters":{"color":7,"width":384,"height":304,"content":"## Build and encode contract\n\nBuilds the contract HTML and encodes it for further processing."},"typeVersion":1},{"name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[-128,-688],"parameters":{"color":7,"height":368,"content":"## Environment decision branch\n\nDetermines whether to proceed in a sandbox or production environment."},"typeVersion":1},{"name":"Sticky Note4","type":"n8n-nodes-base.stickyNote","position":[176,-688],"parameters":{"color":7,"width":608,"height":304,"content":"## DocuSign envelope - Production\n\nHandles creation of DocuSign envelope in the production environment."},"typeVersion":1},{"name":"Sticky Note5","type":"n8n-nodes-base.stickyNote","position":[176,-352],"parameters":{"color":7,"width":608,"height":288,"content":"## DocuSign envelope - Sandbox\n\nHandles creation of DocuSign envelope in the sandbox environment."},"typeVersion":1},{"name":"Sticky Note6","type":"n8n-nodes-base.stickyNote","position":[848,-688],"parameters":{"color":7,"height":384,"content":"## Final update to Supabase\n\nUpdates the final status back to the Supabase, irrespective of environment used."},"typeVersion":1},{"name":"Triggered by Another Workflow","type":"n8n-nodes-base.executeWorkflowTrigger","position":[-976,-496],"parameters":{"workflowInputs":{"values":[{"name":"id"},{"name":"contract_title"}]}},"typeVersion":1.1},{"name":"Post to DocuSign JWT API","type":"n8n-nodes-base.httpRequest","position":[224,-560],"parameters":{"url":"https://YOUR-PROJECT.supabase.co/functions/v1/docusign-sign-jwt","method":"POST","options":{},"jsonBody":"={\n  \"environment\": \"prod\",\n  \"integration_key\": \"{{ $vars.DOCUSIGN_PROD_INTEGRATION_KEY }}\",\n  \"user_id\": \"{{ $vars.DOCUSIGN_PROD_USER_ID }}\"\n}","sendBody":true,"sendHeaders":true,"specifyBody":"json","authentication":"predefinedCredentialType","headerParameters":{"parameters":[{"name":"Content-Type","value":"application/json"}]},"nodeCredentialType":"supabaseApi"},"typeVersion":4.4},{"name":"Post for DocuSign Access Token","type":"n8n-nodes-base.httpRequest","position":[432,-560],"parameters":{"url":"https://account.docusign.com/oauth/token","method":"POST","options":{},"sendBody":true,"contentType":"form-urlencoded","bodyParameters":{"parameters":[{"name":"grant_type","value":"urn:ietf:params:oauth:grant-type:jwt-bearer"},{"name":"assertion","value":"={{$node[\"Post to DocuSign JWT API\"].json.jwt_assertion}}"}]}},"typeVersion":4.4},{"name":"Post to Create DocuSign Envelope","type":"n8n-nodes-base.httpRequest","position":[640,-560],"parameters":{"url":"=https://na4.docusign.net/restapi/v2.1/accounts/{{ $vars.DOCUSIGN_PROD_ACCOUNT_ID }}/envelopes","method":"POST","options":{},"jsonBody":"={\n  \"emailSubject\": \"Your Company Agreement, Please review and sign\",\n  \"status\": \"sent\",\n  \"documents\": [\n    {\n      \"documentBase64\": \"{{ $('Encode Contract HTML').item.json.contract_html_b64 }}\",\n      \"name\": \"Your Company Agreement\",\n      \"fileExtension\": \"html\",\n      \"documentId\": \"1\"\n    }\n  ],\n  \"recipients\": {\n    \"signers\": [\n      {\n        \"email\": \"you@your-domain.com\",\n        \"name\": \"Your Name\",\n        \"recipientId\": \"1\",\n        \"routingOrder\": \"1\",\n        \"tabs\": {\n          \"signHereTabs\": [\n            {\n              \"anchorString\": \"SIGN_HERE\",\n              \"anchorUnits\": \"pixels\",\n              \"anchorXOffset\": \"0\",\n              \"anchorYOffset\": \"0\"\n            }\n          ],\n          \"dateSignedTabs\": [\n            {\n              \"anchorString\": \"SIGN_HERE\",\n              \"anchorUnits\": \"pixels\",\n              \"anchorXOffset\": \"-170\",\n              \"anchorYOffset\": \"-1\"\n            }\n          ]\n        }\n      },\n      {\n        \"email\": \"{{ $('Fetch Assessment from Supabase').item.json.contact_email }}\",\n        \"name\": \"{{ $('Fetch Assessment from Supabase').item.json.contact_name }}\",\n        \"recipientId\": \"2\",\n        \"routingOrder\": \"2\",\n        \"tabs\": {\n          \"signHereTabs\": [\n            {\n              \"anchorString\": \"CLIENT_SIGN_HERE\",\n              \"anchorUnits\": \"pixels\",\n              \"anchorXOffset\": \"0\",\n              \"anchorYOffset\": \"0\"\n            }\n          ],\n          \"dateSignedTabs\": [\n            {\n              \"anchorString\": \"CLIENT_SIGN_HERE\",\n              \"anchorUnits\": \"pixels\",\n              \"anchorXOffset\": \"-170\",\n              \"anchorYOffset\": \"-1\"\n            }\n          ]\n        }\n      }\n    ]\n  }\n}\n","sendBody":true,"sendHeaders":true,"specifyBody":"json","headerParameters":{"parameters":[{"name":"Authorization","value":"=Bearer {{ $('Post for DocuSign Access Token').item.json.access_token }}"},{"name":"Content-Type","value":"application/json"}]}},"typeVersion":4.4},{"name":"Encode Contract HTML","type":"n8n-nodes-base.code","position":[-336,-496],"parameters":{"jsCode":"const j = $input.first().json;\nconst html = j.contract_html ?? \"\";\nconst b64 = Buffer.from(html, \"utf8\").toString(\"base64\");\nreturn [{ json: { ...j, contract_html_b64: b64 } }];"},"typeVersion":2},{"name":"Update in Supabase DB","type":"n8n-nodes-base.supabase","position":[896,-480],"parameters":{"filters":{"conditions":[{"keyName":"id","keyValue":"={{ $('Fetch Assessment from Supabase').item.json.id }}","condition":"eq"}]},"tableId":"assessments","fieldsUi":{"fieldValues":[{"fieldId":"contract_envelope_id","fieldValue":"={{ $json.envelopeId }}"},{"fieldId":"contract_status","fieldValue":"envelope_sent"}]},"matchType":"allFilters","operation":"update"},"typeVersion":1},{"name":"Fetch Assessment from Supabase","type":"n8n-nodes-base.supabase","position":[-784,-496],"parameters":{"limit":1,"filters":{"conditions":[{"keyName":"id","keyValue":"={{ $json.id }}","condition":"eq"}]},"tableId":"assessments","operation":"getAll"},"typeVersion":1},{"name":"Compose Contract HTML Code","type":"n8n-nodes-base.code","position":[-528,-496],"parameters":{"jsCode":"const data = $input.first().json;\n\nconst businessNameUpper = (data.business_name || '').toUpperCase();\nconst contactName = data.contact_name || '';\nconst raw = String(data.contract_text || '').replace(/\\r\\n/g, '\\n');\n\nconst esc = (s) => String(s)\n  .replace(/&/g, '&amp;')\n  .replace(/</g, '&lt;')\n  .replace(/>/g, '&gt;');\n\n// format Retainer / Setup Fee numbers as USD (idempotent)\nconst money = (s) => String(s).replace(\n  /((?:Monthly Retainer|One-Time Setup Fee|Setup Fee|Retainer|Fee)\\s*:\\s*)\\$?\\s*(\\d{3,}(?:,\\d{3})*(?:\\.\\d{1,2})?)/gi,\n  (mm, label, num) => {\n    const n = Number(String(num).replace(/,/g, ''));\n    return isFinite(n) ? label + '$' + n.toLocaleString('en-US') : mm;\n  }\n);\n\n// --- theme tokens (match the proposal PDF) ---\nconst NAVY = '#1B4F8A';\nconst ORANGE = '#F97316';\nconst INK = '#1a1a1a';\nconst SERIF = \"Georgia, 'Times New Roman', serif\";\nconst SANS = \"Arial, Helvetica, sans-serif\";\n\nconst sSection = `font-family:${SANS}; font-size:13.5pt; font-weight:700; color:${NAVY}; border-bottom:2px solid ${ORANGE}; padding-bottom:5px; margin:24px 0 11px 0;`;\nconst sPara = `font-family:${SERIF}; font-size:11pt; line-height:1.5; color:${INK}; margin:0 0 8px 0;`;\nconst sNum = `font-weight:700; color:${INK};`;\nconst sep = `<div style=\"border-top:1px solid ${ORANGE}; margin:20px 0 14px 0;\"></div>`;\n\n// --- parse the plain contract text into tight, styled HTML ---\nconst SEC = /^(\\d+)\\.\\s+(\\S.*)$/;          // \"1. Parties and Effective Date\"\nconst SUB = /^(\\d+(?:\\.\\d+)+)\\s+(\\S.*)$/;  // \"1.1 ...\" / \"2.2.1 ...\"\nconst ALPHA = /^\\(([a-z])\\)\\s+(\\S.*)$/i;   // \"(a) ...\"\n\nlet body = '';\nlet prevDepth = 0;        // dot-count of previous numbered clause (2.2 -> 1, 2.2.1 -> 2)\nlet phaseBreakDone = false;\nfor (const rawLine of raw.split('\\n')) {\n  const t = rawLine.trim();\n  if (!t) continue;                         // collapse blank-line sprawl\n  if (/^(Your Company inc\\.?\\s*)?service agreement$/i.test(t)) continue; // drop stray title\n  let m;\n  if ((m = t.match(SUB))) {\n    const num = m[1];\n    const depth = (num.match(/\\./g) || []).length;\n    // boundary: a shallower subsection after deeper sub-clauses (e.g., 2.3 after 2.2.x)\n    if (depth === 1 && prevDepth >= 2) body += sep;\n    // boundary: first \"Implementation Phase ...\" clause inside the deliverables\n    if (!phaseBreakDone && /^Implementation Phase\\b/i.test(m[2])) { body += sep; phaseBreakDone = true; }\n    body += `<p style=\"${sPara}\"><span style=\"${sNum}\">${esc(num)}</span> ${esc(money(m[2]))}</p>`;\n    prevDepth = depth;\n  } else if ((m = t.match(SEC))) {\n    body += `<h2 style=\"${sSection}\">${esc(m[1])}. ${esc(m[2])}</h2>`;\n    prevDepth = 0; phaseBreakDone = false;  // reset per top-level section\n  } else if ((m = t.match(ALPHA))) {\n    body += `<p style=\"${sPara} margin-left:22px;\"><span style=\"${sNum}\">(${esc(m[1])})</span> ${esc(money(m[2]))}</p>`;\n  } else {\n    body += `<p style=\"${sPara}\">${esc(money(t))}</p>`;\n  }\n}\n\nconst html = `\n<html>\n  <body style=\"font-family:${SERIF}; font-size:11pt; line-height:1.5; color:${INK};\">\n\n    <div style=\"height:4px; background:${NAVY}; margin:0 0 16px 0;\"></div>\n    <div style=\"font-family:${SANS}; font-size:9pt; font-weight:700; letter-spacing:0.16em; text-transform:uppercase; color:${ORANGE}; margin:0 0 4px 0;\">Your Company Inc.</div>\n    <div style=\"font-family:${SANS}; font-size:21pt; font-weight:700; color:${NAVY}; margin:0 0 6px 0;\">Service Agreement</div>\n    <div style=\"width:64px; height:3px; background:${ORANGE}; margin:0 0 22px 0;\"></div>\n\n    ${body}\n\n    <hr style=\"border:none; border-top:1px solid #ddd; margin:34px 0 26px 0;\" />\n\n    <div style=\"page-break-inside: avoid; margin-top: 20px; font-family: Verdana, Tahoma, Arial, sans-serif; font-size:14pt; line-height:1.6; color:#000000;\">\n\n      <div style=\"text-align:center; font-weight:700; letter-spacing:0.5px; margin-bottom:10px;\">\n        YOUR COMPANY INC.\n      </div>\n\n      <table style=\"width:100%; margin-bottom:40px; border-collapse:collapse;\">\n        <tr>\n          <td style=\"width:50%; padding:8px 0;\">\n            Date: ____________________\n          </td>\n          <td style=\"width:50%; padding:8px 0;\">\n            By:\n            <div style=\"margin-top:6px;\">\n              <span style=\"font-size:12pt; color:#FFFFFF;\">SIGN_HERE</span>\n            </div>\n            <div style=\"font-size:12pt; margin-top:6px;\">\n              Your Name, President\n            </div>\n          </td>\n        </tr>\n      </table>\n\n      <div style=\"text-align:center; font-style:italic; margin-bottom:10px;\">\n        ${businessNameUpper}\n      </div>\n\n      <table style=\"width:100%; border-collapse:collapse;\">\n        <tr>\n          <td style=\"width:50%; padding:8px 0;\">\n            Date: ____________________\n          </td>\n          <td style=\"width:50%; padding:8px 0;\">\n            By:\n            <div style=\"margin-top:6px;\">\n              <span style=\"font-size:12pt; color:#FFFFFF;\">CLIENT_SIGN_HERE</span>\n            </div>\n            <div style=\"font-size:12pt; margin-top:6px;\">\n              ${contactName}\n            </div>\n          </td>\n        </tr>\n      </table>\n\n    </div>\n\n  </body>\n</html>\n`;\n\nreturn [{ json: { contract_html: html } }];"},"typeVersion":2},{"name":"Post to DocuSign JWT API (SBX)","type":"n8n-nodes-base.httpRequest","position":[224,-240],"parameters":{"url":"https://YOUR-PROJECT.supabase.co/functions/v1/docusign-sign-jwt","method":"POST","options":{},"jsonBody":"={\n  \"environment\": \"sbx\",\n  \"integration_key\": \"{{ $vars.DOCUSIGN_SBX_INTEGRATION_KEY }}\",\n  \"user_id\": \"{{ $vars.DOCUSIGN_SBX_USER_ID }}\"\n}","sendBody":true,"sendHeaders":true,"specifyBody":"json","authentication":"predefinedCredentialType","headerParameters":{"parameters":[{"name":"Content-Type","value":"application/json"}]},"nodeCredentialType":"supabaseApi"},"typeVersion":4.4},{"name":"Post for DS Access Token (SBX)","type":"n8n-nodes-base.httpRequest","position":[432,-240],"parameters":{"url":"https://account-d.docusign.com/oauth/token","method":"POST","options":{},"sendBody":true,"contentType":"form-urlencoded","bodyParameters":{"parameters":[{"name":"grant_type","value":"urn:ietf:params:oauth:grant-type:jwt-bearer"},{"name":"assertion","value":"={{$node[\"Post to DocuSign JWT API (SBX)\"].json.jwt_assertion}}"}]}},"typeVersion":4.4},{"name":"Post to Create DS Envelope (SBX)","type":"n8n-nodes-base.httpRequest","position":[640,-240],"parameters":{"url":"=https://demo.docusign.net/restapi/v2.1/accounts/{{ $vars.DOCUSIGN_SBX_ACCOUNT_ID }}/envelopes","method":"POST","options":{},"jsonBody":"={\n  \"emailSubject\": \"Your Company Agreement, Please review and sign\",\n  \"status\": \"sent\",\n  \"documents\": [\n    {\n      \"documentBase64\": \"{{ $('Encode Contract HTML').item.json.contract_html_b64 }}\",\n      \"name\": \"Your Company Agreement\",\n      \"fileExtension\": \"html\",\n      \"documentId\": \"1\"\n    }\n  ],\n  \"recipients\": {\n    \"signers\": [\n      {\n        \"email\": \"you@your-domain.com\",\n        \"name\": \"Your Name\",\n        \"recipientId\": \"1\",\n        \"routingOrder\": \"1\",\n        \"tabs\": {\n          \"signHereTabs\": [\n            {\n              \"anchorString\": \"SIGN_HERE\",\n              \"anchorUnits\": \"pixels\",\n              \"anchorXOffset\": \"0\",\n              \"anchorYOffset\": \"0\"\n            }\n          ],\n          \"dateSignedTabs\": [\n            {\n              \"anchorString\": \"SIGN_HERE\",\n              \"anchorUnits\": \"pixels\",\n              \"anchorXOffset\": \"-170\",\n              \"anchorYOffset\": \"-1\"\n            }\n          ]\n        }\n      },\n      {\n        \"email\": \"{{ $('Fetch Assessment from Supabase').item.json.contact_email }}\",\n        \"name\": \"{{ $('Fetch Assessment from Supabase').item.json.contact_name }}\",\n        \"recipientId\": \"2\",\n        \"routingOrder\": \"2\",\n        \"tabs\": {\n          \"signHereTabs\": [\n            {\n              \"anchorString\": \"CLIENT_SIGN_HERE\",\n              \"anchorUnits\": \"pixels\",\n              \"anchorXOffset\": \"0\",\n              \"anchorYOffset\": \"0\"\n            }\n          ],\n          \"dateSignedTabs\": [\n            {\n              \"anchorString\": \"CLIENT_SIGN_HERE\",\n              \"anchorUnits\": \"pixels\",\n              \"anchorXOffset\": \"-170\",\n              \"anchorYOffset\": \"-1\"\n            }\n          ]\n        }\n      }\n    ]\n  }\n}\n","sendBody":true,"sendHeaders":true,"specifyBody":"json","headerParameters":{"parameters":[{"name":"Authorization","value":"=Bearer {{ $('Post for DS Access Token (SBX)').item.json.access_token }}"},{"name":"Content-Type","value":"application/json"}]}},"typeVersion":4.4},{"name":"Check SBX Environment","type":"n8n-nodes-base.if","position":[-80,-496],"parameters":{"options":{},"conditions":{"options":{"version":2,"leftValue":"","caseSensitive":false,"typeValidation":"loose"},"combinator":"and","conditions":[{"id":"YOUR-ID-HERE","operator":{"type":"string","operation":"contains"},"leftValue":"={{ $('Fetch Assessment from Supabase').item.json.contact_email }}","rightValue":"you+"}]}},"typeVersion":2.2}],"settings":{"executionOrder":"v1"},"connections":{"Encode Contract HTML":{"main":[[{"node":"Check SBX Environment","type":"main","index":0}]]},"Check SBX Environment":{"main":[[{"node":"Post to DocuSign JWT API (SBX)","type":"main","index":0}],[{"node":"Post to DocuSign JWT API","type":"main","index":0}]]},"Update in Supabase DB":{"main":[[]]},"Post to DocuSign JWT API":{"main":[[{"node":"Post for DocuSign Access Token","type":"main","index":0}]]},"Compose Contract HTML Code":{"main":[[{"node":"Encode Contract HTML","type":"main","index":0}]]},"Triggered by Another Workflow":{"main":[[{"node":"Fetch Assessment from Supabase","type":"main","index":0}]]},"Fetch Assessment from Supabase":{"main":[[{"node":"Compose Contract HTML Code","type":"main","index":0}]]},"Post for DS Access Token (SBX)":{"main":[[{"node":"Post to Create DS Envelope (SBX)","type":"main","index":0}]]},"Post for DocuSign Access Token":{"main":[[{"node":"Post to Create DocuSign Envelope","type":"main","index":0}]]},"Post to DocuSign JWT API (SBX)":{"main":[[{"node":"Post for DS Access Token (SBX)","type":"main","index":0}]]},"Post to Create DS Envelope (SBX)":{"main":[[{"node":"Update in Supabase DB","type":"main","index":0}]]},"Post to Create DocuSign Envelope":{"main":[[{"node":"Update in Supabase DB","type":"main","index":0}]]}}}