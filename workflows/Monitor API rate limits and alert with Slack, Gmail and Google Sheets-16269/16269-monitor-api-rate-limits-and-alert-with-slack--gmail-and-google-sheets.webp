{"id":"CoAwzG75kILKh6VD","meta":{"instanceId":"c91c5b6efe2709e07c37996245857ac5d863d575d07e0072127351337c204c40"},"name":"API Rate Limit Monitor & Alert","tags":[{"id":"2V3HXFbv2wqNGm6s","name":"Dev","createdAt":"2025-06-17T05:42:41.949Z","updatedAt":"2025-06-17T05:42:41.949Z"}],"nodes":[{"id":"44cbe890-335c-470d-88cd-3eb6a221c9de","name":"Schedule Check","type":"n8n-nodes-base.scheduleTrigger","position":[-1392,400],"parameters":{"rule":{"interval":[{"field":"minutes"}]}},"typeVersion":1.2},{"id":"536d60c9-c8d4-443f-9d3a-cf3225bae986","name":"Fetch Rate Limit Status","type":"n8n-nodes-base.httpRequest","position":[-1168,400],"parameters":{"url":"https://api.example.com/v1/account/rate-limit-status","options":{},"sendHeaders":true,"authentication":"genericCredentialType","genericAuthType":"httpHeaderAuth","headerParameters":{"parameters":[{"name":"Authorization","value":"Bearer YOUR_TOKEN_HERE"}]}},"typeVersion":4.3},{"id":"def5b794-8481-4393-bfb5-0e0c8b49be1a","name":"Parse Usage Data","type":"n8n-nodes-base.code","position":[-944,400],"parameters":{"jsCode":"// ================================================\n// RATE LIMIT PARSER & USAGE CALCULATOR\n// Normalizes rate limit headers/body across APIs\n// ================================================\n\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n\n  // Support common rate limit field names across providers\n  const limit = Number(data.limit || data.rate_limit || data.x_ratelimit_limit || 1000);\n  const remaining = Number(data.remaining || data.rate_remaining || data.x_ratelimit_remaining || 0);\n  const used = limit - remaining;\n  const usagePercent = limit > 0 ? Math.round((used / limit) * 100) : 0;\n\n  // Reset window\n  const resetEpoch = Number(data.reset || data.x_ratelimit_reset || 0);\n  const resetTime = resetEpoch > 0\n    ? new Date(resetEpoch * 1000).toISOString()\n    : 'Unknown';\n\n  results.push({\n    json: {\n      apiName: data.api_name || data.service || 'Primary API',\n      limit,\n      remaining,\n      used,\n      usagePercent,\n      resetTime,\n      checkedAt: new Date().toISOString()\n    }\n  });\n}\n\nreturn results;"},"typeVersion":2},{"id":"9788799f-2c98-4b83-91db-2ce94ed8a245","name":"Score Severity","type":"n8n-nodes-base.set","position":[-720,400],"parameters":{"options":{},"assignments":{"assignments":[{"id":"a-severity","name":"severity","type":"string","value":"={{ $json.usagePercent >= 95 ? 'Critical' : $json.usagePercent >= 80 ? 'High' : $json.usagePercent >= 60 ? 'Warning' : 'Normal' }}"},{"id":"a-emoji","name":"severityEmoji","type":"string","value":"={{ $json.usagePercent >= 95 ? 'RED' : $json.usagePercent >= 80 ? 'ORANGE' : $json.usagePercent >= 60 ? 'YELLOW' : 'GREEN' }}"},{"id":"a-breach","name":"isBreach","type":"boolean","value":"={{ $json.usagePercent >= 80 }}"},{"id":"a-subject","name":"alertSubject","type":"string","value":"=API RATE LIMIT [{{ $json.usagePercent >= 95 ? 'CRITICAL' : 'HIGH' }}]: {{ $json.apiName }} at {{ $json.usagePercent }} percent"}]}},"typeVersion":3.4},{"id":"5e2d1a77-efb1-490f-b3b8-edb4384606e5","name":"Threshold Breached","type":"n8n-nodes-base.if","position":[-496,400],"parameters":{"options":{},"conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"check-breach","operator":{"type":"boolean","operation":"equals"},"leftValue":"={{ $json.isBreach }}","rightValue":true}]}},"typeVersion":2},{"id":"3f273fed-2ab2-4d4b-abeb-23af66a87b35","name":"Is Critical","type":"n8n-nodes-base.if","position":[-272,400],"parameters":{"options":{},"conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"check-critical","operator":{"type":"string","operation":"equals"},"leftValue":"={{ $json.severity }}","rightValue":"Critical"}]}},"typeVersion":2},{"id":"94250ed7-f0da-4f80-8b35-affd06b9f19d","name":"Slack Critical Alert","type":"n8n-nodes-base.slack","position":[-48,304],"webhookId":"48032b12-e275-434e-9aea-550d73179568","parameters":{"text":"=CRITICAL API RATE LIMIT ALERT\n\nService: {{ $('Score Severity').item.json.apiName }}\nUsage: {{ $('Score Severity').item.json.usagePercent }} percent ({{ $('Score Severity').item.json.used }} of {{ $('Score Severity').item.json.limit }})\nRemaining: {{ $('Score Severity').item.json.remaining }}\nResets At: {{ $('Score Severity').item.json.resetTime }}\nSeverity: {{ $('Score Severity').item.json.severity }}\n\nImmediate action required. Requests may start failing.","select":"channel","channelId":{"__rl":true,"mode":"list","value":"YOUR_SLACK_CHANNEL_ID","cachedResultName":"incidents"},"otherOptions":{"includeLinkToWorkflow":false}},"typeVersion":2.2},{"id":"1ad83a5e-bc53-4a71-9d6a-0104dafa977f","name":"Slack Warning Alert","type":"n8n-nodes-base.slack","position":[-48,496],"webhookId":"f45e70ed-7790-4af8-bad5-89406f911abc","parameters":{"text":"=API RATE LIMIT WARNING\n\nService: {{ $('Score Severity').item.json.apiName }}\nUsage: {{ $('Score Severity').item.json.usagePercent }} percent ({{ $('Score Severity').item.json.used }} of {{ $('Score Severity').item.json.limit }})\nRemaining: {{ $('Score Severity').item.json.remaining }}\nResets At: {{ $('Score Severity').item.json.resetTime }}\nSeverity: {{ $('Score Severity').item.json.severity }}\n\nUsage is high. Monitor closely and consider throttling.","select":"channel","channelId":{"__rl":true,"mode":"list","value":"YOUR_SLACK_CHANNEL_ID","cachedResultName":"alerts"},"otherOptions":{"includeLinkToWorkflow":false}},"typeVersion":2.2},{"id":"bc17f0a9-ef78-43b7-b2b7-fa37b89a602a","name":"Email On-Call","type":"n8n-nodes-base.gmail","position":[176,400],"webhookId":"0e269536-17c1-449e-8668-97ef989b48ca","parameters":{"sendTo":"user@example.com","message":"=A monitored API is approaching or has breached its rate limit.\n\nService: {{ $('Score Severity').item.json.apiName }}\nUsage: {{ $('Score Severity').item.json.usagePercent }} percent\nUsed: {{ $('Score Severity').item.json.used }} of {{ $('Score Severity').item.json.limit }}\nRemaining: {{ $('Score Severity').item.json.remaining }}\nResets At: {{ $('Score Severity').item.json.resetTime }}\nSeverity: {{ $('Score Severity').item.json.severity }}\nChecked At: {{ $('Score Severity').item.json.checkedAt }}\n\nPlease investigate and apply throttling or request a quota increase if needed.","options":{},"subject":"={{ $('Score Severity').item.json.alertSubject }}"},"typeVersion":2.1},{"id":"ade511ba-04b3-4885-96fc-c2603a4a3587","name":"Log to Sheets","type":"n8n-nodes-base.googleSheets","position":[400,400],"parameters":{"columns":{"value":{"API":"={{ $('Score Severity').item.json.apiName }}","Used":"={{ $('Score Severity').item.json.used }}","Limit":"={{ $('Score Severity').item.json.limit }}","Severity":"={{ $('Score Severity').item.json.severity }}","Timestamp":"={{ $('Score Severity').item.json.checkedAt }}","Reset Time":"={{ $('Score Severity').item.json.resetTime }}","Usage Percent":"={{ $('Score Severity').item.json.usagePercent }}"},"mappingMode":"defineBelow"},"options":{},"operation":"append","sheetName":{"__rl":true,"mode":"list","value":"Log","cachedResultName":"Log"},"documentId":{"__rl":true,"mode":"id","value":"YOUR_SHEET_ID"},"authentication":"serviceAccount"},"typeVersion":4.5},{"id":"4b07eb85-7f4c-4b00-93d0-681658c7c057","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[-1984,32],"parameters":{"width":496,"height":688,"content":"## API Rate Limit Monitor & Alert\nThis workflow continuously monitors the usage of your critical third party APIs and warns your team before requests start failing. On a fixed schedule it pulls the current rate limit status, calculates how much of the quota has been consumed, and decides how serious the situation is. When usage crosses a safe threshold it routes a notification to the right channel and logs every check for trend analysis. This prevents silent outages, throttled customers, and lost data caused by hitting quota ceilings unnoticed.\n\n### How it Works\n\n\t-\tA schedule trigger runs the check at a fixed interval.\n\t-\tIt calls the API endpoint that returns the current rate limit status.\n\t-\tIt parses the response and calculates used, remaining, and usage percent.\n\t-\tIt scores the severity as Normal, Warning, High, or Critical.\n\t-\tIt checks whether the usage has breached the safe threshold.\n\t-\tIt routes critical breaches to the incident channel and email.\n\t-\tIt routes high usage warnings to the alerts channel.\n\t-\tIt logs every run to a spreadsheet for historical tracking.\n\n### Setup Steps\n\n\t1.\tAdd the API credential (header auth) for the service you want to monitor.\n\t2.\tSet the correct rate limit status endpoint URL in the HTTP node.\n\t3.\tAdjust the schedule interval to match your needs.\n\t4.\tConnect your Slack account and set the channel IDs.\n\t5.\tConnect Gmail and set the on-call recipient address.\n\t6.\tConnect Google Sheets and set the log spreadsheet ID.\n\t7.\tActivate the workflow so it runs automatically."},"typeVersion":1},{"id":"3d988b50-1cc1-4046-97b8-5453bac522d6","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[-1472,32],"parameters":{"color":7,"width":688,"height":688,"content":"## Step 1: Fetch and Parse Usage\n\nA schedule trigger starts the workflow at a fixed interval and calls the API to read its current rate limit status. The parser then normalizes the response and calculates how much of the quota has been used, how much remains, and the usage percentage."},"typeVersion":1},{"id":"5d8f814f-4abc-4ceb-ad07-8d76df704c75","name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[-768,32],"parameters":{"color":7,"width":656,"height":688,"content":"## Step 2: Score and Branch\n\nThese nodes assign a severity level based on the usage percentage and decide whether the safe threshold has been breached. A second check separates critical breaches from high usage warnings so each can be routed to the correct destination."},"typeVersion":1},{"id":"25e3e6ec-86ca-49ed-a19f-e0e3ea330061","name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[-96,32],"parameters":{"color":7,"width":704,"height":688,"content":"## Step 3: Notify and Log\n\nCritical breaches trigger an urgent Slack message and an email to the on-call team, while high usage sends a warning to the alerts channel. Every check is written to a spreadsheet for trend analysis, and a short wait debounces repeated alerts."},"typeVersion":1}],"active":false,"pinData":{},"settings":{"executionOrder":"v1"},"versionId":"31e90f91-5b98-4bbf-b317-2edfcf596d32","connections":{"Is Critical":{"main":[[{"node":"Slack Critical Alert","type":"main","index":0}],[{"node":"Slack Warning Alert","type":"main","index":0}]]},"Email On-Call":{"main":[[{"node":"Log to Sheets","type":"main","index":0}]]},"Log to Sheets":{"main":[[]]},"Schedule Check":{"main":[[{"node":"Fetch Rate Limit Status","type":"main","index":0}]]},"Score Severity":{"main":[[{"node":"Threshold Breached","type":"main","index":0}]]},"Parse Usage Data":{"main":[[{"node":"Score Severity","type":"main","index":0}]]},"Threshold Breached":{"main":[[{"node":"Is Critical","type":"main","index":0}]]},"Slack Warning Alert":{"main":[[{"node":"Email On-Call","type":"main","index":0}]]},"Slack Critical Alert":{"main":[[{"node":"Email On-Call","type":"main","index":0}]]},"Fetch Rate Limit Status":{"main":[[{"node":"Parse Usage Data","type":"main","index":0}]]}}}