{"id":"GCrtnCAIw0KfMKT7","meta":{"instanceId":"a80aa23bbabefc7b3844cf4784450d00d7b8a75aa6c77e60231c3e62d3933fe4","templateCredsSetupCompleted":true},"name":"Detect duplicate files in Google Drive and log results to Google Sheets","tags":[{"id":"ESdtU65Wllxq9nEk","name":"auditing","createdAt":"2026-03-19T14:31:37.415Z","updatedAt":"2026-03-19T14:31:37.415Z"},{"id":"NqkO0R23De6nAXL7","name":"indexing","createdAt":"2026-04-28T17:40:23.258Z","updatedAt":"2026-04-28T17:40:23.258Z"}],"nodes":[{"id":"31cb2b0b-6fce-42a9-8c75-a0c3d005a950","name":"Fetch Files from Drive","type":"n8n-nodes-base.googleDrive","position":[944,1632],"parameters":{"filter":{"folderId":{"__rl":true,"mode":"id","value":"={{ $json.folderID }}"},"whatToSearch":"files"},"options":{"fields":"={{ [\"id\", \"name\", \"size\", \"createdTime\", \"modifiedTime\", \"webViewLink\", \"mimeType\"] }}"},"resource":"fileFolder","returnAll":true},"credentials":{"googleDriveOAuth2Api":{"id":"Gml2F10AGgbpj71Q","name":"Google Drive account"}},"typeVersion":3,"alwaysOutputData":true},{"id":"ef6caf32-ae0f-4b9c-bf10-dfb40be3b1cb","name":"Identify Duplicate Files","type":"n8n-nodes-base.code","position":[1168,1632],"parameters":{"jsCode":"// =============================================================\n// DUPLICATE FILE DETECTOR\n// Pass 1: Exact duplicates (identical filenames)\n// Pass 2: Near-duplicates (copy/version naming patterns)\n// =============================================================\n\nconst files = $input.all().map(item => item.json);\nconst results = [];\nconst scanDate = new Date().toISOString().split('T')[0];\n\n// -----------------------------------------------\n// PASS 1: EXACT DUPLICATES (identical filenames)\n// -----------------------------------------------\nconst nameMap = {};\n\nfiles.forEach(file => {\n  const key = file.name.toLowerCase().trim();\n  if (!nameMap[key]) nameMap[key] = [];\n  nameMap[key].push(file);\n});\n\nconst exactDupeIds = new Set();\n\nObject.entries(nameMap).forEach(([nameKey, group]) => {\n  if (group.length < 2) return;\n\n  // Sort oldest first — oldest is most likely the original\n  const sorted = [...group].sort((a, b) =>\n    new Date(a.createdTime || 0) - new Date(b.createdTime || 0)\n  );\n\n  sorted.forEach((file, index) => {\n    exactDupeIds.add(file.id);\n    results.push({\n      json: {\n        scanDate: scanDate,\n        duplicateType: 'EXACT DUPLICATE',\n        groupKey: nameKey,\n        fileName: file.name,\n        fileId: file.id,\n        fileSize: file.size || 'N/A',\n        createdTime: file.createdTime || '',\n        modifiedTime: file.modifiedTime || '',\n        webViewLink: file.webViewLink || '',\n        recommendedAction: index === 0 ? 'KEEP' : 'DELETE',\n        notes: index === 0\n          ? 'Oldest copy — likely original'\n          : 'Same filename — candidate for deletion'\n      }\n    });\n  });\n});\n\n// -----------------------------------------------\n// PASS 2: NEAR-DUPLICATES (similar filenames)\n// Strips copy/version suffixes to find related files\n// -----------------------------------------------\nconst normalizeName = (filename) => {\n  return filename\n    .replace(/\\.[^.]+$/, '')                         // Remove file extension\n    .replace(/\\s*\\(\\d+\\)\\s*$/, '')                   // Remove \"(1)\", \"(2)\"\n    .replace(/\\s*-\\s*copy(\\s*\\(\\d+\\))?\\s*$/i, '')   // Remove \"- Copy (2)\"\n    .replace(/\\s*copy\\s*$/i, '')                      // Remove trailing \"copy\"\n    .replace(/\\s*v\\d+(\\.\\d+)?\\s*$/i, '')             // Remove \"v2\", \"v1.1\"\n    .replace(/\\s*_\\d+\\s*$/, '')                      // Remove \"_2\", \"_3\"\n    .replace(/^copy\\s+of\\s+/i, '')                   // Remove \"Copy of \" prefix\n    .trim()\n    .toLowerCase();\n};\n\nconst nearMap = {};\n\nfiles.forEach(file => {\n  if (exactDupeIds.has(file.id)) return; // Already caught above — skip\n  const normalized = normalizeName(file.name);\n  if (!nearMap[normalized]) nearMap[normalized] = [];\n  nearMap[normalized].push(file);\n});\n\nObject.entries(nearMap).forEach(([normalizedKey, group]) => {\n  if (group.length < 2) return;\n\n  const sorted = [...group].sort((a, b) =>\n    new Date(a.createdTime || 0) - new Date(b.createdTime || 0)\n  );\n\n  sorted.forEach((file, index) => {\n    results.push({\n      json: {\n        scanDate: scanDate,\n        duplicateType: 'NEAR DUPLICATE',\n        groupKey: normalizedKey,\n        fileName: file.name,\n        fileId: file.id,\n        fileSize: file.size || 'N/A',\n        createdTime: file.createdTime || '',\n        modifiedTime: file.modifiedTime || '',\n        webViewLink: file.webViewLink || '',\n        recommendedAction: index === 0 ? 'KEEP' : 'REVIEW',\n        notes: index === 0\n          ? 'Likely original version — keep unless superseded'\n          : 'Filename suggests copy or version — review before deleting'\n      }\n    });\n  });\n});\n\n// -----------------------------------------------\n// If no duplicates found, return a clean-scan record\n// -----------------------------------------------\nif (results.length === 0) {\n  return [{\n    json: {\n      scanDate: scanDate,\n      duplicateType: 'NONE FOUND',\n      groupKey: '',\n      fileName: `Scan complete — ${files.length} files checked`,\n      fileId: '',\n      fileSize: '',\n      createdTime: new Date().toISOString(),\n      modifiedTime: '',\n      webViewLink: '',\n      recommendedAction: 'N/A',\n      notes: 'No duplicate or near-duplicate files detected.'\n    }\n  }];\n}\n\nreturn results;"},"typeVersion":2},{"id":"6c101096-0c4a-4b21-be54-c347f49f36a5","name":"Check for Duplicates","type":"n8n-nodes-base.if","position":[1392,1632],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"0ca23553-c49a-4ec9-9402-ad6a80f41410","operator":{"type":"string","operation":"notEquals"},"leftValue":"={{ $json.duplicateType }}","rightValue":"NONE FOUND"}]}},"typeVersion":2.3},{"id":"1778e69a-dbb4-4f5c-b9fd-dff13c333616","name":"Append Duplicates to Sheets","type":"n8n-nodes-base.googleSheets","position":[1872,1536],"parameters":{"columns":{"value":{},"schema":[],"mappingMode":"autoMapInputData","matchingColumns":[],"attemptToConvertTypes":false,"convertFieldsToString":false},"options":{},"operation":"append","sheetName":{"__rl":true,"mode":"name","value":"Sheet1"},"documentId":{"__rl":true,"mode":"id","value":"={{ $('Set Configuration Parameters').item.json.spreadsheetID }}"}},"credentials":{"googleSheetsOAuth2Api":{"id":"gg4qCMRWXFU6YUur","name":"Google Sheets account"}},"typeVersion":4.7},{"id":"ddde2e4f-91db-427b-ba64-9469f12dc5d7","name":"Limit to 10 Entries","type":"n8n-nodes-base.limit","position":[2096,1536],"parameters":{},"typeVersion":1},{"id":"5c7ba7b0-ed42-4988-bc9c-9fe9ee794fd3","name":"Append Clean Log to Sheets","type":"n8n-nodes-base.googleSheets","position":[1872,1904],"parameters":{"columns":{"value":{"Notes":"={{ $json.notes }}","File ID":"={{ $json.fileId }}","File Link":"={{ $json.webViewLink }}","File Name":"={{ $json.fileName }}","File Size":"={{ $json.fileSize }}","Group Key":"={{ $json.groupKey }}","Scan Date":"={{ $json.scanDate }}","Created Date":"={{ $json.createdTime }}","Modified Date":"={{ $json.modifiedTime }}","Duplicate Type":"={{ $json.duplicateType }}","Recommended Action":"={{ $json.recommendedAction }}"},"schema":[{"id":"Scan Date","type":"string","display":true,"required":false,"displayName":"Scan Date","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Duplicate Type","type":"string","display":true,"required":false,"displayName":"Duplicate Type","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Group Key","type":"string","display":true,"required":false,"displayName":"Group Key","defaultMatch":false,"canBeUsedToMatch":true},{"id":"File Name","type":"string","display":true,"required":false,"displayName":"File Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"File ID","type":"string","display":true,"removed":false,"required":false,"displayName":"File ID","defaultMatch":false,"canBeUsedToMatch":true},{"id":"File Size","type":"string","display":true,"required":false,"displayName":"File Size","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Created Date","type":"string","display":true,"required":false,"displayName":"Created Date","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Modified Date","type":"string","display":true,"required":false,"displayName":"Modified Date","defaultMatch":false,"canBeUsedToMatch":true},{"id":"File Link","type":"string","display":true,"required":false,"displayName":"File Link","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Recommended Action","type":"string","display":true,"required":false,"displayName":"Recommended Action","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Notes","type":"string","display":true,"required":false,"displayName":"Notes","defaultMatch":false,"canBeUsedToMatch":true}],"mappingMode":"autoMapInputData","matchingColumns":[],"attemptToConvertTypes":false,"convertFieldsToString":false},"options":{},"operation":"append","sheetName":{"__rl":true,"mode":"list","value":"gid=0","cachedResultUrl":"https://docs.google.com/spreadsheets/d/1nELjc7wxDf13MJ39PiuHigQAwiTYJPXtqWSLWYSlCOM/edit#gid=0","cachedResultName":"Sheet1"},"documentId":{"__rl":true,"mode":"id","value":"={{ $('Set Configuration Parameters').item.json.spreadsheetID }}"}},"credentials":{"googleSheetsOAuth2Api":{"id":"gg4qCMRWXFU6YUur","name":"Google Sheets account"}},"typeVersion":4.7},{"id":"29181b87-e47a-4452-a48a-95729b09051d","name":"Notify via Gmail","type":"n8n-nodes-base.gmail","position":[2304,1536],"webhookId":"dd3da347-14c9-4a79-9733-d67f23c39c46","parameters":{"message":"Your duplicate file scan has completed.  Duplicate files were found and logged to your Google Sheet for review.  Each file has been tagged with a Recommended Action:   • KEEP — likely the original   • DELETE — confirmed exact duplicate   • REVIEW — similar name, needs human judgment  Please open your sheet to review the results before deleting anything.","options":{},"subject":"⚠️ Duplicate Files Detected in Google Drive"},"credentials":{"gmailOAuth2":{"id":"oATh6Ndynk0fUULG","name":"Gmail account"}},"typeVersion":2.2},{"id":"3950b6c8-b402-47ac-a629-81301b2c0fa1","name":"Set Configuration Parameters","type":"n8n-nodes-base.set","position":[720,1632],"parameters":{"options":{},"assignments":{"assignments":[{"id":"e1714e1b-bb8e-4cf5-90e8-ec742f81b6a7","name":"folderID","type":"string","value":""},{"id":"e4aa016c-0a7b-4725-9b2c-05e0f05ac4f6","name":"spreadsheetID","type":"string","value":""},{"id":"8245632c-0c98-4ded-b156-b4fac0537429","name":"sheetName","type":"string","value":"Sheet1"}]}},"typeVersion":3.4},{"id":"f5ae42d7-272e-4673-8637-781f93961f49","name":"Prepare Clean Log Fields","type":"n8n-nodes-base.set","position":[1632,1904],"parameters":{"options":{},"assignments":{"assignments":[{"id":"b5465bff-a619-4c7e-8bb4-0c364f73ac94","name":"=Scan Date","type":"string","value":"={{ $('Identify Duplicate Files').item.json.scanDate }}"},{"id":"acdadbe5-78ee-4780-aa78-5455612a4689","name":"=Duplicate Type","type":"string","value":"={{ $('Identify Duplicate Files').item.json.duplicateType }}"},{"id":"e9d13dfa-6799-4ffb-842e-f128d9ebe22c","name":"Group Key","type":"string","value":"={{ $('Identify Duplicate Files').item.json.groupKey }}"},{"id":"0f157117-2fc1-4ee2-83fc-c31dd32b0da3","name":"File Name","type":"string","value":"={{ $('Identify Duplicate Files').item.json.fileName }}"},{"id":"dacfd8a2-4a93-4a81-a3bc-9479cbce01a9","name":"File ID","type":"string","value":"={{ $('Identify Duplicate Files').item.json.fileId }}"},{"id":"db7e09e3-2e42-4315-a9d6-fae775f1cb5d","name":"File Size","type":"string","value":"={{ $('Identify Duplicate Files').item.json.fileSize }}"},{"id":"cad3bd2f-bd10-4d3e-a6a8-ade009ccbb85","name":"Created Date","type":"string","value":"={{ $('Identify Duplicate Files').item.json.createdTime }}"},{"id":"209136d4-5453-46c3-9602-c3e12479268b","name":"Modified Date","type":"string","value":"={{ $('Identify Duplicate Files').item.json.modifiedTime }}"},{"id":"31594856-5f74-4ca4-bf3d-753f4f55b7e2","name":"File Link","type":"string","value":"={{ $('Identify Duplicate Files').item.json.webViewLink }}"},{"id":"2305d284-b3e9-4b56-9801-be2d982d9257","name":"Recommended Action","type":"string","value":"={{ $('Identify Duplicate Files').item.json.recommendedAction }}"},{"id":"b2289ee7-994b-4e0b-a477-eee5f2b48e6b","name":"Notes","type":"string","value":"={{ $('Identify Duplicate Files').item.json.notes }}"}]}},"typeVersion":3.4},{"id":"9b6f9d47-43bc-47c2-9e4f-ee0478e3b911","name":"Prepare Duplicates Log Fields","type":"n8n-nodes-base.set","position":[1632,1536],"parameters":{"options":{},"assignments":{"assignments":[{"id":"b5465bff-a619-4c7e-8bb4-0c364f73ac94","name":"=Scan Date","type":"string","value":"={{ $('Identify Duplicate Files').item.json.scanDate }}"},{"id":"acdadbe5-78ee-4780-aa78-5455612a4689","name":"=Duplicate Type","type":"string","value":"={{ $('Identify Duplicate Files').item.json.duplicateType }}"},{"id":"e9d13dfa-6799-4ffb-842e-f128d9ebe22c","name":"Group Key","type":"string","value":"={{ $('Identify Duplicate Files').item.json.groupKey }}"},{"id":"0f157117-2fc1-4ee2-83fc-c31dd32b0da3","name":"File Name","type":"string","value":"={{ $('Identify Duplicate Files').item.json.fileName }}"},{"id":"dacfd8a2-4a93-4a81-a3bc-9479cbce01a9","name":"File ID","type":"string","value":"={{ $('Identify Duplicate Files').item.json.fileId }}"},{"id":"db7e09e3-2e42-4315-a9d6-fae775f1cb5d","name":"File Size","type":"string","value":"={{ $('Identify Duplicate Files').item.json.fileSize }}"},{"id":"cad3bd2f-bd10-4d3e-a6a8-ade009ccbb85","name":"Created Date","type":"string","value":"={{ $('Identify Duplicate Files').item.json.createdTime }}"},{"id":"209136d4-5453-46c3-9602-c3e12479268b","name":"Modified Date","type":"string","value":"={{ $('Identify Duplicate Files').item.json.modifiedTime }}"},{"id":"31594856-5f74-4ca4-bf3d-753f4f55b7e2","name":"File Link","type":"string","value":"={{ $('Identify Duplicate Files').item.json.webViewLink }}"},{"id":"2305d284-b3e9-4b56-9801-be2d982d9257","name":"Recommended Action","type":"string","value":"={{ $('Identify Duplicate Files').item.json.recommendedAction }}"},{"id":"b2289ee7-994b-4e0b-a477-eee5f2b48e6b","name":"Notes","type":"string","value":"={{ $('Identify Duplicate Files').item.json.notes }}"}]}},"typeVersion":3.4},{"id":"0bdbf7db-c6bd-4f23-ba5d-d4935ea7c5b2","name":"Sticky Note6","type":"n8n-nodes-base.stickyNote","position":[-112,1408],"parameters":{"width":480,"height":816,"content":"## Detect duplicate files in Google Drive and log results to Google Sheets\n\n### How it works\n\nThis workflow is manually triggered to scan a configured Google Drive folder for files, detect possible duplicates, and branch based on whether duplicates are found. Duplicate findings are formatted and appended to Google Sheets, then an email notification is sent. If no duplicates are found, the workflow logs a clean scan result to the same reporting spreadsheet.\n\n### Setup steps\n\n- Connect Google Drive credentials for the file scan node.\n- Connect Google Sheets credentials and ensure the target spreadsheet and sheet exist with columns matching the renamed fields, such as Scan Date, Duplicate Type, Group Key, and File Name.\n- Connect Gmail credentials for the notification step and configure the recipient, subject, and message content.\n- Edit the CONFIG - Set These First node with the target folderID, spreadsheetID, and sheetName values.\n\n### Customization\n\nAdjust the duplicate detection code to change how duplicates are identified, such as by file name, size, checksum, or other metadata. The manual trigger can also be replaced with a schedule trigger for recurring scans."},"typeVersion":1},{"id":"ed0b6bdf-cb48-4d55-a1c4-94820ef5900f","name":"Sticky Note7","type":"n8n-nodes-base.stickyNote","position":[448,1456],"parameters":{"color":7,"width":416,"height":336,"content":"## Manual scan setup\n\nStarts the workflow manually and defines the key configuration values used by the scan, including the Google Drive folder and Google Sheets target."},"typeVersion":1},{"id":"36d05dab-43fb-4095-ba88-016017fb5c23","name":"Sticky Note8","type":"n8n-nodes-base.stickyNote","position":[896,1472],"parameters":{"color":7,"width":640,"height":320,"content":"## Fetch and detect duplicates\n\nRetrieves files from the configured Google Drive folder, runs the duplicate detection logic, and routes the result into duplicate or clean-scan branches."},"typeVersion":1},{"id":"1f14c494-111d-4163-b9e4-10f74c9fe95d","name":"Sticky Note9","type":"n8n-nodes-base.stickyNote","position":[1584,1408],"parameters":{"color":7,"width":864,"height":304,"content":"## Log duplicates and notify\n\nFormats duplicate scan results for the report sheet, writes them to Google Sheets, limits the downstream notification payload, and sends an email alert."},"typeVersion":1},{"id":"531740da-3378-4c5b-82db-40a53bf3fc13","name":"Sticky Note10","type":"n8n-nodes-base.stickyNote","position":[1584,1744],"parameters":{"color":7,"width":432,"height":320,"content":"## Log clean scan\n\nFormats the no-duplicate result and appends a clean scan entry to Google Sheets for audit history."},"typeVersion":1}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","executionOrder":"v1"},"versionId":"53fc2253-a8d0-4f22-a4ca-182f37fcb56d","nodeGroups":[],"connections":{"Limit to 10 Entries":{"main":[[{"node":"Notify via Gmail","type":"main","index":0}]]},"Check for Duplicates":{"main":[[{"node":"Prepare Duplicates Log Fields","type":"main","index":0}],[{"node":"Prepare Clean Log Fields","type":"main","index":0}]]},"Fetch Files from Drive":{"main":[[{"node":"Identify Duplicate Files","type":"main","index":0}]]},"Identify Duplicate Files":{"main":[[{"node":"Check for Duplicates","type":"main","index":0}]]},"Prepare Clean Log Fields":{"main":[[{"node":"Append Clean Log to Sheets","type":"main","index":0}]]},"Append Duplicates to Sheets":{"main":[[{"node":"Limit to 10 Entries","type":"main","index":0}]]},"Set Configuration Parameters":{"main":[[{"node":"Fetch Files from Drive","type":"main","index":0}]]},"Prepare Duplicates Log Fields":{"main":[[{"node":"Append Duplicates to Sheets","type":"main","index":0}]]}}}