{"id":"EjEo3TqyhWeF0Gj5","meta":{"instanceId":"3451bbea24dfcee452168673c34fefe6daafd346c71a4c240f8c721e35c1d4c4"},"name":"Every 5AM check task not update - Mark stale or alert","tags":[],"nodes":[{"id":"a8aa8e1f-d900-4157-b45e-e782fe28e76a","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[-80,-128],"parameters":{"width":480,"height":896,"content":"## Every 5AM check task not update - Mark stale or alert\n\n### How it works\n\nThis workflow runs on a schedule to review ClickUp tasks and identify items that have not been updated within configured stale thresholds. It pulls tasks from two ClickUp lists, merges and deduplicates them, skips tasks already marked as second-stale, then decides whether to apply a first-stale tag or escalate to second-stale handling. For tasks reaching the second-stale threshold, it removes the first-stale tag, applies the second-stale tag, and adds a ClickUp comment; tasks that do not qualify are ignored.\n\n### Setup steps\n\n- Configure the schedule trigger to run at the intended time, such as every day at 5:00 AM.\n- Connect valid ClickUp credentials on all ClickUp nodes.\n- Set the monitored ClickUp list IDs in the task retrieval nodes.\n- Review the SetContext node values for monitoredStatuses, monitoredTags, daysUntilFirstStaleTag, and daysUntilSecondStaleTag.\n- Ensure the ClickUp tag names and comment text used by the update nodes match your workspace conventions.\n\n### Customization\n\nAdjust the stale-day thresholds, monitored statuses, monitored tags, source lists, and escalation comment to match your team’s process."},"typeVersion":1},{"id":"04113c69-ec0f-44e4-bd6c-e1438d8f5460","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[480,32],"parameters":{"color":7,"width":640,"height":304,"content":"## Schedule and context\n\nStarts the workflow on a timed schedule, defines stale-check configuration, and retrieves tasks from the first monitored ClickUp list."},"typeVersion":1},{"id":"d689e15f-ea5d-4a5f-9737-960a0ca73fa1","name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[944,544],"parameters":{"color":7,"height":384,"content":"## Fetch second list\n\nRetrieves tasks from a second ClickUp list through a separate lower input branch before they are merged with the first list’s results."},"typeVersion":1},{"id":"68c3e99e-c2d9-439c-b748-aa71fe9ec139","name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[1152,128],"parameters":{"color":7,"width":640,"height":304,"content":"## Merge and filter tasks\n\nCombines tasks from both lists, removes duplicates, and filters out items that are already marked with the second-stale tag."},"typeVersion":1},{"id":"ee8d7b89-6f2e-40a7-a711-084cacaacce7","name":"Sticky Note4","type":"n8n-nodes-base.stickyNote","position":[2272,-128],"parameters":{"color":7,"width":480,"height":352,"content":"## Classify first stale\n\nChecks whether each remaining task has not yet been marked first-stale, then routes qualifying tasks toward first-stale tagging or possible second-stale escalation."},"typeVersion":1},{"id":"63b55974-5861-4553-93d3-d427b8f9c1df","name":"Sticky Note5","type":"n8n-nodes-base.stickyNote","position":[2048,256],"parameters":{"color":7,"width":416,"height":560,"content":"## Evaluate second stale\n\nChecks whether an already first-stale task has remained untouched long enough to become second-stale, removes the first-stale tag when escalation is needed, or sends non-qualifying tasks to a no-op path."},"typeVersion":1},{"id":"07d6ffdd-442c-4217-9286-bca167b06f6d","name":"Sticky Note6","type":"n8n-nodes-base.stickyNote","position":[2576,256],"parameters":{"color":7,"width":416,"height":320,"content":"## Apply escalation updates\n\nApplies the second-stale ClickUp tag and adds a ClickUp comment to alert or document that the task has reached the second stale stage."},"typeVersion":1},{"id":"006c3253-88de-4003-b682-f1ebcbc2f34c","name":"If Date Not Updated for 2nd Stale","type":"n8n-nodes-base.if","position":[2096,560],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"ebd4d16b-cabf-4598-9f10-4ae1033a4274","operator":{"type":"dateTime","operation":"beforeOrEquals"},"leftValue":"={{ $json.date_updated.toDateTime('ms') }}","rightValue":"={{ \n$now.minus(\n  ($('Configure Task Monitoring').first().json.daysUntilSecondStaleTag - $('Configure Task Monitoring').first().json.daysUntilFirstStaleTag), \n  'days'\n)}}"}]}},"typeVersion":2.3},{"id":"771029f3-328a-447f-9249-7afa8ee0a0fe","name":"Tag Task as 2nd Stale","type":"n8n-nodes-base.clickUp","position":[2624,416],"parameters":{"taskId":"={{ $('Deduplicate by Task ID').item.json.id }}","tagName":"={{ $('Configure Task Monitoring').first().json.secondStaleTagName }}","resource":"taskTag","additionalFields":{}},"credentials":{"clickUpApi":{"id":"PrpfhU9o2JivwaKh","name":"ClickUp account"}},"retryOnFail":true,"typeVersion":1,"alwaysOutputData":false},{"id":"aba5d904-f4eb-49f2-a0d5-48c2188bf9ba","name":"Add First Stale Tag","type":"n8n-nodes-base.clickUp","position":[2608,48],"parameters":{"taskId":"={{ $('Deduplicate by Task ID').item.json.id }}","tagName":"={{ $('Configure Task Monitoring').first().json.firstStaleTagName }}","resource":"taskTag","additionalFields":{}},"credentials":{"clickUpApi":{"id":"PrpfhU9o2JivwaKh","name":"ClickUp account"}},"retryOnFail":true,"typeVersion":1},{"id":"2a3da81b-9ec7-45b8-aab3-b2505b3e4db1","name":"Check First Stale Tag Presence","type":"n8n-nodes-base.if","position":[1872,256],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"3333b4c1-db4b-4728-b23b-20ff9f07aca3","operator":{"type":"array","operation":"notContains","rightType":"any"},"leftValue":"={{ $json.tags.map( tag => tag?.name ) }}","rightValue":"={{ $('Configure Task Monitoring').first().json.firstStaleTagName }}"}]}},"typeVersion":2.3},{"id":"c2c3d46c-893a-45b7-8c65-6b8b59ee039c","name":"Remove First Stale Tag","type":"n8n-nodes-base.clickUp","position":[2320,464],"parameters":{"taskId":"={{ $('Deduplicate by Task ID').item.json.id }}","tagName":"={{ $('Configure Task Monitoring').first().json.firstStaleTagName }}","resource":"taskTag","operation":"remove","additionalFields":{}},"credentials":{"clickUpApi":{"id":"PrpfhU9o2JivwaKh","name":"ClickUp account"}},"retryOnFail":true,"typeVersion":1,"alwaysOutputData":false},{"id":"615d39eb-3c5a-4066-83b6-dd2c9d594840","name":"Comment on 2nd Stale Task","type":"n8n-nodes-base.clickUp","position":[2848,416],"parameters":{"id":"={{ $('Deduplicate by Task ID').item.json.id }}","resource":"comment","commentOn":"task","commentText":"=⚠️ This task has not been updated in the last ( {{ $('Deduplicate by Task ID').item.json.date_updated.toDateTime('ms').diffToNow('days').round().abs() }} ) day(s).","additionalFields":{"assignee":"={{ $('Deduplicate by Task ID').item.json.assignees?.[0]?.id ?? $('Deduplicate by Task ID').item.json.creator?.id  }}"}},"credentials":{"clickUpApi":{"id":"PrpfhU9o2JivwaKh","name":"ClickUp account"}},"retryOnFail":true,"typeVersion":1},{"id":"c4f8fcae-3f0f-46de-aa91-84458dec35c0","name":"Merge Task Lists","type":"n8n-nodes-base.merge","position":[1200,256],"parameters":{},"typeVersion":3.2},{"id":"15efe82e-1043-4e9f-8a45-e258b8975297","name":"Filter Already 2nd Stale Tasks","type":"n8n-nodes-base.filter","position":[1648,256],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"68fecf9a-11f7-44ed-91a7-3d5188e7354b","operator":{"type":"array","operation":"notContains","rightType":"any"},"leftValue":"={{ $json.tags.map( tag => tag?.name ) }}","rightValue":"={{ $('Configure Task Monitoring').first().json.secondStaleTagName }}"}]}},"typeVersion":2.3},{"id":"ec5058eb-d821-4964-a55c-13