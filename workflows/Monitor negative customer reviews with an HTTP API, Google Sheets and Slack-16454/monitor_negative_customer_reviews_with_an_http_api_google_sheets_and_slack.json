{"id":"hqQSZC40uc2RLEQR","meta":{"instanceId":"6ab8f18301c57fe5508c3c98c40f1759365371ba574c699a1652064e9d2bc1b3","templateCredsSetupCompleted":true},"name":"Negative Review Monitor","tags":[],"nodes":[{"id":"8e4472a8-3662-40a4-8c02-b30df58af82c","name":"Every 6 Hours","type":"n8n-nodes-base.scheduleTrigger","position":[800,1552],"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":6}]}},"typeVersion":1.2},{"id":"7c293816-dd9f-4dd2-ac4b-e5c4af637c0e","name":"Fetch Latest Reviews","type":"n8n-nodes-base.httpRequest","position":[1056,1472],"parameters":{"url":"https://YOUR_REVIEW_API/reviews","options":{}},"typeVersion":4.2},{"id":"bf839b0c-946d-42ce-b5d9-abc3d4225a00","name":"Normalize Review Data","type":"n8n-nodes-base.set","position":[1312,1472],"parameters":{"options":{},"assignments":{"assignments":[{"id":"n1","name":"review_id","type":"string","value":"={{ String($json.id) }}"},{"id":"n2","name":"rating","type":"number","value":"={{ Number($json.rating) }}"},{"id":"n3","name":"author","type":"string","value":"={{$json.author}}"},{"id":"n4","name":"text","type":"string","value":"={{$json.text}}"},{"id":"n5","name":"date","type":"string","value":"={{$json.date}}"}]}},"typeVersion":3.4},{"id":"bf5277fe-d836-418f-87e0-30bf49775d33","name":"Filter Negative Reviews","type":"n8n-nodes-base.code","position":[1568,1472],"parameters":{"jsCode":"return $input.all().filter(i => Number(i.json.rating) <= 3).map(i => ({ json: i.json }));"},"typeVersion":2},{"id":"29bba2cf-4c6c-4aa0-b81b-821615f9ea08","name":"Get Processed Review IDs","type":"n8n-nodes-base.googleSheets","position":[1312,1792],"parameters":{"options":{},"sheetName":{"__rl":true,"mode":"id","value":"ProcessedReviews","cachedResultName":"ProcessedReviews"},"documentId":{"__rl":true,"mode":"id","value":"YOUR_PROCESSED_REVIEWS_SHEET_ID","cachedResultName":"REPLACE_WITH_YOUR_LOG_SHEET"}},"typeVersion":4.5},{"id":"3a06d146-af51-4996-a13b-3cd0bdaac065","name":"Combine Reviews and Log","type":"n8n-nodes-base.merge","position":[1824,1632],"parameters":{},"typeVersion":3.2},{"id":"2e5d4f83-39d6-4b01-9b15-c9b4022ee4e6","name":"Filter Out Already Processed","type":"n8n-nodes-base.code","position":[2080,1632],"parameters":{"jsCode":"const items = $input.all().map(i => i.json);\nconst processedIds = new Set(items.filter(i => i.review_id !== undefined && i.rating === undefined).map(i => String(i.review_id)));\nconst reviews = items.filter(i => i.rating !== undefined);\nreturn reviews.filter(r => !processedIds.has(String(r.review_id))).map(r => ({ json: r }));"},"typeVersion":2},{"id":"546f6677-6a6e-4717-9b17-8390145151aa","name":"Any New Negative Reviews","type":"n8n-nodes-base.if","position":[2336,1632],"parameters":{"options":{},"conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"loose"},"combinator":"and","conditions":[{"id":"a1","operator":{"type":"number","operation":"gt"},"leftValue":"={{ $input.all().length }}","rightValue":0}]}},"typeVersion":2},{"id":"7e4d3f1e-7960-4bd5-8bb4-d97072a228d2","name":"Classify Severity","type":"n8n-nodes-base.if","position":[2592,1632],"parameters":{"options":{},"conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"loose"},"combinator":"and","conditions":[{"id":"s1","operator":{"type":"number","operation":"lte"},"leftValue":"={{$json.rating}}","rightValue":2}]}},"typeVersion":2},{"id":"e59540c6-577f-464a-a5c7-2faf36a55737","name":"Alert Manager Urgent","type":"n8n-nodes-base.slack","position":[2848,1488],"webhookId":"5305abc2-7bbe-4ccc-90a1-acc697c9bda8","parameters":{"text":"URGENT — new {{$json.rating}} star review from {{$json.author}}: {{$json.text}}","select":"channel","channelId":{"__rl":true,"mode":"list","value":"C0B4D54BBFB","cachedResultName":"price-drop"},"otherOptions":{},"authentication":"oAuth2"},"typeVersion":2.3},{"id":"15007865-eab7-4bce-92b9-b5dfb73ffc31","name":"Log Critical Review","type":"n8n-nodes-base.googleSheets","position":[3104,1488],"parameters":{"columns":{"value":{"severity":"critical","review_id":"={{ $json.review_id }}","alerted_at":"={{ $now.toISO() }}"},"schema":[{"id":"review_id","type":"string","display":true,"removed":false,"required":false,"displayName":"review_id","defaultMatch":false,"canBeUsedToMatch":true},{"id":"alerted_at","type":"string","display":true,"removed":false,"required":false,"displayName":"alerted_at","defaultMatch":false,"canBeUsedToMatch":false},{"id":"severity","type":"string","display":true,"removed":false,"required":false,"displayName":"severity","defaultMatch":false,"canBeUsedToMatch":false}],"mappingMode":"defineBelow","matchingColumns":["review_id"],"attemptToConvertTypes":false,"convertFieldsToString":false},"options":{},"operation":"append","sheetName":{"__rl":true,"mode":"id","value":"ProcessedReviews","cachedResultName":"ProcessedReviews"},"documentId":{"__rl":true,"mode":"id","value":"YOUR_PROCESSED_REVIEWS_SHEET_ID","cachedResultName":"REPLACE_WITH_YOUR_LOG_SHEET"}},"typeVersion":4.5},{"id":"b2cb680a-2ecf-4ddc-9698-0de47f2f690d","name":"Alert Manager Standard","type":"n8n-nodes-base.slack","position":[2848,1776],"webhookId":"5305abc2-7bbe-4ccc-90a1-acc697c9bda8","parameters":{"text":"New negative review ({{$json.rating}} stars) from {{$json.author}}: {{$json.text}}","select":"channel","channelId":{"__rl":true,"mode":"list","value":"C0B4D54BBFB","cachedResultName":"price-drop"},"otherOptions":{},"authentication":"oAuth2"},"typeVersion":2.3},{"id":"74068ca4-f92f-4ab2-86eb-6014abe151dd","name":"Log Standard Review","type":"n8n-nodes-base.googleSheets","position":[3104,1776],"parameters":{"columns":{"value":{"severity":"moderate","review_id":"={{ $json.review_id }}","alerted_at":"={{ $now.toISO() }}"},"schema":[{"id":"review_id","type":"string","display":true,"removed":false,"required":false,"displayName":"review_id","defaultMatch":false,"canBeUsedToMatch":true},{"id":"alerted_at","type":"string","display":true,"removed":false,"required":false,"displayName":"alerted_at","defaultMatch":false,"canBeUsedToMatch":false},{"id":"severity","type":"string","display":true,"removed":false,"required":false,"displayName":"severity","defaultMatch":false,"canBeUsedToMatch":false}],"mappingMode":"defineBelow","matchingColumns":["review_id"],"attemptToConvertTypes":false,"convertFieldsToString":false},"options":{},"operation":"append","sheetName":{"__rl":true,"mode":"id","value":"ProcessedReviews","cachedResultName":"ProcessedReviews"},"documentId":{"__rl":true,"mode":"id","value":"YOUR_PROCESSED_REVIEWS_SHEET_ID","cachedResultName":"REPLACE_WITH_YOUR_LOG_SHEET"}},"typeVersion":4.5},{"id":"eb54a9a2-79f2-4036-9cc0-3e6b20b27076","name":"Workflow Error Trigger","type":"n8n-nodes-base.errorTrigger","position":[1312,2112],"parameters":{},"typeVersion":1},{"id":"cb6f9c14-9ae8-43cd-9126-976b98023f36","name":"Alert Team on Monitor Failure","type":"n8n-nodes-base.slack","position":[1568,2112],"webhookId":"755e75d5-997e-443e-808f-348488a0bddb","parameters":{"text":"Negative Review Monitor workflow failed: {{$json.execution.error.message}}","select":"channel","channelId":{"__rl":true,"mode":"list","value":"C0B4D54BBFB","cachedResultName":"price-drop"},"otherOptions":{},"authentication":"oAuth2"},"typeVersion":2.3},{"id":"e935d5af-d385-44c2-8c50-26392bf260cf","name":"Overview","type":"n8n-nodes-base.stickyNote","position":[128,1232],"parameters":{"color":7,"width":560,"height":1156,"content":"## ⭐ Negative Review Monitor\n\nChecks your review feed every 6 hours, isolates low rated reviews, skips anything already alerted on a previous run, splits critical from moderate severity, and notifies your manager in Slack — logging every alert so it never repeats.\n\n**Perfect for:** restaurants, cafes and hospitality venues.\n\n---\n\n## How it works\n\n1. **Every 6 Hours** — schedule trigger that polls on a fixed interval.\n2. **Fetch Latest Reviews** — calls your review source and returns recent reviews.\n3. **Normalize Review Data** — extracts a clean id, numeric rating, author, text, and date from each review.\n4. **Filter Negative Reviews** — keeps only reviews rated 3 stars or lower.\n5. **Get Processed Review IDs** — reads the log of reviews already alerted on, in parallel.\n6. **Combine Reviews and Log** — brings both lists together for comparison.\n7. **Filter Out Already Processed** — drops any review that was already alerted in a previous run.\n8. **Any New Negative Reviews** — continues only if at least one genuinely new review was found.\n9. **Classify Severity** — splits 1–2 star reviews from 3 star reviews.\n10. **Alert Manager Urgent** / **Log Critical Review** — *(1–2 star path)* posts an urgent Slack alert, then logs it so it is never alerted twice.\n11. **Alert Manager Standard** / **Log Standard Review** — *(3 star path)* posts a standard Slack alert, then logs it.\n12. **Workflow Error Trigger** / **Alert Team on Monitor Failure** — *(error path)* posts to Slack if any step in this workflow throws an error.\n\n---\n\n## Setup (~15 min)\n\n1. **HTTP Request** — set your review endpoint URL in *Fetch Latest Reviews* and add auth if needed.\n2. **Google Sheets** — connect your account and create a log sheet with columns review_id, alerted_at, severity; set its id in *Get Processed Review IDs*, *Log Critical Review*, and *Log Standard Review*.\n3. **Slack** — connect Slack and set the channel in *Alert Manager Urgent*, *Alert Manager Standard*, and *Alert Team on Monitor Failure*.\n> Adjust the rating cutoff in *Filter Negative Reviews* and *Classify Severity* if you want a different split. Replace every placeholder sheet id with your own before publishing."},"typeVersion":1},{"id":"95b7ef79-8cb5-4cd8-ab9b-e6a1e40c85bf","name":"1️⃣ Poll Reviews","type":"n8n-nodes-base.stickyNote","position":[720,1280],"parameters":{"color":5,"width":760,"height":688,"content":"## 1️⃣ Poll Reviews\n\n**Every 6 Hours** runs on a schedule and **Fetch Latest Reviews** pulls the most recent reviews from your chosen source. **Normalize Review Data** turns the raw payload into a clean shape every later node can rely on."},"typeVersion":1},{"id":"89c025e3-fb4f-4d7f-8587-56bea2430811","name":"2️⃣ Deduplicate","type":"n8n-nodes-base.stickyNote","position":[1504,1280],"parameters":{"color":3,"width":704,"height":656,"content":"## 2️⃣ Deduplicate\n\n**Get Processed Review IDs** reads the log of reviews already alerted on, and **Combine Reviews and Log** brings that log together with the latest fetch so **Filter Out Already Processed** can drop anything that was already handled in a previous run."},"typeVersion":1},{"id":"5e0e8b64-376b-413e-b3d5-4f98a1b105a8","name":"3️⃣ Detect & Classify","type":"n8n-nodes-base.stickyNote","position":[2224,1392],"parameters":{"color":6,"width":560,"height":480,"content":"## 3️⃣ Detect & Classify\n\n**Any New Negative Reviews** stops the run when there is nothing genuinely new to report, and **Classify Severity** separates 1–2 star reviews from 3 star reviews so each gets the right level of urgency."},"typeVersion":1},{"id":"9b792e96-6fbd-441b-ad17-a476833f1984","name":"4️⃣ Alert & Log","type":"n8n-nodes-base.stickyNote","position":[2800,1312],"parameters":{"color":4,"width":624,"height":708,"content":"## 4️⃣ Alert & Log\n\n**Alert Manager Urgent** and **Alert Manager Standard** post each flagged review to your team channel at the right urgency, and **Log Critical Review** / **Log Standard Review** record every alert so it is never sent twice."},"typeVersion":1}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","availableInMCP":false,"executionOrder":"v1"},"versionId":"542b86ce-247d-46c3-8298-07375270f419","nodeGroups":[],"connections":{"Every 6 Hours":{"main":[[{"node":"Fetch Latest Reviews","type":"main","index":0},{"node":"Get Processed Review IDs","type":"main","index":0}]]},"Classify Severity":{"main":[[{"node":"Alert Manager Urgent","type":"main","index":0}],[{"node":"Alert Manager Standard","type":"main","index":0}]]},"Alert Manager Urgent":{"main":[[{"node":"Log Critical Review","type":"main","index":0}]]},"Fetch Latest Reviews":{"main":[[{"node":"Normalize Review Data","type":"main","index":0}]]},"Normalize Review Data":{"main":[[{"node":"Filter Negative Reviews","type":"main","index":0}]]},"Alert Manager Standard":{"main":[[{"node":"Log Standard Review","type":"main","index":0}]]},"Workflow Error Trigger":{"main":[[{"node":"Alert Team on Monitor Failure","type":"main","index":0}]]},"Combine Reviews and Log":{"main":[[{"node":"Filter Out Already Processed","type":"main","index":0}]]},"Filter Negative Reviews":{"main":[[{"node":"Combine Reviews and Log","type":"main","index":0}]]},"Any New Negative Reviews":{"main":[[{"node":"Classify Severity","type":"main","index":0}]]},"Get Processed Review IDs":{"main":[[{"node":"Combine Reviews and Log","type":"main","index":1}]]},"Filter Out Already Processed":{"main":[[{"node":"Any New Negative Reviews","type":"main","index":0}]]}}}