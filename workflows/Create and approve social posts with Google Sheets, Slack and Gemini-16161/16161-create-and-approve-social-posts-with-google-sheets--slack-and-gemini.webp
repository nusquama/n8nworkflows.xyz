e":"image_1","defaultMatch":false,"canBeUsedToMatch":true},{"id":"image_2","type":"string","display":true,"removed":true,"required":false,"displayName":"image_2","defaultMatch":false,"canBeUsedToMatch":true},{"id":"image_3","type":"string","display":true,"removed":true,"required":false,"displayName":"image_3","defaultMatch":false,"canBeUsedToMatch":true},{"id":"carousel_slide_count","type":"string","display":true,"removed":true,"required":false,"displayName":"carousel_slide_count","defaultMatch":false,"canBeUsedToMatch":true},{"id":"carousel_json","type":"string","display":true,"removed":true,"required":false,"displayName":"carousel_json","defaultMatch":false,"canBeUsedToMatch":true},{"id":"approve_note","type":"string","display":true,"removed":true,"required":false,"displayName":"approve_note","defaultMatch":false,"canBeUsedToMatch":true},{"id":"marcus_revise_note","type":"string","display":true,"removed":true,"required":false,"displayName":"marcus_revise_note","defaultMatch":false,"canBeUsedToMatch":true},{"id":"taylor_revise_note","type":"string","display":true,"removed":false,"required":false,"displayName":"taylor_revise_note","defaultMatch":false,"canBeUsedToMatch":true},{"id":"rejected_by_stage","type":"string","display":true,"removed":true,"required":false,"displayName":"rejected_by_stage","defaultMatch":false,"canBeUsedToMatch":true},{"id":"content_status","type":"string","display":true,"removed":false,"required":false,"displayName":"content_status","defaultMatch":false,"canBeUsedToMatch":true},{"id":"row_number","type":"number","display":true,"removed":false,"readOnly":true,"required":false,"displayName":"row_number","defaultMatch":false,"canBeUsedToMatch":true}],"mappingMode":"defineBelow","matchingColumns":["brief_id"],"attemptToConvertTypes":false,"convertFieldsToString":false},"options":{},"operation":"update","sheetName":{"__rl":true,"mode":"list","value":780992481,"cachedResultUrl":"https://docs.google.com/spreadsheets/d/1N3iOkwTFPuuba2AXIEj8FsIxyB447CW1bp0E7hJprv8/edit#gid=780992481","cachedResultName":"Post Content"},"documentId":{"__rl":true,"mode":"id","value":"=1N3iOkwTFPuuba2AXIEj8FsIxyB447CW1bp0E7hJprv8"}},"credentials":{"googleSheetsOAuth2Api":{"id":"CjB4pVPhUNjDvDTe","name":"DS Ggl Sheet"}},"typeVersion":4.5},{"id":"30cdeb2b-ca47-44a8-8bb9-f5db4a75e440","name":"Sticky Note27","type":"n8n-nodes-base.stickyNote","position":[-496,2064],"parameters":{"color":"#4A4B11","width":640,"height":288,"content":""},"typeVersion":1},{"id":"8b39dd52-e7a3-4ea3-a30b-27b6a6e3c65c","name":"Sticky Note28","type":"n8n-nodes-base.stickyNote","position":[-896,2912],"parameters":{"color":"#4A4B11","width":1040,"height":272,"content":""},"typeVersion":1},{"id":"b6ee37cb-f7a2-467e-866f-76c8ed1e6129","name":"M-Instruct","type":"n8n-nodes-base.set","position":[-256,2240],"parameters":{"options":{},"assignments":{"assignments":[{"id":"b93a90b0-352e-4b65-9562-b40ebc535c16","name":"revise_instruct","type":"string","value":"=Attention, your last post angles were declined. Here is your instruct: {{ $('Approve Form1').item.json['Revise Note'] }}"},{"id":"09ba8cea-e4dd-47f7-a01f-d24fcef6def7","name":"brief_id","type":"string","value":"={{ $('Marcus AI').last().json.body.brief_id }}"},{"id":"ffa866bf-f731-4441-a5df-1f829e4d580d","name":"revised_brief_id","type":"string","value":"={{ $json.brief_id.replace(/-(\\d+)$/, (match, p1) => '-' + String(Number(p1) + 1).padStart(p1.length, '0')) }}"},{"id":"c0a3dd34-0ae3-4a6c-a9ae-89dc120a59ef","name":"client","type":"string","value":"={{ $('Marcus AI').last().json.body.client}}"},{"id":"fc602232-41ba-45cb-a805-b10cdd72341d","name":"platform","type":"string","value":"={{ $('Marcus AI').last().json.body.platform }}"}]}},"typeVersion":3.4},{"id":"8ae8a9bc-75cb-409f-bce3-4597ea4f9101","name":"T-Instruct","type":"n8n-nodes-base.set","position":[-256,2080],"parameters":{"options":{},"assignments":{"assignments":[{"id":"b93a90b0-352e-4b65-9562-b40ebc535c16","name":"revise_instruct","type":"string","value":"=Attention, your last post angles were declined. Here is your instruct: {{ $('Taylor-Marcus Revise').item.json.body.revise_note }}"},{"id":"09ba8cea-e4dd-47f7-a01f-d24fcef6def7","name":"brief_id","type":"string","value":"={{ $('Taylor-Marcus Revise').item.json.body.brief_id }}"},{"id":"ffa866bf-f731-4441-a5df-1f829e4d580d","name":"revised_brief_id","type":"string","value":"={{ $json.brief_id.replace(/-(\\d+)$/, (match, p1) => '-' + String(Number(p1) + 1).padStart(p1.length, '0')) }}"},{"id":"c0a3dd34-0ae3-4a6c-a9ae-89dc120a59ef","name":"client","type":"string","value":"={{ $('Taylor-Marcus Revise').item.json.body.client }}"},{"id":"fc602232-41ba-45cb-a805-b10cdd72341d","name":"platform","type":"string","value":"={{ $('Taylor-Marcus Revise').item.json.body.platform }}"}]}},"typeVersion":3.4},{"id":"61b47572-3f73-4c49-99b3-8b3aa7573087","name":"Sticky Note15","type":"n8n-nodes-base.stickyNote","position":[-4512,848],"parameters":{"color":"#FEFFA8","width":784,"height":816,"content":"# 🗺️ Workflow Overview - HitL 'Human in the Loop' Post Creation\n\n## **Content Agency Flow**  \n*Human-In-The-Loop Social Media Creation*\n\n-  **Slack as the Comms Hub** — All real-time status alerts, interactive review forms, and routing notifications are pushed directly to Slack to keep creative teams in sync.\n-  **Sheets as the Data Backbone** — Strategy angles, post drafts, image assets, and compliance scorecards are logged and indexed continuously across databases.\n-  **Brief ID as the Master Key** — Formulated at intake as `MMDDYY-Client-Platform-001` and incremented recursively (e.g., `-002`) on revisions. This identifier coordinates database writes, agent prompts, and Slack alerts.\n\n---\n\n## 🗺️ Flow Structure: 3 Human-AI Collaboration Gates\n\n### 🎯 Phase 1 — Sofia Strategy\n\n- **Intake Form Trigger** — Client, platform, content type, and initial topic seeds are captured. In Slack - use bookmark \"CREATE NEW BRIEF\" (pointed to the form trigger)\n- **Client Validation** — System checks the client profile in the Relay-Database. If missing, it alerts IT via Gmail and pauses the queue.\n- **Sofia AI Strategic Ideation** — Sofia researches trends and drafts 3 distinct conceptual angles.\n- **HitL Strategist Review** — Picks the winning angle, triggers a revision iteration, or cancels.\n\n### 🎨 Phase 2 — Marcus Post Content\n\n- **Internal Handoff** — Incoming approved strategical angles trigger Marcus via webhook.\n- **Marcus AI Execution** — Drafts channel-native copy and details visual directions optimized for the Flux/Recraft/v4 generator.\n- **Recraft model Asset Generation** — Renders the high-fidelity ad creative with text overlays.\n- **HitL Editor Gate** — Human-in-the-loop review approves, cancels, or routes revisions to Marcus.\n\n### 👑 Phase 3 — Taylor Approval\n\n- **Taylor AI Audit** — Automated auditor cross-checks post text and images against tone, visual standards, and banned words.\n- ** HitL Final Decision Sign-off** — Human executive approves for scheduled publication, cancels, or sends back to Marcus or Sofia with revision logs.\n\n## Live run video https://youtu.be/rJ5n9Nq9CSc"},"typeVersion":1},{"id":"5ec0ad13-e8d1-405d-940d-89d027d4c725","name":"Sticky Note16","type":"n8n-nodes-base.stickyNote","position":[-4512,1696],"parameters":{"color":"#FEFFA8","width":784,"height":688,"content":"# ⚙️ Setup Guide\n\n##  1. Google Sheets Setup (Pre-configured)\n\n- No need to rebuild database schemas manually! Download our pre-configured templates using the public Drive link:  \n👉 [Google Drive Templates](https://drive.google.com/drive/folders/1uhw8HB5r3Q4UrkHv63PyxKpH5Fk7mSzq?usp=drive_link)\n- Import these into your Google Drive and authorize your **Google Sheets OAuth2 credentials** within all Sheet nodes.\n\n##  2. Slack Setup (Manual Deployment Note)\n\n- Slack requires explicit scopes and setup in the Slack Web UI to run this dashboard:\n  - Ensure your Slack App manifest has the `chat:write` scope active.\n  - Invite your app to your target social operations channel.\n  - Copy your **Slack Channel ID** (e.g., `C0B5JFMJK6E`) and paste it directly into the **Channel ID parameter field** inside all Slack nodes.\n  - Create \"CREATE NEW BRIEF\" bookmark in Slack channel - point to Sofia Brief Intake Form node.\n\n## 🔗 3. Webhook Canvas Isolation (Clean Architecture)\n\n- To keep the canvas clean and prevent an overlapping mess of connection lines, this layout uses **decoupled webhooks** to pass payloads:\n  - **Webhook URLs** — On import, n8n randomizes your webhook paths (Marcus Webhook & Taylor Webhook).\n  - **Update Nodes** — Copy these new paths from your webhook nodes and paste them into the **target URL parameters** of the matching outbound triggers (To Marcus and To Taylor).\n- **Note:** Since executions break into separate processes across webhooks, track state updates using your **central Sheet logs**!s/components/sticky-notes/)\n\n##  4. Update Other Creds\n### Update your LLM tool node Creds. Update your image gen in 'Flux' node (recraft used from fal.ai as a cost efficient model that CAN render perfect text overlays).\n"},"typeVersion":1},{"id":"55f08712-fdec-4b84-9871-be5fd177ad30","name":"Sticky Note17","type":"n8n-nodes-base.stickyNote","position":[-1088,640],"parameters":{"color":7,"width":352,"height":224,"content":"## 🔄 Wait Node: Parallel Form Resume Trick\n\n## Cross-Execution Token Binding\n\n- When n8n pauses an execution thread at a **Wait node** to generate a manual approval form, parallel branches can struggle to pass state keys downstream.\n- This workflow uses a neat architecture: the parallel Slack notification node carries the `$execution.resumeFormUrl` expression. Because this is broadcasted right as the execution reaches the wait state, teams can securely click the **interactive link in Slack** to submit approvals without losing workflow metadata or context flags.\n"},"typeVersion":1},{"id":"58284c16-c60e-4a83-b8ee-12af1e440cb6","name":"Sticky Note29","type":"n8n-nodes-base.stickyNote","position":[-96,3440],"parameters":{"color":7,"width":560,"height":272,"content":"## 🔁 Revision Logic: Taylor to Marcus Hook\n\n## Closed-Loop Production Corrections\n\n- If Taylor rejects a draft post in the final phase, she can trigger a revision directly back to Marcus instead of resetting the strategy phase with Sofia.\n- This handoff re-enters the active production environment via the **Taylor-Marcus Revise webhook**.\n- Marcus AI calls its custom retrieval tool to compare previous attempts, processes the revision comments, and outputs a revised post under an updated brief suffix (e.g., `...-002`)."},"typeVersion":1},{"id":"ef4d8786-3b88-4b78-9044-15fe040c44fa","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[-4496,624],"parameters":{"color":"#3D3D3D","width":784,"content":"## * n8n May Community Challenge Winner * https://www.youtube.com/watch?v=WjafiTfvp0Q at 1:01:33 "},"typeVersion":1},{"id":"66433763-f86f-4e35-bd08-ca207eb614f3","name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[-2544,1136],"parameters":{"color":7,"width":1456,"height":464,"content":"## AI Strategy research and creation\n### DB write"},"typeVersion":1},{"id":"21175709-f70c-43f0-8232-2f0401aa07cc","name":"Sticky Note30","type":"n8n-nodes-base.stickyNote","position":[-2848,1968],"parameters":{"color":7,"width":1664,"height":528,"content":"## AI content creation and media generation\n### DB write"},"typeVersion":1},{"id":"afa9b01e-374e-4584-8447-32dae9fe1fea","name":"Sticky Note31","type":"n8n-nodes-base.stickyNote","position":[-2240,2896],"parameters":{"color":7,"width":768,"height":464,"content":"## AI review and post approval\n### DB write"},"typeVersion":1},{"id":"cf9226b8-0be4-4410-b584-25ec4acb791d","name":"Sticky Note32","type":"n8n-nodes-base.stickyNote","position":[-912,2704],"parameters":{"color":4,"width":1056,"height":112,"content":""},"typeVersion":1},{"id":"6ede1204-8913-4120-9244-c914fe56178a","name":"Sticky Note33","type":"n8n-nodes-base.stickyNote","position":[128,1840],"parameters":{"color":4,"width":320,"height":112,"content":"## Approved"},"typeVersion":1},{"id":"49cc5985-bd12-4f33-a307-56dddf992c8a","name":"Sticky Note34","type":"n8n-nodes-base.stickyNote","position":[-496,1840],"parameters":{"color":4,"width":624,"height":112,"content":""},"typeVersion":1},{"id":"21382b80-bba9-4daf-9f40-d68e85de2a53","name":"Sticky Note35","type":"n8n-nodes-base.stickyNote","position":[-496,1088],"parameters":{"color":4,"width":624,"height":112,"content":""},"typeVersion":1},{"id":"a03b346f-8231-4dee-8976-0884a2ceba03","name":"Sticky Note36","type":"n8n-nodes-base.stickyNote","position":[128,1088],"parameters":{"color":4,"width":320,"height":112,"content":"## Approved"},"typeVersion":1},{"id":"92305716-0246-4ec0-b17d-59f0403a3171","name":"Sticky Note37","type":"n8n-nodes-base.stickyNote","position":[-496,1312],"parameters":{"color":"#4A4B11","width":624,"height":96,"content":""},"typeVersion":1}],"active":true,"pinData":{},"settings":{"binaryMode":"separate","executionOrder":"v1"},"versionId":"31369d04-730f-454c-a6a2-ae812f41ad50","nodeGroups":[],"connections":{"If":{"main":[[{"node":"Revise Instruct to Marcus","type":"main","index":0}],[{"node":"👑 Revise Mssg Sofia","type":"main","index":0}]]},"Flux":{"main":[[{"node":"DB - Log Content","type":"main","index":0}]]},"TB-01":{"main":[[]]},"TB-02":{"main":[[{"node":"Parse — Brief Fields","type":"main","index":0}]]},"parse":{"ai_outputParser":[[{"node":"Marcus AI","type":"ai_outputParser","index":0}]]},"Serper":{"ai_tool":[[{"node":"Sofia AI","type":"ai_tool","index":0}]]},"Tavily":{"ai_tool":[[{"node":"Marcus AI","type":"ai_tool","index":0}]]},"parse1":{"ai_outputParser":[[{"node":"Taylor AI","type":"ai_outputParser","index":0}]]},"Read DB":{"ai_tool":[[{"node":"Marcus AI","type":"ai_tool","index":0}]]},"Sofia AI":{"main":[[{"node":"OBJECTS Sofia","type":"main","index":0}]]},"DB Client":{"main":[[{"node":"Marcus AI","type":"main",