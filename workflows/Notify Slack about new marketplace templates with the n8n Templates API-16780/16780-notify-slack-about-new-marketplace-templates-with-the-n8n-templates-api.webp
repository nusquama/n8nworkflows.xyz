{"id":"WTzdLjbritEwzYi4","meta":{"instanceId":"80897ea1339d978a55fa25e26fed1bffe362c5aa715796ed59f0f9d7e991c16c"},"name":"n8n Template Notifier","tags":[],"nodes":[{"id":"e1e4c42f-01b7-4e07-b678-253a9bd210e9","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[0,0],"parameters":{"width":480,"height":768,"content":"## n8n Template Notifier\n\n### How it works\n\nThis workflow runs twice daily to monitor the n8n template catalog for new templates in a configured category. It fetches recent templates from the n8n API, extracts metadata, and uses workflow static data as a cache to detect templates that have not been seen before. When new templates are found, it posts a formatted Slack digest; when none are found, it can optionally post a quiet all-clear message.\n\n### Setup steps\n\n- Configure the schedule trigger times to match when you want checks to run.\n- Update the Configuration node values for categorySlug, slackChannel, templatesToCheck, and reportEvenIfNone.\n- Connect Slack credentials to the Slack nodes and ensure the bot has permission to post in the configured channel.\n- Verify the n8n templates API URL and category query match the template collection you want to monitor.\n\n### Customization\n\nAdjust the template category, number of templates checked, Slack message formatting, or the all-clear behavior to fit your team's notification preferences."},"typeVersion":1},{"id":"0afb7dab-8e4e-4b91-93b7-55ecfb84dfd0","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[560,128],"parameters":{"color":7,"width":432,"height":400,"content":"## Schedule and options\n\nStarts the workflow twice daily and sets the monitoring options, including the template category, Slack channel, number of templates to check, and whether to report when no new templates are found."},"typeVersion":1},{"id":"3fc316ca-6ad3-4c0c-896d-a0a05bd000bb","name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[1024,128],"parameters":{"color":7,"width":672,"height":400,"content":"## Fetch and compare templates\n\nCalls the n8n templates API, extracts the relevant template metadata, and compares the latest template IDs against workflow static data used as a persistent cache."},"typeVersion":1},{"id":"c668ccd1-db2e-4a0a-ac5e-a0c373dc126e","name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[1728,128],"parameters":{"color":7,"height":400,"content":"## Check for new items\n\nSplits execution based on whether the cache comparison found any new templates."},"typeVersion":1},{"id":"91d543ba-d830-4dab-b683-b2058a29b282","name":"Sticky Note4","type":"n8n-nodes-base.stickyNote","position":[2032,0],"parameters":{"color":7,"width":496,"height":320,"content":"## Send template digest\n\nFormats a Slack digest for newly discovered templates and posts it to the configured Slack channel."},"typeVersion":1},{"id":"4ca3afd1-8d4a-4129-980e-fe952098b2bb","name":"Sticky Note5","type":"n8n-nodes-base.stickyNote","position":[2032,352],"parameters":{"color":7,"width":496,"height":320,"content":"## Optional all-clear message\n\nHandles the no-new-templates path by checking whether quiet reports are enabled and, if so, sending an all-clear Slack message."},"typeVersion":1},{"id":"dc28f2ff-cb67-480a-bb89-8d2116096463","name":"Twice-Daily Trigger Every 2 Hours","type":"n8n-nodes-base.scheduleTrigger","position":[608,320],"parameters":{"rule":{"interval":[{"field":"hours","hoursInterval":2}]}},"typeVersion":1.3},{"id":"14f7c866-fe85-40c6-b53d-6c60a23735f3","name":"Set Template Check Configuration","type":"n8n-nodes-base.set","position":[848,320],"parameters":{"options":{},"assignments":{"assignments":[{"id":"categorySlug","name":"categorySlug","type":"string","value":"your-preferred-category"},{"id":"slackChannel","name":"slackChannel","type":"string","value":"#your-slack-channel"},{"id":"templatesToCheck","name":"templatesToCheck","type":"number","value":5},{"id":"reportEvenIfNone","name":"reportEvenIfNone","type":"boolean","value":false}]}},"typeVersion":3.4},{"id":"0ee88207-e55f-4e7a-a517-ffee81663304","name":"Fetch n8n Templates","type":"n8n-nodes-base.httpRequest","position":[1088,320],"parameters":{"url":"=https://api.n8n.io/templates/search?categories={{ $('Set Template Check Configuration').item.json.categorySlug }}&limit=5","options":{"timeout":60000}},"typeVersion":4.4},{"id":"7848fec5-022e-4950-9332-f9f6af5fb6f9","name":"Check for New Templates","type":"n8n-nodes-base.if","position":[1808,320],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"has-new","operator":{"type":"number","operation":"gt"},"leftValue":"={{ $json.newCount }}","rightValue":0}]}},"typeVersion":2.3},{"id":"e1cacfa4-6374-4e37-a512-f1a9fa82b77f","name":"Decide on Reporting None","type":"n8n-nodes-base.if","position":[2080,512],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"report-none","operator":{"type":"boolean","operation":"equals"},"leftValue":"={{ $('Set Template Check Configuration').item.json.reportEvenIfNone }}","rightValue":true}]}},"typeVersion":2.3},{"id":"a0aaebdd-011a-41d9-a252-79e1be271b19","name":"Extract Metadata from Templates","type":"n8n-nodes-base.code","position":[1328,320],"parameters":{"jsCode":"// Extract relevant fields from the n8n search API response.\n// /templates/search returns { workflows: [...], totalWorkflows: N, filters: [...] }\n\nconst templates = $input.item.json.workflows || [];\nconst config = $('Set Template Check Configuration').item.json;\n\nif (!Array.isArray(templates) || templates.length === 0) {\n  return [];\n}\n\nreturn templates.slice(0, config.templatesToCheck).map(t => ({\n  id: t.id,\n  name: t.name || 'Untitled',\n  description: (t.description || '').substring(0, 160),\n  creator: t.user?.username || t.creator?.name || t.creator?.username || 'Unknown',\n  createdAt: t.createdAt || 'unknown date',\n  url: `https://n8n.io/workflows/${t.id}/`,\n  categorySlug: config.categorySlug,\n  categories: (t.categories || []).map(c => c.name).join(', ')\n}));\n"},"typeVersion":2},{"id":"abb3b172-cce5-49b8-bfcc-085d09456e9b","name":"Identify New Templates","type":"n8n-nodes-base.code","position":[1568,320],"parameters":{"jsCode":"// Workflow static data persists across runs — we use it to track seen template IDs.\nconst wfData = $getWorkflowStaticData('global');\n\n// Initialize seen IDs list if this is the first run\nif (!wfData.seenTemplateIds) {\n  wfData.seenTemplateIds = [];\n}\n\n// Get the templates fetched from the API\nconst incoming = $input.all();\nconst seenSet = new Set(wfData.seenTemplateIds);\n\n// Find templates we haven't seen before\nconst newTemplates = incoming.filter(item => !seenSet.has(item.json.id));\n\n// Mark all incoming as seen (so next run, only truly new templates alert)\nconst newIds = incoming.map(item => item.json.id);\nfor (const id of newIds) {\n  seenSet.add(id);\n}\n\n// Update static data (trim to last 500 to keep it bounded)\nwfData.seenTemplateIds = Array.from(seenSet).slice(-500);\n\nreturn {\n  totalFetched: incoming.length,\n  newCount: newTemplates.length,\n  newTemplates: newTemplates.map(t => t.json),\n  allTemplates: incoming.map(t => t.json)\n};"},"typeVersion":2},{"id":"7cffc55b-c7b4-4b26-b5ca-ab728f080363","name":"Build Slack Message Format","type":"n8n-nodes-base.code","position":[2080,160],"parameters":{"jsCode":"const data = $('Identify New Templates').item.json;\nconst slug = $('Set Template Check Configuration').item.json.categorySlug;\nconst categoryName = slug.charAt(0).toUpperCase() + slug.replace(/-/g, ' ').slice(1);\n\nif (data.newCount === 0) return { message: null };\n\nlet lines = [];\nlines.push(`🆕 *${data.newCount} new ${categoryName} template${data.newCount > 1 ? 's' : ''} on n8n.io*`);\nlines.push('');\n\nfor (const t of data.newTemplates.slice(0, 10)) {\n  const dateStr = t.createdAt ? new Date(t.createdAt).toLocaleDateString('en-ZA', { day: 'numeric', month: 'short' }) : '?';\n  lines.push(`• *${t.name}* — by ${t.creator} (${dateStr})`);\n  if (t.description) {\n    lines.push(`  _${t.description}_`);\n  }\n  lines.push(`  <${t.url}|View on n8n.io>`);\n  lines.push('');\n}\n\nif (data.newCount > 10) {\n  lines.push(`_…and ${data.newCount - 10} more_`);\n}\n\nreturn { message: lines.join('\\n') };"},"typeVersion":2},{"id":"dce02b5f-02b8-408f-b72d-6c775dbd8e86","name":"Send Digest to Slack Channel","type":"n8n-nodes-base.slack","position":[2320,160],"webhookId":"48d849d9-fadf-48be-ac83-5d3dadcd70f8","parameters":{"text":"={{ $json.message }}","select":"channel","channelId":{"__rl":true,"mode":"id","value":"={{ $('Set Template Check Configuration').item.json.slackChannel }}"},"otherOptions":{"includeLinkToWorkflow":true}},"typeVersion":2.5},{"id":"560e1a55-bef5-44be-83ef-5061d9efd9b5","name":"Send Clear Notification to Slack","type":"n8n-nodes-base.slack","position":[2320,512],"webhookId":"459fceae-5eed-4871-bad6-0109ba1bfa48","parameters":{"text":"=✅ *n8n Template Scanner — No new templates*\n\nChecked {{ $('Identify New Templates').item.json.totalFetched }} recent templates in \"{{ $('Set Template Check Configuration').item.json.categorySlug }}\". Nothing new since last check.","select":"channel","channelId":{"__rl":true,"mode":"id","value":"={{ $('Set Template Check Configuration').item.json.slackChannel }}"},"otherOptions":{"includeLinkToWorkflow":true}},"typeVersion":2.5}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","availableInMCP":true,"executionOrder":"v1"},"versionId":"bbe622c1-e7a4-441a-8643-61fb4dc1c124","nodeGroups":[],"connections":{"Fetch n8n Templates":{"main":[[{"node":"Extract Metadata from Templates","type":"main","index":0}]]},"Identify New Templates":{"main":[[{"node":"Check for New Templates","type":"main","index":0}]]},"Check for New Templates":{"main":[[{"node":"Build Slack Message Format","type":"main","index":0}],[{"node":"Decide on Reporting None","type":"main","index":0}]]},"Decide on Reporting None":{"main":[[{"node":"Send Clear Notification to Slack","type":"main","index":0}]]},"Build Slack Message Format":{"main":[[{"node":"Send Digest to Slack Channel","type":"main","index":0}]]},"Extract Metadata from Templates":{"main":[[{"node":"Identify New Templates","type":"main","index":0}]]},"Set Template Check Configuration":{"main":[[{"node":"Fetch n8n Templates","type":"main","index":0}]]},"Twice-Daily Trigger Every 2 Hours":{"main":[[{"node":"Set Template Check Configuration","type":"main","index":0}]]}}}