{"id":"Rq1xLspjak2LaAUD","meta":{"instanceId":"4d371716b55a85c13893d860b962a8d51791e063b737ae53fef7dba00fb601c2"},"name":"Check Due Reminders (Google Calendar + Telegram)","tags":[],"nodes":[{"id":"1af5b947-ea55-4508-bf47-b2ae7f13003c","name":"📋 Setup & Operations","type":"n8n-nodes-base.stickyNote","position":[-560,0],"parameters":{"color":"#FFEE33","width":560,"height":420,"content":"## Setup\n1. **Google Calendar OAuth2** on all Calendar nodes (same calendar ID everywhere).\n2. **Telegram Bot API** → `YOUR_TELEGRAM_GROUP_CHAT_ID`.\n3. **Schedule Trigger**: daily at midnight (timezone = n8n instance)—adjust as needed.\n4. Events are filtered by summary containing your check label (e.g. `BDO Check No.`—edit in IF nodes).\n\n## Operation\n- Daily reminders: today, tomorrow, and rolling week for matching calendar events.\n\n## Credentials\nGoogle Calendar OAuth2 API, Telegram Bot API"},"typeVersion":1},{"id":"f332107c-a961-47b9-b49d-fc1d6c52036c","name":"If item length is zero","type":"n8n-nodes-base.if","position":[752,592],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"3638b066-0f83-4917-b4d0-e13a4e94cf0f","operator":{"type":"boolean","operation":"true","singleValue":true},"leftValue":"={{ Object.keys($items(\"Filter checks due next week\")[0].json).length === 0 }}","rightValue":0}]}},"typeVersion":2.3},{"id":"04697bec-11ba-4975-bf6e-cfb283354e14","name":"Aggregate","type":"n8n-nodes-base.aggregate","position":[976,592],"parameters":{"include":"specifiedFields","options":{},"aggregate":"aggregateAllItemData","fieldsToInclude":"summary, start"},"typeVersion":1},{"id":"f1aaee9d-b523-4269-92af-9f323a9a34e3","name":"Get events today until next week","type":"n8n-nodes-base.googleCalendar","position":[304,592],"parameters":{"options":{},"timeMax":"={{ $now.plus({ weeks: 1 }) }}","timeMin":"={{ $now.minus({ days: 1 }) }}","calendar":{"__rl":true,"mode":"id","value":"user@example.com","cachedResultName":"user@example.com"},"operation":"getAll","returnAll":true},"typeVersion":1.3,"alwaysOutputData":true},{"id":"7ff31825-5d98-4713-946f-47b3e2d455ea","name":"Filter checks due day before","type":"n8n-nodes-base.filter","position":[528,336],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"0b04a4a5-0bae-459a-8112-57d4ac74c9f9","operator":{"type":"dateTime","operation":"before"},"leftValue":"={{ $json.start.date }}","rightValue":"={{ DateTime.now().plus({ hours: 24 }) }}"},{"id":"8dab4e08-0973-4705-869e-b5c813496fea","operator":{"type":"dateTime","operation":"after"},"leftValue":"={{ $json.start.date }}","rightValue":"={{ DateTime.now() }}"}]}},"typeVersion":2.3,"alwaysOutputData":false},{"id":"19af3be1-ed7d-4e25-8c96-5328f17d8df4","name":"Send reminder day before for checks due","type":"n8n-nodes-base.telegram","position":[976,336],"webhookId":"4fb10111-a03c-4f93-a4a9-c46ed3e261ca","parameters":{"text":"=Checks due TOMORROW:\n\n{{ $json.data.map(item => `• ${item.summary} (Date: ${item.start.date})`).join('\\n') }}\n\nFYI. @teammate1, @teammate2","chatId":"YOUR_TELEGRAM_GROUP_CHAT_ID","additionalFields":{"appendAttribution":false}},"typeVersion":1.2},{"id":"3fa3c438-8068-48e7-98c0-410911939a43","name":"Get events for tomorrow","type":"n8n-nodes-base.googleCalendar","position":[304,336],"parameters":{"options":{},"timeMax":"={{ $now.plus({ weeks: 1 }) }}","timeMin":"={{ $now.minus({ days: 1 }) }}","calendar":{"__rl":true,"mode":"id","value":"user@example.com","cachedResultName":"user@example.com"},"operation":"getAll","returnAll":true},"typeVersion":1.3,"alwaysOutputData":true},{"id":"2fa9200b-7a67-4c70-8791-1737b2a69d37","name":"Filter checks due today","type":"n8n-nodes-base.filter","position":[528,80],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typ