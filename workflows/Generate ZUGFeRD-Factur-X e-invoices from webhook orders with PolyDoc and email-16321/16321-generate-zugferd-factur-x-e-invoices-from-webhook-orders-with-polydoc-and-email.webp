{"meta":{},"name":"PolyDoc - Webhook to ZUGFeRD/Factur-X e-invoice","nodes":[{"id":"c1111111-1111-4111-8111-111111111111","name":"Receive order","type":"n8n-nodes-base.webhook","position":[220,380],"webhookId":"polydoc-einvoice","parameters":{"path":"einvoice","options":{},"httpMethod":"POST","responseMode":"responseNode"},"typeVersion":2},{"id":"c2222222-2222-4222-8222-222222222222","name":"Valid order?","type":"n8n-nodes-base.if","position":[460,380],"parameters":{"options":{},"conditions":{"options":{"version":2,"leftValue":"","caseSensitive":true,"typeValidation":"loose"},"combinator":"and","conditions":[{"id":"cond-valid-order","operator":{"type":"boolean","operation":"true","singleValue":true},"leftValue":"={{ !!$json.body.order && Array.isArray($json.body.order.lines) && $json.body.order.lines.length > 0 && (!!$json.body.order.dueDate || !!$json.body.order.paymentTerms) }}","rightValue":""}]}},"typeVersion":2.2},{"id":"c3333333-3333-4333-8333-333333333333","name":"Build e-invoice","type":"n8n-nodes-base.code","position":[700,300],"parameters":{"mode":"runOnceForAllItems","jsCode":"  const order = $input.first().json.body.order;\n  const vatRate = order.vatRate ?? 19;\n\n  let net = 0;\n  const lines = order.lines.map((l) => {\n    const qty = Number(l.quantity);\n    const unit = Number(l.unitPrice);\n    const lineTotal = Math.round(qty * unit * 100) / 100;\n    net += lineTotal;\n    return {\n      description: l.description ? `${l.name} - ${l.description}` : l.name,\n      quantity: qty,\n      unitPrice: unit,\n      lineTotal,\n      vatRate,\n      vatCategoryCode: 'S',\n    };\n  });\n\n  net = Math.round(net * 100) / 100;\n  const tax = Math.round(net * vatRate) / 100;\n  const gross = Math.round((net + tax) * 100) / 100;\n\n  const addr = (a) => ({\n    line1: a.line1 ?? a.street,\n    city: a.city,\n    postalCode: a.postalCode ?? a.postcode,\n    countryCode: a.countryCode,\n  });\n\n  const invoice = {\n    number: order.number,\n    issueDate: order.issueDate,\n    dueDate: order.dueDate,\n    currencyCode: order.currencyCode ?? 'EUR',\n    seller: {\n      name: order.seller.name,\n      address: addr(order.seller.address),\n      taxId: order.seller.taxId,\n      email: order.seller.email,\n    },\n    buyer: {\n      name: order.buyer.name,\n      address: addr(order.buyer.address),\n      email: order.buyer.email,\n    },\n    lines,\n    taxSummary: [{ categoryCode: 'S', rate: vatRate, taxableAmount: net, taxAmount: tax }],\n    paymentTerms: order.paymentTerms,\n    totalNetAmount: net,\n    totalTaxAmount: tax,\n    totalGrossAmount: gross,\n  };\n\n  const money = (n) => `${invoice.currencyCode} ${n.toFixed(2)}`;\n  const rows = lines\n    .map(\n      (l) =>\n        `<tr><td>${l.description}</td><td class=\"r\">${l.quantity}</td><td class=\"r\">${money(l.unitPrice)}</td><td class=\"r\">${money(l.lineTotal)}</td></tr>`,\n    )\n    .join('');\n\n  const html = `<!doctype html><html><head><meta charset=\"utf-8\"><style>\nbody{font-family:Arial,Helvetica,sans-serif;color:#1a1a1a;font-size:12px;margin:40px}\nh1{font-size:20px;margin:0 0 4px}\n.muted{color:#666}\ntable{width:100%;border-collapse:collapse;margin-top:16px}\nth,td{padding:6px 8px;border-bottom:1px solid #ddd}\nth{text-align:left;background:#f5f5f5}\n.r{text-align:right}\n.totals{margin-top:12px;width:260px;float:right}\n.totals td{border:none;padding:2px 8px}\n</style></head><body>\n<h1>Invoice ${invoice.number}</h1>\n<div class=\"muted\">Issued ${invoice.issueDate} &middot; Due ${invoice.dueDate}</div>\n<div style=\"margin-top:16px\"><strong>${invoice.seller.name}</strong><br>${invoice.seller.address.line1}, ${invoice.seller.address.postalCode} ${invoice.seller.address.city}<br>Tax ID ${invoice.seller.taxId}</div>\n<div style=\"margin-top:8px\">Bill to: <strong>${invoice.buyer.name}</strong>, ${invoice.buyer.address.line1}, ${invoice.buyer.address.postalCode} ${invoice.buyer.address.city}</div>\n<table><thead><tr><th>Description</th><th class=\"r\">Qty</th><th class=\"r\">Unit</th><th class=\"r\">Amount</th></tr></thead><tbody>${rows}</tbody></table>\n<table class=\"totals\"><tr><td>Net</td><td class=\"r\">${money(invoice.totalNetAmount)}</td></tr><tr><td>VAT ${vatRate}%</td><td class=\"r\">${money(invoice.totalTaxAmount)}</td></tr><tr><td><strong>Total</strong></td><td class=\"r\"><strong>${money(invoice.totalGrossAmount)}</strong></td></tr></table>\n<div style=\"clear:both;margin-top:24px\" class=\"muted\">Payment terms: ${invoice.paymentTerms}</div>\n</body></html>`;\n\n  return [{ json: { invoice, html, buyerEmail: order.buyer.email } }];"},"typeVersion":2},{"id":"c4444444-4444-4444-8444-444444444444","name":"Generate ZUGFeRD PDF","type":"n8n-nodes-polydoc.polyDoc","position":[940,300],"parameters":{"html":"={{ $json.html }}","invoice":"={{ $json.invoice }}","operation":"einvoice","sourceType":"html","deliveryMode":"download","eInvoiceVerify":true,"eInvoiceProfile":"en16931","additionalFields":{"filename":"=invoice-{{ $json.invoice.number }}.pdf"},"eInvoiceStandard":"zugferd","binaryPropertyName":"data"},"typeVersion":1},{"id":"c5555555-5555-4555-8555-555555555555","name":"Email invoice to buyer","type":"n8n-nodes-base.emailSend","position":[1180,200],"parameters":{"text":"=Hello,\n\nAttached is invoice {{ $('Build e-invoice').item.json.invoice.number }} for {{ $('Build e-invoice').item.json.invoice.currencyCode }} {{ $('Build e-invoice').item.json.invoice.totalGrossAmount }} (ZUGFeRD / Factur-X PDF/A-3).\n\nThank you.","options":{"attachments":"data"},"subject":"=Invoice {{ $('Build e-invoice').item.json.invoice.number }} from {{ $('Build e-invoice').item.json.invoice.seller.name }}","toEmail":"={{ $('Build e-invoice').item.json.buyerEmail }}","fromEmail":"={{ $('Build e-invoice').item.json.invoice.seller.email }}","emailFormat":"text"},"typeVersion":2.1},{"id":"c6666666-6666-4666-8666-666666666666","name":"Return PDF","type":"n8n-nodes-base.respondToWebhook","position":[1180,380],"parameters":{"options":{},"respondWith":"binary"},"typeVersion":1.1},{"id":"c7777777-7777-4777-8777-777777777777","name":"Reject (422)","type":"n8n-nodes-base.respondToWebhook","position":[700,540],"parameters":{"options":{"responseCode":422},"respondWith":"json","responseBody":"={{ { \"error\": \"Invalid order\", \"message\": \"Provide order.lines (1 or more) and either order.dueDate or order.paymentTerms.\" } }}"},"typeVersion":1.1},{"id":"c8888888-8888-4888-8888-888888888888","name":"How to use","type":"n8n-nodes-base.stickyNote","position":[-340,200],"parameters":{"width":460,"height":520,"content":"## Webhook to compliant e-invoice PDF\n\nPOST an **order** to the webhook. The workflow maps it into an EN 16931 invoice (line totals, VAT, tax summary), generates a hybrid **ZUGFeRD / Factur-X** PDF/A-3 (human-readable PDF + embedded XML) with PolyDoc, emails it to the buyer, and returns it to the caller.\n\n**Flow**\n1. Receive order (webhook)\n2. Valid order? guards lines >= 1 and a due date or payment terms (EN 16931 BR-CO-25)\n3. Build e-invoice maps the order to the invoice schema + a printable HTML layer\n4. PolyDoc generates the ZUGFeRD/Factur-X PDF\n5. Email it to the buyer and return it on the webhook response\n\n**Setup**\n1. Add your **PolyDoc API** credential on the *Generate ZUGFeRD PDF* node (key from dashboard.polydoc.tech).\n2. Add an **SMTP** credential on the *Email invoice to buyer* node, or delete that node.\n3. The workflow ships with a pinned sample order, so you can run it right away.\n\nExpected body: `{ \"order\": { \"number\", \"issueDate\", \"dueDate\", \"currencyCode\", \"vatRate\", \"paymentTerms\", \"seller\", \"buyer\", \"lines\": [{ \"name\", \"description\", \"quantity\", \"unitPrice\" }] } }`\n\nFull invoice schema: https://docs.polydoc.tech\n\nPolyDoc generates the compliant document. Transmission (Peppol), archiving and tax-authority reporting are separate.\n\nStart free: https://polydoc.tech/?utm_source=n8n&utm_medium=template&utm_campaign=einvoice"},"typeVersion":1}],"active":false,"pinData":{"Receive order":[{"json":{"body":{"order":{"buyer":{"name":"Contoso SARL","email":"ap@contoso.example","address":{"city":"Paris","line1":"Rue de Rivoli 10","postalCode":"75001","countryCode":"FR"}},"lines":[{"name":"Design retainer","quantity":1,"unitPrice":1800,"description":"June 2026"},{"name":"Stock photography","quantity":4,"unitPrice":50,"description":"License pack"}],"number":"ORD-2026-0042","seller":{"name":"Northwind Studio GmbH","email":"billing@northwind.example","taxId":"DE123456789","address":{"city":"Berlin","line1":"Hauptstrasse 5","postalCode":"10115","countryCode":"DE"}},"dueDate":"2026-07-01","vatRate":19,"issueDate":"2026-06-01","currencyCode":"EUR","paymentTerms":"Net 30"}},"query":{},"params":{},"headers":{"content-type":"application/json"}}}]},"settings":{"executionOrder":"v1"},"connections":{"Valid order?":{"main":[[{"node":"Build e-invoice","type":"main","index":0}],[{"node":"Reject (422)","type":"main","index":0}]]},"Receive order":{"main":[[{"node":"Valid order?","type":"main","index":0}]]},"Build e-invoice":{"main":[[{"node":"Generate ZUGFeRD PDF","type":"main","index":0}]]},"Generate ZUGFeRD PDF":{"main":[[{"node":"Email invoice to buyer","type":"main","index":0},{"node":"Return PDF","type":"main","index":0}]]}}}