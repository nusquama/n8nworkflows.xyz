{"id":"1iSarsa9VoR1XZWx","meta":{"instanceId":"8247b806b0e6f94d28ae959e03ad09e53ffbc2a7aafba4df32b48bec8415d11b","templateCredsSetupCompleted":true},"name":"Financial Documents Assistant (Qdrant + Mistral AI)","tags":[],"nodes":[{"id":"16751b3b-3faa-4b91-b872-46d0febc5774","name":"When clicking \"Test workflow\"","type":"n8n-nodes-base.manualTrigger","position":[1680,2848],"parameters":{},"typeVersion":1},{"id":"6177b2e3-f2e1-44b1-88e5-9c43f196660b","name":"Set Variables","type":"n8n-nodes-base.set","position":[1856,2848],"parameters":{"options":{},"assignments":{"assignments":[{"id":"35ea70c4-8669-4975-a68d-bbaa094713c0","name":"directory","type":"string","value":"/home/node/BankStatements"},{"id":"1d081d19-ff4e-462a-9cbe-7af2244bf87f","name":"file_added","type":"string","value":"={{ $json.event === 'add' && $json.path || ''}}"},{"id":"18f8dc03-51ca-48c7-947f-87ce8e1979bf","name":"file_changed","type":"string","value":"={{ $json.event === 'change' && $json.path || '' }}"},{"id":"65074ff7-037b-4b3b-b2c3-8a61755ab43b","name":"file_deleted","type":"string","value":"={{ $json.event === 'unlink' && $json.path || '' }}"},{"id":"9a1902e7-f94d-4d1f-9006-91c67354d3e8","name":"qdrant_collection","type":"string","value":"local_file_search"}]}},"typeVersion":3.3},{"id":"c3103584-e209-40a0-9be7-fb4dd2f8fcf6","name":"Read File","type":"n8n-nodes-base.readWriteFile","position":[2368,3264],"parameters":{"options":{},"fileSelector":"={{ $json.file_added }}"},"typeVersion":1},{"id":"947a7b95-a6f3-4d04-8045-6aabb31f7a19","name":"Embeddings Mistral Cloud","type":"@n8n/n8n-nodes-langchain.embeddingsMistralCloud","position":[2736,3424],"parameters":{"options":{}},"typeVersion":1},{"id":"37041aba-d25d-4f31-bf88-912ac10aea76","name":"Default Data Loader","type":"@n8n/n8n-nodes-langchain.documentDefaultDataLoader","position":[2848,3424],"parameters":{"options":{"metadata":{"metadataValues":[{"name":"filter_by_filename","value":"={{ $json.file_location }}"},{"name":"filter_by_created_month","value":"={{ $now.year + '-' + $now.monthShort }}"},{"name":"filter_by_created_week","value":"={{ $now.year + '-' + $now.monthShort + '-W' + $now.weekNumber }}"}]}},"jsonData":"={{ $json.data }}","jsonMode":"expressionData"},"typeVersion":1},{"id":"ea548be9-a9a7-4a1d-a6ee-8383a3215c61","name":"Recursive Character Text Splitter","type":"@n8n/n8n-nodes-langchain.textSplitterRecursiveCharacterTextSplitter","position":[2864,3568],"parameters":{"options":{}},"typeVersion":1},{"id":"52aa456b-3c2b-43d7-bcc8-e3f14ab6f6af","name":"Prepare Embedding Document","type":"n8n-nodes-base.set","position":[2544,3264],"parameters":{"options":{},"assignments":{"assignments":[{"id":"41a1d4ca-e5a5-4fb9-b249-8796ae759b33","name":"data","type":"string","value":"=## file location\n{{ [$json.directory, $json.fileName].join('/') }}\n## file created\n{{ $now.toISO() }}\n## file contents\n{{ $input.item.binary.data.data.base64Decode() }}"},{"id":"c091704d-b81c-448b-8c90-156ef568b871","name":"file_location","type":"string","value":"={{ [$json.directory, $json.fileName].join('/') }}"}]}},"typeVersion":3.3},{"id":"32e46086-5cfa-40be-96e4-dda0492b982b","name":"Remap for File_Added Flow","type":"n8n-nodes-base.set","position":[2944,2768],"parameters":{"options":{},"assignments":{"assignments":[{"id":"840219e1-ed47-4b00-83fd-6b3c0bd71650","name":"file_added","type":"string","value":"={{ $('Set Variables').item.json.file_changed }}"}]}},"typeVersion":3.3},{"id":"52d161ba-ecc9-45a0-af90-cefa531d47f6","name":"Search For Existing Point","type":"n8n-nodes-base.httpRequest","position":[2400,2512],"parameters":{"url":"=http://qdrant:6333/collections/{{ $('Set Variables').item.json.qdrant_collection }}/points/scroll","method":"POST","options":{},"jsonBody":"={\n \"filter\": {\n \"must\": [\n {\n \"key\": \"metadata.filter_by_filename\",\n \"match\": {\n \"value\": \"{{ $json.file_changed }}\"\n }\n }\n ]\n },\n \"limit\": 1,\n \"with_payload\": false,\n \"with_vector\": false\n}","sendBody":true,"specifyBody":"json","authentication":"predefinedCredentialType","nodeCredentialType":"qdrantApi"},"typeVersion":4.2},{"id":"7b4e4c77-b9db-4507-b2fa-94b65191b48b","name":"Has Existing Point?","type":"n8n-nodes-base.if","position":[2576,2512],"parameters":{"options":{},"conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"0392bac0-8fb5-406b-b59f-575edf5ab30d","operator":{"type":"array","operation":"notEmpty","singleValue":true},"leftValue":"={{ $json.result.points }}","rightValue":""}]}},"typeVersion":2},{"id":"034adafc-ccd1-4a87-b6b0-9cb967e4d37c","name":"Delete Existing Point","type":"n8n-nodes-base.httpRequest","position":[2736,2768],"parameters":{"url":"=http://qdrant:6333/collections/{{ $('Set Variables').item.json.qdrant_collection }}/points/delete","method":"POST","options":{},"sendBody":true,"authentication":"predefinedCredentialType","bodyParameters":{"parameters":[{"name":"points","value":"={{ $json.result.points.map(point => point.id) }}"}]},"nodeCredentialType":"qdrantApi"},"typeVersion":4.2},{"id":"e57c55b2-f634-4625-9180-8718a4263514","name":"Search For Existing Point1","type":"n8n-nodes-base.httpRequest","position":[2368,2768],"parameters":{"url":"=http://qdrant:6333/collections/{{ $('Set Variables').item.json.qdrant_collection }}/points/scroll","method":"POST","options":{},"jsonBody":"={\n \"filter\": {\n \"must\": [\n {\n \"key\": \"metadata.filter_by_filename\",\n \"match\": {\n \"value\": \"{{ $json.file_changed }}\"\n }\n }\n ]\n },\n \"limit\": 1,\n \"with_payload\": false,\n \"with_vector\": false\n}","sendBody":true,"specifyBody":"json","authentication":"predefinedCredentialType","nodeCredentialType":"qdrantApi"},"typeVersion":4.2},{"id":"fdfcdbf7-6c3b-469f-a7f4-c170f3971f3c","name":"Has Existing Point?1","type":"n8n-nodes-base.if","position":[2544,2768],"parameters":{"options":{},"conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"0392bac0-8fb5-406b-b59f-575edf5ab30d","operator":{"type":"array","operation":"notEmpty","singleValue":true},"leftValue":"={{ $json.result.points }}","rightValue":""}]}},"typeVersion":2},{"id":"ee7f4f70-acfb-47d8-aa85-dec6580256de","name":"Delete Existing Point1","type":"n8n-nodes-base.httpRequest","position":[2752,2512],"parameters":{"url":"=http://qdrant:6333/collections/{{ $('Set Variables').item.json.qdrant_collection }}/points/delete","method":"POST","options":{},"sendBody":true,"authentication":"predefinedCredentialType","bodyParameters":{"parameters":[{"name":"points","value":"={{ $json.result.points.map(point => point.id) }}"}]},"nodeCredentialType":"qdrantApi"},"typeVersion":4.2},{"id":"612da39a-9af3-416b-9d38-c00d58a3df65","name":"Handle File Event","type":"n8n-nodes-base.switch","position":[2016,2848],"parameters":{"rules":{"values":[{"outputKey":"file_deleted","conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"a1f6d86a-9805-4d0e-ac70-90c9cf0ad339","operator":{"type":"string","operation":"notEmpty","singleValue":true},"leftValue":"={{ $json.file_deleted }}","rightValue":""}]},"renameOutput":true},{"outputKey":"file_changed","conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"d15cde67-b5b0-4676-b4fb-ead749147392","operator":{"type":"string","operation":"notEmpty","singleValue":true},"leftValue":"={{ $json.file_changed }}","rightValue":""}]},"renameOutput":true},{"outputKey":"file_added","conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"operator":{"type":"string","operation":"notEmpty","singleValue":true},"leftValue":"={{ $json.file_added }}","rightValue":""}]},"renameOutput":true}]},"options":{}},"typeVersion":3},{"id":"41d35e5c-4c91-4391-89d9-e4b22c7fc970","name":"Qdrant Vector Store","type":"@n8n/n8n-nodes-langchain.vectorStoreQdrant","position":[2720,3264],"parameters":{"mode":"insert","options":{},"qdrantCollection":{"__rl":true,"mode":"id","value":"={{ $('Set Variables').item.json.qdrant_collection }}"}},"typeVersion":1},{"id":"3d7025bb-57b7-4cc2-b14b-07a189826a5f","name":"Overview","type":"n8n-nodes-base.stickyNote","position":[960,2560],"parameters":{"color":7,"width":560,"height":1660,"content":"## 📄 Financial Documents Assistant (Qdrant + Mistral AI)\n\nWatches a local folder of financial documents, keeps a Qdrant vector store in sync as files are added, changed, or deleted, and exposes a Mistral-powered chat agent that answers questions about your bank statements.\n\n**Perfect for:** Finance teams and analysts who want a private, self-hosted RAG assistant over their own financial documents.\n\n---\n\n## How it works\n\n1. **Local File Trigger** — Watches a target folder and fires whenever a file is added, changed, or removed.\n2. **When clicking \"Test workflow\"** — Manual trigger for testing the ingestion path. *(optional path)*\n3. **Set Variables** — Sets the working variables such as file path, collection name, and event type.\n4. **Handle File Event** — Switch node that routes to the correct branch based on whether the file was deleted, updated, or added.\n5. **Search For Existing Point** — Queries Qdrant for the existing vector point of an updated file. *(update branch)*\n6. **Has Existing Point?** — If node that checks whether a matching point was found. *(update branch)*\n7. **Delete Existing Point1** — Removes the stale point from Qdrant before re-indexing. *(update branch)*\n8. **Search For Existing Point1** — Queries Qdrant for the point of a deleted file. *(delete branch)*\n9. **Has Existing Point?1** — If node that checks whether the point exists. *(delete branch)*\n10. **Delete Existing Point** — Purges the deleted file's point from Qdrant. *(delete branch)*\n11. **Remap for File_Added Flow** — Reshapes the data so an updated file re-enters the add/index path.\n12. **Read File** — Reads the document from disk.\n13. **Prepare Embedding Document** — Builds the document payload for embedding.\n14. **Recursive Character Text Splitter** — Chunks the document text.\n15. **Default Data Loader** — Wraps the chunks as LangChain documents.\n16. **Embeddings Mistral Cloud** — Generates embeddings via Mistral for ingestion.\n17. **Qdrant Vector Store** — Inserts the embedded chunks into the Qdrant collection.\n18. **Chat Trigger** — Starts the Q&A flow when a user sends a chat message.\n19. **Question and Answer Chain** — Retrieval QA chain that answers the question from stored documents.\n20. **Mistral Cloud Chat Model** — Mistral LLM that generates the answer.\n21. **Vector Store Retriever** — Retrieves the relevant chunks for the question.\n22. **Qdrant Vector Store1** — Qdrant collection used as the retrieval source.\n23. **Embeddings Mistral Cloud1** — Embeds the query for similarity search.\n\n---\n\n## Setup (~15 minutes)\n\n1. **Target folder** — In *Local File Trigger*, set the folder path n8n can access (a Docker volume or mounted host folder).\n2. **Mistral Cloud** — Add your Mistral API key in *Embeddings Mistral Cloud*, *Embeddings Mistral Cloud1*, and *Mistral Cloud Chat Model*.\n3. **Qdrant** — Set your Qdrant URL and API key in *Qdrant Vector Store*, *Qdrant Vector Store1*, and the *Search/Delete Existing Point* HTTP nodes.\n4. **Collection** — Make sure the Qdrant collection name in *Set Variables* matches across every node.\n> Requires a running Qdrant instance and a self-hosted n8n with disk access to the watched folder. The manual trigger is for testing the ingestion path only."},"typeVersion":1},{"id":"3ff08518-8742-470a-ab53-dbe39dc3226a","name":"Section: Watch & Route","type":"n8n-nodes-base.stickyNote","position":[1584,2624],"parameters":{"color":5,"width":660,"height":606,"content":"## 1️⃣ Watch the Folder and Route Events\n\nThe **Local File Trigger** watches your target folder and fires on any add, change, or delete, while **When clicking \"Test workflow\"** lets you run the ingestion path manually. **Set Variables** prepares the file path and collection details, then the **Handle File Event** switch routes each run down the deleted, updated, or added branch."},"typeVersion":1},{"id":"7e94f14c-2da9-4945-baee-572f62e91df5","name":"Section: Sync Qdrant","type":"n8n-nodes-base.stickyNote","position":[2272,2288],"parameters":{"color":3,"width":940,"height":780,"content":"## 2️⃣ Keep Qdrant in Sync\n\nWhen a file is updated or deleted, these branches keep the vector store clean. **Search For Existing Point** and **Search For Existing Point1** look up the file's point in Qdrant, **Has Existing Point?** and **Has Existing Point?1** confirm it exists, and **Delete Existing Point** and **Delete Existing Point1** purge the stale vectors. **Remap for File_Added Flow** then funnels updated files back into the indexing path."},"typeVersion":1},{"id":"9ce6a5c4-3525-4eba-b09c-fa55537ba724","name":"Section: Embed & Store","type":"n8n-nodes-base.stickyNote","position":[2272,3088],"parameters":{"color":6,"width":860,"height":640,"content":"## 3️⃣ Embed and Store Documents\n\n**Read File** loads the document from disk and **Prepare Embedding Document** builds its payload. The **Recursive Character Text Splitter** chunks the text, the **Default Data Loader** wraps it for LangChain, and **Embeddings Mistral Cloud** turns each chunk into a vector before **Qdrant Vector Store** writes them into your collection."},"typeVersion":1}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","executionOrder":"v1"},"versionId":"31bfbfa7-4c8b-4ea2-9fac-37b110b16fd9","nodeGroups":[],"connections":{"Read File":{"main":[[{"node":"Prepare Embedding Document","type":"main","index":0}]]},"Set Variables":{"main":[[{"node":"Handle File Event","type":"main","index":0}]]},"Handle File Event":{"main":[[{"node":"Search For Existing Point","type":"main","index":0}],[{"node":"Search For Existing Point1","type":"main","index":0}],[{"node":"Read File","type":"main","index":0}]]},"Default Data Loader":{"ai_document":[[{"node":"Qdrant Vector Store","type":"ai_document","index":0}]]},"Has Existing Point?":{"main":[[{"node":"Delete Existing Point1","type":"main","index":0}]]},"Has Existing Point?1":{"main":[[{"node":"Delete Existing Point","type":"main","index":0}]]},"Delete Existing Point":{"main":[[{"node":"Remap for File_Added Flow","type":"main","index":0}]]},"Embeddings Mistral Cloud":{"ai_embedding":[[{"node":"Qdrant Vector Store","type":"ai_embedding","index":0}]]},"Remap for File_Added Flow":{"main":[[{"node":"Read File","type":"main","index":0}]]},"Search For Existing Point":{"main":[[{"node":"Has Existing Point?","type":"main","index":0}]]},"Prepare Embedding Document":{"main":[[{"node":"Qdrant Vector Store","type":"main","index":0}]]},"Search For Existing Point1":{"main":[[{"node":"Has Existing Point?1","type":"main","index":0}]]},"When clicking \"Test workflow\"":{"main":[[{"node":"Set Variables","type":"main","index":0}]]},"Recursive Character Text Splitter":{"ai_textSplitter":[[{"node":"Default Data Loader","type":"ai_textSplitter","index":0}]]}}}