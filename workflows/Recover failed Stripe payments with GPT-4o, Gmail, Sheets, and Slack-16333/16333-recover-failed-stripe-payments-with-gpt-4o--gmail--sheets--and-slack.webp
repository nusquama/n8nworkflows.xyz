{"id":"7f14aa7e50c5294e","meta":{},"name":"Score customer churn risk and draft win-back emails in Gmail using OpenAI","tags":[{"name":"customer-retention"},{"name":"churn"},{"name":"win-back"},{"name":"crm"},{"name":"gmail"},{"name":"google-sheets"},{"name":"openai"},{"name":"ai"}],"nodes":[{"id":"b90d1d23-cff1-46d5-9379-4a6c3a3bb68c","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[-640,-176],"parameters":{"width":480,"height":656,"content":"## Score customer churn risk and draft win-back emails in Gmail using OpenAI\n\n## How it works\n\n1. Schedules the win-back process to run daily.\n2. Reads customer data from Google Sheets.\n3. Scores each customer's churn risk using OpenAI.\n4. Drafts emails for high-risk customers in Gmail.\n5. Logs actions and alerts the team using Google Sheets and Slack.\n\n## Setup steps\n\n- [ ] Set up Google Sheets account access for customer data.\n- [ ] Configure OpenAI API credentials for churn scoring.\n- [ ] Ensure Gmail account is linked for sending emails.\n- [ ] Set up Google Sheets for logging win-back efforts.\n- [ ] Integrate Slack account for team alerts.\n\n## Customization\n\nAdjust the churn risk threshold in the 'High Risk?' node to customize email targeting."},"typeVersion":1},{"id":"1c0e3537-c543-4530-bee9-c5018e1fa094","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[-80,-128],"parameters":{"color":7,"width":432,"height":304,"content":"## Schedule and read data\n\nTriggers daily and fetches customer data from Google Sheets."},"typeVersion":1},{"id":"a6f68ae9-e7c2-4cff-a362-767f78ee806f","name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[400,-112],"parameters":{"color":7,"width":640,"height":480,"content":"## Analyze churn risk\n\nScores customer churn risk and drafts win-back strategy."},"typeVersion":1},{"id":"61f73778-14ef-4616-aaef-e79ca251b0cf","name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[1072,-176],"parameters":{"color":7,"width":432,"height":544,"content":"## Decide and draft email\n\nBranches between high and low risk and drafts Gmail emails for high risk."},"typeVersion":1},{"id":"ec944323-4317-4fff-abb7-ebaa4014a51c","name":"Sticky Note4","type":"n8n-nodes-base.stickyNote","position":[1552,-176],"parameters":{"color":7,"width":432,"height":304,"content":"## Log and alert\n\nLogs the action to Google Sheets and sends an alert to Slack."},"typeVersion":1},{"id":"83935c8a-2a68-46d1-ac85-9421076459fd","name":"When Win-back Daily at 8am","type":"n8n-nodes-base.scheduleTrigger","position":[-40,0],"parameters":{"rule":{"interval":[{"field":"days","triggerAtHour":8}]}},"typeVersion":1.2},{"id":"376aec60-9e6a-425c-bbac-c3a739855fca","name":"Read Customers from Sheets","type":"n8n-nodes-base.googleSheets","position":[200,0],"parameters":{"options":{},"sheetName":{"__rl":true,"mode":"list","value":"Customers"},"documentId":{"__rl":true,"mode":"url","value":"https://docs.google.com/spreadsheets/d/REPLACE_ID/edit"}},"typeVersion":4.5},{"id":"4b4c4e8e-14fe-4822-89c3-87286b6eb102","name":"Analyze Churn and Draft Email","type":"@n8n/n8n-nodes-langchain.chainLlm","position":[440,0],"parameters":{"text":"=You are a customer-retention specialist. For this customer, estimate churn risk (0-100) and a risk level (high/medium/low), give the single biggest reason, recommend a win-back offer, and write a short, warm win-back email (subject + body, under 130 words) referencing their situation.\n\nName: {{ $json.name }}\nPlan: {{ $json.plan }}\nMonthly value: {{ $json.monthly_value }}\nDays since last active: {{ $json.last_active_days }}\nUsage trend: {{ $json.usage_trend }}","promptType":"define","hasOutputParser":true},"typeVersion":1.5},{"id":"9d9b1517-13bf-4e11-9a35-355e3878702f","name":"OpenAI Retention Model","type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","position":[440,220],"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4o","cachedResultName":"gpt-4o"},"options":{"temperature":0.4}},"typeVersion":1.2},{"id":"d23e70f9-fad4-469e-b387-e330b021ee40","name":"Parse Churn Schema","type":"@n8n/n8n-nodes-langchain.outputParserStructured","position":[660,220],"parameters":{"schemaType":"fromJson","jsonSchemaExample":"{\n  \"risk_score\": 78,\n  \"risk_level\": \"high\",\n  \"reason\": \"Logins dropped 60% this month and the renewal is in 2 weeks.\",\n  \"recommended_offer\": \"Offer a 1:1 onboarding call + 20% loyalty discount.\",\n  \"email\": {\n    \"subject\": \"We'd love to keep helping you\",\n    \"body\": \"Hi there, I noticed you haven't been around lately...\"\n  }\n}"},"typeVersion":1.2},{"id":"bd9cf2e0-8944-4ebe-b3fa-17f4e26bb635","name":"Set Customer Risk Details","type":"n8n-nodes-base.set","position":[880,0],"parameters":{"options":{},"assignments":{"assignments":[{"id":"8f205c3d-83b9-4f02-8406-e1fd673c8e31","name":"name","type":"string","value":"={{ $('Read Customers from Sheets').item.json.name }}"},{"id":"a3b8e943-3a4a-411f-a114-733ed9bdcde0","name":"email","type":"string","value":"={{ $('Read Customers from Sheets').item.json.email }}"},{"id":"ad33f909-e85a-4ba4-b427-2309060f6fc3","name":"risk_score","type":"number","value":"={{ $json.output.risk_score }}"},{"id":"5c7c2c1c-819f-4ba4-9809-e81d41e2d442","name":"risk_level","type":"string","value":"={{ $json.output.risk_level }}"},{"id":"af85de51-a41b-4301-94b1-922fe706a427","name":"reason","type":"string","value":"={{ $json.output.reason }}"},{"id":"a24815a7-e5a7-4cb2-bad1-25ea1385366c","name":"offer","type":"string","value":"={{ $json.output.recommended_offer }}"},{"id":"3e43e693-6688-43b4-b165-7eda2e175ad3","name":"subject","type":"string","value":"={{ $json.output.email.subject }}"},{"id":"c0a119f3-c407-457c-b374-d432009d2b5f","name":"body","type":"string","value":"={{ $json.output.email.body }}"},{"id":"598bb2a3-8a85-4ae7-9112-9e9da8e0bd10","name":"scored_at","type":"string","value":"={{ $now.toISO() }}"}]}},"typeVersion":3.4},{"id":"6a030cbe-3f5f-4983-8f7f-375263f784a0","name":"If High Churn Risk","type":"n8n-nodes-base.if","position":[1120,0],"parameters":{"conditions":{"options":{"typeValidation":"loose"},"combinator":"and","conditions":[{"operator":{"type":"string","operation":"equals"},"leftValue":"={{ $json.risk_level }}","rightValue":"high"}]}},"typeVersion":2},{"id":"c349876a-ebae-45ef-b66c-443b029be019","name":"Skip Lower Risk Customers","type":"n8n-nodes-base.noOp","position":[1120,200],"parameters":{},"typeVersion":1},{"id":"69efab91-b6be-4edd-9bb3-364e9f624a18","name":"Draft Win-back Email via Gmail","type":"n8n-nodes-base.gmail","position":[1360,-40],"parameters":{"message":"={{ $json.body }}","options":{"sendTo":"={{ $json.email }}"},"subject":"={{ $json.subject }}","resource":"draft"},"typeVersion":2.1},{"id":"2d6c6604-06d3-45d9-a264-f38cb22697c5","name":"Append to Win-back Log Sheets","type":"n8n-nodes-base.googleSheets","position":[1600,-40],"parameters":{"columns":{"value":{},"mappingMode":"autoMapInputData"},"options":{},"operation":"append","sheetName":{"__rl":true,"mode":"list","value":"Win-back"},"documentId":{"__rl":true,"mode":"url","value":"https://docs.google.com/spreadsheets/d/REPLACE_ID/edit"}},"typeVersion":4.5},{"id":"34d4c881-1d54-461f-9864-8b0950b5555d","name":"Post Alert to Slack Channel","type":"n8n-nodes-base.slack","position":[1840,-40],"parameters":{"text":"=:warning: At-risk customer — {{ $json.name }} ({{ $json.risk_score }}/100). {{ $json.reason }} A win-back draft is ready in Gmail. Suggested offer: {{ $json.offer }}","select":"channel","resource":"message","channelId":{"__rl":true,"mode":"name","value":"#retention"},"operation":"post","otherOptions":{}},"typeVersion":2.2}],"active":false,"pinData":{},"settings":{"executionOrder":"v1"},"connections":{"If High Churn Risk":{"main":[[{"node":"Draft Win-back Email via Gmail","type":"main","index":0}],[{"node":"Skip Lower Risk Customers","type":"main","index":0}]]},"Parse Churn Schema":{"ai_outputParser":[[{"node":"Analyze Churn and Draft Email","type":"ai_outputParser","index":0}]]},"OpenAI Retention Model":{"ai_languageModel":[[{"node":"Analyze Churn and Draft Email","type":"ai_languageModel","index":0}]]},"Set Customer Risk Details":{"main":[[{"node":"If High Churn Risk","type":"main","index":0}]]},"Read Customers from Sheets":{"main":[[{"node":"Analyze Churn and Draft Email","type":"main","index":0}]]},"When Win-back Daily at 8am":{"main":[[{"node":"Read Customers from Sheets","type":"main","index":0}]]},"Analyze Churn and Draft Email":{"main":[[{"node":"Set Customer Risk Details","type":"main","index":0}]]},"Append to Win-back Log Sheets":{"main":[[{"node":"Post Alert to Slack Channel","type":"main","index":0}]]},"Draft Win-back Email via Gmail":{"main":[[{"node":"Append to Win-back Log Sheets","type":"main","index":0}]]}}}