{"id":"6uL5evqwLGYYEKL6","meta":{"instanceId":"760a32067d6a65474de3247d153123b70374ce2216154b9fff06770ede115f75","templateCredsSetupCompleted":true},"name":"Daily reports from lists in ClickUp","tags":[],"nodes":[{"id":"c137a65c-ec04-4dc3-b4e4-02d194bb8686","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[-608,-240],"parameters":{"width":480,"height":896,"content":"## Daily reports from lists in ClickUp\n\n### How it works\n\nThis workflow runs on a daily morning schedule to collect tasks from a ClickUp folder or list and prepare them for reporting. It merges the retrieved tasks, verifies that data is present, and then either generates an AI-written summary report in ClickUp or records an error and stops. The success and error paths are visually separated into distinct branches after the data validation step.\n\n### Setup steps\n\n- Configure the Schedule Trigger for the desired daily report time and timezone.\n- Add ClickUp credentials and set the correct workspace, folder, list, and destination locations in the ClickUp nodes.\n- Configure the AI Agent chat model credentials, including the OpenRouter/API key and preferred model.\n- Review the ClickUp nodes that create the report and mark errors to ensure they write to the intended list, task, or status fields.\n\n### Customization\n\nAdjust the schedule, ClickUp source folder/list, AI model, and report prompt or formatting to match the team’s daily reporting requirements."},"typeVersion":1},{"id":"db3efc6b-8382-4442-a0af-4102e2875673","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[-48,-32],"parameters":{"color":7,"width":864,"height":304,"content":"## Schedule and gather tasks\n\nStarts the daily morning run, pulls tasks from the configured ClickUp folder or list, merges the task data, and checks whether usable data was retrieved before continuing."},"typeVersion":1},{"id":"b7d353a4-4e84-4a48-a2e3-e824bbca049e","name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[848,-240],"parameters":{"color":7,"width":768,"height":544,"content":"## Generate report summary\n\nHandles the successful path by creating a report list/item in ClickUp, sending the gathered task data through an AI Agent with its chat model, and saving the generated summary report back to ClickUp."},"typeVersion":1},{"id":"714072d3-0786-457b-b93e-e0d4282afa8e","name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[848,336],"parameters":{"color":7,"width":368,"height":336,"content":"## Mark retrieval failure\n\nHandles the failure branch when no data is retrieved by marking an error in ClickUp and then stopping the workflow with an explicit error."},"typeVersion":1},{"id":"c4aa6607-8fd8-4d8e-b11c-a9f27a6ae133","name":"Verify Data Retrieval","type":"n8n-nodes-base.if","position":[672,96],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"daf4a81d-8be5-466b-ab09-14b2c3871a46","operator":{"type":"string","operation":"exists","singleValue":true},"leftValue":"={{ $json.tasksOutput }}","rightValue":""}]}},"typeVersion":2.3},{"id":"6e598704-71c2-4fef-bcc7-f2525467a512","name":"Compile Task Data","type":"n8n-nodes-base.code","position":[448,96],"parameters":{"jsCode":"// Input: array of ClickUp tasks\nconst inputItems = items.map(item => item.json);\n\n// Build ONE object with all tasks merged\nconst aggregatedData = {};\nlet tasksOutput = \"\";\n\ninputItems.forEach((task, index) => {\n  const num = index + 1; // Start numbering from 1\n  \n  // Add each field with numbered suffix\n  aggregatedData[`taskId_${num}`] = task.taskId || \"\";\n  aggregatedData[`name_${num}`] = task.name || \"\";\n  aggregatedData[`description_${num}`] = task.description || \"\";\n  \n  aggregatedData[`createdDate_${num}`] = task.createdDate || \"\";\n  aggregatedData[`dueDate_${num}`] = task.dueDate || \"\";\n  aggregatedData[`updatedDate_${num}`] = task.updatedDate || \"\";\n  \n  aggregatedData[`status_${num}`] = task.status || \"\";\n  aggregatedData[`priority_${num}`] = task.priority || \"\";\n  \n  aggregatedData[`customFields_${num}`] = task.customFields ? JSON.stringify(task.customFields) : \"\";\n  aggregatedData[`tags_${num}`] = task.tags || \"\";\n  \n  aggregatedData[`listId_${num}`] = task.listId || \"\";\n  aggregatedData[`folderId_${num}`] = task.folderId || \"\";\n  aggregatedData[`spaceId_${num}`] = task.spaceId || \"\";\n  aggregatedData[`taskUrl_${num}`] = task.taskUrl || \"\";\n  \n  // Build merged tasksOutput for this iteration\n  const separator = index < inputItems.length - 1 ? \"\\n---\\n\" : \"\";\n  tasksOutput += `[Task ${num}] ${task.name || \"(no name)\"}\\n${task.description || \"(no description)\"}${separator}`;\n});\n\n// Add metadata about total count\naggregatedData._totalTasks = inputItems.length;\n\n// Add the merged tasksOutput\naggregatedData.tasksOutput = tasksOutput.trim();\n\n// Return as SINGLE n8n item\nreturn [{ json: aggregatedData }];\n\n// INFRAWEB.PL"},"typeVersion":2},{"id":"f4e42b70-e838-4c69-a619-2c5e496cca1d","name":"Retrieve ClickUp Task List","type":"n8n-nodes-base.clickUp","position":[224,96],"parameters":{"list":"901524181718","space":"90154501378","filters":{},"operation":"getAll","authentication":"oAuth2"},"credentials":{"clickUpOAuth2Api":{"id":"HGriRB0WwxQQ9km0","name":"ClickUp OAuth2 API"}},"typeVersion":1},{"id":"f6e65f4d-0d6e-41af-a1ca-d9a367d2ce50","name":"Log Error Status","type":"n8n-nodes-base.clickUp","position":[896,512],"parameters":{"name":"={{$now.format('D HH:mm')}} ERROR","space":"90154501378","resource":"list","operation":"create","authentication":"oAuth2","additionalFields":{}},"credentials":{"clickUpOAuth2Api":{"id":"HGriRB0WwxQQ9km0","name":"ClickUp OAuth2 API"}},"typeVersion":1},{"id":"7960bf8c-131a-45ee-9792-19596598e4a4","name":"Terminate on Error","type":"n8n-nodes-base.stopAndError","position":[1072,512],"parameters":{"errorMessage":"Can't fetch data."},"typeVersion":1},{"id":"498d8ac9-6e94-4536-ab68-dfbcfc9568da","name":"Daily 8am Report Trigger","type":"n8n-nodes-base.scheduleTrigger","position":[0,96],"parameters":{"rule":{"interval":[{"triggerAtHour":8}]}},"typeVersion":1.3},{"id":"5d4b8876-24bf-499d-b318-7d94c9fef49c","name":"Generate Summary Report","type":"n8n-nodes-base.clickUp","position":[1472,0],"parameters":{"list":"={{ $('Build Report List').item.json.id }}","name":"Report","authentication":"oAuth2","additionalFields":{"content":"={{ $json.output }}"}},"credentials":{"clickUpOAuth2Api":{"id":"HGriRB0WwxQQ9km0","name":"ClickUp OAuth2 API"}},"typeVersion":1},{"id":"3051b25a-b75e-4177-9520-c5381cca57a7","name":"Build Report List","type":"n8n-nodes-base.clickUp","position":[896,-80],"parameters":{"name":"={{$now.format('D HH:mm')}} report","space":"90154501378","resource":"list","operation":"create","authentication":"oAuth2","additionalFields":{}},"credentials":{"clickUpOAuth2Api":{"id":"HGriRB0WwxQQ9km0","name":"ClickUp OAuth2 API"}},"typeVersion":1},{"id":"a2b07cac-aaa1-419c-aa37-1caa6280ca78","name":"Task Analysis Agent","type":"@n8n/n8n-nodes-langchain.agent","position":[1120,0],"parameters":{"text":"=You are an AI assistant that helps fetch current taks and based on them suggest new tasks to do and prepare a daily raport in the list named \"{{ $json.name }}\"\n\nUse your tool to create tasks and raport summary in the list.\n\nTasks list:\n{{ $('Compile Task Data').item.json.tasksOutput }}","options":{},"promptType":"define"},"typeVersion":3.1},{"id":"a38a7cc2-e556-425a-9b3d-ce4a00702339","name":"AI Conversational Model","type":"@n8n/n8n-nodes-langchain.lmChatOpenRouter","position":[1120,160],"parameters":{"model":"openai/o3-mini","options":{}},"credentials":{"openRouterApi":{"id":"HLd7EuxL7NO4jUX0","name":"OpenRouter account"}},"typeVersion":1}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","availableInMCP":false,"executionOrder":"v1"},"versionId":"56527a90-dea4-48f5-a4a4-dbee6db635d9","nodeGroups":[],"connections":{"Log Error Status":{"main":[[{"node":"Terminate on Error","type":"main","index":0}]]},"Build Report List":{"main":[[{"node":"Task Analysis Agent","type":"main","index":0}]]},"Compile Task Data":{"main":[[{"node":"Verify Data Retrieval","type":"main","index":0}]]},"Task Analysis Agent":{"main":[[{"node":"Generate Summary Report","type":"main","index":0}]]},"Verify Data Retrieval":{"main":[[{"node":"Build Report List","type":"main","index":0}],[{"node":"Log Error Status","type":"main","index":0}]]},"AI Conversational Model":{"ai_languageModel":[[{"node":"Task Analysis Agent","type":"ai_languageModel","index":0}]]},"Daily 8am Report Trigger":{"main":[[{"node":"Retrieve ClickUp Task List","type":"main","index":0}]]},"Retrieve ClickUp Task List":{"main":[[{"node":"Compile Task Data","type":"main","index":0}]]}}}