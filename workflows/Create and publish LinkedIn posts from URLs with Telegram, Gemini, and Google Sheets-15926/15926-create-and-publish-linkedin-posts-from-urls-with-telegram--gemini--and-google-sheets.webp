('?','').trim()}}","options":{"limitWaitTime":{"values":{"resumeUnit":"minutes","resumeAmount":5}},"appendAttribution":false},"operation":"sendAndWait","approvalOptions":{"values":{"approvalType":"double"}}},"credentials":{"telegramApi":{"id":"bIr8O0YKWQjhXJda","name":"n8nlocalintegrationbot"}},"typeVersion":1.2},{"id":"f7df8413-150c-4396-b936-acd7ddd70bc5","name":"Send Fail Message","type":"n8n-nodes-base.telegram","position":[2432,-432],"webhookId":"0c177ac2-4ba0-4c7c-a2ba-3de286eac4ad","parameters":{"text":"The output couldn't be process either due to AI's error, URL fetch issue or something else. Please again with your URL or Delete the subject URL from the sheet and use the existing topics option. ","chatId":"={{ $('Route By Command').item.json.callback_query.message.chat.id }}","additionalFields":{"appendAttribution":false}},"credentials":{"telegramApi":{"id":"bIr8O0YKWQjhXJda","name":"n8nlocalintegrationbot"}},"typeVersion":1.2},{"id":"11b75354-b2a8-4fbb-89b8-56350f197b12","name":"Fallback Post Generation Model","type":"@n8n/n8n-nodes-langchain.lmChatGroq","position":[1872,-96],"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"credentials":{"groqApi":{"id":"Oy4LNFB1CCI8MTHJ","name":"Groq spikesol22"}},"typeVersion":1},{"id":"71f1fe42-d863-48a9-8450-fb48ab5d84b3","name":"Primary QC Model","type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","position":[2128,-176],"parameters":{"options":{},"modelName":"models/gemma-4-26b-a4b-it"},"credentials":{"googlePalmApi":{"id":"Ag10lG0zf1jiTP0u","name":"Google Gemini(PaLM) Api account"}},"typeVersion":1.1},{"id":"e5183256-8b7e-423e-9317-100c8ae419ba","name":"Fallback QC model","type":"@n8n/n8n-nodes-langchain.lmChatGroq","position":[2176,-32],"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"credentials":{"groqApi":{"id":"Oy4LNFB1CCI8MTHJ","name":"Groq spikesol22"}},"typeVersion":1},{"id":"d0f59c32-9b85-48a1-af17-6947e1f70d8b","name":"Primary Post Creation Model","type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","position":[1472,432],"parameters":{"options":{},"modelName":"models/gemma-4-31b-it"},"credentials":{"googlePalmApi":{"id":"AL1T9Rvq1avQasOD","name":"Spikesolutions 22"}},"typeVersion":1.1},{"id":"9e858266-f5dd-405d-8844-5d2cb38371ce","name":"Fallback Post Creation Model","type":"@n8n/n8n-nodes-langchain.lmChatGroq","position":[1520,640],"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"credentials":{"groqApi":{"id":"Oy4LNFB1CCI8MTHJ","name":"Groq spikesol22"}},"typeVersion":1},{"id":"5664348a-e842-47b9-bd52-a93eb4db6c1a","name":"QC Primary Model","type":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","position":[1792,544],"parameters":{"options":{},"modelName":"models/gemma-4-26b-a4b-it"},"credentials":{"googlePalmApi":{"id":"Ag10lG0zf1jiTP0u","name":"Google Gemini(PaLM) Api account"}},"typeVersion":1.1},{"id":"69d2cde3-8f9b-487f-b9ac-831b9917f9be","name":"QC Fallback Model","type":"@n8n/n8n-nodes-langchain.lmChatGroq","position":[1840,688],"parameters":{"model":"llama-3.3-70b-versatile","options":{}},"credentials":{"groqApi":{"id":"Oy4LNFB1CCI8MTHJ","name":"Groq spikesol22"}},"typeVersion":1},{"id":"61dd8518-b9e6-4248-94b3-ea9b46d69b54","name":"Send Invalid URL Message","type":"n8n-nodes-base.telegram","position":[944,1248],"webhookId":"af49d252-81f1-4a79-ab4e-e3aa312868a6","parameters":{"text":"Please enter a valid URL - start the workflow again.","chatId":"={{ $('Route By Command').item.json.callback_query.message.chat.id }}","additionalFields":{"appendAttribution":false}},"credentials":{"telegramApi":{"id":"bIr8O0YKWQjhXJda","name":"n8nlocalintegrationbot"}},"typeVersion":1.2},{"id":"1b25aef1-b880-4d43-bad8-8ac872491474","name":"Send Duplicate URL Warning","type":"n8n-nodes-base.telegram","position":[1440,1056],"webhookId":"60503f47-0c49-4545-a3c1-219356eaaabb","parameters":{"text":"The URL already exists - Please start the workflow again and add a new URL. Thanks!","chatId":"={{ $('Route By Command').item.json.callback_query.message.chat.id }}","additionalFields":{"appendAttribution":false}},"credentials":{"telegramApi":{"id":"bIr8O0YKWQjhXJda","name":"n8nlocalintegrationbot"}},"typeVersion":1.2},{"id":"53a0c5f0-56a8-43cb-9cbf-2adfc270d064","name":"Send Duplicate URL Warning1","type":"n8n-nodes-base.telegram","position":[1888,1088],"webhookId":"60503f47-0c49-4545-a3c1-219356eaaabb","parameters":{"text":"=Your URL -  {{ $json.URLs }} was added to the sheet.","chatId":"={{ $('Route By Command').item.json.callback_query.message.chat.id }}","additionalFields":{"appendAttribution":false}},"credentials":{"telegramApi":{"id":"bIr8O0YKWQjhXJda","name":"n8nlocalintegrationbot"}},"typeVersion":1.2},{"id":"6786fb17-1357-4ee1-9145-8620b346ff4b","name":"Template Description","type":"n8n-nodes-base.stickyNote","position":[-1808,-80],"parameters":{"color":6,"width":832,"height":812,"content":"## Automate LinkedIn draft creation and publishing from Telegram\n\n### This n8n template demonstrates how to use AI to generate, quality-check, and publish LinkedIn posts, using Telegram as your mobile command center.\n\nPerfect for content creators and marketers: Quickly turn web articles into polished LinkedIn posts, run them through an automated AI quality check, and approve them on-the-go directly from your Telegram app!\n\n### How it works\n* The workflow listens for commands from your Telegram bot to initiate a draft or check the queue.\n* It scrapes content from provided URLs or accepts direct text input.\n* A Primary AI model generates a LinkedIn draft (with a Fallback model ready just in case).\n* Dedicated AI Quality Control (QC) models audit the draft to ensure it meets your compliance and quality standards.\n* The workflow sends the generated draft back to you on Telegram using a \"Wait\" node, waiting for your final human-in-the-loop approval or rejection.\n* Upon approval, the post is directly published to LinkedIn, and your Google Sheet is updated to track published vs. unpublished content.\n\n### How to set up\n1. Connect your Telegram bot, Google Sheets, LinkedIn, and chosen AI model credentials.\n2. Update the Google Sheets nodes with your specific Sheet ID (ensure it has columns for tracking URLs, drafts, and publish statuses).\n3. Activate the workflow and send your starting command to your Telegram bot to begin the drafting process.\n\n### Requirements\n* Telegram Bot Token\n* Google Sheets account (for database logging)\n* LinkedIn account\n* API keys for your chosen AI Models (e.g., OpenAI, Anthropic, or Gemini)"},"typeVersion":1},{"id":"feb7580e-898c-4bd0-8357-94e7e5c565ba","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[240,-656],"parameters":{"color":7,"width":4048,"height":752,"content":"## Branch: Database Queue Processing\n- Retrieve unpublished records from Google Sheets.\n- Request execution approval via Telegram.\n- Generate LinkedIn draft using AI models.\n- Audit draft compliance using quality control models.\n- Request publication approval via Telegram.\n- Publish post to LinkedIn and update sheet status."},"typeVersion":1},{"id":"ca816990-1808-4a68-a46c-da61666052c4","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[352,144],"parameters":{"color":7,"width":3616,"height":704,"content":"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n## Branch: Direct Draft Generation\n- Request page URL or text input via Telegram.\n- Validate input format and alert user if invalid.\n- Generate LinkedIn draft using AI models (with webpage scraping if URL provided).\n- Audit draft compliance using quality control models.\n- Request publication approval via Telegram.\n- Publish post to LinkedIn and append new record to Google Sheets."},"typeVersion":1},{"id":"a9a86b9c-47a8-459c-8f23-2d57e17fd367","name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[304,880],"parameters":{"color":7,"width":1728,"height":544,"content":"## Branch: URL Queue Ingestion\n- Request URL input via Telegram.\n- Validate URL format and alert user if invalid.\n- Fetch sheet records to verify URL presence.\n- Send warning message if duplicate record exists.\n- Insert new URL record into Google Sheets.\n- Send confirmation message via Telegram."},"typeVersion":1},{"id":"e8587946-0cba-4a68-a4c0-56f81790a7fc","name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[-912,112],"parameters":{"color":7,"width":1248,"height":512,"content":"## Setup and Routing\n- Listens for Telegram updates.\n- Routes callback access and commands.\n- Checks start commands and sends message options."},"typeVersion":1},{"id":"c103d9a3-0f4b-4a41-af34-03f9f2110be0","name":"Sticky Note4","type":"n8n-nodes-base.stickyNote","position":[1408,144],"parameters":{"width":656,"height":704,"content":"### Direct Generation and Audit\n- Generates post text from direct input via primary or fallback AI models.\n- Scrapes web page data for context.\n- Audits text compliance using primary or fallback QC models."},"typeVersion":1},{"id":"9387603e-a289-4d31-b5f1-fcf797589bcc","name":"Sticky Note5","type":"n8n-nodes-base.stickyNote","position":[1760,-576],"parameters":{"width":624,"height":656,"content":"### Draft Generation and Audit\n- Generates post text via primary or fallback AI models.\n- Scrapes web page data for context if required.\n- Audits compliance using primary or fallback QC models."},"typeVersion":1},{"id":"994a9d26-3f40-4278-bfc1-adf2f6775b69","name":"Sticky Note6","type":"n8n-nodes-base.stickyNote","position":[3632,-624],"parameters":{"width":608,"height":320,"content":"### Publication and Status Update\n- Publishes post to LinkedIn.\n- Updates published status in Google Sheets.\n- Notifies of publish success via Telegram."},"typeVersion":1},{"id":"6503d20f-eaac-43ff-a8a5-fd1b5a217ec0","name":"Sticky Note7","type":"n8n-nodes-base.stickyNote","position":[3344,176],"parameters":{"width":576,"height":400,"content":"\n\n\n\n\n\n\n\n\n\n\n\n### Publication and Log Append\n- Publishes post to LinkedIn.\n- Updates sheet record.\n