{"id":"D9mEVTOLg9xIUwbK","meta":{"instanceId":"f65635fe42aeebebf44eaa521e38cac56bb6b5ccb60db8ca4a763a8fbba06ee8"},"name":"W57th Vector DB 2.0","tags":[],"nodes":[{"id":"61262bba-1c4c-4b59-88fc-03e43077c815","name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[-2512,368],"parameters":{"color":7,"width":624,"height":656,"content":"## Route media jobs\n\nBranches files by media type and dispatches image and PDF batches to external/internal processing webhooks."},"typeVersion":1},{"id":"07d7bbdb-9bc8-40c3-b5d3-d51f99aa71c9","name":"Sticky Note5","type":"n8n-nodes-base.stickyNote","position":[-1152,352],"parameters":{"color":7,"width":400,"height":320,"content":"## Return image analysis\n\nAggregates Gemini image outputs and forwards the finished image results to the follow-up callback webhook."},"typeVersion":1},{"id":"8b3a108f-cdd5-4339-92ab-5f8f1655533f","name":"Sticky Note6","type":"n8n-nodes-base.stickyNote","position":[-720,352],"parameters":{"color":7,"width":544,"height":320,"content":"## Parse image callback\n\nReceives completed image analysis, splits returned records, and maps album, URL, date, and MIME fields for ingestion."},"typeVersion":1},{"id":"e4d276ec-336f-464d-85ab-4a7cdbeb8e34","name":"Sticky Note8","type":"n8n-nodes-base.stickyNote","position":[-1152,720],"parameters":{"color":7,"width":400,"height":320,"content":"## Return PDF analysis\n\nAggregates Gemini PDF outputs and sends the finished PDF results to the follow-up callback webhook."},"typeVersion":1},{"id":"9058d41e-1d7d-49c0-99bf-d46cda30db28","name":"Sticky Note9","type":"n8n-nodes-base.stickyNote","position":[-720,720],"parameters":{"color":7,"width":544,"height":320,"content":"## Parse PDF callback\n\nReceives completed PDF analysis, splits returned records, and maps album, URL, date, and MIME fields for ingestion."},"typeVersion":1},{"id":"01864c33-9110-48c5-a075-f332a4151140","name":"Sticky Note10","type":"n8n-nodes-base.stickyNote","position":[-2016,1104],"parameters":{"color":7,"width":480,"height":576,"content":"## Extract multimedia assets\n\nUses FFmpeg-related code to prepare audio and frame/prompt inputs for the multimedia analysis branches."},"typeVersion":1},{"id":"bcd2d36f-29ba-4a6b-acba-496ed805633f","name":"Sticky Note11","type":"n8n-nodes-base.stickyNote","position":[-1488,1088],"parameters":{"color":7,"width":432,"height":320,"content":"## Transcribe audio track\n\nSends extracted audio to Groq speech-to-text and parses the transcription output for later merging."},"typeVersion":1},{"id":"1fc8002b-b87d-4b7d-a028-de6311820df0","name":"Sticky Note12","type":"n8n-nodes-base.stickyNote","position":[-1488,1440],"parameters":{"color":7,"width":656,"height":304,"content":"## Analyze video frames\n\nSends prepared video frames to Gemini, captures the generated output, and parses category, summary, details, and tags."},"typeVersion":1},{"id":"3c1644d9-436e-4e02-b514-fa15da0eaa70","name":"Sticky Note13","type":"n8n-nodes-base.stickyNote","position":[-800,1088],"parameters":{"color":7,"width":288,"height":336,"content":"## Merge media summaries\n\nCombines parsed audio transcription and video-frame analysis outputs before record construction."},"typeVersion":1},{"id":"c8c6d38a-2075-4524-b5f4-a684fffe33ae","name":"Sticky Note14","type":"n8n-nodes-base.stickyNote","position":[-80,720],"parameters":{"color":7,"width":368,"height":320,"content":"## Build record metadata\n\nCreates consistent names and assembles each processed item into a content and metadata record for vector storage."},"typeVersion":1},{"id":"4e5288a9-d549-417a-a9b7-0203da168b0b","name":"Sticky Note15","type":"n8n-nodes-base.stickyNote","position":[304,720],"parameters":{"color":7,"width":448,"height":464,"content":"## Store vector embeddings\n\nLoads and chunks record content, generates Gemini embeddings, and writes the documents into the Supabase vector store."},"typeVersion":1},{"id":"ad0ed239-0553-4502-82a8-e11a197c5c7b","name":"Sticky Note16","type":"n8n-nodes-base.stickyNote","position":[-112,0],"parameters":{"color":7,"width":496,"height":432,"content":"## Query vector index\n\nReceives semantic search requests, embeds the query with Gemini, and searches the Supabase vector store."},"typeVersion":1},{"id":"b451ccf6-33d8-47a0-a7ef-d04e10e55abc","name":"Sticky Note17","type":"n8n-nodes-base.stickyNote","position":[416,0],"parameters":{"color":7,"width":384,"height":432,"content":"## Format query response\n\nMaps vector search matches into ranked result fields and sends them back through the webhook response."},"typeVersion":1},{"id":"8d757139-0bbe-490e-a596-a81184a3b9f0","name":"Sticky Note18","type":"n8n-nodes-base.stickyNote","position":[-3104,1088],"parameters":{"color":7,"width":496,"height":320,"content":"## List Google Drive\n\nAuxiliary isolated cluster that lists Google Drive files and normalizes their key metadata fields."},"typeVersion":1},{"id":"02824094-c97e-494c-b71d-70d513c3d79c","name":"Set Content and Metadata","type":"n8n-nodes-base.set","position":[144,848],"parameters":{"options":{},"assignments":{"assignments":[{"id":"m1","name":"content","type":"string","value":"={{ [\n  'public_url: '       + $json.public_url,\n  'album: '            + $json.album,\n  'file_date: '        + $json.file_date,\n  'mime_type: '        + $json.mime_type,\n  'summary: '          + $json.summary,\n  'detail_description: ' + $json.detail_description,\n  'tags: '             + $json.tags.join(', ')\n].join('\\n\\n') }}"},{"id":"m2","name":"metadata","type":"object","value":"={{ {\n  name:          $json.name,\n  public_url:    $json.public_url,\n  album:         $json.album,\n  file_date:     $json.file_date ?? null,\n  mime_type:     $json.mime_type,\n  score_social: parseInt($json.score_social) ?? null,\n  score_quality: parseInt($json.score_quality) ?? null,\n  chunk_index:   $json.chunk_index ?? null,\n  chunk_total:   $json.chunk_total ?? null\n} }}"}]}},"typeVersion":3.4},{"id":"5fa3c397-3935-4070-8059-367357193a0f","name":"Embedding with Gemini Model","type":"@n8n/n8n-nodes-langchain.embeddingsGoogleGemini","position":[368,992],"parameters":{},"credentials":{"googlePalmApi":{"id":"2qUzA3DAEFRc7DI1","name":"Gemini FRAINK key"}},"typeVersion":1},{"id":"06b9982e-1038-4728-a450-9036d6a1b7a1","name":"Load Default Data","type":"@n8n/n8n-nodes-langchain.documentDefaultDataLoader","position":[512,992],"parameters":{"options":{"metadata":{"metadataValues":[{"name":"metadata","value":"={{ $json.metadata }}"}]}},"jsonData":"={{ $json.content }}","jsonMode":"expressionData","textSplittingMode":"custom"},"typeVersion":1.1},{"id":"551df692-9ec7-4c32-8011-fd86933f3fb1","name":"Split Text by Character","type":"@n8n/n8n-nodes-langchain.textSplitterCharacterTextSplitter","position":[528,1088],"parameters":{"chunkSize":50000,"separator":"NEVER_SPLIT_XYZ"},"typeVersion":1},{"id":"ddde736c-7a1e-4521-98fe-7d196d6c6434","name":"Ingest to Vector Store","type":"@n8n/n8n-nodes-langchain.vectorStoreSupabase","position":[368,848],"parameters":{"mode":"insert","options":{},"tableName":"vec10"},"credentials":{"supabaseApi":{"id":"fDZJQQDFT5tFE3WD","name":"Vector Supabase"}},"typeVersion":1},{"id":"9f8034e9-8a60-4080-a3b8-2bb8cbc64ac7","name":"Post PDF to API","type":"n8n-nodes-base.httpRequest","position":[-2032,832],"parameters":{"url":"https://n8n.airpg.ai/webhook/pdf","method":"POST","options":{},"sendBody":true,"bodyParameters":{"parameters":[{"name":"mimeType","value":"={{ $json.mimeType }}"},{"name":"public_url","value":"={{ $json.public_url }}"},{"name":"album","value":"={{ $('Configure Input Data').item.json.prefix }}"},{"name":"file_date","value":"={{ $json.file_date }}"}]}},"typeVersion":4.4},{"id":"659c2e3f-4860-445e-aa0d-1838f45679bd","name":"Post Image to API","type":"n8n-nodes-base.httpRequest","position":[-2032,496],"parameters":{"url":"https://n8n.airpg.ai/webhook/image","method":"POST","options":{},"sendBody":true,"bodyParameters":{"parameters":[{"name":"mimeType","value":"={{ $json.mimeType }}"},{"name":"public_url","value":"={{ $json.public_url }}"},{"name":"album","value":"={{ $('Configure Input Data').first().json.prefix }}"},{"name":"file_date","value":"={{ $json.file_date }}"}]}},"typeVersion":4.4},{"id":"821cffd0-6b9b-4cf4-bef1-450da249a800","name":"Image Webhook Trigger","type":"n8n-nodes-base.webhook","position":[-1776,496],"webhookId":"0287891b-7da8-4b25-b5b0-68688c5b5870","parameters":{"path":"image","options":{},"httpMethod":"POST"},"typeVersion":2.1},{"id":"37531b3b-55fc-477e-8e4a-f698fe7146ef","name":"PDF Webhook Trigger","type":"n8n-nodes-base.webhook","position":[-1776,848],"webhookId":"0287891b-7da8-4b25-b5b0-68688c5b5870","parameters":{"path":"pdf","options":{},"httpMethod":"POST"},"typeVersion":2.1},{"id":"4723f676-cda7-4fb2-a9a6-ea0d52dfb6c4","name":"Post New Image to API","type":"n8n-nodes-base.httpRequest","position":[-896,496],"parameters":{"url":"https://n8n.airpg.ai/webhook/imageF","method":"POST","options":{},"sendBody":true,"bodyParameters":{"parameters":[{"name":"output","value":"={{ $json.output }}"}]}},"typeVersion":4.4},{"id":"d802315e-1446-4408-9d2b-70cc6f143913","name":"Post New PDF to API","type":"n8n-nodes-base.httpRequest","position":[-896,848],"parameters":{"url":"https://n8n.airpg.ai/webhook/pdfF","method":"POST","options":{},"sendBody":true,"bodyParameters":{"parameters":[{"name":"output","value":"={{ $json.output }}"}]}},"typeVersion":4.4},{"id":"5e9739e9-b1a6-4b0d-a4d3-6d46f55d6127","name":"Parse Audio Transcription","type":"n8n-nodes-base.code","position":[-1200,1248],"parameters":{"jsCode":"// ═══════════════════════════════════════════════════════════════════\n// ver 3.4 Groq Parse: Sentence-aware transcript chunker & auto-tagger\n// ~900 char target, 1 sentence overlap, outputs flat Build Record shape\n// CHANGE 3.4: Parallel tag extraction via Promise.all (was sequential await)\n// ═══════════════════════════════════════════════════════════════════\nconst CHUNK_TARGET = 900;\nconst https = require('https');\n\n// ── SECTION 1: Chunker ──────────────────────────────────────────\n// Splits transcript into sentence-aware chunks with 1-sentence overlap.\n// Falls back to treating full text as one chunk if no sentence endings found.\nfunction chunkTranscript(text) {\n    const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];\n    const chunks = [];\n    let current = '';\n    let lastSentence = '';\n    let chunkIndex = 0;\n\n    for (const sentence of sentences) {\n        const trimmed = sentence.trim();\n        if (!trimmed) continue;\n\n        if ((current + ' ' + trimmed).length > CHUNK_TARGET && current.length > 0) {\n            chunks.push({ chunk_index: chunkIndex++, chunk_text: current.trim() });\n            current = lastSentence + ' ' + trimmed; // 1-sentence overlap\n        } else {\n            current = current ? current + ' ' + trimmed : trimmed;\n        }\n        lastSentence = trimmed;\n    }\n\n    if (current.trim()) {\n        chunks.push({ chunk_index: chunkIndex, chunk_text: current.trim() });\n    }\n\n    return chunks;\n}\n\n// ── SECTION 2: Tag Extractor ─────────────────────────────────────\n// Single Groq API call for one chunk. Returns parsed string array.\n// Regex-extracts JSON array to handle Groq wrapping response in prose/markdown.\nasync function extractTags(text) {\n    const response = await new Promise((resolve, reject) => {\n        const body = JSON.stringify({\n            model: 'llama-3.1-8b-instant',\n            max_tokens: 30,\n            messages: [{\n                role: 'user',\n                content: `Return 3 to 5 specific topical keywords from this text as a JSON array. No filler words. Text: \"${text}\"`\n            }]\n        });\n\n        const req = https.request({\n            hostname: 'api.groq.com',\n            path: '/openai/v1/chat/completions',\n            method: 'POST',\n            headers: {\n                'Authorization': `Bearer ${$env.GROQ_API_KEY}`,\n                'Content-Type': 'application/json'\n            }\n        }, res => {\n            let data = '';\n            res.on('data', chunk => data += chunk);\n            res.on('end', () => resolve(JSON.parse(data)));\n        });\n\n        req.on('error', reject);\n        req.write(body);\n        req.end();\n    });\n\n    try {\n        const raw = response.choices[0].message.content;\n        const match = raw.match(/\\[[\\s\\S]*?\\]/);\n        return match ? JSON.parse(match[0]) : [];\n    } catch(e) {\n        return [];\n    }\n}\n\n// ── SECTION 3: Main Loop ─────────────────────────────────────────\n// Iterates all transcript inputs, chunks each, then fires ALL tag\n// extraction calls in parallel per transcript via Promise.all.\n// Upstream refs: FFmpeg Audio (public_url), Set Input (album/prefix).\nconst results = [];\nconst allInputs = $input.all();\nconst ffmpegItems = $('Generate FFmpeg Audio').all();\nconst setInputItem = $('Configure Input Data').first();\nconst album = setInputItem?.json?.prefix || null;\n\nfor (let i = 0; i < allInputs.length; i++) {\n    const item = allInputs[i];\n    const transcript = item.json.transcript;\n    if (!transcript) continue;\n\n    const matchedFFmpeg = ffmpegItems[i] || ffmpegItems[0] || {};\n    const public_url = matchedFFmpeg.json?.public_url || null;\n\n    const chunks = chunkTranscript(transcript.trim());\n\n    // Fire all tag calls for this transcript's chunks simultaneously\n    const allTags = await Promise.all(chunks.map(chunk => extractTags(chunk.chunk_text)));\n\n    // Build result records now that all tags are resolved\n    chunks.forEach((chunk, idx) => {\n        results.push({\n            json: {\n                public_url,\n                album,\n                file_date:          item.json.file_date,\n                mime_type:          'video_transcript',\n                chunk_index:        chunk.chunk_index,\n                chunk_total:        chunks.length,\n                summary:            `Transcript chunk ${chunk.chunk_index + 1} of ${chunks.length}`,\n                detail_description: `[Transcript Chunk]: ${chunk.chunk_text}`,\n                tags:               allTags[idx],\n                score_social:       null,\n                score_quality:      null\n            }\n        });\n    });\n}\n\nreturn results;"},"typeVersion":2},{"id":"bd8f27be-2ed6-4754-bac7-b21c89ffc47e","name":"Append and Merge Data","type":"n8n-nodes-base.merge","position":[-704,1264],"parameters":{},"typeVersion":3.2},{"id":"fa99189d-4fbe-4045-aec9-9987e70fd1d9","name":"Filter Unknown File Types","type":"n8n-nodes-base.filter","position":[-1344,144],"parameters":{"options":{"ignoreCase":false},"conditions":{"options":{"version":2,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"13d34ed6-213f-40c1-9352-0443bd0320ca","operator":{"type":"boolean","operation":"true","singleValue":true},"leftValue":"={{ ['.jpg','.jpeg','.png','.webp','.mp4','.mov','.avi','.mkv','.pdf'].some(ext => $json.key.toLowerCase().endsWith(ext)) }}","rightValue":"={{ ['.jpg','.jpeg','.png','.webp','.mp4','.mov','.avi','.mkv','.pdf'].some(ext => $json.key.toLowerCase().endsWith(ext)) }}"}]}},"typeVersion":2.2},{"id":"9bc7fe8d-46fc-439d-b3a1-2161d156cd9e","name":"Set Media Metadata","type":"n8n-nodes-base.set","position":[-1120,144],"parameters":{"options":{},"assignments":{"assignments":[{"id":"mt","name":"mimeType","type":"string","value":"={{ $json.key.toLowerCase().match(/\\.(mp4|mov|avi|mkv)$/) ? 'video' : $json.key.toLowerCase().match(/\\.pdf$/) ? 'pdf' : 'image' }}"},{"id":"fn","name":"public_url","type":"string","value":"={{ $('Configure Input Data').item.json.bucket_url + '/' + $json.key }}"},{"id":"e0ddfafc-9e2b-4954-8b84-4d3b05dad705","name":"file_date","type":"string","value":"={{ $json.last_modified }}"}]}},"typeVersion":3.4},{"id":"d2848235-11e3-4366-9b08-0d9a8814b41a","name":"Separate Objects","type":"n8n-nodes-base.splitOut","position":[-1552,144],"parameters":{"options":{},"fieldToSplitOut":"objects"},"typeVersion":1},{"id":"322635c1-91f7-44a2-92c8-5f756655de36","name":"Configure Input Data","type":"n8n-nodes-base.set","position":[-2000,144],"parameters":{"options":{},"assignments":{"assignments":[{"id":"1","name":"bucket","type":"string","value":"={{ $json.body.bucket }}"},{"id":"2","name":"prefix","type":"string","value":"={{ $json.body.folder_url.split('/').slice(3).filter(s => s.length > 0 && !s.includes('.')).join('/') }}"},{"id":"4476cf58-f93e-495e-a296-94caf529a2db","name":"bucket_url","type":"string","value":"={{ $json.body.folder_url.split('/').slice(0, 3).join('/') }}"},{"id":"4","name":"temp_root","type":"string","value":"C:\\Users\\USERFOLDER\\vector"},{"id":"5","name":"frames_dir","type":"string","value":"C:\\Users\\USERFOLDER\\vector\\frames"},{"id":"6","name":"video_path","type":"string","value":"C:\\Users\\USERFOLDER\\vector\\video"}]}},"typeVersion":3.4},{"id":"c7e4313c-4b32-453a-a798-a00557073c75","name":"Normalize Google Drive Item","type":"n8n-nodes-base.set","disabled":true,"position":[-2800,1200],"parameters":{"options":{},"assignments":{"assignments":[{"id":"gd1","name":"name","type":"string","value":"={{ $json.name }}"},{"id":"gd2","name":"public_url","type":"string","value":"=https://drive.google.com/thumbnail?sz=w1920&id={{ $json.id }}"},{"id":"gd3","name":"view_url","type":"string","value":"=https://drive.google.com/file/d/{{ $json.id }}/preview"},{"id":"83850e76-24ef-45f4-909d-8bd0e74e6c17","name":"mimeType","type":"string","value":"={{ $json.name.toLowerCase().match(/\\.(mp4|mov|avi|mkv)$/) ? 'video' : ($json.name.toLowerCase().match(/\\.pdf$/) ? 'pdf' : 'image') }}"},{"id":"0f4f74b3-a8f8-49b1-a2ab-2d2d3422bb96","name":"download_url","type":"string","value":"=https://drive.google.com/uc?id={{ $json.id }}&export=download"}]}},"typeVersion":3.4},{"id":"76ec62ba-4e2c-4300-81bc-6571cb50e7ca","name":"List Google Drive Files","type":"n8n-nodes-base.googleDrive","disabled":true,"position":[-3040,1200],"parameters":{"filter":{"folderId":{"__rl":true,"mode":"id","value":"={{ $json.album_name }}"}},"options":{},"resource":"fileFolder","returnAll":true,"queryString":"="},"credentials":{"googleDriveOAuth2Api":{"id":"x3ZSEBzUKx57u1qp","name":"Dave Ggl Main"}},"typeVersion":3},{"id":"0a29309c-2cf6-48c8-8d58-016b21b85dd5","name":"Generate FFmpeg Audio","type":"n8n-nodes-base.code","position":[-1664,1248],"parameters":{"jsCode":"// ═══════════════════════════════════════════════════════════════════\n// ver 3.0 Node 2: Audio Extractor\n// video_id is now a public URL - extract base name for file ops\n// line 43 -q:a 8 -ac 1 -ar 16000   **lower to 9 and 8000 **\n// ═══════════════════════════════════════════════════════════════════\nconst fs   = require('fs');\nconst path = require('path');\nconst { execSync } = require('child_process');\n\nconst toFF  = p => p.replace(/\\\\/g, '/');\nconst toWin = p => p.replace(/\\//g, '\\\\');\n\nconst incomingItems = $input.all();\nconst videosDir     = toWin($('Configure Input Data').first().json.video_path);\n\nconst results = [];\nconst processedVideos = new Set();\n\nfor (const item of incomingItems) {\n    const publicUrl  = item.json.public_url;\n    const videoFile  = item.json.source_video_path;\n\n    if (!publicUrl || !videoFile || processedVideos.has(publicUrl)) continue;\n    processedVideos.add(publicUrl);\n\n    if (!fs.existsSync(toWin(videoFile))) continue;\n\n    // Extract safe filename from source_video_path, not public URL\n    const baseName = path.basename(videoFile, path.extname(videoFile));\n    const audioFile = toFF(path.join(videosDir, baseName + '.mp3'));\n\n    let hasAudio = false;\n    try {\n        const audioProbe = execSync(\n            `ffprobe -v error -select_streams a -show_entries stream=codec_type -of csv=p=0 \"${toFF(videoFile)}\"`,\n            { windowsHide: true }\n        ).toString().trim();\n        hasAudio = audioProbe.includes('audio');\n    } catch(e) {}\n\n    if (hasAudio) {\n        try {\n            execSync(\n                `ffmpeg -y -i \"${toFF(videoFile)}\" -vn -acodec libmp3lame -q:a 9 -ac 1 -ar 8000 \"${audioFile}\"`,\n                { windowsHide: true }\n            );\n\n            if (fs.existsSync(toWin(audioFile))) {\n                const audioBuffer = fs.readFileSync(toWin(audioFile));\n                results.push({\n                    json: {\n                        mimeType:   'audio/mpeg',\n                        video_id:   publicUrl,\n                        public_url: publicUrl,\n                        album:      item.json.album || null,\n                        file_date:  item.json.file_date,\n                        filename:   baseName + '.mp3',\n                        filepath:   audioFile,\n                        has_audio:  true\n                    },\n                    binary: {\n                        file: {\n                            data:     audioBuffer.toString('base64'),\n                            mimeType: 'audio/mpeg',\n                            fileName: baseName + '.mp3'\n                        }\n                    }\n                });\n            }\n        } catch(e) {}\n    }\n}\n\nreturn results;"},"typeVersion":2},{"id":"53eef274-ae6b-42e1-89ab-d660d3be562c","name":"Call Groq STT API","type":"n8n-nodes-base.code","position":[-1440,1248],"parameters":{"jsCode":"// Ver 1.0 calls to Groq Stt to transcribe. API token from $env at n8n startup\n\nconst fs = require('fs');\nconst FormData = require('form-data');\nconst https = require('https');\n\nconst results = [];\n\nfor (const item of $input.all()) {\n    if (!item.binary?.file) continue;\n    \n    const audioPath = item.json.filepath;\n    const audioBuffer = fs.readFileSync(audioPath);\n    \n    const form = new FormData();\n    form.append('file', audioBuffer, {\n        filename: item.json.filename,\n        contentType: 'audio/mpeg'\n    });\n    form.append('model', 'whisper-large-v3-turbo');\n    \n    const transcript = await new Promise((resolve, reject) => {\n        const req = https.request({\n            hostname: 'api.groq.com',\n            path: '/openai/v1/audio/transcriptions',\n            method: 'POST',\n            headers: {\n                ...form.getHeaders(),\n                'Authorization': `Bearer ${$env.GROQ_API_KEY}`\n            }\n        }, res => {\n            let data = '';\n            res.on('data', chunk => data += chunk);\n            res.on('end', () => resolve(JSON.parse(data)));\n        });\n        req.on('error', reject);\n        form.pipe(req);\n    });\n    \n    results.push({\n        json: {\n            ...item.json,\n            transcript: transcript.text\n        }\n    });\n}\n\nreturn results;"},"typeVersion":2},{"id":"a8b0746f-76e1-47a4-be72-77e1220fd163","name":"New Image Webhook","type":"n8n-nodes-base.webhook","position":[-672,496],"webhookId":"0287891b-7da8-4b25-b5b0-68688c5b5870","parameters":{"path":"imageF","options":{},"httpMethod":"POST"},"typeVersion":2.1},{"id":"3e6ab77d-ef3e-4c67-94ee-dac108e4d3cf","name":"New PDF Webhook","type":"n8n-nodes-base.webhook","position":[-672,848],"webhookId":"0287891b-7da8-4b25-b5b0-68688c5b5870","parameters":{"path":"pdfF","options":{},"httpMethod":"POST"},"typeVersion":2.1},{"id":"9e5ea16b-c5df-43da-b717-5e14596f5ab6","name":"Parse Image Output","type":"n8n-nodes-base.set","position":[-320,496],"parameters":{"options":{},"assignments":{"assignments":[{"id":"p4","name":"album","type":"string","value":"={{ JSON.parse($json['body.output'].replace(/```json|```/g,'').trim()).album }}"},{"id":"73c9a5c1-dab3-4a1a-b4fd-2deebf6bb170","name":"public_url","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).public_url }}"},{"id":"78cc1d51-ee49-4eea-905c-69889822bc42","name":"file_date","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).file_date }}"},{"id":"fe31547c-d07b-4596-b70a-4bae6b875116","name":"mime_type","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).mime_type }}"},{"id":"23c86fea-bade-4f87-83af-91fee6909f17","name":"category","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).category }}"},{"id":"379776fc-9d1d-462b-8096-207995ef5bef","name":"summary","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).summary }}"},{"id":"3958886b-243d-4aa3-92d4-56330a8d1de6","name":"detail_description","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).detail_description }}"},{"id":"15bb6849-3df7-4111-93b5-e19c96d5055c","name":"tags","type":"array","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).tags }}"},{"id":"e1dd3b41-a164-428d-9fb6-b1d60b7efe57","name":"score_social","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).score_social }}"},{"id":"62d0c89c-3a7d-4378-923e-fd1e48b3dfbd","name":"score_quality","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).score_quality }}"}]}},"typeVersion":3.4},{"id":"7d8ef36d-c14f-4573-909b-6108ba0a4426","name":"Construct Name Code","type":"n8n-nodes-base.code","position":[-32,848],"parameters":{"jsCode":"// ver 1.0 Build Name code\n// Helper function to slugify text roots cleanly\nfunction slugify(text) {\n  return text\n    .toLowerCase()\n    .replace(/[\\s_]+/g, '-')     // Spaces/underscores to hyphens\n    .replace(/[^a-z0-9-]/g, ''); // Strip special characters\n}\n\n// Track item counts per unique file root in this specific execution batch\nconst typeCounters = {};\n\n// Process all items passing through the flow\nfor (const item of $input.all()) {\n  const mimeType = item.json.mime_type || '';\n  const url = item.json.public_url || '';\n  \n  // 1. Extract file title root from URL safely\n  const rawFileName = decodeURIComponent(url.split('/').pop().split('.').shift() || 'unknown');\n  const baseSlug = slugify(rawFileName);\n  \n  // 2. Determine type prefix\n  let prefix = 'img';\n  if (mimeType === 'video_frame') prefix = 'vidframe';\n  if (mimeType === 'video_transcript')  prefix = 'transcript';\n  if (mimeType === 'pdf')         prefix = 'pdf';\n  \n  // 3. For types that split/chunk, generate an incrementing counter suffix\n  if (prefix === 'vidframe' || prefix === 'transcript') {\n    const groupKey = `${prefix}_${baseSlug}`;\n    \n    // Initialize or increment sequence counter\n    typeCounters[groupKey] = (typeCounters[groupKey] || 0) + 1;\n    \n    // Pad sequence number to 2 digits (e.g., 1 -> \"01\", 12 -> \"12\")\n    const sequenceString = String(typeCounters[groupKey]).padStart(2, '0');\n    \n    // Inject the final human-readable name sequence\n    item.json.name = `${groupKey}-${sequenceString}`;\n  } else {\n    // Single-item types (images, pdfs) don't need a counter suffix\n    item.json.name = `${prefix}_${baseSlug}`;\n  }\n}\n\nreturn $input.all();"},"typeVersion":2},{"id":"fa78f3ec-5906-4dcc-a8f5-87481814a729","name":"Embed with Gemini Model 2","type":"@n8n/n8n-nodes-langchain.embeddingsGoogleGemini","position":[144,272],"parameters":{},"credentials":{"googlePalmApi":{"id":"2qUzA3DAEFRc7DI1","name":"Gemini FRAINK key"}},"typeVersion":1},{"id":"8e3f8cdf-90ca-4ada-b693-9f8e96397909","name":"Rank Search Results","type":"n8n-nodes-base.set","position":[432,160],"parameters":{"options":{},"assignments":{"assignments":[{"id":"r1","name":"public_url","type":"string","value":"={{ $json.document.metadata.metadata.public_url }}"},{"id":"70759740-6741-407d-9eb2-b80c7557740a","name":"mime_type","type":"string","value":"={{ $json.document.metadata.metadata.mime_type }}"},{"id":"ad30ab1a-1bd4-4db6-b034-fa65b3a8aa31","name":"summary","type":"string","value":"={{ $json.document.pageContent.match(/summary:\\s*(.+?)(?=\\n\\n|\\n[a-z_]+:)/s)?.[1]?.trim() }}"},{"id":"88cc6719-633f-4ab8-a5d1-6ea4f071b34f","name":"score","type":"number","value":"={{ $json.score }}"}]}},"typeVersion":3.4},{"id":"8d1ce220-dabb-4d46-ac27-595a13f185ea","name":"Query Vector Store","type":"@n8n/n8n-nodes-langchain.vectorStoreSupabase","position":[144,160],"parameters":{"mode":"load","prompt":"={{ $json.body.query }}","options":{},"tableName":{"__rl":true,"mode":"list","value":"vec10","cachedResultName":"vec10"}},"credentials":{"supabaseApi":{"id":"fDZJQQDFT5tFE3WD","name":"Vector Supabase"}},"typeVersion":1},{"id":"c64ad2ed-0576-46e8-94d9-9c758df0c832","name":"Vector Query Webhook","type":"n8n-nodes-base.webhook","position":[-80,160],"webhookId":"a2f0df0f-f0f3-4a60-ba93-dbfa3ec927dc","parameters":{"path":"vector-query","options":{},"httpMethod":"POST","responseMode":"responseNode"},"typeVersion":2.1},{"id":"53ffe897-f3e3-4807-b238-7a4ddf66915e","name":"Send Webhook Response","type":"n8n-nodes-base.respondToWebhook","position":[624,160],"parameters":{"options":{},"respondWith":"allIncomingItems"},"typeVersion":1.5},{"id":"de4c4aac-87fa-4b37-938f-6ea7de3c3fc8","name":"Aggregate Image Data","type":"n8n-nodes-base.aggregate","position":[-2208,496],"parameters":{"options":{},"fieldsToAggregate":{"fieldToAggregate":[{"fieldToAggregate":"mimeType"},{"fieldToAggregate":"public_url"},{"fieldToAggregate":"file_date"}]}},"typeVersion":1},{"id":"8f6acbb2-eb6c-46b9-8ba0-7514718e8b43","name":"Separate Image Metadata","type":"n8n-nodes-base.splitOut","position":[-1552,496],"parameters":{"options":{},"fieldToSplitOut":"body.mimeType, body.public_url, body.file_date"},"executeOnce":false,"typeVersion":1},{"id":"bb60ae7c-a455-4218-9505-698b1b7d51b6","name":"Aggregate New Images","type":"n8n-nodes-base.aggregate","position":[-1104,496],"parameters":{"options":{},"fieldsToAggregate":{"fieldToAggregate":[{"renameField":true,"outputFieldName":"output","fieldToAggregate":"candidates[0].content.parts[0].text"}]}},"typeVersion":1},{"id":"fd41538f-910c-46ef-af34-d36cfb6ecb48","name":"Separate New Image Output","type":"n8n-nodes-base.splitOut","position":[-496,496],"parameters":{"options":{},"fieldToSplitOut":"body.output"},"typeVersion":1},{"id":"36e79617-a349-46f2-bfc3-4eb7dc442230","name":"Aggregate PDF Data","type":"n8n-nodes-base.aggregate","position":[-2208,832],"parameters":{"options":{},"fieldsToAggregate":{"fieldToAggregate":[{"fieldToAggregate":"mimeType"},{"fieldToAggregate":"public_url"},{"fieldToAggregate":"file_date"}]}},"typeVersion":1},{"id":"1f06f457-ce09-4aa1-b440-7b5dd2d86fde","name":"Separate PDF Metadata","type":"n8n-nodes-base.splitOut","position":[-1552,848],"parameters":{"options":{},"fieldToSplitOut":"body.mimeType, body.public_url, body.file_date"},"executeOnce":false,"typeVersion":1},{"id":"f1e1a47b-1333-4c3a-9f01-764596a7899e","name":"Aggregate New PDFs","type":"n8n-nodes-base.aggregate","position":[-1104,848],"parameters":{"options":{},"fieldsToAggregate":{"fieldToAggregate":[{"renameField":true,"outputFieldName":"output","fieldToAggregate":"candidates[0].content.parts[0].text"}]}},"typeVersion":1},{"id":"3111fa11-3e0a-42d1-a816-99fb220a2316","name":"Separate New PDF Output","type":"n8n-nodes-base.splitOut","position":[-496,848],"parameters":{"options":{},"fieldToSplitOut":"body.output"},"typeVersion":1},{"id":"f481a0e5-745e-4250-95ff-f59a96c1e330","name":"Process PDF with Gemini","type":"@n8n/n8n-nodes-langchain.googleGemini","position":[-1344,848],"parameters":{"text":"=TASK:\nAnalyze the document in the Document URL(s) visually for semantic retrieval, embeddings, and social/cinematic understanding.\n\n## Input Data for Pass-Through:\npublic_url: {{ $json[\"body.public_url\"] }}\nalbum: {{ $('PDF Webhook Trigger').item.json.body.album }}\nfile_date: {{ $json[\"body.file_date\"] }}\n\n# EVALUATE\n1. Category - you must select exactly ONE value for the \"category\" field based on these definitions:\n- \"personal_document\": receipt, list, plan, travel, private.\n- \"social_content\": Vlogs, online datasheet, podcast reference, script.\n- \"professional_presentation\": tutorials, online walkthoughs, portfolio renders, pitch slides, corporate presentation.\n- \"professional_documents\": document, other company content.\n\n2. Summary - a single, short, dense sentence capturing the core action or subject. Perfect for keyword search.\n\n3. Detail Description - Rich semantic description optimized for vector search. Include ALL of: document type, purpose, key entities (people/companies/places), dates, amounts, actions, outcomes, every major section or topic covered. If it is a contract cover parties, terms, payment, dates. If technical cover every system or spec mentioned.\n\n4. Tags - a flat string array of 5 to 8 low-level keywords (lowercase, alphanumeric, hyphenated if multi-word) capturing intent, objects, styles, materials, people, items.\n\n5. Scores - evaluate 'score_social': Rate viral/engagement potential. Is it catchy, scroll-stopping, or highly shareable? Integer 1-10.\n- evaluate 'score_quality': Rate technical execution. Is it stable, clear, well-framed, and is the subject context obvious? Integer 1-10.\n\n# REQUIRED SCHEMA\nReturn a clean, raw JSON object matching this structure identically:\n{\n  \"public_url\": {{ $('PDF Webhook Trigger').item.json.body.public_url }},\n  \"mime_type\": \"pdf\",\n  \"album\": {{ $('PDF Webhook Trigger').item.json.body.album }},\n  \"file_date\": {{ $json[\"body.file_date\"] }},\n  \"category\": \"Choose one from rules\",\n  \"summary\": \"Short searchable sentence\",\n  \"detail_description\": \"Dense physical description of layout, materials, colors, and items\",\n  \"tags\": [],\n  \"score_social\": 1,\n  \"score_quality\": 1\n}","modelId":{"__rl":true,"mode":"list","value":"models/gemini-2.5-flash-lite","cachedResultName":"models/gemini-2.5-flash-lite"},"options":{},"resource":"document","simplify":false,"documentUrls":"={{ $json[\"body.public_url\"] }}"},"credentials":{"googlePalmApi":{"id":"2qUzA3DAEFRc7DI1","name":"Gemini FRAINK key"}},"retryOnFail":true,"typeVersion":1.1},{"id":"e7b89bf5-d143-416a-badc-c2b8f7be9697","name":"Parse New PDF Output","type":"n8n-nodes-base.set","position":[-320,848],"parameters":{"options":{},"assignments":{"assignments":[{"id":"p4","name":"album","type":"string","value":"={{ JSON.parse($json['body.output'].replace(/```json|```/g,'').trim()).album }}"},{"id":"73c9a5c1-dab3-4a1a-b4fd-2deebf6bb170","name":"public_url","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).public_url }}"},{"id":"7daab872-1a88-439e-a035-b32e020a4bbb","name":"file_date","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).file_date }}"},{"id":"fe31547c-d07b-4596-b70a-4bae6b875116","name":"mime_type","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).mime_type }}"},{"id":"23c86fea-bade-4f87-83af-91fee6909f17","name":"category","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).category }}"},{"id":"379776fc-9d1d-462b-8096-207995ef5bef","name":"summary","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).summary }}"},{"id":"3958886b-243d-4aa3-92d4-56330a8d1de6","name":"detail_description","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).detail_description }}"},{"id":"15bb6849-3df7-4111-93b5-e19c96d5055c","name":"tags","type":"array","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).tags }}"},{"id":"e1dd3b41-a164-428d-9fb6-b1d60b7efe57","name":"score_social","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).score_social }}"},{"id":"62d0c89c-3a7d-4378-923e-fd1e48b3dfbd","name":"score_quality","type":"string","value":"={{ JSON.parse($json[\"body.output\"].replace(/```json|```/g,'').trim()).score_quality }}"}]}},"typeVersion":3.4},{"id":"118a5e97-e31b-4df2-9f0a-7bbbcad58e05","name":"List R2 Storage Files","type":"n8n-nodes-cloudflare-r2-storage.cloudflareR2Storage","position":[-1776,144],"parameters":{"operation":"list","bucketName":"={{ $json.bucket }}","listOptions":{"prefix":"={{ $json.prefix }}"}},"credentials":{"cloudflareR2StorageApi":{"id":"IYgY6Cdy8RwrUhy4","name":"Cloudflare R2 vector"}},"typeVersion":1},{"id":"bc0d6f99-0d94-4916-bb8c-d0f17ca63e03","name":"Route Files by Type","type":"n8n-nodes-base.switch","position":[-2464,816],"parameters":{"rules":{"values":[{"outputKey":"image","conditions":{"options":{"version":2,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"f8e63397-79eb-4bd0-b3cd-e1fe84954832","operator":{"type":"string","operation":"equals"},"leftValue":"={{ $json.mimeType }}","rightValue":"image"}]},"renameOutput":true},{"outputKey":"pdf","conditions":{"options":{"version":2,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"a3cb0f5f-96db-4276-8fae-8e235ba215e5","operator":{"name":"filter.operator.equals","type":"string","operation":"equals"},"leftValue":"={{ $json.mimeType }}","rightValue":"pdf"}]},"renameOutput":true},{"outputKey":"video","conditions":{"options":{"version":2,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"2db50870-96ad-40cd-8ebe-55df51b7a99f","operator":{"type":"string","operation":"equals"},"leftValue":"={{ $json.mimeType }}","rightValue":"video"}]},"renameOutput":true}]},"options":{}},"typeVersion":3.2},{"id":"b2b278bd-c57c-4c48-b1d2-7275bff82620","name":"Vector Ingest Webhook","type":"n8n-nodes-base.webhook","position":[-2208,144],"webhookId":"e7f0b960-a7e9-4c24-8fed-c431dcf7fba4","parameters":{"path":"vector-ingest","options":{"rawBody":false},"httpMethod":"POST"},"typeVersion":2.1},{"id":"1a1a8bfc-fec3-4985-8954-a3df5d9cc116","name":"FFmpeg Process","type":"n8n-nodes-base.code","position":[-1968,1360],"parameters":{"jsCode":"// ═══════════════════════════════════════════════════════════════════\n// Node: High-Speed Visual Frame Cutter + Gemini Payload Builder (Async Parallel)\n// Version: 4.1.3 (Original Base + Regex Character space, #, ?, &, - Sanitization Patch)\n// Upgrade: Thread-safe dynamic isolation + Smart bounding-box aspect scale.\n// ═══════════════════════════════════════════════════════════════════\n\n// ── DEV DEBUG TUNING CONSTANTS ──────────────────────────────────────\nconst LONG_VIDEO_THRESHOLD_MIN = 3;      // Videos >= this use True Scene Detection\nconst MAX_FRAMES_PER_VIDEO     = 15;     // Absolute ceiling for total frames captured per video\nconst SCENE_DETECT_THRESHOLD   = 0.4;    // Sensitivity: 0.4 = 40% visual shift required to trigger a frame capture\n\n// Logarithmic Math Settings for short videos (< 3 mins), lower is less frames\nconst LOG_MATH_MULTIPLIER    = 2.0;      // 1.5-3.0 Controls scale curve steepness (Lowered per design testing)\nconst LOG_MATH_OFFSET        = 1.0;      // Shifts baseline up/down\nconst MIN_FRAMES_SHORT       = 2;        // Absolute fallback floor so short videos never result in 0 or 1 frames\n\nconst JPEG_QUALITY            = 6;       // ffmpeg -q:v (1=best quality, 31=worst)\nconst DOWNLOAD_TIMEOUT_S      = 120;     // curl max-time in seconds\nconst FFMPEG_TIMEOUT_S        = 240;     // ffmpeg execution timeout in seconds\n\n// ── HELPERS ──────────────────────────────────────────────────────────\nconst fs              = require('fs');\nconst path            = require('path');\nconst { exec }        = require('child_process');\nconst util            = require('util');\nconst execAsync       = util.promisify(exec); // Non-blocking wrapper for terminal execution\n\nconst toFF            = p => p.replace(/\\\\/g, '/');\nconst toWin           = p => p.replace(/\\//g, '\\\\');\n\n// ── DIRS ─────────────────────────────────────────────────────────────\nconst items     = $input.all();\nconst framesDir = toWin($('Configure Input Data').first().json.frames_dir);\nconst videosDir = toWin($('Configure Input Data').first().json.video_path);\n\n// ── INITIAL CLEANUP (Fires once immediately before loop starts) ──────\nfor (const dir of [framesDir, videosDir]) {\n    if (!fs.existsSync(dir)) {\n        fs.mkdirSync(dir, { recursive: true });\n    } else {\n        for (const f of fs.readdirSync(dir)) {\n            try { fs.unlinkSync(path.join(dir, f)); } catch {}\n        }\n    }\n}\n\n// ── MAIN PARALLEL LOOP ───────────────────────────────────────────────\nconst processingPromises = items.map(async (item) => {\n    const videoUrl   = item.json.public_url;\n    const fileDate   = item.json.file_date;\n    \n    // PATCH: Expand your original space replacement to natively encode hashes, question marks, and ampersands\n    const encodedUrl = videoUrl\n        .replace(/ /g, '%20')\n        .replace(/#/g, '%23')\n        .replace(/\\?/g, '%3F')\n        .replace(/&/g, '%26');\n\n    // Derive safe file name from incoming URL\n    const rawName   = path.basename(decodeURIComponent(videoUrl));\n    const ext       = path.extname(rawName);\n    const baseName  = path.basename(rawName, ext).replace(/\\s+/g, '_');\n    const videoFile = toFF(path.join(videosDir, baseName + ext));\n\n    // Isolated tracking array so parallel tasks don't corrupt each other's data\n    const createdFramePaths = [];\n\n    // ── PARALLEL DOWNLOAD ───────────────────────────────────────────\n    try {\n        await execAsync(`curl -L --max-time ${DOWNLOAD_TIMEOUT_S} --retry 1 -o \"${videoFile}\" \"${encodedUrl}\"`);\n    } catch(e) {\n        return []; // skip this video if download fails without crashing entire stream\n    }\n\n    const dlSize = fs.existsSync(toWin(videoFile)) ? fs.statSync(toWin(videoFile)).size : 0;\n    if (dlSize === 0) return [];\n\n    // ── PROBE DURATION ─────────────────────────────────────────────\n    let durationSecs = 0;\n    try {\n        const { stdout } = await execAsync(`ffprobe -v error -show_entries format=duration -of csv=p=0 \"${videoFile}\"`);\n        durationSecs = parseFloat(stdout.trim()) || 0;\n    } catch(e) {}\n\n    const durationMins = durationSecs / 60;\n    const isLongVideo  = durationMins >= LONG_VIDEO_THRESHOLD_MIN;\n    const outputPattern = toFF(path.join(framesDir, `${baseName}-%02d.jpg`));\n\n    // ── DYNAMIC FRAME EXTRACTION STRATEGY ───────────────────────────\n    if (!isLongVideo) {\n        // Method A: Logarithmic scaling math for short videos (< 3 mins)\n        let targetFrames = Math.round((Math.log(durationSecs) * LOG_MATH_MULTIPLIER) + LOG_MATH_OFFSET);\n        \n        targetFrames = Math.max(MIN_FRAMES_SHORT, targetFrames);\n        targetFrames = Math.min(MAX_FRAMES_PER_VIDEO, targetFrames);\n\n        const calculatedInterval = (durationSecs / targetFrames).toFixed(2);\n\n        try {\n            // Uses smart bounding-box scaling to lock the longest side to 960px (Supports portrait/shorts natively)\n            await execAsync(`ffmpeg -y -i \"${videoFile}\" -vf \"fps=1/${calculatedInterval},scale='if(gt(iw,ih),960,-2)':'if(gt(iw,ih),-2,960)'\" -q:v ${JPEG_QUALITY} \"${outputPattern}\"`);\n            \n            // Explicitly verify and collect files that match this video's signature\n            for (let i = 1; i <= (targetFrames + 2); i++) {\n                const frameNum = String(i).padStart(2, '0');\n                const expectedFile = path.join(framesDir, `${baseName}-${frameNum}.jpg`);\n                if (fs.existsSync(expectedFile)) createdFramePaths.push(expectedFile);\n            }\n        } catch(e) {}\n\n    } else {\n        // Method B: True Scene Change Detection for long videos (3 to 10+ mins)\n        try {\n            await execAsync(`ffmpeg -y -i \"${videoFile}\" -vf \"select='gt(scene,${SCENE_DETECT_THRESHOLD})',scale='if(gt(iw,ih),960,-2)':'if(gt(iw,ih),-2,960)'\" -vsync vfr -q:v ${JPEG_QUALITY} \"${outputPattern}\"`);\n            \n            // FIXED: Isolated direct lookup array build instead of live global directory parsing\n            const filesInDir = fs.readdirSync(framesDir);\n            const discoveredFrames = [];\n            \n            for (const f of filesInDir) {\n                if (f.startsWith(baseName) && f.endsWith('.jpg')) {\n                    discoveredFrames.push(path.join(framesDir, f));\n                }\n            }\n\n            discoveredFrames.sort(); // Natural alphabetical sorting verification\n            const cappedFrames = discoveredFrames.slice(0, MAX_FRAMES_PER_VIDEO);\n            createdFramePaths.push(...cappedFrames);\n        } catch(e) {}\n    }\n\n    // ── BUILD LOCAL BATCH ───────────────────────────────────────────\n    const localResults = [];\n    createdFramePaths.sort(); // Maintain absolute visual sequence order\n\n    for (const fullPath of createdFramePaths) {\n        if (!fs.existsSync(fullPath)) continue;\n        \n        const file = path.basename(fullPath);\n        const buffer = fs.readFileSync(fullPath);\n\n        localResults.push({\n            json: {\n                filename:          file,\n                filepath:          fullPath,\n                public_url:        videoUrl,\n                file_date:         fileDate,\n                source_video_path: videoFile,\n                mimeType:          \"video\",\n                duration_min:      durationMins.toFixed(1),\n                base64_data:       buffer.toString('base64')\n            }\n        });\n    }\n\n    return localResults;\n});\n\n// Await completion of all concurrent OS CPU/Network operations\nconst allVideoBatches = await Promise.all(processingPromises);\n\n// Flatten the multi-video array matrices down to a single item stream for n8n\nreturn allVideoBatches.flat();"},"typeVersion":2},{"id":"9e31d871-6a3c-426e-b243-826843d6639a","name":"Set Output Data","type":"n8n-nodes-base.set","position":[-1200,1552],"parameters":{"options":{},"assignments":{"assignments":[{"id":"0951eee4-0394-4efe-90ac-cb65234fd8ff","name":"output","type":"string","value":"={{ $json.candidates[0].content.parts[0].text }}"},{"id":"762a3a15-45f5-4c22-8c33-f7302980cbce","name":"","type":"string","value":""}]}},"typeVersion":3.4},{"id":"4b7da604-0742-40d8-b0f6-034b2a1f7dab","name":"Parse Results Data","type":"n8n-nodes-base.set","position":[-976,1552],"parameters":{"options":{},"assignments":{"assignments":[{"id":"23c86fea-bade-4f87-83af-91fee6909f17","name":"category","type":"string","value":"={{ JSON.parse($json.output.slice(0, $json.output.indexOf('}') + 1)).category }}"},{"id":"379776fc-9d1d-462b-8096-207995ef5bef","name":"summary","type":"string","value":"={{ JSON.parse($json.output.slice(0, $json.output.indexOf('}') + 1)).summary }}"},{"id":"3958886b-243d-4aa3-92d4-56330a8d1de6","name":"detail_description","type":"string","value":"={{ JSON.parse($json.output.slice(0, $json.output.indexOf('}') + 1)).detail_description}}"},{"id":"15bb6849-3df7-4111-93b5-e19c96d5055c","name":"tags","type":"array","value":"={{ JSON.parse($json.output.slice(0, $json.output.indexOf('}') + 1)).tags }}"},{"id":"e1dd3b41-a164-428d-9fb6-b1d60b7efe57","name":"score_social","type":"string","value":"={{ JSON.parse($json.output.slice(0, $json.output.indexOf('}') + 1)).score_social }}"},{"id":"62d0c89c-3a7d-4378-923e-fd1e48b3dfbd","name":"score_quality","type":"string","value":"={{ JSON.parse($json.output.slice(0, $json.output.indexOf('}') + 1)).score_quality }}"},{"id":"05a7c465-eb4c-4a61-8c2d-78eed47ed6f9","name":"public_url","type":"string","value":"={{ $('FFmpeg Process').item.json.public_url }}"},{"id":"529b3075-3e51-4b87-aac3-fc07fae691aa","name":"album","type":"string","value":"={{ $('Configure Input Data').first().json.prefix }}"},{"id":"b2e2f8e6-0a5d-4f68-bda7-7d4df6cad888","name":"file_date","type":"string","value":"={{ $('FFmpeg Process').item.json.file_date }}"},{"id":"8ce3af81-b4d1-4941-89d6-d0a89767b5c5","name":"mime_type","type":"string","value":"video_frame"},{"id":"f2046201-6504-49f1-9fc9-ec8854aa1435","name":"name","type":"string","value":"={{ $('FFmpeg Process').item.json.filename }}"}]}},"typeVersion":3.4},{"id":"1d5dfd2f-1af6-4872-ac45-fa7726bc34a8","name":"Loop Through FFmpeg","type":"n8n-nodes-base.code","position":[-1664,1552],"parameters":{"jsCode":"// Loop through every item coming from the previous FFmpeg node\nreturn $input.all().map(item => {\n  return {\n    json: {\n      ...item.json, // Automatically passes through filename, base64_data, public_url, file_date, etc.\n      prompt: `\n# TASK\nAnalyze the attached visual asset and output a structured metadata object mapping its physical properties and content domain.\n\n# EVALUATE\n1. Category - you must select exactly ONE value for the \"category\" field based on these definitions:\n- \"personal_life\": Family, friends, vacations, private moments.\n- \"curated_inspiration\": Saved clips, interviews, podcasts, news.\n- \"social_content\": Vlogs, talking to camera, trendy content explicitly shot for public growth.\n- \"professional_work\": Real-world site walks, materials, company meeting.\n- \"professional_presentation\": tutorials, online walkthoughs, portfolio renders, pitch slides, corporate materials.\n- \"professional_documents\": document, paperwork content and review.\n\n2. Summary - a single, short, dense sentence capturing the core action or subject. Perfect for keyword search.\n\n3. Detail Description - a comprehensive, objective visual semantic description optimized for vector search embeddings. 3 sentences.\n\n4. Tags - a flat string array of 5 to 8 low-level keywords (lowercase, alphanumeric, hyphenated if multi-word) capturing visible objects, styles, materials, people, items.\n\n5. Scores - evaluate 'score_social': Rate viral/engagement potential. Is it catchy, scroll-stopping, or highly shareable?\n- evaluate 'score_quality': Rate technical execution. Is it stable, clear, well-framed, and is the subject context obvious?\n\n# REQUIRED SCHEMA\nReturn a clean, raw JSON object matching this structure identically:\n{\n  \"mime_type\": \"video_frame\",\n  \"category\": \"Choose one from rules\",\n  \"summary\": \"Short searchable sentence\",\n  \"detail_description\": \"Dense physical description of layout, materials, colors, and items\",\n  \"tags\": [],\n  \"score_social\": 1,\n  \"score_quality\": 1\n} \n`\n    }\n  };\n});"},"typeVersion":2},{"id":"25e05270-00bd-4076-887b-86e546e09a29","name":"Submit Video Frame to API","type":"n8n-nodes-base.httpRequest","position":[-1440,1552],"parameters":{"url":"=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent","method":"POST","options":{"response":{}},"jsonBody":"={\n  \"contents\": [\n    {\n      \"role\": \"user\",\n      \"parts\": [\n        {\n          \"inline_data\": {\n            \"mime_type\": \"image/jpeg\",\n            \"data\": \"{{ $json.base64_data }}\"\n          }\n        },\n        {\n          \"text\": {{ JSON.stringify($json.prompt) }}\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"responseMimeType\": \"application/json\",\n    \"temperature\": 0.2\n  }\n}","sendBody":true,"specifyBody":"json","authentication":"genericCredentialType","genericAuthType":"httpHeaderAuth"},"credentials":{"httpHeaderAuth":{"id":"ZnyE0VrTqcsrXHyx","name":"Gemini"}},"typeVersion":4.4},{"id":"c1a508b5-8f13-4ba8-a655-f9c2aeef774b","name":"Submit Image to Gemini API","type":"n8n-nodes-base.httpRequest","position":[-1344,496],"parameters":{"url":"=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent","method":"POST","options":{"response":{}},"jsonBody":"={\n  \"contents\": [\n    {\n      \"role\": \"user\",\n      \"parts\": [\n        {\n          \"file_data\": {\n            \"mime_type\": \"image/jpeg\",\n            \"file_uri\": {{ JSON.stringify($json[\"body.public_url\"]) }}\n          }\n        },\n        {\n          \"text\": {{ JSON.stringify(\"TASK:\\nAnalyze the image in the input URL visually for semantic retrieval, embeddings, and social/cinematic understanding.\\n\\n## Input Data for Pass-Through:\\n- public_url: \" + $json[\"body.public_url\"] + \"\\n- album: \" + $('Image Webhook Trigger').item.json.body.album + \"\\n- file_date: \" + $json[\"body.file_date\"] + \"\\n\\n# EVALUATE\\n1. Category - you must select exactly ONE value for the \\\"category\\\" field based on these definitions:\\n- \\\"personal_life\\\": Family, friends, vacations, private moments.\\n- \\\"curated_inspiration\\\": Saved clips, interviews, podcasts, news.\\n- \\\"social_content\\\": Vlogs, talking to camera, trendy content explicitly shot for public growth.\\n- \\\"professional_work\\\": Real-world site walks, materials, company meeting.\\n- \\\"professional_presentation\\\": tutorials, online walkthoughs, portfolio renders, pitch slides, corporate materials.\\n- \\\"professional_documents\\\": document, paperwork content and review.\\n\\n2. Summary - a single, short, dense sentence capturing the core action or subject. Perfect for keyword search.\\n\\n3. Detail Description - an objective visual semantic description optimized for vector search embeddings. 2 to 4 sentences.\\n\\n4. Tags - a flat string array of 5 to 8 low-level keywords (lowercase, alphanumeric, hyphenated if multi-word) capturing visible objects, styles, materials, people, items.\\n\\n5. Scores - evaluate 'score_social': Rate viral/engagement potential. Is it catchy, scroll-stopping, or highly shareable?\\n- evaluate 'score_quality': Rate technical execution. Is it stable, clear, well-framed, and is the subject context obvious?\\n\\n# REQUIRED SCHEMA\\nReturn a clean, raw JSON object matching this structure identically:\\n{\\n  \\\"public_url\\\": \\\"\" + $json[\"body.public_url\"] + \"\\\",\\n  \\\"mime_type\\\": \\\"image\\\",\\n  \\\"album\\\": \\\"\" + $('Image Webhook Trigger').item.json.body.album + \"\\\",\\n  \\\"file_date\\\": \\\"\" + $json[\"body.file_date\"] + \"\\\",\\n  \\\"category\\\": \\\"Choose one from rules\\\",\\n  \\\"summary\\\": \\\"Short searchable sentence\\\",\\n  \\\"detail_description\\\": \\\"Dense physical description of layout, materials, colors, and items\\\",\\n  \\\"tags\\\": [],\\n  \\\"score_social\\\": 1,\\n  \\\"score_quality\\\": 1\\n}\") }}\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"responseMimeType\": \"application/json\",\n    \"temperature\": 0.2\n  }\n}","sendBody":true,"specifyBody":"json","authentication":"genericCredentialType","genericAuthType":"httpHeaderAuth"},"credentials":{"httpHeaderAuth":{"id":"ZnyE0VrTqcsrXHyx","name":"Gemini"}},"typeVersion":4.4},{"id":"e547489c-dbc2-40f7-af8c-56092b65b344","name":"Sticky Note19","type":"n8n-nodes-base.stickyNote","position":[-3088,176],"parameters":{"color":"#EBF0A3","width":480,"height":896,"content":"## * 🗄️W57th Vector 2.0\n\n### How it works\n\nThis workflow ingests media files into a Supabase vector store and exposes a webhook for semantic vector search. It lists files from Cloudflare R2, routes images, PDFs, audio, and video through specialized Gemini/Groq processing paths, normalizes the extracted descriptions and metadata, builds vector records, and stores them with Gemini embeddings. A separate query webhook searches the vector index and returns ranked results.\n\n### Setup steps\n\n- Configure Cloudflare R2 credentials and update the bucket, prefix, bucket URL, and temp path values in the input setup node.\n- Configure Google Gemini credentials/API keys for image, PDF, video-frame analysis, and embedding generation.\n- Configure Supabase vector store credentials, table/index settings, and document metadata schema used by both ingest and query nodes.\n- Provide the Groq API token in the n8n environment for speech-to-text transcription.\n- Ensure the internal webhook URLs for image/PDF processing callbacks are reachable and match the deployed n8n webhook paths.\n- If using the auxiliary Google Drive listing path, connect Google Drive credentials and select the intended folder/source.\n\n### Customization\n\nAdjust routing rules for supported MIME types, Gemini prompts, FFmpeg frame/audio extraction settings, text splitter chunking, embedding model, and the fields returned from ranked vector search."},"typeVersion":1},{"id":"2b7d3b29-5607-4e8c-8384-12e35eb6815b","name":"Sticky Note20","type":"n8n-nodes-base.stickyNote","position":[-2256,16],"parameters":{"color":7,"width":624,"height":304,"content":"## Start R2 ingestion\n\nReceives the ingest request, sets the Cloudflare R2 folder parameters, and lists objects from the target bucket/prefix."},"typeVersion":1},{"id":"b848a56b-c2dc-462f-88f1-46818768b2f0","name":"Sticky Note21","type":"n8n-nodes-base.stickyNote","position":[-1600,16],"parameters":{"color":7,"width":624,"height":304,"content":"## Normalize R2 files\n\nSplits the R2 listing into individual files, removes unsupported types, and standardizes media metadata for downstream routing."},"typeVersion":1},{"id":"08fa179d-f23e-4692-bd18-25c96ad8e066","name":"Sticky Note22","type":"n8n-nodes-base.stickyNote","position":[-1824,368],"parameters":{"color":7,"width":624,"height":304,"content":"## Analyze image payload\n\nReceives image webhook batches, splits them into items, and sends each image to Gemini for visual understanding."},"typeVersion":1},{"id":"d8e5d43f-dee3-4453-aab7-0da662f1208c","name":"Sticky Note23","type":"n8n-nodes-base.stickyNote","position":[-1824,720],"parameters":{"color":7,"width":624,"height":304,"content":"## Analyze PDF payload\n\nReceives PDF webhook batches, splits them into items, and uses Gemini to extract or summarize document content."},"typeVersion":1}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","executionOrder":"v1"},"versionId":"6f11b7d2-0115-4579-bc02-facf52ca2522","nodeGroups":[],"connections":{"FFmpeg Process":{"main":[[{"node":"Loop Through FFmpeg","type":"main","index":0},{"node":"Generate FFmpeg Audio","type":"main","index":0}]]},"New PDF Webhook":{"main":[[{"node":"Separate New PDF Output","type":"main","index":0}]]},"Set Output Data":{"main":[[{"node":"Parse Results Data","type":"main","index":0}]]},"Separate Objects":{"main":[[{"node":"Filter Unknown File Types","type":"main","index":0}]]},"Call Groq STT API":{"main":[[{"node":"Parse Audio Transcription","type":"main","index":0}]]},"Load Default Data":{"ai_document":[[{"node":"Ingest to Vector Store","type":"ai_document","index":0}]]},"New Image Webhook":{"main":[[{"node":"Separate New Image Output","type":"main","index":0}]]},"Aggregate New PDFs":{"main":[[{"node":"Post New PDF to API","type":"main","index":0}]]},"Aggregate PDF Data":{"main":[[{"node":"Post PDF to API","type":"main","index":0}]]},"Parse Image Output":{"main":[[{"node":"Construct Name Code","type":"main","index":0}]]},"Parse Results Data":{"main":[[{"node":"Append and Merge Data","type":"main","index":1}]]},"Query Vector Store":{"main":[[{"node":"Rank Search Results","type":"main","index":0}]]},"Set Media Metadata":{"main":[[{"node":"Route Files by Type","type":"main","index":0}]]},"Construct Name Code":{"main":[[{"node":"Set Content and Metadata","type":"main","index":0}]]},"Loop Through FFmpeg":{"main":[[{"node":"Submit Video Frame to API","type":"main","index":0}]]},"PDF Webhook Trigger":{"main":[[{"node":"Separate PDF Metadata","type":"main","index":0}]]},"Rank Search Results":{"main":[[{"node":"Send Webhook Response","type":"main","index":0}]]},"Route Files by Type":{"main":[[{"node":"Aggregate Image Data","type":"main","index":0}],[{"node":"Aggregate PDF Data","type":"main","index":0}],[{"node":"FFmpeg Process","type":"main","index":0}]]},"Aggregate Image Data":{"main":[[{"node":"Post Image to API","type":"main","index":0}]]},"Aggregate New Images":{"main":[[{"node":"Post New Image to API","type":"main","index":0}]]},"Configure Input Data":{"main":[[{"node":"List R2 Storage Files","type":"main","index":0}]]},"Parse New PDF Output":{"main":[[{"node":"Construct Name Code","type":"main","index":0}]]},"Vector Query Webhook":{"main":[[{"node":"Query Vector Store","type":"main","index":0}]]},"Append and Merge Data":{"main":[[{"node":"Construct Name Code","type":"main","index":0}]]},"Generate FFmpeg Audio":{"main":[[{"node":"Call Groq STT API","type":"main","index":0}]]},"Image Webhook Trigger":{"main":[[{"node":"Separate Image Metadata","type":"main","index":0}]]},"List R2 Storage Files":{"main":[[{"node":"Separate Objects","type":"main","index":0}]]},"Separate PDF Metadata":{"main":[[{"node":"Process PDF with Gemini","type":"main","index":0}]]},"Vector Ingest Webhook":{"main":[[{"node":"Configure Input Data","type":"main","index":0}]]},"List Google Drive Files":{"main":[[{"node":"Normalize Google Drive Item","type":"main","index":0}]]},"Process PDF with Gemini":{"main":[[{"node":"Aggregate New PDFs","type":"main","index":0}]]},"Separate Image Metadata":{"main":[[{"node":"Submit Image to Gemini API","type":"main","index":0}]]},"Separate New PDF Output":{"main":[[{"node":"Parse New PDF Output","type":"main","index":0}]]},"Split Text by Character":{"ai_textSplitter":[[{"node":"Load Default Data","type":"ai_textSplitter","index":0}]]},"Set Content and Metadata":{"main":[[{"node":"Ingest to Vector Store","type":"main","index":0}]]},"Embed with Gemini Model 2":{"ai_embedding":[[{"node":"Query Vector Store","type":"ai_embedding","index":0}]]},"Filter Unknown File Types":{"main":[[{"node":"Set Media Metadata","type":"main","index":0}]]},"Parse Audio Transcription":{"main":[[{"node":"Append and Merge Data","type":"main","index":0}]]},"Separate New Image Output":{"main":[[{"node":"Parse Image Output","type":"main","index":0}]]},"Submit Video Frame to API":{"main":[[{"node":"Set Output Data","type":"main","index":0}]]},"Submit Image to Gemini API":{"main":[[{"node":"Aggregate New Images","type":"main","index":0}]]},"Embedding with Gemini Model":{"ai_embedding":[[{"node":"Ingest to Vector Store","type":"ai_embedding","index":0}]]}}}