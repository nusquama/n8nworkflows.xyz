:"https://drive.google.com/drive/folders/1mVH83kyAX-DX41YuIVZLGkG2bjz5RbaB","cachedResultName":"franchise letters"},"operation":"copy","sameFolder":false},"credentials":{"googleDriveOAuth2Api":{"id":"GKbr9ykvIA7NGfQo","name":"Google Drive account"}},"typeVersion":3},{"id":"a89081af-40e4-44a5-914e-4b1a3546984d","name":"Update Google Document","type":"n8n-nodes-base.googleDocs","position":[1360,16],"parameters":{"actionsUi":{"actionFields":[{"text":"[Dear Owner]","action":"replaceAll","replaceText":"={{ $('Extract File Data').item.json.Franchise_Owner }}"},{"text":"[Franchise]","action":"replaceAll","replaceText":"={{ $('Extract File Data').item.json.Franchise_Name }}"},{"text":"[City]","action":"replaceAll","replaceText":"={{ $('Extract File Data').item.json.City }}"},{"text":"[Fee]","action":"replaceAll","replaceText":"={{ String($('Extract File Data').item.json.Franchise_Fee) }}"},{"text":"[Date Today]","action":"replaceAll","replaceText":"={{ $now.toFormat(\"MM/dd/yyyy\") }}"}]},"operation":"update","documentURL":"={{ $json.id }}"},"credentials":{"googleDocsOAuth2Api":{"id":"ycYt8eQpOfiASrb9","name":"Google Docs account"}},"typeVersion":2},{"id":"19b25f88-5d54-4608-aab7-8dbb8969b2b0","name":"Download from Google Drive","type":"n8n-nodes-base.googleDrive","position":[1600,16],"parameters":{"fileId":{"__rl":true,"mode":"id","value":"={{ $json.documentId }}"},"options":{"binaryPropertyName":"data","googleFileConversion":{"conversion":{"docsToFormat":"application/pdf"}}},"operation":"download"},"credentials":{"googleDriveOAuth2Api":{"id":"GKbr9ykvIA7NGfQo","name":"Google Drive account"}},"typeVersion":3},{"id":"7aa5b225-f90b-4531-8c6b-0bfb994bbbbd","name":"Upload to Google Drive","type":"n8n-nodes-base.googleDrive","position":[1808,16],"parameters":{"name":"=franchise_{{ $('Extract File Data').item.json.Franchise_Name }}","driveId":{"__rl":true,"mode":"list","value":"My Drive"},"options":{},"folderId":{"__rl":true,"mode":"list","value":"1mVH83kyAX-DX41YuIVZLGkG2bjz5Rb