{"id":"0OEy2b9hbbLjD7K4","meta":{"instanceId":"0b46bf175b280bd64fd3bb08d27eb45d0acb38f28eb71744afe7b1b5ba2d35e5","templateCredsSetupCompleted":true},"name":"Generate, email, and archive PDFs from HTML with PDFBolt","tags":[{"id":"6R0qCXOebueUozzd","name":"html-to-pdf","createdAt":"2026-06-26T10:33:16.635Z","updatedAt":"2026-06-26T10:33:16.635Z"},{"id":"TKhkZyKTJXT0ASJy","name":"pdf","createdAt":"2026-06-26T10:33:08.804Z","updatedAt":"2026-06-26T10:33:08.804Z"},{"id":"TvYN1J2d3R36gWwM","name":"webhook","createdAt":"2026-06-26T10:33:23.908Z","updatedAt":"2026-06-26T10:33:23.908Z"},{"id":"YnR5xvA1nGWfkF2e","name":"gmail","createdAt":"2026-06-26T16:32:25.511Z","updatedAt":"2026-06-26T16:32:25.511Z"},{"id":"CRldW5uxHhICzBQZ","name":"google-drive","createdAt":"2026-06-30T09:03:04.922Z","updatedAt":"2026-06-30T09:03:04.922Z"},{"id":"nRT2BxCwybU9dJQx","name":"pdfbolt","createdAt":"2026-06-26T10:33:29.960Z","updatedAt":"2026-06-26T10:33:29.960Z"},{"id":"FipQwXzGnzxstVMH","name":"automation","createdAt":"2026-06-26T10:33:42.428Z","updatedAt":"2026-06-26T10:33:42.428Z"}],"nodes":[{"id":"740d3d48-6984-4750-acd4-7508545560f9","name":"Workflow overview","type":"n8n-nodes-base.stickyNote","position":[2960,2144],"parameters":{"width":648,"height":468,"content":"## Generate, email, and archive PDFs from HTML with PDFBolt\n\nThis workflow receives HTML from an app through an n8n webhook, validates the request, generates a PDF with PDFBolt, emails the PDF to a recipient, archives the same file in Google Drive, and returns a JSON response to the caller.\n\n### Setup\n1. Install the PDFBolt community node.\n2. Add your PDFBolt API key from https://app.pdfbolt.com/api-keys.\n3. Connect Gmail and Google Drive credentials in n8n.\n4. Choose the Google Drive folder in the archive node.\n5. Activate the workflow and send JSON to the Production webhook URL.\n\nUse this when another app already creates HTML and n8n handles PDF generation, delivery, and archiving."},"typeVersion":1},{"id":"485f6afc-d6cd-4b9f-b278-01ab92a7b156","name":"Example payload","type":"n8n-nodes-base.stickyNote","position":[2960,2640],"parameters":{"color":7,"width":648,"height":472,"content":"## Example webhook payload\n\nSend a POST request with JSON like this:\n\n```json\n{\n  \"html\": \"<html><body><h1>Quarterly Report</h1><p>Generated from webhook data.</p></body></html>\",\n  \"filename\": \"quarterly-report.pdf\",\n  \"recipientEmail\": \"customer@example.com\",\n  \"recipientName\": \"Example Customer\",\n  \"emailSubject\": \"Your quarterly report\",\n  \"emailMessage\": \"Hi Example Customer,\\n\\nPlease find your report attached.\\n\\nThank you.\"\n}\n```\n\nThe workflow requires `html` and `recipientEmail`. If either field is missing, it returns a structured error response instead of trying to generate a PDF."},"typeVersion":1},{"id":"2891bc99-af9f-435a-aa84-64788f8ae81b","name":"Validation note","type":"n8n-nodes-base.stickyNote","position":[3856,2560],"parameters":{"color":7,"width":360,"height":196,"content":"## Validate request\nThe Code node checks required fields, normalizes the PDF filename, prepares email text, and sends invalid requests to the error response branch."},"typeVersion":1},{"id":"7c0d14a2-2156-4343-9baf-ef2cb6f72166","name":"Delivery note","type":"n8n-nodes-base.stickyNote","position":[4432,2304],"parameters":{"color":7,"width":872,"height":152,"content":"## Generate, send, and archive\nPDFBolt uses the Direct endpoint and returns the PDF as binary field `data`. Gmail sends that binary field as an attachment. Google Drive uploads the same binary field for archiving."},"typeVersion":1},{"id":"a54cb723-7369-483e-81b6-e1d87c79668d","name":"Validate and prepare request","type":"n8n-nodes-base.code","position":[3968,2784],"parameters":{"jsCode":"const input = $input.first().json;\nconst body = input.body ?? input;\n\nfunction isPlainObject(value) {\n    return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction timestamp() {\n    return new Date().toISOString().replace(/[:.]/g, '-');\n}\n\nfunction safeFilename(value) {\n    const fallback = `pdfbolt-document-${timestamp()}.pdf`;\n    const raw = String(value || fallback).trim() || fallback;\n    const cleaned = raw\n        .replace(/[^a-zA-Z0-9._-]+/g, '-')\n        .replace(/-+/g, '-')\n        .replace(/^-|-$/g, '')\n        .slice(0, 120);\n\n    const filename = cleaned || fallback;\n    return filename.toLowerCase().endsWith('.pdf') ? filename : `${filename}.pdf`;\n}\n\nconst errors = [];\n\nif (!isPlainObject(body)) {\n    errors.push('Request body must be a JSON object.');\n}\n\nconst html = typeof body.html === 'string' ? body.html.trim() : '';\nconst recipientEmail = typeof body.recipientEmail === 'string' ? body.recipientEmail.trim() : '';\n\nif (!html) {\n    errors.push('Missing required field: html.');\n}\n\nif (!recipientEmail) {\n    errors.push('Missing required field: recipientEmail.');\n}\n\nconst filename = safeFilename(body.filename);\nconst recipientName = String(body.recipientName || 'there').trim();\nconst emailSubject = String(body.emailSubject || `Your PDF document: ${filename}`).trim();\nconst emailMessage = String(\n    body.emailMessage ||\n    `Hi ${recipientName},\n\nPlease find your PDF document attached.\n\nThank you.`\n).trim();\n\nconst status = errors.length === 0 ? 'valid' : 'invalid';\n\nreturn [{\n    json: {\n        valid: status === 'valid',\n        status,\n        errors,\n        html,\n        filename,\n        recipientEmail,\n        recipientName,\n        emailSubject,\n        emailMessage,\n        receivedFields: isPlainObject(body) ? Object.keys(body) : []\n    }\n}];"},"typeVersion":2},{"id":"2a033df2-3d70-47f5-ad11-ab6f7f5deb35","name":"Request valid?","type":"n8n-nodes-base.if","position":[4272,2784],"parameters":{"options":{},"conditions":{"options":{"version":3,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"7b0f9f81-4f22-4d0f-b6ce-3ea0df7c31aa","operator":{"type":"string","operation":"equals"},"leftValue":"={{ $json.status }}","rightValue":"valid"}]}},"typeVersion":2.3},{"id":"e974fc4d-29bb-47fe-9f40-660918671ceb","name":"Generate PDF with PDFBolt","type":"n8n-nodes-pdfbolt.pdfBolt","position":[4576,2672],"parameters":{"html":"={{ $json.html }}","operation":"convertHtml","endpointType":"direct","additionalOptions":{"format":"A4","filename":"={{ $json.filename }}","printBackground":true}},"typeVersion":1},{"id":"58af3b66-3731-4d5b-94f6-b6fc05530abc","name":"Archive PDF in Google Drive","type":"n8n-nodes-base.googleDrive","position":[4896,2800],"parameters":{"name":"={{ $('Validate and prepare request').item.json.filename }}","driveId":{"__rl":true,"mode":"list","value":"My Drive","cachedResultUrl":"https://drive.google.com/drive/my-drive","cachedResultName":"My Drive"},"options":{},"folderId":{"__rl":true,"mode":"list","value":"root","cachedResultUrl":"https://drive.google.com/drive","cachedResultName":"/ (Root folder)"},"inputDataFieldName":"data"},"typeVersion":3},{"id":"7f003544-61b1-484d-aaa2-a003b0905af2","name":"Return success response","type":"n8n-nodes-base.respondToWebhook","position":[5200,2576],"parameters":{"options":{},"respondWith":"json","responseBody":"={{ { success: true, status: 'sent', filename: $('Validate and prepare request').item.json.filename, recipientEmail: $('Validate and prepare request').item.json.recipientEmail } }}"},"typeVersion":1.5},{"id":"3b24fb9f-96b4-44f4-aa42-9a578960c78d","name":"Receive HTML payload","type":"n8n-nodes-base.webhook","position":[3680,2784],"webhookId":"570e357b-4414-4f76-bfca-14453054f950","parameters":{"path":"pdfbolt-html-pdf-delivery","options":{},"httpMethod":"POST","responseMode":"responseNode"},"typeVersion":2.1},{"id":"fef89312-c51c-42d9-befb-5bcd31790f6e","name":"Return error response","type":"n8n-nodes-base.respondToWebhook","position":[4576,2976],"parameters":{"options":{"responseCode":400},"respondWith":"json","responseBody":"={{ { success: false, errors: $json.errors, receivedFields: $json.receivedFields } }}"},"typeVersion":1.5},{"id":"916f959d-2768-4d54-a19b-c94242c6f59c","name":"Email PDF attachment","type":"n8n-nodes-base.gmail","position":[4896,2576],"webhookId":"a305d5bc-de0b-4592-a0f3-1a833e7b8330","parameters":{"sendTo":"={{ $('Validate and prepare request').item.json.recipientEmail }}","message":"={{ $('Validate and prepare request').item.json.emailMessage }}","options":{"attachmentsUi":{"attachmentsBinary":[{"property":"data"}]}},"subject":"={{ $('Validate and prepare request').item.json.emailSubject }}","emailType":"text"},"typeVersion":2.1},{"id":"f5702dd6-4dac-4534-a7aa-0c8b0ab2d804","name":"PDFBolt API key note","type":"n8n-nodes-base.stickyNote","position":[4432,2480],"parameters":{"color":5,"width":360,"content":"## PDFBolt API key\nAdd your PDFBolt API key from https://app.pdfbolt.com/api-keys to this node before running the workflow."},"typeVersion":1}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","executionOrder":"v1"},"versionId":"13ae8018-01b3-4e19-8130-57e397fe0290","nodeGroups":[],"connections":{"Request valid?":{"main":[[{"node":"Generate PDF with PDFBolt","type":"main","index":0}],[{"node":"Return error response","type":"main","index":0}]]},"Email PDF attachment":{"main":[[{"node":"Return success response","type":"main","index":0}]]},"Receive HTML payload":{"main":[[{"node":"Validate and prepare request","type":"main","index":0}]]},"Generate PDF with PDFBolt":{"main":[[{"node":"Email PDF attachment","type":"main","index":0},{"node":"Archive PDF in Google Drive","type":"main","index":0}]]},"Validate and prepare request":{"main":[[{"node":"Request valid?","type":"main","index":0}]]}}}