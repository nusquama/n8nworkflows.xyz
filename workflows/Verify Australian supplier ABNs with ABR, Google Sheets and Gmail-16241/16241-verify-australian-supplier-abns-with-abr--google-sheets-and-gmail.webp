{"id":"ItRryynA32GJtmC9","meta":{"instanceId":"3814f307919f73a3a92c19396212e3d29c8efbdbbf2ce0ceab8d2d7afc20c590","templateCredsSetupCompleted":true},"name":"Australian Supplier Onboarding with ABN Verification","tags":[],"nodes":[{"id":"e8bf5d22-93a3-49af-8efa-3b56c33a645e","name":"Overview","type":"n8n-nodes-base.stickyNote","position":[-2240,-96],"parameters":{"color":4,"width":600,"height":400,"content":"## Australian Supplier Onboarding with ABN Verification\n\n**Who this is for:** Any business that needs to verify a Australian supplier's ABN before onboarding them.\n\n**How it works:**\n1. Supplier fills in the onboarding form\n2. Their ABN is looked up against the Australian Business Register\n3. Active ABN -> saved to Google Sheet + team is notified\n4. Inactive or not found -> supplier sees a clear rejection message\n\n**Before you activate:**\n- Replace masked GUID in the **ABR Lookup** node with your real GUID\n- Connect your Google Sheets credential in **Save to Supplier Register** and set your Sheet ID\n- Connect your Gmail credential in **Notify Team** and set the recipient address"},"typeVersion":1},{"id":"0759c4ba-c88a-477c-b3f9-814795c5fdc5","name":"Note: Step 1","type":"n8n-nodes-base.stickyNote","position":[-1600,-96],"parameters":{"color":7,"width":300,"height":404,"content":"### Step 1\nSupplier fills in their details in the form"},"typeVersion":1},{"id":"c94ed81b-71e6-47f7-b7be-da5f807d8af3","name":"Note: Step 2","type":"n8n-nodes-base.stickyNote","position":[-1248,-96],"parameters":{"color":7,"width":220,"height":404,"content":"### Step 2\nClean ABN data received from the form"},"typeVersion":1},{"id":"9aa94360-a793-40a8-a7d0-449c68988dc6","name":"Note: Step 3","type":"n8n-nodes-base.stickyNote","position":[-992,-96],"parameters":{"color":7,"width":380,"height":408,"content":"### Step 3\nCalls the official API to verify the provided details\n\n⚠️ Note\nAdd your real GUID here, and replace the current masked one"},"typeVersion":1},{"id":"dc15fa70-e035-437c-b53c-8cd979d186b7","name":"Note: Step 4","type":"n8n-nodes-base.stickyNote","position":[-528,-96],"parameters":{"color":7,"width":220,"height":404,"content":"### Step 4\nExtract fields from response and clean them"},"typeVersion":1},{"id":"69109b5b-5db8-416a-86b1-ed82bd8fce5d","name":"Note: Step 5","type":"n8n-nodes-base.stickyNote","position":[-224,-96],"parameters":{"color":7,"width":236,"height":408,"content":"### Step 5\nCheck if ABN is active or not"},"typeVersion":1},{"id":"981944a0-3999-4541-89a7-b2c11028acb8","name":"Prepare Form Data","type":"n8n-nodes-base.set","position":[-1184,64],"parameters":{"options":{},"assignments":{"assignments":[{"id":"abn-clean","name":"abn","type":"string","value":"={{ $json['ABN'].replace(/[\\s\\-\\.]/g, '') }}"},{"id":"business-name","name":"businessName","type":"string","value":"={{ $json['Business Name'].trim() }}"},{"id":"contact-name","name":"contactName","type":"string","value":"={{ $json['Contact Name'].trim() }}"},{"id":"contact-email","name":"contactEmail","type":"string","value":"={{ $json['Contact Email'].trim() }}"},{"id":"contact-phone","name":"contactPhone","type":"string","value":"={{ $json['Contact Phone'] || '' }}"},{"id":"services","name":"servicesProvided","type":"string","value":"={{ $json['Services Provided'].trim() }}"},{"id":"submitted-at","name":"submittedAt","type":"string","value":"={{ $now.toISO() }}"}]}},"typeVersion":3.4},{"id":"25ecd1d7-5aa4-4e96-a4d7-e95d705c2878","name":"ABR Lookup","type":"n8n-nodes-base.httpRequest","position":[-848,64],"parameters":{"url":"=https://abr.business.gov.au/json/AbnDetails.aspx","options":{"timeout":10000,"response":{"response":{"responseFormat":"text"}}},"sendQuery":true,"queryParameters":{"parameters":[{"name":"abn","value":"={{ $json.abn }}"},{"name":"guid","value":"4ef...d1a"},{"name":"callback","value":"callback"}]}},"typeVersion":4.2},{"id":"2ff49f33-a455-4cae-87d6-c3349d9d00b6","name":"Extract ABR Fields","type":"n8n-nodes-base.set","position":[-464,64],"parameters":{"options":{},"assignments":{"assignments":[{"id":"abr-raw","name":"abrRaw","type":"string","value":"={{ $json.data }}"},{"id":"abr-json-string","name":"abrJsonString","type":"string","value":"={{ $json.data.replace(/^callback\\(/, '').replace(/\\)$/, '') }}"},{"id":"abn-status","name":"abnStatus","type":"string","value":"={{ JSON.parse($json.data.replace(/^callback\\(/, '').replace(/\\)$/, '')).AbnStatus }}"},{"id":"entity-name","name":"registeredEntityName","type":"string","value":"={{ JSON.parse($json.data.replace(/^callback\\(/, '').replace(/\\)$/, '')).EntityName }}"},{"id":"entity-type","name":"entityTypeName","type":"string","value":"={{ JSON.parse($json.data.replace(/^callback\\(/, '').replace(/\\)$/, '')).EntityTypeName }}"},{"id":"gst-date","name":"gstDate","type":"string","value":"={{ JSON.parse($json.data.replace(/^callback\\(/, '').replace(/\\)$/, '')).Gst }}"},{"id":"abn-status-from","name":"abnStatusEffectiveFrom","type":"string","value":"={{ JSON.parse($json.data.replace(/^callback\\(/, '').replace(/\\)$/, '')).AbnStatusEffectiveFrom }}"},{"id":"state","name":"addressState","type":"string","value":"={{ JSON.parse($json.data.replace(/^callback\\(/, '').replace(/\\)$/, '')).AddressState }}"},{"id":"postcode","name":"addressPostcode","type":"string","value":"={{ JSON.parse($json.data.replace(/^callback\\(/, '').replace(/\\)$/, '')).AddressPostcode }}"},{"id":"abr-message","name":"abrMessage","type":"string","value":"={{ JSON.parse($json.data.replace(/^callback\\(/, '').replace(/\\)$/, '')).Message || '' }}"},{"id":"pass-abn","name":"abn","type":"string","value":"={{ $('Prepare Form Data').first().json.abn }}"},{"id":"pass-business","name":"businessName","type":"string","value":"={{ $('Prepare Form Data').first().json.businessName }}"},{"id":"pass-contact","name":"contactName","type":"string","value":"={{ $('Prepare Form Data').first().json.contactName }}"},{"id":"pass-email","name":"contactEmail","type":"string","value":"={{ $('Prepare Form Data').first().json.contactEmail }}"},{"id":"pass-phone","name":"contactPhone","type":"string","value":"={{ $('Prepare Form Data').first().json.contactPhone }}"},{"id":"pass-services","name":"servicesProvided","type":"string","value":"={{ $('Prepare Form Data').first().json.servicesProvided }}"},{"id":"pass-submitted","name":"submittedAt","type":"string","value":"={{ $('Prepare Form Data').first().json.submittedAt }}"}]}},"typeVersion":3.4},{"id":"7b163a1b-6db9-4c8f-873a-9f7cc7de81da","name":"ABN Active?","type":"n8n-nodes-base.if","position":[-160,64],"parameters":{"options":{},"conditions":{"options":{"version":2,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"active-check","operator":{"type":"string","operation":"equals"},"leftValue":"={{ $json.abnStatus }}","rightValue":"Active"}]}},"typeVersion":2.2},{"id":"d3960f48-585c-4584-8ca6-b10a26da905e","name":"Save to Supplier Register","type":"n8n-nodes-base.googleSheets","position":[208,0],"parameters":{"columns":{"value":{},"schema":[{"id":"Registered Entity Name","type":"string","display":true,"required":false,"displayName":"Registered Entity Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Business Name","type":"string","display":true,"required":false,"displayName":"Business Name","defaultMatch":false,"canBeUsedToMatch":true},{"id":"ABN","type":"string","display":true,"required":false,"displayName":"ABN","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Entity Type","type":"string","display":true,"required":false,"displayName":"Entity Type","defaultMatch":false,"canBeUsedToMatch":true},{"id":"State","type":"string","display":true,"required":false,"displayName":"State","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Postcode","type":"string","display":true,"required":false,"displayName":"Postcode","defaultMatch":false,"canBeUsedToMatch":true},{"id":"Contact Name","type":"string","display":true,"required":false,"displayName":"Contact N