":[576,64],"webhookId":"2599382d-c314-4223-99ec-902e1cab6dff","parameters":{"sendTo":"teamarbazasif@gmail.com","message":"=A new supplier has completed onboarding and their ABN has been verified.\n\nSUPPLIER DETAILS\nRegistered Entity Name: {{ $json.registeredEntityName }}\nABN: {{ $json.abn }}\nABN Status: {{ $json.abnStatus }} (since {{ $json.abnStatusEffectiveFrom }})\nGST Registered: {{ $json.gstDate ? 'Yes — ' + $json.gstDate : 'No' }}\nEntity Type: {{ $json.entityTypeName }}\nState / Postcode: {{ $json.addressState }} {{ $json.addressPostcode }}\n\nCONTACT\nName: {{ $json.contactName }}\nEmail: {{ $json.contactEmail }}\nPhone: {{ $json.contactPhone }}\nServices: {{ $json.servicesProvided }}\n\nThis record has been added to the Supplier Register sheet.","options":{},"subject":"=New supplier verified - {{ $json.registeredEntityName }} (ABN {{ $json.abn }})","emailType":"text"},"credentials":{"gmailOAuth2":{"id":"T3t41ZTA4Baw0pPF","name":"Gmail account"}},"typeVersion":2.1},{"id":"4fd08d4b-a720-44d6-8371-4c2d955895e7","name":"Note: Step 6","type":"n8n-nodes-base.stickyNote","position":[480,-96],"parameters":{"color":7,"width":268,"height":408,"content":"### Step 7\nInform team that supplier has been verified and added to Google Sheet"},"typeVersion":1},{"id":"ee08c3ae-15b2-4d74-a059-49dd337fd137","name":"Note: Step 7","type":"n8n-nodes-base.stickyNote","position":[784,-96],"parameters":{"color":7,"width":316,"height":408,"content":"### Step 8\nShow success message to supplier on form page "},"typeVersion":1}],"active":false,"pinData":{},"settings":{"executionOrder":"v1"},"versionId":"0781b47c-3580-4c21-81bb-ed6be35bc87c","connections":{"ABR Lookup":{"main":[[{"node":"Extract ABR Fields","type":"main","index":0}]]},"ABN Active?":{"main":[[{"node":"Save to Supplier Register","type":"main","index":0}],[{"node":"Show ABN Inactive Page","type":"main","index":0}]]},"Notify Team":{"main":[[{"node":"Show Success Page","type":"main","index":0}]]},"Prepare Form Data":{"mai