o you can jump directly to the failed execution. To set up: create an account at pushover.net, note your User Key, create an App to generate the App Token, then configure both in n8n.","onError":"continueRegularOutput","position":[2784,1392],"parameters":{},"typeVersion":1},{"id":"980dc500-225a-4967-8f31-8ccf4e25f602","name":"WF-04 Overview","type":"n8n-nodes-base.stickyNote","position":[2144,960],"parameters":{"content":""},"typeVersion":1},{"id":"2370fab0-38ac-482d-91cf-b16e8d841f86","name":"Note: How It Works","type":"n8n-nodes-base.stickyNote","position":[2080,1088],"parameters":{"content":""},"typeVersion":1},{"id":"71e7eab7-348b-4e64-a498-c9e45354c7bb","name":"Format Error Message","type":"n8n-nodes-base.set","notes":"Builds the formatted alert text from the error payload received by the Error Trigger. The output is HTML formatted for Pushover which natively supports b, i, code, pre, and a href tags when the html flag is set. Error text is trimmed to 400 chars and stack to 250 chars to reduce message-size failures. Also extracts the execution URL as a separate field so Pushover can display it as a clickable link below the alert when available. All field references use safe fallbacks so this node never throws even if some fields are absent in the payload.","onError":"continueRegularOutput","position":[2544,1392],"parameters":{},"typeVersion":3.4}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","executionOrder":"v1"},"versionId":"b480aeb6-e1cf-4876-8d0a-d96b19a5d7b0","connections":{"Config":{"main":[[{"node":"Set Post Context","type":"main","index":0}]]},"Wait 1 min":{"main":[[{"node":"Multi-Source Research Agent","type":"main","index":0}]]},"Parse Angle":{"main":[[{"node":"Wait 1 min","type":"main","index":0}]]},"Mark as Live":{"main":[[{"node":"Notify Post Published","type":"main","index":0}]]},"Parse Social":{"main":[[{"node":"Update Notion Pending Review","type":"main","index":0}]]},"Error Trigger":{"main":[[{"node":"Format Error Message","t