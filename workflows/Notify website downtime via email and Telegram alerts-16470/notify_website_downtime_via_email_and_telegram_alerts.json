{"id":"cfitFEJWFIhi2psZ","meta":{"instanceId":"246a53600b1ece5d9b47eb832897710858cd6aa5961a6940cb6679aaf2fccbe8"},"name":"Website Down Checker Robot","tags":[],"nodes":[{"id":"85e01a79-a528-4454-bdba-af57be5fa77e","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[-512,-160],"parameters":{"width":480,"height":896,"content":"## Website Down Checker Robot\n\n### How it works\n\nThis workflow periodically monitors a configured list of websites for availability. It checks each site once, calculates whether it is up, and waits before retrying any site that appears down. If the second check also fails, it sends downtime notifications by email and Telegram.\n\n### Setup steps\n\n- Configure the Schedule Trigger with the desired monitoring interval.\n- Edit the Config node to set the website URLs, retry wait time, Telegram chat ID, and destination alert email address.\n- Set up credentials for the Email Send node, such as SMTP or the selected email provider credentials.\n- Set up Telegram credentials with a bot token and ensure the configured chat ID can receive messages from the bot.\n- Review the HTTP Request nodes and status calculation logic to confirm the workflow treats the desired response codes or errors as downtime.\n\n### Customization\n\nAdjust the website list, retry delay, schedule frequency, alert recipients, and notification message templates to match your monitoring needs. You can also change the switch conditions if certain HTTP status codes should be treated differently."},"typeVersion":1},{"id":"a0edf5b2-6451-4e56-952e-7f0249931679","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[48,-16],"parameters":{"color":7,"width":400,"height":336,"content":"## Schedule and configuration\n\nStarts the workflow on a schedule and defines shared monitoring settings such as target websites, retry wait time, Telegram chat ID, and alert email address."},"typeVersion":1},{"id":"3d513f8d-4791-4936-8341-f40654312b1f","name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[496,-160],"parameters":{"color":7,"width":256,"height":608,"content":"## Prepare website checks\n\nNormalizes the configured website list and splits it into individual items so each site can be tested separately."},"typeVersion":1},{"id":"0b75b57e-6e62-4004-a590-8c7a3529e5e4","name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[784,0],"parameters":{"color":7,"width":928,"height":352,"content":"## Initial site status check\n\nPerforms the first HTTP GET request for each website, merges the resulting success/error paths, calculates an IS_UP status, and routes only sites that need a retry."},"typeVersion":1},{"id":"47022719-4c1d-4506-8cfe-85316de448b5","name":"Sticky Note4","type":"n8n-nodes-base.stickyNote","position":[1808,0],"parameters":{"color":7,"width":240,"height":368,"content":"## Retry delay\n\nPauses the workflow for the configured wait period before performing a second check on websites that appeared to be down."},"typeVersion":1},{"id":"5c967455-1b0b-4a96-84d0-09ba2dee1e8a","name":"Sticky Note5","type":"n8n-nodes-base.stickyNote","position":[960,416],"parameters":{"color":7,"width":896,"height":304,"content":"## Second status verification\n\nRuns a follow-up HTTP check after the wait, merges outcomes, recalculates the up/down status, and routes confirmed failures toward alerting."},"typeVersion":1},{"id":"74ed27f5-93c6-4cec-9169-b1f8328a25be","name":"Sticky Note6","type":"n8n-nodes-base.stickyNote","position":[1024,752],"parameters":{"color":7,"width":400,"height":320,"content":"## Send downtime alerts\n\nSends an email alert and then a Telegram text message when a website is still down after the retry check."},"typeVersion":1},{"id":"13daf9f6-80a8-4b3d-bfb7-966a96ea81d2","name":"Every Minute Trigger","type":"n8n-nodes-base.scheduleTrigger","position":[96,160],"parameters":{"rule":{"interval":[{"field":"minutes"}]}},"typeVersion":1.2},{"id":"8b1f7e0a-9c84-4ca7-b39a-ed83cdb7883c","name":"Set Site Status Fields","type":"n8n-nodes-base.set","position":[1328,128],"parameters":{"options":{},"assignments":{"assignments":[{"id":"b0cbcff5-bfcf-46a5-a386-65c4dd56c42f","name":"date","type":"string","value":"={{ $json.headers.date }}"},{"id":"8c4155e4-bcc6-41dd-9582-346a57a7b997","name":"website","type":"string","value":"={{ $('Split Websites').item.json.Websites }}"},{"id":"9af72278-5b29-406a-b4c5-f47f3d805063","name":"IS_UP","type":"boolean","value":"={{ $json.statusCode <= 400  }}"}]}},"typeVersion":3.3},{"id":"70ff379f-2dbd-4bf4-9836-59fbbd197350","name":"Check Website Status","type":"n8n-nodes-base.httpRequest","onError":"continueErrorOutput","position":[832,176],"parameters":{"url":"={{ $json.Websites }}","options":{"batching":{"batch":{}},"response":{"response":{"neverError":true,"fullResponse":true}}},"sendHeaders":true,"headerParameters":{"parameters":[{}]}},"typeVersion":4.2},{"id":"2687154c-909f-4166-a6d5-d3b3a848ab55","name":"Route by Site Status","type":"n8n-nodes-base.switch","position":[1568,160],"parameters":{"rules":{"values":[{"outputKey":"UP","conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"7191e7cb-f2e1-4288-aa68-21f6efefafc5","operator":{"type":"boolean","operation":"true","singleValue":true},"leftValue":"={{ $json.IS_UP }}","rightValue":""}]},"renameOutput":true},{"outputKey":"DOWN","conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"e07edddc-70be-46ed-9f5c-7fba0ed52bc3","operator":{"type":"boolean","operation":"false","singleValue":true},"leftValue":"={{ $json.IS_UP }}","rightValue":""}]},"renameOutput":true}]},"options":{}},"typeVersion":3},{"id":"d02503c8-cecd-48d2-8b62-731a929ebfa0","name":"Split Websites","type":"n8n-nodes-base.splitOut","position":[608,288],"parameters":{"options":{},"fieldToSplitOut":"Websites"},"typeVersion":1},{"id":"da662a42-9322-4da6-ad2c-6dab13df8893","name":"Set Configuration Parameters","type":"n8n-nodes-base.set","position":[304,160],"parameters":{"options":{},"assignments":{"assignments":[{"id":"72b729c6-e0af-46f0-955f-c649e9d397bc","name":"Websites","type":"string","value":"=\nhttps://www.midclearonline.com.lb"},{"id":"25457f32-6440-404d-8e99-eb772e552982","name":"wait_secs","type":"number","value":5},{"id":"4f646a6a-3f84-4410-bed2-3b0d770066c7","name":"telegram_chat_id","type":"string","value":"chat Id here!"},{"id":"5ea1be97-40ce-4696-9454-ecb17127e674","name":"alert_email","type":"string","value":"you@example.com"}]}},"typeVersion":3.4},{"id":"051e824f-d10b-48f3-9c30-bced06853e28","name":"Set Website Field","type":"n8n-nodes-base.set","position":[544,48],"parameters":{"options":{},"assignments":{"assignments":[{"id":"ce076f11-d745-43a9-8069-a55759ceb0c9","name":"Websites","type":"array","value":"={{\n  // we split by line, and only keep non-empty lines\n  $json.Websites.split('\\n').filter((url) => url)\n}}"}]}},"typeVersion":3.4},{"id":"3d752ff8-b699-4008-b73e-a095eddf71b3","name":"Merge Test Results","type":"n8n-nodes-base.merge","position":[1120,128],"parameters":{},"typeVersion":3.2},{"id":"cbb3099a-faa4-4e25-82af-574605ea5788","name":"Wait Configured Seconds","type":"n8n-nodes-base.wait","position":[1856,208],"webhookId":"84690808-e584-41b6-95a3-1f5bd0c87fe7","parameters":{"amount":"={{ $('Set Configuration Parameters').item.json.wait_secs }}"},"typeVersion":1.1},{"id":"ddfff72a-c249-4caa-a65c-aa577764eff9","name":"Set Site Status Fields 2","type":"n8n-nodes-base.set","position":[1488,544],"parameters":{"options":{},"assignments":{"assignments":[{"id":"b0cbcff5-bfcf-46a5-a386-65c4dd56c42f","name":"date","type":"string","value":"={{ $json.headers.date }}"},{"id":"8c4155e4-bcc6-41dd-9582-346a57a7b997","name":"website","type":"string","value":"={{ $('Split Websites').item.json.Websites }}"},{"id":"9af72278-5b29-406a-b4c5-f47f3d805063","name":"IS_UP","type":"boolean","value":"={{ $json.statusCode <= 400  }}"}]}},"typeVersion":3.3},{"id":"385f7133-02b1-4c12-b26a-efdbf652dbda","name":"Check Website Status 2","type":"n8n-nodes-base.httpRequest","onError":"continueErrorOutput","position":[1008,544],"parameters":{"url":"={{ $json.Websites }}","options":{"batching":{"batch":{}},"response":{"response":{"neverError":true,"fullResponse":true}}},"sendHeaders":true,"headerParameters":{"parameters":[{}]}},"typeVersion":4.2},{"id":"620b82ff-8231-418e-b4bc-3437dbb0a1aa","name":"Aggregate Test Results 2","type":"n8n-nodes-base.merge","position":[1264,544],"parameters":{},"typeVersion":3.2},{"id":"5173a540-7f6d-4e94-a414-3380101d81f7","name":"Route by Site Status 2","type":"n8n-nodes-base.switch","position":[1712,544],"parameters":{"rules":{"values":[{"outputKey":"UP","conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"7191e7cb-f2e1-4288-aa68-21f6efefafc5","operator":{"type":"boolean","operation":"true","singleValue":true},"leftValue":"={{ $json.IS_UP }}","rightValue":""}]},"renameOutput":true},{"outputKey":"DOWN","conditions":{"options":{"version":1,"leftValue":"","caseSensitive":true,"typeValidation":"strict"},"combinator":"and","conditions":[{"id":"e07edddc-70be-46ed-9f5c-7fba0ed52bc3","operator":{"type":"boolean","operation":"false","singleValue":true},"leftValue":"={{ $json.IS_UP }}","rightValue":""}]},"renameOutput":true}]},"options":{}},"typeVersion":3},{"id":"ca26faf3-1bcc-40a9-8075-4ddbb79f068d","name":"Send Telegram Alert","type":"n8n-nodes-base.telegram","position":[1280,912],"webhookId":"df3b407d-2d19-419a-9d70-774218ac986b","parameters":{"text":"={{ $('Set Site Status Fields').item.json.website }} is DOWN.\nFrom: n8n uptime","chatId":"={{ $('Set Configuration Parameters').item.json.telegram_chat_id }}","additionalFields":{"appendAttribution":false}},"typeVersion":1.2},{"id":"b4493614-8716-4b6c-999e-02dadf23e074","name":"Send Email Alert","type":"n8n-nodes-base.emailSend","position":[1072,912],"webhookId":"575f16e4-65b4-4ebd-8151-230bfc7ba214","parameters":{"html":"<!doctype html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n  <title>Website Down Notification</title>\n</head>\n<body style=\"margin:0;padding:0;background:#f2f4f6;font-family:Arial,Helvetica,sans-serif;\">\n  <!-- Container -->\n  <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:600px;margin:24px auto;background:#ffffff;border-radius:6px;overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,0.08);\">\n    <tr>\n      <td style=\"padding:18px 20px;background:#0b69ff;color:#ffffff;text-align:center;\">\n        <h1 style=\"margin:0;font-size:20px;\">Website Offline Alert</h1>\n      </td>\n    </tr>\n\n    <tr>\n      <td style=\"padding:20px;\">\n        <p style=\"margin:0 0 12px 0;color:#333333;font-size:15px;line-height:1.5;\">\n          Hello <strong>{{Recipient Name}}</strong>,\n        </p>\n\n        <p style=\"margin:0 0 12px 0;color:#333333;font-size:15px;line-height:1.5;\">\n          We wanted to let you know that <strong>{{YourWebsite.com}}</strong> is currently <strong>unavailable</strong>. Our team has been notified and is investigating the issue.\n        </p>\n\n        <table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin:12px 0;\">\n          <tr>\n            <td style=\"padding:10px;background:#f7f9fc;border:1px solid #eef1f6;border-radius:6px;font-size:14px;color:#333;\">\n              <strong>Incident:</strong> Website unreachable<br>\n              <strong>Detected at:</strong> {{YYYY-MM-DD HH:MM}}<br>\n              <strong>Estimated fix:</strong> {{If known, e.g. ~30 minutes}} or \"Under investigation\"\n            </td>\n          </tr>\n        </table>\n\n        <p style=\"margin:12px 0;color:#333333;font-size:15px;line-height:1.5;\">\n          We apologize for the inconvenience. You can reply to this email or contact our support:\n        </p>\n\n        <p style=\"margin:0 0 18px 0;color:#333333;font-size:15px;line-height:1.5;\">\n          Phone: <a href=\"tel:+880XXXXXXXXXX\" style=\"color:#0b69ff;text-decoration:none;\">+880XXXXXXXXXX</a><br>\n          Email: <a href=\"mailto:user@example.com\" style=\"color:#0b69ff;text-decoration:none;\">user@example.com</a>\n        </p>\n\n        <div style=\"text-align:center;margin-bottom:8px;\">\n          <a href=\"{{status_page_url}}\" style=\"display:inline-block;padding:10px 18px;border-radius:6px;text-decoration:none;background:#0b69ff;color:#fff;font-weight:600;font-size:14px;\">\n            Check Status Page\n          </a>\n        </div>\n\n        <p style=\"margin:0;color:#777;font-size:13px;line-height:1.4;\">\n          Thank you,<br>\n          The <strong>{{YourCompanyName}}</strong> Team\n        </p>\n      </td>\n    </tr>\n\n    <tr>\n      <td style=\"padding:12px 20px;background:#fafbfc;color:#99a1ab;font-size:12px;text-align:center;\">\n        This is an automated message. Please do not reply to this address.\n      </td>\n    </tr>\n  </table>\n\n  <!-- Plain-text fallback (for clients that ignore HTML) -->\n  <div style=\"display:none;font-size:1px;color:#ffffff;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;\">\n    [ALERT] {{YourWebsite.com}} is currently unavailable. Detected at {{YYYY-MM-DD HH:MM}}. Contact: user@example.com\n  </div>\n</body>\n</html>\n","options":{},"subject":"Website Down","toEmail":"user@example.com","fromEmail":"user@example.com"},"typeVersion":2.1}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","executionOrder":"v1"},"versionId":"e177e2df-6777-44c4-9eb7-a92428c1afa4","nodeGroups":[],"connections":{"Split Websites":{"main":[[{"node":"Check Website Status","type":"main","index":0}]]},"Send Email Alert":{"main":[[{"node":"Send Telegram Alert","type":"main","index":0}]]},"Set Website Field":{"main":[[{"node":"Split Websites","type":"main","index":0}]]},"Merge Test Results":{"main":[[{"node":"Set Site Status Fields","type":"main","index":0}]]},"Check Website Status":{"main":[[{"node":"Merge Test Results","type":"main","index":0}],[{"node":"Merge Test Results","type":"main","index":1}]]},"Every Minute Trigger":{"main":[[{"node":"Set Configuration Parameters","type":"main","index":0}]]},"Route by Site Status":{"main":[[],[{"node":"Wait Configured Seconds","type":"main","index":0}]]},"Check Website Status 2":{"main":[[{"node":"Aggregate Test Results 2","type":"main","index":0}],[{"node":"Aggregate Test Results 2","type":"main","index":1}]]},"Route by Site Status 2":{"main":[[],[{"node":"Send Email Alert","type":"main","index":0}]]},"Set Site Status Fields":{"main":[[{"node":"Route by Site Status","type":"main","index":0}]]},"Wait Configured Seconds":{"main":[[{"node":"Check Website Status 2","type":"main","index":0}]]},"Aggregate Test Results 2":{"main":[[{"node":"Set Site Status Fields 2","type":"main","index":0}]]},"Set Site Status Fields 2":{"main":[[{"node":"Route by Site Status 2","type":"main","index":0}]]},"Set Configuration Parameters":{"main":[[{"node":"Set Website Field","type":"main","index":0}]]}}}