{"id":"4PF19rQ30EloQhln","meta":{"instanceId":"e78d18caf9c883311547ed1d8191afa865e4fd7003686939bcc7c2c4af95065d","templateCredsSetupCompleted":true},"name":"RAG v2","tags":[],"nodes":[{"id":"34356e0c-9a0c-41e3-bc32-2ceb283f7045","name":"Schedule Document Ingestion","type":"n8n-nodes-base.scheduleTrigger","position":[-784,-16],"parameters":{"rule":{"interval":[{"field":"minutes","minutesInterval":2}]}},"typeVersion":1.3},{"id":"d14ac5a1-41c7-4a65-8775-e824a686f78e","name":"List Pending Documents","type":"n8n-nodes-base.googleDrive","position":[-208,-16],"parameters":{"filter":{"folderId":{"__rl":true,"mode":"id","value":"={{ $json.sourceFolderID }}"}},"options":{},"resource":"fileFolder","returnAll":true},"credentials":{"googleDriveOAuth2Api":{"id":"UW26Iaso96BMxzAk","name":"Google Drive account"}},"typeVersion":3},{"id":"4b7e2081-8dfa-408f-a6b1-bbcd4b4cf55d","name":"Download Source Document","type":"n8n-nodes-base.googleDrive","position":[-16,-16],"parameters":{"fileId":{"__rl":true,"mode":"id","value":"={{ $json.id }}"},"options":{},"operation":"download"},"credentials":{"googleDriveOAuth2Api":{"id":"UW26Iaso96BMxzAk","name":"Google Drive account"}},"typeVersion":3},{"id":"d9e9fd11-bde9-41fe-b5cb-6bb76d85b2b2","name":"Extract PDF Content","type":"n8n-nodes-base.extractFromFile","position":[-784,208],"parameters":{"options":{},"operation":"pdf"},"typeVersion":1.1},{"id":"7b262f8b-1401-4495-b48f-00c48ec6a0ad","name":"Split Documents into Chunks","type":"@n8n/n8n-nodes-langchain.textSplitterRecursiveCharacterTextSplitter","position":[-480,560],"parameters":{"options":{},"chunkSize":2000,"chunkOverlap":200},"typeVersion":1},{"id":"5c28424c-33d3-4747-b5fa-e11c00a8d34a","name":"Generate Embeddings","type":"@n8n/n8n-nodes-langchain.embeddingsOpenAi","position":[-688,864],"parameters":{"options":{}},"credentials":{"openAiApi":{"id":"zg4ISmesSZ7Oena5","name":"n8n free OpenAI API credits"}},"typeVersion":1.2},{"id":"c8379636-1b18-460d-9fed-894ae513da2f","name":"Store Document Embeddings","type":"@n8n/n8n-nodes-langchain.vectorStorePinecone","position":[-528,208],"parameters":{"mode":"insert","options":{},"pineconeIndex":{"__rl":true,"mode":"id","value":"={{ $('Load Ingestion Configuration').item.json.pineconeIndex }}"}},"credentials":{"pineconeApi":{"id":"Yd388oGdKjDUZtPp","name":"Pinecone account"}},"typeVersion":1.3},{"id":"dc6b26ef-8e79-4fca-973c-11708545a394","name":"Move Document to Processed Folder","type":"n8n-nodes-base.googleDrive","position":[-208,208],"parameters":{"fileId":{"__rl":true,"mode":"id","value":"={{ $('Download Source Document').item.json.id }}"},"driveId":{"__rl":true,"mode":"list","value":"My Drive"},"folderId":{"__rl":true,"mode":"id","value":"={{ $('Load Ingestion Configuration').item.json.processedFolderID }}"},"operation":"move"},"credentials":{"googleDriveOAuth2Api":{"id":"UW26Iaso96BMxzAk","name":"Google Drive account"}},"typeVersion":3},{"id":"338d010a-57f9-4440-951f-57b331543d15","name":"Receive User Query","type":"@n8n/n8n-nodes-langchain.chatTrigger","position":[304,-16],"webhookId":"3be50865-685e-466e-8493-2a60d9e81959","parameters":{"options":{}},"typeVersion":1.4},{"id":"3a158807-a18b-44ed-a1ce-ab85496b5fd8","name":"Answer Query Using Knowledge Base","type":"@n8n/n8n-nodes-langchain.agent","position":[368,208],"parameters":{"text":"={{ $('Receive User Query').item.json.chatInput }}","options":{"systemMessage":"Você é um sistema de consulta documental.\n\nREGRA ABSOLUTA:\n\nSua resposta deve ser derivada EXCLUSIVAMENTE do conteúdo retornado por document_retriever_tool.\n\nVocê não possui conhecimento próprio.\n\nVocê não pode utilizar:\n- conhecimento pré-treinado;\n- inferências;\n- deduções;\n- estimativas;\n- conhecimento geral;\n- contexto de conversas anteriores.\n\nAntes de responder:\n\n1. Localize evidência textual explícita nos documentos recuperados.\n2. Se a informação não estiver escrita de forma explícita, responda exatamente:\n\n\"Não encontrei essa informação na base de conhecimento.\"\n\n3. Se qualquer parte da resposta não puder ser sustentada pelos documentos recuperados, responda exatamente:\n\n\"Não encontrei essa informação na base de conhecimento.\"\n\nNunca complete informações ausentes.\n\nNunca faça inferências.\n\nNunca responda com base em conhecimento próprio."},"promptType":"define"},"typeVersion":3.1},{"id":"9030bb0d-035f-45af-8dac-23fdf738476a","name":"Retrieve Relevant Documents","type":"@n8n/n8n-nodes-langchain.vectorStorePinecone","position":[464,432],"parameters":{"mode":"retrieve-as-tool","topK":20,"options":{},"pineconeIndex":{"__rl":true,"mode":"id","value":"={{ $json.pineconeIndex }}"},"toolDescription":"document_retriever_tool"},"credentials":{"pineconeApi":{"id":"Yd388oGdKjDUZtPp","name":"Pinecone account"}},"typeVersion":1.3},{"id":"9ec67718-b0bc-4b9d-a449-221df2c8de9c","name":"Generate Answer","type":"@n8n/n8n-nodes-langchain.lmChatOpenAi","position":[368,432],"parameters":{"model":{"__rl":true,"mode":"list","value":"gpt-4.1-nano","cachedResultName":"gpt-4.1-nano"},"options":{},"builtInTools":{}},"credentials":{"openAiApi":{"id":"zg4ISmesSZ7Oena5","name":"n8n free OpenAI API credits"}},"typeVersion":1.3},{"id":"dffe8f28-f8cb-483e-b2a4-199aaeeb9e07","name":"Get Ingestion Settings","type":"n8n-nodes-base.executeWorkflow","position":[-592,-16],"parameters":{"options":{},"workflowId":{"__rl":true,"mode":"id","value":"={{ $workflow.id }}","cachedResultName":"={{ $workflow.id }}"},"workflowInputs":{"value":{},"schema":[],"mappingMode":"defineBelow","matchingColumns":[],"attemptToConvertTypes":false,"convertFieldsToString":true}},"typeVersion":1.3},{"id":"847d9b6b-d06a-4e63-a5c1-d40cd57b41d6","name":"Ingestion Complete","type":"n8n-nodes-base.noOp","position":[-16,208],"parameters":{},"typeVersion":1},{"id":"974be94f-3fad-4fe1-ad4b-123f1764ade7","name":"Get Retrieval Settings","type":"n8n-nodes-base.executeWorkflow","position":[496,-16],"parameters":{"options":{},"workflowId":{"__rl":true,"mode":"id","value":"={{ $workflow.id }}","cachedResultName":"={{ $workflow.id }}"},"workflowInputs":{"value":{},"schema":[],"mappingMode":"defineBelow","matchingColumns":[],"attemptToConvertTypes":false,"convertFieldsToString":true}},"typeVersion":1.3},{"id":"89b026d8-c331-4546-a1d7-670ed77d010e","name":"Provide Knowledge Base Settings","type":"n8n-nodes-base.executeWorkflowTrigger","position":[304,864],"parameters":{"inputSource":"passthrough","returnOutput":"allRuns"},"typeVersion":1.1},{"id":"4bd3ca63-d6e4-4771-b87d-544dff0a3c62","name":"Convert Text to Documents","type":"@n8n/n8n-nodes-langchain.documentDefaultDataLoader","position":[-480,432],"parameters":{"options":{},"textSplittingMode":"custom"},"typeVersion":1.1},{"id":"21df1f54-2ca3-4761-9822-440ccd455864","name":"Sticky Note4","type":"n8n-nodes-base.stickyNote","position":[-2080,-112],"parameters":{"color":2,"width":1168,"height":592,"content":"## Document Knowledge Base RAG Assistant\n\n### How It Works\n\n1. Runs on a schedule every 2 minutes to check a Google Drive source folder for new PDF documents.\n2. Downloads each pending PDF, extracts its text, splits the content into searchable chunks, and creates OpenAI embeddings.\n3. Stores the document embeddings in a Pinecone index, then moves the original file to a processed Google Drive folder.\n4. Receives user questions through the Chat Trigger and loads the same knowledge base settings.\n5. Retrieves the most relevant document chunks from Pinecone and asks OpenAI to answer using only the retrieved documents. If no explicit evidence is found, it returns a fixed **\"not found\"** response.\n\n### Setup\n\n* [ ] Connect your Google Drive account.\n* [ ] Connect your OpenAI API key for embeddings and answers.\n* [ ] Connect your Pinecone account.\n* [ ] Create a Pinecone index for the knowledge base.\n* [ ] Add your source Google Drive folder ID.\n* [ ] Add your processed Google Drive folder ID.\n* [ ] Replace the Pinecone index placeholder with your index name.\n* [ ] Adjust the ingestion schedule if needed.\n"},"typeVersion":1},{"id":"e895dcbe-b05e-4673-b49d-5ff8c21feb5c","name":"Sticky Note","type":"n8n-nodes-base.stickyNote","position":[-864,-112],"parameters":{"color":7,"width":1040,"height":816,"content":"## &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;**01) Cost Engineering RAG Ingestion Pipeline**"},"typeVersion":1},{"id":"21e45281-778b-46c7-bbad-6ad9db0da6e2","name":"Sticky Note3","type":"n8n-nodes-base.stickyNote","position":[-864,752],"parameters":{"color":7,"width":1040,"height":288,"content":"## &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;**03) Embedding**"},"typeVersion":1},{"id":"a838c242-92b5-4265-9464-e196e4e5bae7","name":"Sticky Note1","type":"n8n-nodes-base.stickyNote","position":[224,-112],"parameters":{"color":7,"width":688,"height":816,"content":"## &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;**02) Cost Engineering RAG Retrieval Pipeline**"},"typeVersion":1},{"id":"a533c5b0-0cee-4d44-98e5-86ff4a6eabe3","name":"Sticky Note2","type":"n8n-nodes-base.stickyNote","position":[224,752],"parameters":{"color":7,"width":688,"height":288,"content":"## &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;**04) Knowledge Base Settings**"},"typeVersion":1},{"id":"7dcbf046-b23d-4c9f-986a-0a265d72a57c","name":"Response Ready","type":"n8n-nodes-base.noOp","position":[688,208],"parameters":{},"typeVersion":1},{"id":"5b7dd555-e0f6-423a-a766-703a5c07e2ff","name":"Define Knowledge Base Configuration","type":"n8n-nodes-base.set","position":[496,864],"parameters":{"options":{},"assignments":{"assignments":[{"id":"0f1954e3-584f-4ea5-b4e2-e57c91d02120","name":"sourceFolderID","type":"string","value":"YOUR_SOURCE_FOLDER_ID"},{"id":"e2933257-77af-45cb-8e60-6e2b6ae7912a","name":"processedFolderID","type":"string","value":"YOUR_PROCESSED_FOLDER_ID"},{"id":"56731ed7-1672-4e4b-9cba-9672d1fb23c1","name":"pineconeIndex","type":"string","value":"YOUR_PINECONE_INDEX_NAME"}]}},"typeVersion":3.4},{"id":"7a3eb340-00c6-4f22-af45-c5b208df2ff8","name":"Configuration Ready","type":"n8n-nodes-base.noOp","position":[688,864],"parameters":{},"typeVersion":1},{"id":"7b31c37d-9384-4084-9dcf-db3d6c658323","name":"Load Ingestion Configuration","type":"n8n-nodes-base.set","position":[-400,-16],"parameters":{"options":{},"assignments":{"assignments":[{"id":"0f1954e3-584f-4ea5-b4e2-e57c91d02120","name":"sourceFolderID","type":"string","value":"={{ $json.sourceFolderID }}"},{"id":"e2933257-77af-45cb-8e60-6e2b6ae7912a","name":"processedFolderID","type":"string","value":"={{ $json.processedFolderID }}"},{"id":"56731ed7-1672-4e4b-9cba-9672d1fb23c1","name":"pineconeIndex","type":"string","value":"={{ $json.pineconeIndex }}"}]}},"typeVersion":3.4},{"id":"3458cc29-5f61-4000-8c3c-f2154fe79d72","name":"Load Retrieval Configuration","type":"n8n-nodes-base.set","position":[688,-16],"parameters":{"options":{},"assignments":{"assignments":[{"id":"0f1954e3-584f-4ea5-b4e2-e57c91d02120","name":"documentosRecebidos","type":"string","value":"={{ $json.processedFolderID }}"},{"id":"e2933257-77af-45cb-8e60-6e2b6ae7912a","name":"documentosProcessados","type":"string","value":"={{ $json.documentosProcessados }}"},{"id":"56731ed7-1672-4e4b-9cba-9672d1fb23c1","name":"pineconeIndex","type":"string","value":"={{ $json.pineconeIndex }}"}]}},"typeVersion":3.4}],"active":false,"pinData":{},"settings":{"binaryMode":"separate","availableInMCP":false,"executionOrder":"v1"},"versionId":"aec05871-29ed-41e6-93e3-dfd673436141","nodeGroups":[],"connections":{"Generate Answer":{"ai_languageModel":[[{"node":"Answer Query Using Knowledge Base","type":"ai_languageModel","index":0}]]},"Ingestion Complete":{"main":[[]]},"Receive User Query":{"main":[[{"node":"Get Retrieval Settings","type":"main","index":0}]]},"Extract PDF Content":{"main":[[{"node":"Store Document Embeddings","type":"main","index":0}]]},"Generate Embeddings":{"ai_embedding":[[{"node":"Store Document Embeddings","type":"ai_embedding","index":0},{"node":"Retrieve Relevant Documents","type":"ai_embedding","index